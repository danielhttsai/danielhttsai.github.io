---
import "../styles/globals.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title?: string;
  description?: string;
  /** Add a subtle teal-green tint to the body (used by the home page). */
  tint?: boolean;
}

const {
  title = "Daniel Hsiang-Te Tsai — Pharmacoepidemiology & Real-World Evidence",
  description = "Daniel Hsiang-Te Tsai is a postdoctoral research fellow at the Population Health Data Center, NCKU, specializing in comparative effectiveness research, causal inference, and real-world evidence tooling.",
  tint = false,
} = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const SITE_ORIGIN = "https://danielhttsai.github.io";
const canonical = `${SITE_ORIGIN}${Astro.url.pathname}`;

// Privacy-friendly analytics (GoatCounter — free, cookieless, no consent
// banner). After signing up at https://www.goatcounter.com/ you pick a code,
// e.g. "danieltsai" → your dashboard is https://danieltsai.goatcounter.com.
// Put that code here and analytics turns on (production builds only).
const GOATCOUNTER = ""; // e.g. "danieltsai"

// JSON-LD Person markup helps search engines recognise Daniel as an entity
// and link his ORCID / professional profiles.
const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Daniel Hsiang-Te Tsai",
  url: SITE_ORIGIN,
  email: "mailto:danielhttsai@gmail.com",
  jobTitle: "Postdoctoral Research Fellow, Pharmacoepidemiology",
  affiliation: {
    "@type": "Organization",
    name: "Population Health Data Center, National Cheng Kung University",
    url: "https://www.phdcenter.org.tw/",
  },
  image: `${SITE_ORIGIN}/images/daniel.jpeg`,
  sameAs: [
    "https://orcid.org/0000-0003-2841-0338",
    "https://scholar.google.com/citations?user=3IxiZOoAAAAJ",
    "https://www.linkedin.com/in/daniel-hsiang-te-tsai/",
    "https://www.phdcenter.org.tw/",
    "https://www.aspensig.asia/",
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
    <title>{title}</title>
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="Daniel Hsiang-Te Tsai" />
    <meta property="og:image" content={`${SITE_ORIGIN}/og.png`} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${SITE_ORIGIN}/og.png`} />
    <script type="application/ld+json" set:html={JSON.stringify(personSchema)} is:inline />
    <link rel="sitemap" type="application/xml" href="/sitemap-index.xml" />
    {GOATCOUNTER && import.meta.env.PROD && (
      <script
        is:inline
        data-goatcounter={`https://${GOATCOUNTER}.goatcounter.com/count`}
        async
        src="//gc.zgo.at/count.js"
      />
    )}
  </head>
  <body class:list={["text-slate-800 antialiased", tint ? "home-tint" : "bg-white"]}>
    <a href="#main" class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 bg-brand-600 text-white px-3 py-2 rounded">Skip to content</a>
    <Header />
    <main id="main" class="min-h-[60vh]">
      <slot />
    </main>
    <Footer />
  </body>
</html>
