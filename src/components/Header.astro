---
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const path = Astro.url.pathname.replace(/\/$/, "") || "/";

const nav = [
  { label: "Home", href: `${base}/` || "/" },
  { label: "About", href: `${base}/about` },
  { label: "Publications", href: `${base}/publications` },
  { label: "Talks", href: `${base}/talks` },
  { label: "RWE Tools", href: `${base}/tools` },
  { label: "Networks", href: `${base}/networks` },
];

const isActive = (href: string) => {
  const clean = href.replace(/\/$/, "") || "/";
  if (clean === (base || "/")) return path === (base || "/");
  return path === clean || path.startsWith(clean + "/");
};
---

<header class="sticky top-0 z-40 bg-white/85 backdrop-blur border-b border-slate-200">
  <nav class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between gap-4">
    <a href={`${base}/` || "/"} class="flex items-center gap-2 font-extrabold text-slate-900 tracking-tight">
      <span class="inline-grid place-items-center w-8 h-8 rounded-lg bg-brand-600 text-white text-sm">DT</span>
      <span class="hidden sm:inline">Daniel Tsai</span>
    </a>

    <div class="flex items-center gap-1 sm:gap-2 text-sm font-semibold">
      {nav.map((item) => (
        <a
          href={item.href}
          class:list={[
            "px-3 py-2 rounded-lg transition",
            isActive(item.href)
              ? "text-brand-700 bg-brand-50"
              : "text-slate-600 hover:text-brand-700 hover:bg-slate-50",
          ]}
          aria-current={isActive(item.href) ? "page" : undefined}
        >
          {item.label}
        </a>
      ))}
      <a
        href="https://orcid.org/0000-0003-2841-0338"
        target="_blank"
        rel="noopener"
        class="hidden md:inline px-3 py-2 rounded-lg text-slate-600 hover:text-brand-700 hover:bg-slate-50 transition"
      >ORCID ↗</a>
    </div>
  </nav>
</header>
