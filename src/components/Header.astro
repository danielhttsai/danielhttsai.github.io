---
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const path = Astro.url.pathname.replace(/\/$/, "") || "/";

const nav = [
  { label: "Home", href: `${base}/` || "/" },
  { label: "About", href: `${base}/about` },
  { label: "Publications", href: `${base}/publications` },
  { label: "Talks", href: `${base}/talks` },
  { label: "RWE Tools", href: `${base}/tools` },
  { label: "Networks", href: `${base}/networks` },
];

const isActive = (href: string) => {
  const clean = href.replace(/\/$/, "") || "/";
  if (clean === (base || "/")) return path === (base || "/");
  return path === clean || path.startsWith(clean + "/");
};
---

<header class="sticky top-0 z-40 bg-white/85 backdrop-blur border-b border-slate-200">
  <nav class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between gap-4">
    <a href={`${base}/` || "/"} class="flex items-center gap-2 font-extrabold text-slate-900 tracking-tight">
      <span class="inline-grid place-items-center w-8 h-8 rounded-lg bg-brand-600 text-white text-sm">DT</span>
      <span>Daniel Tsai</span>
    </a>

    <!-- Desktop nav -->
    <div class="hidden md:flex items-center gap-1 lg:gap-2 text-sm font-semibold">
      {nav.map((item) => (
        <a
          href={item.href}
          class:list={[
            "px-3 py-2 rounded-lg transition",
            isActive(item.href)
              ? "text-brand-700 bg-brand-50"
              : "text-slate-600 hover:text-brand-700 hover:bg-slate-50",
          ]}
          aria-current={isActive(item.href) ? "page" : undefined}
        >
          {item.label}
        </a>
      ))}
    </div>

    <!-- Mobile hamburger -->
    <button
      type="button"
      data-menu-btn
      aria-label="Open menu"
      aria-expanded="false"
      class="md:hidden inline-grid place-items-center w-10 h-10 -mr-2 rounded-lg text-slate-700 hover:bg-slate-100 transition"
    >
      <svg data-menu-open class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 7h16M4 12h16M4 17h16" /></svg>
      <svg data-menu-close class="w-6 h-6 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 6l12 12M18 6L6 18" /></svg>
    </button>
  </nav>

  <!-- Mobile panel -->
  <div data-menu-panel class="md:hidden hidden border-t border-slate-200 bg-white">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 py-3 flex flex-col gap-1 text-sm font-semibold">
      {nav.map((item) => (
        <a
          href={item.href}
          class:list={[
            "px-3 py-2.5 rounded-lg transition",
            isActive(item.href) ? "text-brand-700 bg-brand-50" : "text-slate-700 hover:bg-slate-50",
          ]}
          aria-current={isActive(item.href) ? "page" : undefined}
        >
          {item.label}
        </a>
      ))}
    </div>
  </div>
</header>

<script is:inline>
  (function () {
    var btn = document.querySelector("[data-menu-btn]");
    var panel = document.querySelector("[data-menu-panel]");
    if (!btn || !panel) return;
    var openI = btn.querySelector("[data-menu-open]");
    var closeI = btn.querySelector("[data-menu-close]");
    btn.addEventListener("click", function () {
      var open = panel.classList.toggle("hidden") === false;
      btn.setAttribute("aria-expanded", String(open));
      if (openI) openI.classList.toggle("hidden", open);
      if (closeI) closeI.classList.toggle("hidden", !open);
    });
  })();
</script>
