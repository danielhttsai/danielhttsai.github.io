---
// Networks & collaborations Daniel works within — styled after the AsPEN
// site's "open source / friendship links" section. These are external
// organisation websites (open in a new tab, as expected for site links).
const base = import.meta.env.BASE_URL.replace(/\/$/, "");

const networks = [
  {
    name: "PHDc",
    full: "Population Health Data Center, NCKU",
    href: "https://www.phdcenter.org.tw/",
    image: "networks/phdc.png",
    imgClass: "max-h-10",
  },
  {
    name: "AsPEN",
    full: "Asian Pharmacoepidemiology Network",
    href: "https://www.aspensig.asia/",
    image: "networks/aspen.png",
    imgClass: "max-h-12",
  },
  {
    name: "NeuroGEN",
    full: "Neurological & mental health Global Epidemiology Network",
    href: "https://neurogen.hku.hk/",
    wordmark: true,
  },
  {
    name: "DARWIN EU",
    full: "Data Analysis and Real World Interrogation Network (EMA)",
    href: "https://www.darwin-eu.org/",
    image: "networks/darwin-eu.png",
    imgClass: "max-h-12",
  },
];
---

<section class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-10">
  <h2 class="text-sm uppercase tracking-widest text-slate-500 font-semibold mb-5">Networks &amp; collaborations</h2>
  <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
    {networks.map((n) => (
      <a href={n.href} target="_blank" rel="noopener noreferrer"
         title={n.full}
         class="group flex flex-col items-center justify-center gap-3 border border-slate-200 rounded-2xl bg-white px-4 py-6 hover:shadow-md hover:border-brand-400 transition">
        <div class="h-12 flex items-center justify-center">
          {n.wordmark ? (
            <div class="flex items-center gap-2">
              <svg viewBox="0 0 56 52" class="h-9 w-auto shrink-0" fill="none" aria-hidden="true">
                <path d="M38 46 C35 42 36 38 34 36 C30 38 26 38 22 36 C16 36 12 32 13 26 C9 24 10 17 16 16 C17 10 25 8 30 11 C34 7 42 8 44 14 C50 14 52 22 47 26 C51 30 48 37 42 36 C44 40 43 44 40 46 Z" stroke="#21443e" stroke-width="2" stroke-linejoin="round" />
                <g stroke="#3d736a" stroke-width="1.3" stroke-linecap="round">
                  <path d="M17 22 C22 19 24 25 29 22 C33 20 35 25 40 22" />
                  <path d="M19 31 C24 28 27 33 32 30 C36 28 39 32 43 30" />
                  <line x1="17" y1="22" x2="19" y2="31" />
                  <line x1="29" y1="22" x2="32" y2="30" />
                  <line x1="40" y1="22" x2="43" y2="30" />
                </g>
                <g fill="#21443e">
                  <circle cx="17" cy="22" r="1.9" /><circle cx="29" cy="22" r="2.1" /><circle cx="40" cy="22" r="1.9" />
                  <circle cx="19" cy="31" r="1.9" /><circle cx="32" cy="30" r="2.1" /><circle cx="43" cy="30" r="1.9" />
                </g>
              </svg>
              <span class="text-xl font-extrabold tracking-tight text-slate-900 leading-none">Neuro<span class="text-brand-600">GEN</span></span>
            </div>
          ) : (
            <img src={`${base}/images/${n.image}`} alt={n.name} class:list={[n.imgClass, "w-auto object-contain"]} />
          )}
        </div>
        <p class="text-xs text-slate-500 group-hover:text-brand-700 transition text-center leading-snug">{n.full}</p>
      </a>
    ))}
  </div>
</section>
