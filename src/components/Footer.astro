---
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const year = 2026;

const links = [
  { label: "Email", href: "mailto:danielhttsai@gmail.com" },
  { label: "ORCID", href: "https://orcid.org/0000-0003-2841-0338" },
  { label: "AsPEN", href: "https://www.aspensig.asia/" },
  { label: "PHDc RWE Tool", href: "https://danielhttsai.github.io/phdc-rwe-tool/" },
];
---

<footer class="border-t border-slate-200 bg-slate-50">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-10 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-6">
    <div>
      <p class="font-extrabold text-slate-900">Daniel Hsiang-Te Tsai</p>
      <p class="text-sm text-slate-600 mt-1">
        Population Health Data Center, National Cheng Kung University · Tainan, Taiwan
      </p>
    </div>
    <ul class="flex flex-wrap gap-x-5 gap-y-2 text-sm font-semibold">
      {links.map((l) => (
        <li>
          <a
            href={l.href}
            target={l.href.startsWith("http") ? "_blank" : undefined}
            rel={l.href.startsWith("http") ? "noopener" : undefined}
            class="text-brand-700 hover:underline"
          >{l.label}</a>
        </li>
      ))}
    </ul>
  </div>
  <div class="border-t border-slate-200">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-4 text-xs text-slate-500">
      © {year} Daniel Hsiang-Te Tsai. The protocol generator is adapted from the AsPEN protocol templates.
    </div>
  </div>
</footer>
