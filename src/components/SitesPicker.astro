---
// Databases / sites checkbox grid, derived from databases.json. Checking sites
// writes the joined list into the form field named by the `target` prop.
import databasesRaw from "../data/databases.json";

const COUNTRY_ORDER = ["TW", "KR", "JP", "HK", "AU", "FI", "GB", "NL", "US"];
const shortDbName = (full: string): string => {
  const m = full.match(/\(([^)]+)\)$/);
  return m ? m[1] : full;
};
type DbRow = (typeof databasesRaw)[number] & { hidden?: boolean };
const SITES = (databasesRaw as DbRow[])
  .filter((d) => !d.hidden && COUNTRY_ORDER.includes(d.code))
  .map((d) => ({ country: d.country, code: d.code, short: shortDbName(d.name) }))
  .sort((a, b) => (COUNTRY_ORDER.indexOf(a.code) - COUNTRY_ORDER.indexOf(b.code)) || a.short.localeCompare(b.short));
const byCountry: Record<string, typeof SITES> = {};
for (const s of SITES) (byCountry[s.country] ??= []).push(s);

const { target = "data" } = Astro.props;
---

<div class="rounded-xl border border-slate-200 bg-slate-50 p-3" data-sites-picker data-target={target}>
  <p class="text-xs uppercase tracking-widest text-brand-700 font-semibold mb-2">📚 Databases / sites (fills “Data source(s)”)</p>
  <div class="grid grid-cols-2 sm:grid-cols-3 gap-x-4 gap-y-0.5 max-h-52 overflow-y-auto">
    {Object.entries(byCountry).map(([country, dbs]) => (
      <div class="mb-1">
        <p class="text-[10px] uppercase tracking-widest text-slate-400 font-bold mt-1">{country}</p>
        {dbs.map((d) => (
          <label class="flex items-center gap-1.5 text-xs text-slate-700 py-0.5 cursor-pointer">
            <input type="checkbox" data-site value={`${d.country} (${d.short})`} class="rounded border-slate-300" />
            {d.short}
          </label>
        ))}
      </div>
    ))}
  </div>
</div>

<script is:inline>
  (function () {
    const picker = document.querySelector("[data-sites-picker]");
    if (!picker) return;
    const target = picker.getAttribute("data-target");
    picker.addEventListener("change", () => {
      const sel = [...picker.querySelectorAll("[data-site]:checked")].map((c) => c.value);
      const el = document.querySelector('[name="' + target + '"]');
      if (el && sel.length) { el.value = sel.join("; "); el.dispatchEvent(new Event("input", { bubbles: true })); }
    });
  })();
</script>
