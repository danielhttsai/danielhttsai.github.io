---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/PageHeader.astro";
import PublicationItem from "../components/PublicationItem.astro";
import type { Pub } from "../components/PublicationItem.astro";
import CiteScript from "../components/CiteScript.astro";
import pubs from "../data/publications.json";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");

// Strict newest → oldest by publication date.
const all = (pubs as (Pub & { date?: number; pmcid?: string })[]).slice().sort((a, b) => (b.date || 0) - (a.date || 0));

// Group by year (newest first)
const years = [...new Set(all.map((p) => p.year))].sort((a, b) => b.localeCompare(a));
const byYear = years.map((y) => ({ year: y, items: all.filter((p) => p.year === y) }));

---

<BaseLayout
  title="Publications — Daniel Hsiang-Te Tsai"
  description="Complete list of peer-reviewed publications by Daniel Hsiang-Te Tsai, with open-access full-text links where available."
>
  <PageHeader
    eyebrow="Research"
    title="Publications"
    description={`${all.length} peer-reviewed publications. Free full text links to PubMed Central where available, otherwise to the PubMed abstract. Click Cite to download a RIS file.`}
  />

  <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 py-12">
    <div class="flex flex-wrap items-center gap-x-6 gap-y-2 text-sm text-slate-600 border-b border-slate-200 pb-6 mb-8">
      <span><strong class="text-brand-700 text-base">{all.length}</strong> publications</span>
      <a href="https://orcid.org/0000-0003-2841-0338" target="_blank" rel="noopener" class="font-semibold text-brand-700 hover:underline">ORCID 0000-0003-2841-0338 ↗</a>
      <a href={`${base}/about`} class="font-semibold text-brand-700 hover:underline">About &amp; CV →</a>
    </div>

    <p class="text-xs text-slate-500 mb-8">
      <span class="inline-flex items-center gap-1.5"><span class="inline-block w-2 h-2 rounded-full bg-accent-500"></span> Free full text on PubMed Central</span>
      <span class="mx-3">·</span>
      <span>Cite downloads a RIS file</span>
    </p>

    {byYear.map((grp) => (
      <section class="mb-10">
        <h2 class="text-xl font-extrabold text-brand-700 mb-4 sticky top-16 bg-white/90 backdrop-blur py-1">{grp.year}</h2>
        <ol class="space-y-5">
          {grp.items.map((p) => <PublicationItem pub={p} />)}
        </ol>
      </section>
    ))}
  </div>

  <CiteScript />
</BaseLayout>
