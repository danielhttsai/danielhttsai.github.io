---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/PageHeader.astro";
import pubs from "../data/publications.json";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");

type Pub = {
  year: string;
  doi: string;
  citation: string;
  isOA: boolean;
  oaUrl: string;
  pmid?: string;
  pmcid?: string; // present when full text is in PubMed Central
  ris?: string;   // EndNote/Zotero-importable RIS record
  date?: number;  // YYYYMMDD sort key (CrossRef issued date)
};

// Strict newest → oldest by publication date.
const all = (pubs as Pub[]).slice().sort((a, b) => (b.date || 0) - (a.date || 0));

// Group by year (newest first)
const years = [...new Set(all.map((p) => p.year))].sort((a, b) => b.localeCompare(a));
const byYear = years.map((y) => ({ year: y, items: all.filter((p) => p.year === y) }));

const fullTextCount = all.filter((p) => p.pmcid).length;
const hasEqual = all.some((p) => p.citation.includes("*"));

// Bold the author's own name in a citation string, escaping the surrounding text.
// "Tsai DHT" covers most papers; the 2019 paper credits him as "Tsai HT".
const esc = (s: string) =>
  s.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;");
const highlight = (citation: string) =>
  esc(citation)
    .replace(/Tsai DHT/g, "<strong class='text-slate-900'>Tsai DHT</strong>")
    .replace(/Tsai HT(?!<)/g, "<strong class='text-slate-900'>Tsai HT</strong>");

// Filename for the downloaded RIS, e.g. "Tsai-2026.ris".
const risName = (p: Pub) =>
  `${(p.citation.split(/[\s,]/)[0] || "ref").replace(/[^A-Za-z]/g, "")}-${p.year}.ris`;
// Full-text link: PubMed Central when the paper is there, else the PubMed
// abstract page. (Per copyright preference, never a direct publisher PDF.)
const ptLink = (p: Pub) =>
  p.pmcid
    ? { href: `https://pmc.ncbi.nlm.nih.gov/articles/${p.pmcid}/`, label: "Full text", title: "Full text on PubMed Central" }
    : p.pmid
    ? { href: `https://pubmed.ncbi.nlm.nih.gov/${p.pmid}/`, label: "PubMed", title: "Abstract on PubMed" }
    : null;
---

<BaseLayout
  title="Publications — Daniel Hsiang-Te Tsai"
  description="Complete list of peer-reviewed publications by Daniel Hsiang-Te Tsai, with open-access full-text links where available."
>
  <PageHeader
    eyebrow="Research"
    title="Publications"
    description={`${all.length} peer-reviewed publications. Free full text links to PubMed Central where available, otherwise to the PubMed abstract. Click Cite to download a RIS file.`}
  />

  <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 py-12">
    <div class="flex flex-wrap items-center gap-x-6 gap-y-2 text-sm text-slate-600 border-b border-slate-200 pb-6 mb-8">
      <span><strong class="text-brand-700 text-base">{all.length}</strong> publications</span>
      <span><strong class="text-brand-700 text-base">{fullTextCount}</strong> with free full text</span>
      <a href="https://orcid.org/0000-0003-2841-0338" target="_blank" rel="noopener" class="font-semibold text-brand-700 hover:underline">ORCID 0000-0003-2841-0338 ↗</a>
      <a href={`${base}/about`} class="font-semibold text-brand-700 hover:underline">About &amp; CV →</a>
    </div>

    <p class="text-xs text-slate-500 mb-8">
      <span class="inline-flex items-center gap-1.5"><span class="inline-block w-2 h-2 rounded-full bg-accent-500"></span> Free full text on PubMed Central</span>
      <span class="mx-3">·</span>
      <span>others link to the PubMed abstract</span>
      <span class="mx-3">·</span>
      <span>Cite downloads a RIS file (EndNote / Zotero / Mendeley)</span>
      {hasEqual && <><span class="mx-3">·</span><span>* equal contribution</span></>}
    </p>

    {byYear.map((grp) => (
      <section class="mb-10">
        <h2 class="text-xl font-extrabold text-brand-700 mb-4 sticky top-16 bg-white/90 backdrop-blur py-1">{grp.year}</h2>
        <ol class="space-y-5">
          {grp.items.map((p) => (
            <li class="border-l-2 pl-4" class:list={[p.pmcid ? "border-accent-500" : "border-slate-200"]}>
              <p class="text-sm text-slate-700 leading-relaxed" set:html={highlight(p.citation)} />
              <div class="mt-1.5 flex flex-wrap items-center gap-x-3 gap-y-1 text-xs">
                {ptLink(p) && (
                  <a href={ptLink(p)!.href} target="_blank" rel="noopener" title={ptLink(p)!.title} class="font-semibold text-brand-700 hover:underline">{ptLink(p)!.label} ↗</a>
                )}
                <a href={`https://doi.org/${p.doi}`} target="_blank" rel="noopener" class="text-slate-500 hover:text-brand-700 hover:underline">DOI ↗</a>
                {p.ris && (
                  <button type="button" data-ris={p.ris} data-filename={risName(p)} title="Download RIS for EndNote / Zotero / Mendeley" class="font-semibold text-brand-700 hover:underline cursor-pointer">⧉ Cite</button>
                )}
              </div>
            </li>
          ))}
        </ol>
      </section>
    ))}
  </div>

  <script is:inline>
    // "Cite" buttons download a RIS file that imports straight into EndNote
    // (also Zotero, Mendeley, RefWorks).
    document.addEventListener("click", (e) => {
      const btn = e.target.closest("[data-ris]");
      if (!btn) return;
      // HTML attribute parsing collapses CRLF to LF; restore CRLF for EndNote.
      const ris = (btn.getAttribute("data-ris") || "").replace(/\r?\n/g, "\r\n");
      const name = btn.getAttribute("data-filename") || "citation.ris";
      const blob = new Blob([ris], { type: "application/x-research-info-systems" });
      const url = URL.createObjectURL(blob);
      const a = document.createElement("a");
      a.href = url; a.download = name;
      document.body.appendChild(a); a.click(); a.remove();
      setTimeout(() => URL.revokeObjectURL(url), 1000);
      const original = btn.textContent;
      btn.textContent = "✓ Downloaded";
      setTimeout(() => { btn.textContent = original; }, 1500);
    });
  </script>
</BaseLayout>
