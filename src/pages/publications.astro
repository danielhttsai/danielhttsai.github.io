---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/PageHeader.astro";
import pubs from "../data/publications.json";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");

type Pub = {
  year: string;
  doi: string;
  citation: string;
  isOA: boolean;
  oaUrl: string;
  pmid?: string;
};

// Order follows the CV: newest first, preserving the CV's within-year order.
const all = pubs as Pub[];

// Group by year (newest first)
const years = [...new Set(all.map((p) => p.year))].sort((a, b) => b.localeCompare(a));
const byYear = years.map((y) => ({ year: y, items: all.filter((p) => p.year === y) }));

const oaCount = all.filter((p) => p.isOA && p.oaUrl).length;
const hasEqual = all.some((p) => p.citation.includes("*"));

// Bold the author's own name in a citation string, escaping the surrounding text.
// "Tsai DHT" covers most papers; the 2019 paper credits him as "Tsai HT".
const esc = (s: string) =>
  s.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;");
const highlight = (citation: string) =>
  esc(citation)
    .replace(/Tsai DHT/g, "<strong class='text-slate-900'>Tsai DHT</strong>")
    .replace(/Tsai HT(?!<)/g, "<strong class='text-slate-900'>Tsai HT</strong>");

// Full plain-text reference for the "Cite" copy button.
const citeText = (p: Pub) =>
  `${p.citation} doi:${p.doi}.${p.pmid ? " PMID: " + p.pmid + "." : ""}`;
---

<BaseLayout
  title="Publications — Daniel Hsiang-Te Tsai"
  description="Complete list of peer-reviewed publications by Daniel Hsiang-Te Tsai, with open-access full-text links where available."
>
  <PageHeader
    eyebrow="Research"
    title="Publications"
    description={`${all.length} peer-reviewed publications. Each links to its PubMed page for full text; open-access articles are marked.`}
  />

  <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 py-12">
    <div class="flex flex-wrap items-center gap-x-6 gap-y-2 text-sm text-slate-600 border-b border-slate-200 pb-6 mb-8">
      <span><strong class="text-brand-700 text-base">{all.length}</strong> publications</span>
      <span><strong class="text-brand-700 text-base">{oaCount}</strong> open access</span>
      <a href="https://orcid.org/0000-0003-2841-0338" target="_blank" rel="noopener" class="font-semibold text-brand-700 hover:underline">ORCID 0000-0003-2841-0338 ↗</a>
      <a href={`${base}/about`} class="font-semibold text-brand-700 hover:underline">About &amp; CV →</a>
    </div>

    <p class="text-xs text-slate-500 mb-8">
      <span class="inline-flex items-center gap-1.5"><span class="inline-block w-2 h-2 rounded-full bg-accent-500"></span> Open access</span>
      <span class="mx-3">·</span>
      <span>Full text via the official links on each article's PubMed page</span>
      {hasEqual && <><span class="mx-3">·</span><span>* equal contribution</span></>}
    </p>

    {byYear.map((grp) => (
      <section class="mb-10">
        <h2 class="text-xl font-extrabold text-brand-700 mb-4 sticky top-16 bg-white/90 backdrop-blur py-1">{grp.year}</h2>
        <ol class="space-y-5">
          {grp.items.map((p) => (
            <li class="border-l-2 pl-4" class:list={[p.isOA ? "border-accent-500" : "border-slate-200"]}>
              <p class="text-sm text-slate-700 leading-relaxed" set:html={highlight(p.citation)} />
              <div class="mt-1.5 flex flex-wrap items-center gap-x-3 gap-y-1 text-xs">
                {p.pmid && (
                  <a href={`https://pubmed.ncbi.nlm.nih.gov/${p.pmid}/`} target="_blank" rel="noopener" title="Full-text links on PubMed" class="font-semibold text-brand-700 hover:underline">PubMed ↗</a>
                )}
                <button type="button" data-cite={citeText(p)} class="font-semibold text-brand-700 hover:underline cursor-pointer">⧉ Cite</button>
                <a href={`https://doi.org/${p.doi}`} target="_blank" rel="noopener" class="text-slate-500 hover:text-brand-700 hover:underline">DOI ↗</a>
                {p.isOA && <span class="text-accent-500 font-medium">Open access</span>}
              </div>
            </li>
          ))}
        </ol>
      </section>
    ))}
  </div>

  <script is:inline>
    // "Cite" buttons copy the full reference (citation + doi + PMID) to the clipboard.
    document.addEventListener("click", (e) => {
      const btn = e.target.closest("[data-cite]");
      if (!btn) return;
      const text = btn.getAttribute("data-cite") || "";
      const flash = () => {
        const original = btn.textContent;
        btn.textContent = "✓ Copied";
        setTimeout(() => { btn.textContent = original; }, 1500);
      };
      const fallback = () => {
        const ta = document.createElement("textarea");
        ta.value = text; ta.style.position = "fixed"; ta.style.opacity = "0";
        document.body.appendChild(ta); ta.select();
        try { document.execCommand("copy"); } catch (err) {}
        ta.remove(); flash();
      };
      if (navigator.clipboard && navigator.clipboard.writeText) {
        navigator.clipboard.writeText(text).then(flash).catch(fallback);
      } else { fallback(); }
    });
  </script>
</BaseLayout>
