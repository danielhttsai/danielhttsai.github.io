---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/PageHeader.astro";
import PublicationItem from "../components/PublicationItem.astro";
import type { Pub } from "../components/PublicationItem.astro";
import CiteScript from "../components/CiteScript.astro";
import pubs from "../data/publications.json";
import metrics from "../data/metrics.json";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");

const education = [
  { degree: "PhD, Pharmacoepidemiology", org: "National Cheng Kung University", when: "Aug 2023 – Jul 2026" },
  { degree: "MClinPharm, Clinical Pharmacy", org: "National Cheng Kung University", when: "Aug 2019 – Jul 2021" },
  { degree: "BS, Pharmacy", org: "China Medical University", when: "Sep 2014 – Jun 2019" },
];

const experience = [
  {
    role: "Research Fellow & Operations/Technology Lead",
    org: "Population Health Data Center, NCKU, Taiwan",
    when: "May 2024 – present",
  },
  {
    role: "Research Data Analyst",
    org: "Centre for Neonatal and Paediatric Infection, St George's, University of London, UK",
    when: "Aug 2021 – Jul 2024",
  },
  {
    role: "Clinical Pharmacist",
    org: "National Cheng Kung University Hospital, Taiwan",
    when: "Sep 2019 – Jul 2021",
  },
];

// Highlighted papers — pulled from the full publications data by DOI so their
// format and links (Full text / PubMed · DOI · Cite) stay identical to the
// Publications page and update with it. Edit this list to change the picks.
const SELECTED_DOIS = [
  "10.2147/clep.s553894",      // NHIRD review — data infrastructure (landmark)
  "10.2147/clep.s426485",      // NeuroGEN cross-regional initiative (landmark)
  "10.1192/bjp.2024.283",      // BJP — antipsychotics & suicide (TTE)
  "10.1503/cmaj.240922",       // CMAJ — SGLT2 & CKD-MBD
  "10.1093/ofid/ofaf329",      // OFID — neonatal invasive candidiasis
  "10.1136/bmj-2023-076045",   // The BMJ — anticholinergic burden & CV events
];
// The two database-infrastructure papers Daniel flags as landmark work.
const LANDMARK_DOIS = new Set(["10.2147/clep.s553894", "10.2147/clep.s426485"]);
const byDoi = new Map((pubs as Pub[]).map((p) => [p.doi.toLowerCase(), p]));
const selected = (SELECTED_DOIS.map((d) => byDoi.get(d)).filter(Boolean) as Pub[])
  .slice()
  .sort((a, b) =>
    ((b as any).year || "").localeCompare((a as any).year || "") ||
    (((b as any).date || 0) - ((a as any).date || 0))
  );
---

<BaseLayout title="About — Daniel Hsiang-Te Tsai">
  <PageHeader
    eyebrow="About"
    title="Daniel Hsiang-Te Tsai"
    description="Postdoctoral research fellow in pharmacoepidemiology at the Population Health Data Center, NCKU."
  />

  <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 py-14 space-y-14">
    <!-- Bio -->
    <section>
      <h2 class="text-2xl font-bold text-slate-900">BIO</h2>
      <p class="mt-4 text-slate-600 leading-relaxed">
        Daniel Tsai is a postdoctoral research fellow at the Population Health Data Center, NCKU. He specialises in
        comparative effectiveness research and policy research. His expertise includes triangulating claims databases,
        electronic health records, and biomedical databases to inform causal inference. He is also actively involved in
        the intersection of artificial intelligence and geriatric medicine. Daniel serves as an educational co-lead of
        the Asian Pharmacoepidemiology Network (AsPEN) and is an active member of the Neurological and Mental Health
        Global Epidemiology Network (NeuroGEN), where he contributes to fostering international research collaboration
        and advancing pharmacoepidemiology.
      </p>
      <div class="mt-6 flex flex-wrap gap-3">
        <a href={`${base}/Daniel-Tsai-CV.pdf`} target="_blank" rel="noopener" class="bg-brand-600 hover:bg-brand-700 text-white font-semibold px-5 py-2.5 rounded-lg transition text-sm">
          ⬇ Download CV (PDF)
        </a>
        <a href="https://orcid.org/0000-0003-2841-0338" target="_blank" rel="noopener" class="border border-slate-300 hover:border-brand-600 text-slate-700 hover:text-brand-700 font-semibold px-5 py-2.5 rounded-lg transition text-sm">
          ORCID ↗
        </a>
      </div>
    </section>

    <!-- Education -->
    <section>
      <h2 class="text-2xl font-bold text-slate-900">Education</h2>
      <ul class="mt-5 space-y-4">
        {education.map((e) => (
          <li class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-1 border-b border-slate-100 pb-4">
            <div>
              <p class="font-semibold text-slate-900">{e.degree}</p>
              <p class="text-sm text-slate-600">{e.org}</p>
            </div>
            <span class="text-sm text-slate-500 shrink-0">{e.when}</span>
          </li>
        ))}
      </ul>
    </section>

    <!-- Experience -->
    <section>
      <h2 class="text-2xl font-bold text-slate-900">Experience</h2>
      <ul class="mt-5 space-y-4">
        {experience.map((e) => (
          <li class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-1 border-b border-slate-100 pb-4">
            <div>
              <p class="font-semibold text-slate-900">{e.role}</p>
              <p class="text-sm text-slate-600">{e.org}</p>
            </div>
            <span class="text-sm text-slate-500 shrink-0">{e.when}</span>
          </li>
        ))}
      </ul>
    </section>

    <!-- Skills -->
    <section>
      <h2 class="text-2xl font-bold text-slate-900">Training &amp; skills</h2>
      <div class="mt-4 space-y-4 text-slate-600 leading-relaxed">
        <p>
          <strong class="text-slate-800">Computing:</strong> Proficient in SAS, Stata, SPSS, and R, with extensive
          experience across the entire data pipeline — extraction, cleaning, analysis, and visualization. I conduct
          large-scale pharmacoepidemiologic studies and triangulate study designs using the Taiwan National Health
          Insurance Database (20M+ individuals). This work has supported complex designs and advanced statistical
          analyses published in journals including BMJ, Nature Communications, CMAJ, JAMA Network Open, PLOS Medicine,
          and BMC Medicine.
        </p>
        <p>
          <strong class="text-slate-800">Clinical Pharmacist</strong> (Licensed in Taiwan; MoHW No. 045275):
          nephrology-ward service covering antibiotic stewardship, medication reconciliation, renal pharmacotherapy
          optimization, therapeutic drug monitoring, adverse drug reaction prevention, and patient education within a
          multidisciplinary team.
        </p>
      </div>
    </section>

    <!-- Grants & awards -->
    <section>
      <h2 class="text-2xl font-bold text-slate-900">Grants &amp; awards</h2>
      <div class="mt-4 space-y-3 text-slate-600 leading-relaxed">
        <p>
          Contributor to projects funded by industry (Amgen, Clarivate, Prospection) and government (Taiwan's National
          Science and Technology Council, National Institutes of Health, Ministry of Education), focused on real-world
          evidence, pharmacoepidemiology, and causal inference. Recognised by multiple ISPE travel/registration
          scholarships for ICPE (2021–2023), ISPE (2024–2025), and ACPE (2021–2025).
        </p>
        <p><strong class="text-slate-800">Award:</strong> ISPE-Asian Conference on Pharmacoepidemiology 15 — Rising Star.</p>
      </div>
    </section>

    <!-- Selected publications -->
    <section>
      <div class="flex items-baseline justify-between gap-4 flex-wrap">
        <h2 class="text-2xl font-bold text-slate-900">Selected publications</h2>
        <a href={`${base}/publications`} class="text-sm font-semibold text-brand-700 hover:underline">View all publications →</a>
      </div>
      <p class="mt-1 text-sm text-slate-500">{pubs.length} publications · {metrics.citations} citations · h-index {metrics.hIndex} <span class="text-slate-400">(Google Scholar)</span></p>
      <ol class="mt-5 space-y-5">
        {selected.map((p) => (
          <PublicationItem pub={p} badge={LANDMARK_DOIS.has(p.doi.toLowerCase()) ? "Landmark paper" : undefined} />
        ))}
      </ol>
    </section>
  </div>

  <CiteScript />
</BaseLayout>
