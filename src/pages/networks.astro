---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/PageHeader.astro";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");

// Networks, centres, and collaborations Daniel works within. Modelled on the
// AsPEN site's "open source / friendship links" page. `image` is a path under
// public/images/ (omit for the NeuroGEN styled wordmark). `heightClass` tunes
// each logo so they read at a similar visual scale despite different aspects.
const networks = [
  {
    name: "Population Health Data Center, NCKU",
    href: "https://www.phdcenter.org.tw/",
    image: "networks/phdc.png",
    heightClass: "max-h-20",
    tagline:
      "PHDc at National Cheng Kung University — Daniel's home centre and the data infrastructure behind much of his Taiwan-based real-world-evidence work.",
  },
  {
    name: "Asian Pharmacoepidemiology Network",
    href: "https://www.aspensig.asia/",
    image: "networks/aspen.png",
    heightClass: "max-h-24",
    tagline:
      "AsPEN — a Special Interest Group of ISPE advancing multi-national database research across the Asia/Pacific region, where Daniel serves as educational co-lead.",
  },
  {
    name: "NeuroGEN",
    href: "https://neurogen.hku.hk/",
    wordmark: true,
    tagline:
      "The Neurological and mental health Global Epidemiology Network — a multi-database platform spanning Asia, Oceania, Europe, and North America, where Daniel is an active member.",
  },
  {
    name: "DARWIN EU",
    href: "https://www.darwin-eu.org/",
    image: "networks/darwin-eu.png",
    heightClass: "max-h-24",
    tagline:
      "Data Analysis and Real World Interrogation Network — the European Medicines Agency's federated real-world-evidence network.",
  },
];
---

<BaseLayout
  title="Networks & collaborations — Daniel Hsiang-Te Tsai"
  description="The networks, centres, and collaborations Daniel Hsiang-Te Tsai works within: PHDc, AsPEN, NeuroGEN, and DARWIN EU."
>
  <PageHeader
    eyebrow="Collaborations"
    title="Networks"
    description="The networks, centres, and collaborations I work within."
  />

  <section class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid gap-6 sm:grid-cols-2">
      {networks.map((n) => (
        <a href={n.href} target="_blank" rel="noopener noreferrer"
           class="group flex flex-col border border-slate-200 rounded-2xl p-8 bg-white hover:shadow-md hover:border-brand-400 transition">
          <div class="h-28 flex items-center">
            {n.wordmark ? (
              <div class="flex items-center gap-3">
                <svg viewBox="0 0 56 52" class="h-20 w-auto shrink-0" fill="none" aria-hidden="true">
                  <path d="M38 46 C35 42 36 38 34 36 C30 38 26 38 22 36 C16 36 12 32 13 26 C9 24 10 17 16 16 C17 10 25 8 30 11 C34 7 42 8 44 14 C50 14 52 22 47 26 C51 30 48 37 42 36 C44 40 43 44 40 46 Z" stroke="#21443e" stroke-width="2" stroke-linejoin="round" />
                  <g stroke="#3d736a" stroke-width="1.3" stroke-linecap="round">
                    <path d="M17 22 C22 19 24 25 29 22 C33 20 35 25 40 22" />
                    <path d="M19 31 C24 28 27 33 32 30 C36 28 39 32 43 30" />
                    <line x1="17" y1="22" x2="19" y2="31" />
                    <line x1="29" y1="22" x2="32" y2="30" />
                    <line x1="40" y1="22" x2="43" y2="30" />
                  </g>
                  <g fill="#21443e">
                    <circle cx="17" cy="22" r="1.9" /><circle cx="29" cy="22" r="2.1" /><circle cx="40" cy="22" r="1.9" />
                    <circle cx="19" cy="31" r="1.9" /><circle cx="32" cy="30" r="2.1" /><circle cx="43" cy="30" r="1.9" />
                  </g>
                </svg>
                <span class="text-5xl font-extrabold tracking-tight text-slate-900 leading-none">Neuro<span class="text-brand-600">GEN</span></span>
              </div>
            ) : (
              <img src={`${base}/images/${n.image}`} alt={n.name} class:list={[n.heightClass, "w-auto object-contain"]} />
            )}
          </div>
          <p class="mt-6 text-sm text-slate-700 leading-relaxed flex-1">{n.tagline}</p>
          <p class="mt-4 text-xs text-brand-700 font-semibold group-hover:underline">
            {n.href.replace(/^https?:\/\//, "").replace(/\/$/, "")} ↗
          </p>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
