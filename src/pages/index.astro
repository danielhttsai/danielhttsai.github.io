---
import BaseLayout from "../layouts/BaseLayout.astro";
import type { Pub } from "../components/PublicationItem.astro";
import { getCollection } from "astro:content";
import pubs from "../data/publications.json";
import metrics from "../data/metrics.json";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");

const latestPosts = (await getCollection("posts", ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 2);

// Featured paper for the home "Latest" band — the flagship first-author study.
// Pulled live from publications.json so its links/format stay in sync.
const FEATURED_DOI = "10.1192/bjp.2024.283";
const featured = (pubs as Pub[]).find((p) => p.doi.toLowerCase() === FEATURED_DOI);

const skills = [
  { group: "Statistical computing", items: ["SAS", "Stata", "SPSS", "R"] },
  { group: "Methods", items: ["Comparative effectiveness", "Causal inference", "Target trial emulation", "Self-controlled designs"] },
  { group: "Data", items: ["Claims databases (NHIRD, 20M+)", "Electronic health records", "Biomedical / registry linkage"] },
  { group: "Domains", items: ["Pharmacoepidemiology", "Policy research", "AI × geriatric medicine"] },
];

const tools = [
  {
    name: "Protocol Generator",
    blurb:
      "Build a publication-ready pharmacoepidemiology protocol (ACNU, case-crossover, descriptive, or self-controlled case-series) with a validated phenotype library, feasibility checks across Asian databases, and one-click Word / Markdown export.",
    href: `${base}/tools/protocol-generator`,
    cta: "Open the tool",
    external: false,
    tag: "Design Infrastructure",
  },
  {
    name: "TARGET Checker",
    blurb:
      "The flip side of the generator: paste or upload an existing protocol and get an AI-assisted, item-by-item read on whether it conforms to the TARGET reporting guideline for target-trial emulations — with evidence and fixes for anything missing.",
    href: `${base}/tools/target-checker`,
    cta: "Open the checker",
    external: false,
    tag: "Design Infrastructure",
  },
  {
    name: "PHDc RWE Toolbox",
    blurb:
      "A real-world-evidence utility from the Population Health Data Center for exploring and operationalising claims-based study designs.",
    href: `${base}/tools/phdc-rwe-tool`,
    cta: "Launch the toolbox",
    external: false,
    tag: "RWE utility",
  },
  {
    name: "NHIRD Data Dictionary",
    blurb:
      "A searchable codebook for Taiwan's NHIRD and Health & Welfare Data Center datasets — variables, formats, and cross-dataset linkages, structured on the DIVERSE data-source framework.",
    href: `${base}/tools/nhird-data-dictionary`,
    cta: "Open the dictionary",
    external: false,
    tag: "Data Infrastructure",
  },
  {
    name: "ACB Calculator",
    blurb:
      "Scores a patient's total anticholinergic burden across 6 international scales and quantifies 30-day risk of cardiovascular events, pneumonia, and out-of-hospital cardiac arrest — with OCR drug-history capture and printable reports. Built on three Taiwan NHI studies (BMJ, Clin Epidemiol, Eur Heart J).",
    href: `${base}/tools/acb-calculator`,
    cta: "Open ACB calculator",
    external: false,
    tag: "Clinical tool",
  },
];
---

<BaseLayout tint={true}>
  <!-- Hero -->
  <section class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 pt-20 pb-16">
    <div class="grid md:grid-cols-[1fr_auto] gap-8 md:gap-12 items-center">
      <img
        src={`${base}/images/daniel.jpeg`}
        alt="Daniel Hsiang-Te Tsai"
        width="240" height="240"
        class="order-1 md:order-2 w-36 h-36 md:w-56 md:h-56 lg:w-64 lg:h-64 rounded-2xl object-cover shadow-md ring-1 ring-slate-200 justify-self-start md:justify-self-end"
      />
      <div class="order-2 md:order-1">
        <p class="uppercase tracking-widest text-xs text-brand-600 font-semibold mb-3">
          Pharmacoepidemiology · Real-World Evidence
        </p>
        <h1 class="text-4xl md:text-6xl font-extrabold text-slate-900 leading-tight">
          Daniel Hsiang-Te Tsai
        </h1>
        <p class="mt-5 text-lg md:text-xl text-slate-700 max-w-2xl leading-relaxed font-medium">
          Building the <strong class="text-brand-700">infrastructure for real-world evidence</strong> — the tools, methods, and multi-country data networks that turn routine health data into causal answers.
        </p>
        <p class="mt-4 text-base text-slate-600 max-w-2xl leading-relaxed">
          Postdoctoral research fellow at the <a href="https://www.phdcenter.org.tw/" target="_blank" rel="noopener" class="text-brand-700 font-semibold hover:underline">Population Health Data Center (PHDc), NCKU</a>, specialising in comparative effectiveness and policy research. Educational co-lead of <strong class="text-slate-800">AsPEN</strong> and active member of <strong class="text-slate-800">NeuroGEN</strong>.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a href={`${base}/tools`} class="bg-brand-600 hover:bg-brand-700 text-white font-semibold px-6 py-3 rounded-xl transition shadow-sm">
            Try the Protocol Generator →
          </a>
          <a href={`${base}/about`} class="bg-white border border-slate-300 text-slate-700 hover:border-brand-600 hover:text-brand-700 font-semibold px-6 py-3 rounded-xl transition">
            About me &amp; publications
          </a>
        </div>
        <div class="mt-8 flex items-center gap-5">
          <a href="mailto:danielhttsai@gmail.com" aria-label="Email" title="Email" class="text-[#EA4335] hover:opacity-75 transition">
            <svg class="w-6 h-6 fill-current" viewBox="0 0 24 24" aria-hidden="true"><path d="M24 5.457v13.909c0 .904-.732 1.636-1.636 1.636h-3.819V11.73L12 16.64l-6.545-4.91v9.273H1.636A1.636 1.636 0 0 1 0 19.366V5.457c0-2.023 2.309-3.178 3.927-1.964L5.455 4.64 12 9.548l6.545-4.91 1.528-1.145C21.69 2.28 24 3.434 24 5.457z"/></svg>
          </a>
          <a href="https://scholar.google.com/citations?user=3IxiZOoAAAAJ" target="_blank" rel="noopener" aria-label="Google Scholar" title="Google Scholar" class="text-[#4285F4] hover:opacity-75 transition">
            <svg class="w-6 h-6 fill-current" viewBox="0 0 24 24" aria-hidden="true"><path d="M5.242 13.769L0 9.5 12 0l12 9.5-5.242 4.269C17.548 11.249 14.978 9.5 12 9.5c-2.977 0-5.548 1.748-6.758 4.269zM12 10a7 7 0 1 0 0 14 7 7 0 0 0 0-14z"/></svg>
          </a>
          <a href="https://orcid.org/0000-0003-2841-0338" target="_blank" rel="noopener" aria-label="ORCID" title="ORCID" class="text-[#A6CE39] hover:opacity-75 transition">
            <svg class="w-6 h-6 fill-current" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 0C5.372 0 0 5.372 0 12s5.372 12 12 12 12-5.372 12-12S18.628 0 12 0zM7.369 4.378c.525 0 .947.431.947.947s-.422.947-.947.947a.95.95 0 0 1-.947-.947c0-.525.422-.947.947-.947zm-.722 3.038h1.444v10.041H6.647V7.416zm3.562 0h3.9c3.712 0 5.344 2.653 5.344 5.025 0 2.578-2.016 5.025-5.325 5.025h-3.919V7.416zm1.444 1.303v7.444h2.297c3.272 0 4.022-2.484 4.022-3.722 0-2.016-1.284-3.722-4.097-3.722h-2.222z"/></svg>
          </a>
          <a href="https://www.linkedin.com/in/daniel-hsiang-te-tsai/" target="_blank" rel="noopener" aria-label="LinkedIn" title="LinkedIn" class="text-[#0A66C2] hover:opacity-75 transition">
            <svg class="w-6 h-6 fill-current" viewBox="0 0 24 24" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0z"/></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Latest / featured paper -->
  {featured && (
    <section class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 pb-4">
      <div class="rounded-2xl border border-brand-200 bg-gradient-to-br from-brand-50 to-white p-6 sm:p-8">
        <div class="flex items-center justify-between gap-4 flex-wrap mb-4">
          <p class="text-sm font-bold text-brand-700">📰 Fresh off the press</p>
          <a href={`${base}/publications`} class="text-sm font-semibold text-brand-700 hover:underline">All publications →</a>
        </div>
        <div class="flex flex-col sm:flex-row gap-6 items-start">
          <a href={`https://doi.org/${featured.doi}`} target="_blank" rel="noopener" class="shrink-0 self-center sm:self-start">
            <img
              src={`${base}/images/papers/trd-ap.jpg`}
              alt="First page of the British Journal of Psychiatry article"
              width="144" height="204"
              class="w-32 sm:w-36 rounded-lg shadow-md ring-1 ring-slate-200 hover:shadow-lg transition"
            />
          </a>
          <div class="flex-1 min-w-0">
            <p class="text-slate-700 leading-relaxed">
              Latest study in the <strong class="text-slate-900">British Journal of Psychiatry</strong>
            </p>
            <p class="mt-1 mb-3 text-sm text-slate-600 leading-relaxed">
              A target trial emulation across Taiwan's National Health Insurance data examining how antipsychotic augmentation relates to suicide risk in treatment-resistant depression.
            </p>
            <a href={`https://doi.org/${featured.doi}`} target="_blank" rel="noopener" class="inline-block text-sm font-semibold text-brand-700 hover:underline">Read the paper →</a>
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- Quick stats -->
  <section class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-3 gap-4">
      {[
        { n: String(pubs.length), l: "Publications" },
        { n: String(metrics.citations), l: "Citations" },
        { n: String(metrics.hIndex), l: "h-index" },
      ].map((s) => (
        <div class="rounded-2xl border border-slate-200 bg-white p-5 text-center shadow-sm">
          <div class="text-3xl font-extrabold text-brand-700">{s.n}</div>
          <div class="text-xs uppercase tracking-wide text-slate-500 mt-1">{s.l}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- Skills -->
  <section class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-12">
    <h2 class="text-2xl font-bold text-slate-900">Technical expertise</h2>
    <div class="mt-6 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
      {skills.map((s) => (
        <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
          <h3 class="font-bold text-slate-900">{s.group}</h3>
          <ul class="mt-3 space-y-1.5">
            {s.items.map((i) => (
              <li class="text-sm text-slate-600 flex gap-2">
                <span class="text-brand-500 mt-0.5">▸</span><span>{i}</span>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </section>

  <!-- RWE Tools -->
  <section class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-12">
    <h2 class="text-2xl font-bold text-slate-900">RWE tools</h2>
    <p class="mt-2 text-slate-600 max-w-2xl">Open-access utilities I build and maintain for real-world-evidence research — each runs right here on this site.</p>
    <div class="mt-6 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {tools.map((t) => (
        <a
          href={t.href}
          target={t.external ? "_blank" : undefined}
          rel={t.external ? "noopener" : undefined}
          class="group flex flex-col rounded-2xl border border-slate-200 bg-white p-6 shadow-sm hover:shadow-md hover:border-brand-400 transition"
        >
          <span class="self-start text-[11px] uppercase tracking-wide font-semibold text-brand-600 bg-brand-50 rounded-full px-2.5 py-1">{t.tag}</span>
          <h3 class="mt-4 text-lg font-bold text-slate-900 group-hover:text-brand-700">{t.name}</h3>
          <p class="mt-2 text-sm text-slate-600 leading-relaxed flex-1">{t.blurb}</p>
          <span class="mt-5 text-sm font-semibold text-brand-700">{t.cta} {t.external ? "↗" : "→"}</span>
        </a>
      ))}
    </div>
  </section>

  <!-- Latest writing -->
  {latestPosts.length > 0 && (
    <section class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-12">
      <div class="flex items-baseline justify-between gap-4 flex-wrap">
        <h2 class="text-2xl font-bold text-slate-900">Latest writing</h2>
        <a href={`${base}/writing`} class="text-sm font-semibold text-brand-700 hover:underline">All notes →</a>
      </div>
      <div class="mt-6 grid gap-5 sm:grid-cols-2">
        {latestPosts.map((p) => (
          <a href={`${base}/writing/${p.id}`} class="group flex flex-col rounded-2xl border border-slate-200 bg-white p-6 shadow-sm hover:shadow-md hover:border-brand-400 transition">
            <div class="flex flex-wrap gap-2 text-[11px] mb-2">
              {p.data.tags.slice(0, 2).map((t) => (
                <span class="rounded-full bg-brand-50 text-brand-700 font-semibold px-2 py-0.5">{t}</span>
              ))}
            </div>
            <h3 class="font-bold text-slate-900 group-hover:text-brand-700 leading-snug">{p.data.title}</h3>
            <p class="mt-2 text-sm text-slate-600 leading-relaxed flex-1 line-clamp-3">{p.data.excerpt}</p>
            <span class="mt-4 text-sm font-semibold text-brand-700 group-hover:underline">Read →</span>
          </a>
        ))}
      </div>
    </section>
  )}

  <!-- Contact / collaborate -->
  <section class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-12">
    <div class="rounded-2xl bg-brand-700 text-white p-8 sm:p-10 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-6">
      <div>
        <h2 class="text-2xl font-bold">Open to collaborations</h2>
        <p class="mt-2 text-brand-100 max-w-2xl leading-relaxed">
          Multi-country RWE studies, methods work (target trial emulation, clone-censor-weight), or building research infrastructure — let's talk.
        </p>
      </div>
      <div class="flex flex-wrap gap-3 shrink-0">
        <a href="mailto:danielhttsai@gmail.com" class="bg-white text-brand-700 hover:bg-brand-50 font-semibold px-6 py-3 rounded-xl transition">Email me</a>
        <a href="https://www.linkedin.com/in/daniel-hsiang-te-tsai/" target="_blank" rel="noopener" class="border border-white/40 hover:bg-white/10 text-white font-semibold px-6 py-3 rounded-xl transition">LinkedIn ↗</a>
      </div>
    </div>
  </section>
</BaseLayout>
