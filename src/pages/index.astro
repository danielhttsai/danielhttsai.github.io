---
import BaseLayout from "../layouts/BaseLayout.astro";
import PublicationItem from "../components/PublicationItem.astro";
import type { Pub } from "../components/PublicationItem.astro";
import CiteScript from "../components/CiteScript.astro";
import pubs from "../data/publications.json";
import metrics from "../data/metrics.json";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");

// Featured paper for the home "Latest" band — the flagship first-author study.
// Pulled live from publications.json so its links/format stay in sync.
const FEATURED_DOI = "10.1192/bjp.2024.283";
const featured = (pubs as Pub[]).find((p) => p.doi.toLowerCase() === FEATURED_DOI);

const skills = [
  { group: "Statistical computing", items: ["SAS", "Stata", "SPSS", "R"] },
  { group: "Methods", items: ["Comparative effectiveness", "Causal inference", "Target trial emulation", "Self-controlled designs"] },
  { group: "Data", items: ["Claims databases (NHIRD, 20M+)", "Electronic health records", "Biomedical / registry linkage"] },
  { group: "Domains", items: ["Pharmacoepidemiology", "Policy research", "AI × geriatric medicine"] },
];

const tools = [
  {
    name: "Protocol Generator",
    blurb:
      "Build a publication-ready pharmacoepidemiology protocol (ACNU, case-crossover, descriptive, or self-controlled case-series) with a validated phenotype library, feasibility checks across Asian databases, and one-click Word / Markdown export.",
    href: `${base}/tools`,
    cta: "Open the tool",
    external: false,
    tag: "Design Infrastructure",
  },
  {
    name: "ACB Calculator",
    blurb:
      "Scores a patient's total anticholinergic burden across 6 international scales and quantifies 30-day risk of cardiovascular events, pneumonia, and out-of-hospital cardiac arrest — with OCR drug-history capture and printable reports. Built on three Taiwan NHI studies (BMJ, Clin Epidemiol, Eur Heart J).",
    href: `${base}/tools/acb-calculator`,
    cta: "Open ACB calculator",
    external: false,
    tag: "Clinical tool",
  },
  {
    name: "PHDc RWE Tool",
    blurb:
      "A real-world-evidence utility from the Population Health Data Center for exploring and operationalising claims-based study designs.",
    href: `${base}/tools/phdc-rwe-tool`,
    cta: "Launch PHDc tool",
    external: false,
    tag: "RWE utility",
  },
];
---

<BaseLayout tint={true}>
  <!-- Hero -->
  <section class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 pt-20 pb-16">
    <div class="grid md:grid-cols-[1fr_auto] gap-8 md:gap-12 items-center">
      <img
        src={`${base}/images/daniel.jpeg`}
        alt="Daniel Hsiang-Te Tsai"
        width="240" height="240"
        class="order-1 md:order-2 w-36 h-36 md:w-56 md:h-56 lg:w-64 lg:h-64 rounded-2xl object-cover shadow-md ring-1 ring-slate-200 justify-self-start md:justify-self-end"
      />
      <div class="order-2 md:order-1">
        <p class="uppercase tracking-widest text-xs text-brand-600 font-semibold mb-3">
          Pharmacoepidemiology · Real-World Evidence
        </p>
        <h1 class="text-4xl md:text-6xl font-extrabold text-slate-900 leading-tight">
          Daniel Hsiang-Te Tsai
        </h1>
        <p class="mt-5 text-lg md:text-xl text-slate-700 max-w-2xl leading-relaxed font-medium">
          Building the <strong class="text-brand-700">infrastructure for real-world evidence</strong> — the tools, methods, and multi-country data networks that turn routine health data into causal answers.
        </p>
        <p class="mt-4 text-base text-slate-600 max-w-2xl leading-relaxed">
          Postdoctoral research fellow at the <a href="https://www.phdcenter.org.tw/" target="_blank" rel="noopener" class="text-brand-700 font-semibold hover:underline">Population Health Data Center (PHDc), NCKU</a>, specialising in comparative effectiveness and policy research. Educational co-lead of <strong class="text-slate-800">AsPEN</strong> and active member of <strong class="text-slate-800">NeuroGEN</strong>.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a href={`${base}/tools`} class="bg-brand-600 hover:bg-brand-700 text-white font-semibold px-6 py-3 rounded-xl transition shadow-sm">
            Try the Protocol Generator →
          </a>
          <a href={`${base}/about`} class="bg-white border border-slate-300 text-slate-700 hover:border-brand-600 hover:text-brand-700 font-semibold px-6 py-3 rounded-xl transition">
            About me &amp; publications
          </a>
        </div>
        <div class="mt-8 flex flex-wrap gap-x-5 gap-y-2 text-sm text-slate-500">
          <a href="mailto:danielhttsai@gmail.com" class="hover:text-brand-700">Email</a>
          <a href="https://scholar.google.com/citations?user=3IxiZOoAAAAJ" target="_blank" rel="noopener" class="hover:text-brand-700">Google Scholar ↗</a>
          <a href="https://orcid.org/0000-0003-2841-0338" target="_blank" rel="noopener" class="hover:text-brand-700">ORCID ↗</a>
          <a href="https://www.linkedin.com/in/daniel-hsiang-te-tsai/" target="_blank" rel="noopener" class="hover:text-brand-700">LinkedIn ↗</a>
          <a href="https://github.com/danielhttsai" target="_blank" rel="noopener" class="hover:text-brand-700">GitHub ↗</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Latest / featured paper -->
  {featured && (
    <section class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 pb-4">
      <div class="rounded-2xl border border-brand-200 bg-brand-50/50 p-6 sm:p-8">
        <div class="flex items-center justify-between gap-4 flex-wrap mb-3">
          <p class="uppercase tracking-widest text-xs text-brand-700 font-bold">Latest first-author paper</p>
          <a href={`${base}/publications`} class="text-sm font-semibold text-brand-700 hover:underline">All publications →</a>
        </div>
        <ol><PublicationItem pub={featured} /></ol>
      </div>
    </section>
  )}

  <!-- Quick stats -->
  <section class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
      {[
        { n: String(pubs.length), l: "Publications" },
        { n: String(metrics.citations), l: "Citations" },
        { n: String(metrics.hIndex), l: "h-index" },
        { n: "ACPE 15", l: "Rising Star" },
      ].map((s) => (
        <div class="rounded-2xl border border-slate-200 bg-white p-5 text-center shadow-sm">
          <div class="text-3xl font-extrabold text-brand-700">{s.n}</div>
          <div class="text-xs uppercase tracking-wide text-slate-500 mt-1">{s.l}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- Skills -->
  <section class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-12">
    <h2 class="text-2xl font-bold text-slate-900">Technical expertise</h2>
    <div class="mt-6 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
      {skills.map((s) => (
        <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
          <h3 class="font-bold text-slate-900">{s.group}</h3>
          <ul class="mt-3 space-y-1.5">
            {s.items.map((i) => (
              <li class="text-sm text-slate-600 flex gap-2">
                <span class="text-brand-500 mt-0.5">▸</span><span>{i}</span>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </section>

  <!-- RWE Tools -->
  <section class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-12">
    <h2 class="text-2xl font-bold text-slate-900">RWE tools</h2>
    <p class="mt-2 text-slate-600 max-w-2xl">Open-access utilities I build and maintain for real-world-evidence research — each runs right here on this site.</p>
    <div class="mt-6 grid gap-6 md:grid-cols-3">
      {tools.map((t) => (
        <a
          href={t.href}
          target={t.external ? "_blank" : undefined}
          rel={t.external ? "noopener" : undefined}
          class="group flex flex-col rounded-2xl border border-slate-200 bg-white p-6 shadow-sm hover:shadow-md hover:border-brand-400 transition"
        >
          <span class="self-start text-[11px] uppercase tracking-wide font-semibold text-brand-600 bg-brand-50 rounded-full px-2.5 py-1">{t.tag}</span>
          <h3 class="mt-4 text-lg font-bold text-slate-900 group-hover:text-brand-700">{t.name}</h3>
          <p class="mt-2 text-sm text-slate-600 leading-relaxed flex-1">{t.blurb}</p>
          <span class="mt-5 text-sm font-semibold text-brand-700">{t.cta} {t.external ? "↗" : "→"}</span>
        </a>
      ))}
    </div>
  </section>

  <!-- Contact / collaborate -->
  <section class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-12">
    <div class="rounded-2xl bg-brand-700 text-white p-8 sm:p-10 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-6">
      <div>
        <h2 class="text-2xl font-bold">Open to collaborations</h2>
        <p class="mt-2 text-brand-100 max-w-2xl leading-relaxed">
          Multi-country RWE studies, methods work (target trial emulation, clone-censor-weight), or building research infrastructure — let's talk.
        </p>
      </div>
      <div class="flex flex-wrap gap-3 shrink-0">
        <a href="mailto:danielhttsai@gmail.com" class="bg-white text-brand-700 hover:bg-brand-50 font-semibold px-6 py-3 rounded-xl transition">Email me</a>
        <a href="https://www.linkedin.com/in/daniel-hsiang-te-tsai/" target="_blank" rel="noopener" class="border border-white/40 hover:bg-white/10 text-white font-semibold px-6 py-3 rounded-xl transition">LinkedIn ↗</a>
      </div>
    </div>
  </section>

  <CiteScript />
</BaseLayout>
