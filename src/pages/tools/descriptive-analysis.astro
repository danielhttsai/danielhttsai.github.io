              <select name="ageStdRef" class="border border-slate-300 rounded px-3 py-2 text-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500">
                <option value="who2000" selected>WHO World Standard 2000</option>
                <option value="esp2013">European Standard Population 2013</option>
