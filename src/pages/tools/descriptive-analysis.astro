          <button type="button" data-action="download-docx" class="bg-white border border-brand-700 text-brand-700 hover:bg-brand-50 font-semibold px-5 py-2.5 rounded-lg transition text-sm">⬇ Download Word (.docx)</button>
          <button type="button" data-action="download-md" class="text-brand-700 hover:underline font-semibold text-sm">⬇ Markdown</button>
          <button type="button" data-action="download-strobe" class="text-brand-700 hover:underline font-semibold text-sm" title="Generate the STROBE reporting checklist (von Elm 2007; strobe-statement.org) as a Word document, pre-filled from your protocol fields.">⬇ STROBE checklist</button>
          <button type="button" data-action="copy" class="text-brand-700 hover:underline font-semibold text-sm">📋 Copy</button>
          <button type="button" data-action="reset" class="ml-auto text-slate-500 hover:text-rose-600 hover:underline text-sm font-semibold">Clear all</button>
          <p data-action-msg class="basis-full text-xs"></p>
        </div>
      </form>

      <aside class="lg:sticky lg:top-20">
        <div class="border border-slate-200 rounded-2xl bg-slate-50 shadow-sm overflow-hidden">
          <header class="flex items-center justify-between px-4 py-2 bg-white border-b border-slate-200">
            <p class="text-xs uppercase tracking-widest text-brand-700 font-bold">Live preview</p>
            <p class="text-[10px] text-slate-500">Auto-saved to this browser</p>
          </header>
          <pre data-preview class="text-xs leading-relaxed text-slate-800 p-4 overflow-auto max-h-[calc(100vh-12rem)] whitespace-pre-wrap font-mono"></pre>
        </div>
      </aside>
    </div>

    <!-- Phenotype library modal -->
    <div data-library-modal class="hidden fixed inset-0 z-50 bg-slate-900/40 backdrop-blur-sm flex items-start justify-center p-4 sm:p-8 overflow-y-auto">
      <div class="bg-white border border-slate-200 rounded-2xl shadow-2xl w-full max-w-3xl my-8">
        <header class="flex items-center justify-between gap-3 px-5 py-4 border-b border-slate-100">
          <div>
            <p class="text-xs uppercase tracking-widest text-brand-700 font-bold">Validated phenotype library</p>
            <h3 class="text-lg font-bold text-slate-900 mt-0.5" data-library-title>Pick a phenotype</h3>
          </div>
          <button type="button" data-library-close class="text-slate-400 hover:text-slate-700 text-2xl leading-none">×</button>
        </header>
        <div class="px-5 py-3 border-b border-slate-100">
          <input type="text" data-library-search placeholder="Filter…" class="w-full border border-slate-300 rounded px-3 py-2 text-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500" />
        </div>
        <div data-library-list class="px-2 py-2 max-h-[60vh] overflow-y-auto"></div>
      </div>
    </div>
  </section>

  <script src="https://unpkg.com/docx@8.5.0/build/index.umd.js" is:inline></script>

  <script is:inline define:vars={{ BASE: base, SITES_DETAIL_MAP, FEATURES, PHENOTYPES, OUTPUT_METRICS, TIMELINE_PRESETS, STROBE_ITEMS }}>
    (() => {
      const setState = (name) => {
        document.querySelectorAll("[data-state]").forEach((el) => {
          el.classList.toggle("hidden", el.dataset.state !== name);
        });
      };

      const STORAGE_KEY = "aspen.protocol-builder.desc";
      const STORAGE_CITATIONS_KEY = "aspen.protocol-builder.desc.citations";
      const form = document.querySelector("[data-builder]");
      const preview = document.querySelector("[data-preview]");
      const actionMsg = document.querySelector("[data-action-msg]");
      const setMsg = (msg, isError = false) => {
        if (!actionMsg) return;
        actionMsg.textContent = msg;
        actionMsg.classList.toggle("text-rose-700", isError);
        actionMsg.classList.toggle("text-brand-700", !isError);
      };

      let pickedCitations = {};
      try { pickedCitations = JSON.parse(localStorage.getItem(STORAGE_CITATIONS_KEY) || "{}") || {}; } catch {}
      const savePickedCitations = () => { try { localStorage.setItem(STORAGE_CITATIONS_KEY, JSON.stringify(pickedCitations)); } catch {} };

      const formatSiteFull = (id) => {
        const d = SITES_DETAIL_MAP[id];
        if (!d) return id;
        const feats = (d.features || []).map((f) => (FEATURES.find((x) => x.id === f) || {}).short || f).join(" ");
        return d.country + " · " + d.short + (feats ? " [" + feats + "]" : "");
      };

      // ── Feasibility detection ───────────────────────────────
      // Permissive regex: scan user-typed text for cues that imply a site
      // feature beyond Rx + Dx. We also check ticked metrics directly
      // (mortAll / mortCause / etc. force the mortality feature).
      const FEATURE_TRIGGERS = {
        labs:      /\b(hba1c|egfr|creatinine|bmi|blood\s*pressure|systolic|diastolic|ldl|hdl|cholesterol|glucose|albumin|hemoglobin|haemoglobin|inr|tsh|lipid|biochemical|biochemist|labora?tor[yi]|lab[s]?\b)/i,
        mortality: /\b(mortality|all-?cause death|cv death|cardiovascular death|cause of death|died|fatal|death|survival|smr|sir)\b/i,
        cancer:    /\b(cancer|carcinom|malignan|neoplasm|tumou?r|sarcoma|leuk[ae]mia|lymphoma|registr[yi].*cancer|cancer.*registr[yi]|sir)\b/i,
        pregnancy: /\b(pregnan|birth|neonatal|gestation|trimester|maternal|fetal|foetal|infant|mother)\b/i,
        imaging:   /\b(imaging|mri|ct\s*scan|x-?ray|ultrasound|echocardio|angio|radiolog)\b/i,
        genomics:  /\b(genomic|snp|gwas|biobank|genotype|exome|gene(?:tic)?\b)\b/i,
      };
      const FEATURE_TEXT_FIELDS = [
        "populationName","populationDef","populationCodes",
        "inclusionCriteria","exclusionCriteria",
        "exposureName","exposureCodes",
        "outcomeName","outcomeCodes","outcomeDef",
        "mortCauseName","mortCauseCodes",
        "picoP","picoMeasure",
        "strataCustom","sensitivityCustom",
      ];
      const FEATURE_MULTI_FIELDS = ["strataPick","sensitivityPick","metricsPick"];

      const computeRequiredFeatures = (state) => {
        let blob = "";
        for (const f of FEATURE_TEXT_FIELDS) blob += " " + (state[f] || "");
        for (const f of FEATURE_MULTI_FIELDS) blob += " " + ((state[f] || []).join(" "));
        const req = new Set(["rx","dx"]);    // descriptive analyses usually start from Rx + Dx
        // Mortality is forced if any mortality metric ticked, regardless of free text.
        if ((state.metricsPick || []).includes("mortAll"))  req.add("mortality");
        if ((state.metricsPick || []).includes("mortCause")) req.add("mortality");
        for (const [feat, rx] of Object.entries(FEATURE_TRIGGERS)) {
          if (rx.test(blob)) req.add(feat);
        }
        return req;
      };

      const renderFeasibility = (state) => {
        const panel  = document.querySelector("[data-feasibility]");
        const list   = document.querySelector("[data-feasibility-list]");
        if (!panel || !list) return;
        const required = computeRequiredFeatures(state);
        const selected = state.sites || [];
        if (selected.length === 0) { panel.classList.add("hidden"); return; }

        const gaps = [];
        for (const featId of required) {
          if (featId === "rx" || featId === "dx") continue;
          const featLabel = (FEATURES.find((f) => f.id === featId) || {}).label || featId;
          const missing = [];
          const have    = [];
          for (const sid of selected) {
            const d = SITES_DETAIL_MAP[sid];
            if (!d) continue;
            (d.features.includes(featId) ? have : missing).push(d.short);
          }
          if (missing.length > 0) {
            gaps.push({ feature: featLabel, missing, have });
          }
        }

        if (gaps.length === 0) { panel.classList.add("hidden"); return; }
        list.innerHTML = gaps.map((g) =>
          `<li><strong>${g.feature}</strong>; implied by your study text / chosen metrics. Missing at: <strong>${g.missing.join(", ")}</strong>` +
          (g.have.length > 0 ? `. Available at: ${g.have.join(", ")}.` : `.`) + `</li>`
        ).join("");
        panel.classList.remove("hidden");
      };

      // ── Form state read / write ─────────────────────
      const readForm = () => {
        const data = new FormData(form);
        const out = {};
        const multi = new Set(["sites", "metricsPick", "strataPick", "sensitivityPick"]);
        for (const k of multi) out[k] = [];
        for (const [k, v] of data.entries()) {
          if (multi.has(k)) out[k].push(String(v));
          else out[k] = String(v);
        }
        return out;
      };
      const writeForm = (state) => {
        const multi = new Set(["sites", "metricsPick", "strataPick", "sensitivityPick"]);
        for (const el of form.querySelectorAll("input, textarea, select")) {
          const name = el.name;
          if (!name) continue;
          if (el.type === "checkbox" && multi.has(name)) el.checked = (state[name] || []).includes(el.value);
          else if (state[name] !== undefined) el.value = state[name];
        }
      };
      const mergeList = (picks, customText) => {
        const lines = (customText || "").split(/\r?\n/).map((l) => l.trim()).filter(Boolean);
        return [...(picks || []), ...lines];
      };
      const bullets = (arr) => arr.length === 0 ? "_(none specified)_" : arr.map((l) => "- " + l).join("\n");
      const numbered = (arr) => arr.length === 0 ? "_(none)_" : arr.map((l, i) => (i + 1) + ". " + l).join("\n");
      const orFb = (s, fb) => (s && s.trim()) ? s : fb;
      const sitesLine = (ids, otherText) => {
        const parts = (ids || []).map((c) => "- " + formatSiteFull(c));
        const others = (otherText || "").split(/\r?\n/).map((l) => l.trim()).filter(Boolean);
        if (parts.length === 0 && others.length === 0) return "_(no sites selected)_";
        let out = parts.join("\n");
        if (others.length > 0) out += (out ? "\n\n**Other sites:**\n" : "**Other sites:**\n") + others.map((o) => "- " + o).join("\n");
        return out;
      };

      // ── Per-metric section content (Markdown) ──
      // Each metric returns an object { name, formula, notes } that
      // gets rendered into a labelled block. The actual section
      // numbering happens in buildMarkdown.
      const metricBlock = (id, s) => {
        const m = OUTPUT_METRICS.find((x) => x.id === id);
        if (!m) return null;
        const strata = mergeList(s.strataPick, s.strataCustom);
        const strataLine = strata.length > 0 ? strata.join(" · ") : "Overall only";
        switch (id) {
          case "incidence": return {
            name: m.label, unit: m.unit,
            numerator: "Incident " + orFb(s.outcomeName, "outcome") + " events (first record meeting code set)",
            denominator: "Person-time at risk = sum of follow-up time from index date to first event / death / disenrolment / study end",
            formula: "IR = (events / person-time) × 1000",
            stratifyBy: strataLine,
          };
          case "periodPrev": return {
            name: m.label, unit: m.unit,
            numerator: "Cohort members with ≥1 qualifying " + orFb(s.outcomeName, "outcome") + " record during the window",
            denominator: "Cohort members alive and enrolled at any point during the window",
            formula: "Period prevalence = numerator / denominator (× 100 for %)",
            stratifyBy: strataLine,
          };
          case "pointPrev": return {
            name: m.label, unit: m.unit,
            numerator: "Cohort members with active " + orFb(s.outcomeName, "outcome") + " condition on the prevalence date (mid-year typical)",
            denominator: "Cohort members alive and enrolled on the prevalence date",
            formula: "Point prevalence = numerator / denominator (× 100 for %)",
            stratifyBy: strataLine,
          };
          case "mortAll": return {
            name: m.label, unit: m.unit,
            numerator: "All-cause deaths in cohort (mortality-linked records)",
            denominator: "Person-time at risk (entry to death / censoring)",
            formula: "All-cause mortality rate = (deaths / person-time) × 1000",
            stratifyBy: strataLine,
          };
          case "mortCause": return {
            name: m.label, unit: m.unit,
            numerator: orFb(s.mortCauseName, "Cause-specific") + " deaths in cohort (codes: " + orFb(s.mortCauseCodes, "see mortality library") + ")",
            denominator: "Person-time at risk",
            formula: "Cause-specific mortality rate = (cause-specific deaths / person-time) × 1000",
            stratifyBy: strataLine,
          };
          case "ddd": return {
            name: m.label, unit: m.unit,
            numerator: "Sum of DDDs dispensed for " + orFb(s.exposureName, "exposure class") + " (codes: " + orFb(s.exposureCodes, "ATC") + ") using WHO ATC/DDD index assignments",
            denominator: "Mid-period source-population estimate × number of days in the window",
            formula: "DDD/1000/day = (DDDs × 1000) / (population × days)",
            stratifyBy: strataLine,
          };
          case "initiation": return {
            name: m.label, unit: m.unit,
            numerator: "New users of " + orFb(s.exposureName, "exposure class") + " (no dispensing in prior 365-d washout)",
            denominator: "Eligible cohort person-time among those not already on the class",
            formula: "Initiation rate = (new users / at-risk person-time) × 1000",
            stratifyBy: strataLine,
          };
          case "persistence": return {
            name: m.label, unit: m.unit,
            numerator: "Time from first dispensing to first gap > grace period (typically 30 d) without re-dispensing",
            denominator: "All new users at index",
            formula: "Median time-to-discontinuation (Kaplan-Meier); % still on therapy at 6 / 12 months",
            stratifyBy: strataLine,
          };
          case "switching": return {
            name: m.label, unit: m.unit,
            numerator: "Transitions between drug classes within the same indication during follow-up",
            denominator: "All cohort members starting on first-line therapy",
            formula: "First-line → second-line → … flow proportions; visualised as a Sankey diagram",
            stratifyBy: strataLine,
          };
          case "concomitant": return {
            name: m.label, unit: m.unit,
            numerator: "Cohort members with overlapping days-of-supply across ≥2 specified drug classes",
            denominator: "Cohort members with ≥1 dispensing in any specified class",
            formula: "Concomitant-use proportion = numerator / denominator (× 100 for %)",
            stratifyBy: strataLine,
          };
          case "ageStandardised": return {
            name: m.label, unit: m.unit,
            numerator: "(See age-stratum-specific rates from the relevant metric above)",
            denominator: "Standardised to: " + (({who2000:"WHO World Standard 2000",esp2013:"European Standard Population 2013",segi1960:"Segi 1960",internal:"Internal-pooled (AsPEN sum)"})[s.ageStdRef] || "WHO 2000"),
            formula: ((s.ageStdMethod === "indirect") ? "Indirect (SMR / SIR): observed / expected events × 1000" : (s.ageStdMethod === "both" ? "Direct AND Indirect (SMR / SIR), reported side-by-side" : "Direct: Σ (age-stratum rate × reference proportion); reported with 95% CI by Dobson method")),
            stratifyBy: "Age bands: " + orFb(s.ageStdBands, "5-year bands 0–4 through 85+"),
          };
          case "joinpoint": return {
            name: m.label, unit: m.unit,
            numerator: "Annual rates from the primary metric (above) over the trend window",
            denominator: "Time-series of " + orFb(s.trendYears, "2010–2023"),
            formula: "Joinpoint regression: identify up to " + (s.trendMaxJp || "3") + " break-points using " + ((s.trendMethod === "permutation") ? "permutation test" : "grid search") + "; report " + (({"apc-aapc":"APC per segment + AAPC over full window","apc":"APC per segment","aapc":"AAPC only"})[s.trendReport] || "APC + AAPC") + ". Reference: Kim HJ et al, Stat Med 2000.",
            stratifyBy: strataLine,
          };
          case "trendInTrend": return {
            name: m.label, unit: m.unit,
            numerator: "Outcome trend in high-exposure stratum",
            denominator: "Outcome trend in low-exposure stratum (stratification by site-level exposure prevalence)",
            formula: "Trend-in-trend (Ji ECC et al 2017): exploits cross-stratum covariance between exposure-trend and outcome-trend to identify causal contribution. **Advanced variant; if this is your central analytic question, consider a dedicated Trend-in-trend protocol.**",
            stratifyBy: strataLine,
          };
          default: return null;
        }
      };

      const buildMarkdown = (s) => {
        const today = new Date().toISOString().slice(0, 10);
        const title = orFb(s.title, "(Untitled multi-national descriptive study)");
        const meta = ({
          re: "Random-effects (DerSimonian-Laird) pooled estimates across sites; report I² and τ². Forest plot.",
          "re-reml": "Random-effects (REML) pooled estimates across sites; report I² and τ². Forest plot.",
          descriptive: "Descriptive only; side-by-side tables and ranked figures; no pooled estimate.",
        })[s.metaMethod] || "Descriptive comparison across sites.";
        const arch = ({
          federated: "Federated; each AsPEN site executes the common analytic package locally and shares aggregate counts + person-time only.",
          cdm: "Common Data Model; each site transforms data into an agreed CDM, runs the shared package.",
          centralised: "Centralised; site-level individual data pooled under DUA.",
        })[s.arch] || "Federated";
        const ciMethod = ({
          "poisson-exact": "Exact Poisson (rates) and Wilson score (proportions); preferred for sparse cells",
          "normal": "Normal approximation (only valid for cells with ≥10 events)",
          "bootstrap": "Non-parametric bootstrap (1000 resamples)",
        })[s.ciMethod] || "Exact Poisson / Wilson";
        const ticked = (s.metricsPick || []);

        const refsUser = (s.references || "").split(/\r?\n/).map((l) => l.trim()).filter(Boolean);
        const refs = (() => { const set = new Set(refsUser); for (const c of Object.values(pickedCitations)) if (c && c.trim()) set.add(c.trim()); return Array.from(set); })();
        const milestones = (s.timeline || "").split(/\r?\n/).map((l) => l.trim()).filter(Boolean);
        const strata = mergeList(s.strataPick, s.strataCustom);
        const inclusion = (s.inclusionCriteria || "").split(/\r?\n/).map((l) => l.trim()).filter(Boolean);
        const exclusion = (s.exclusionCriteria || "").split(/\r?\n/).map((l) => l.trim()).filter(Boolean);
        const sensitivity = mergeList(s.sensitivityPick, s.sensitivityCustom);

        // Render each ticked metric as its own ## section, numbered sequentially.
        let metricSection = "";
        let n = 7;
        for (const id of ticked) {
          const block = metricBlock(id, s);
          if (!block) continue;
          metricSection += `\n## ${n}. ${block.name}\n\n` +
            `**Unit.** ${block.unit}\n\n` +
            `| | |\n|---|---|\n` +
            `| **Numerator** | ${block.numerator} |\n` +
            `| **Denominator** | ${block.denominator} |\n` +
            `| **Formula** | ${block.formula} |\n` +
            `| **Stratify by** | ${block.stratifyBy} |\n`;
          n++;
        }
        if (!metricSection) metricSection = "\n## 7. Output metrics\n\n_(none selected; tick at least one in Section 6 of the form)_\n";

        return `# ${title}

**Study ID:** ${orFb(s.shortId, "(short id)")}
**Lead investigator(s):** ${orFb(s.leadInvestigator, "(lead)")}
**Version:** ${orFb(s.version, "v0.1 draft · " + today)}
**Design:** Multi-national descriptive epidemiology

---

## 1. Research question

| | |
|---|---|
| **Population** | ${orFb(s.picoP, "_(population)_")} |
| **What we measure** | ${orFb(s.picoMeasure, "_(metric)_")} |
| **Time window** | ${orFb(s.picoWindow, "_(window)_")} |

## 2. Sites

${sitesLine(s.sites, s.sitesOther)}

## 3. Population (denominator)

**Name.** ${orFb(s.populationName, "_(population name)_")}

**Operational definition.** ${orFb(s.populationDef, "_(operational definition)_")}

**Code set / criteria.** ${orFb(s.populationCodes, "_(codes)_")}

**Inclusion criteria**

${bullets(inclusion)}

**Exclusion criteria**

${bullets(exclusion)}

**Index date / observation-start rule.** ${orFb(s.indexDateRule, "_(rule)_")}

**Study calendar period.** ${orFb(s.studyCalendar, "_(period)_")}

## 4. Numerator phenotypes

| | Value |
|---|---|
| **Drug exposure; name** | ${orFb(s.exposureName, "_(n/a)_")} |
| **Drug exposure; codes** | ${orFb(s.exposureCodes, "_(n/a)_")} |
| **Outcome; name** | ${orFb(s.outcomeName, "_(n/a)_")} |
| **Outcome; codes** | ${orFb(s.outcomeCodes, "_(n/a)_")} |
| **Outcome; operational definition** | ${orFb(s.outcomeDef, "_(n/a)_")} |
| **Cause of death; name** | ${orFb(s.mortCauseName, "_(n/a)_")} |
| **Cause of death; codes** | ${orFb(s.mortCauseCodes, "_(n/a)_")} |

## 5. Output metrics; selected

${ticked.length > 0 ? ticked.map((id, i) => "- " + ((OUTPUT_METRICS.find((m) => m.id === id) || {}).label || id)).join("\n") : "_(none selected)_"}

## 6. Stratification

${bullets(strata)}
${metricSection}

## ${n}. Statistical analysis

- **CI method:** ${ciMethod}
- **Cross-site comparison:** ${meta}
- **Site contribution model:** ${(({aggregate:"Site-level aggregate (counts + person-time) only",anonymised:"De-identified record-level subset",full:"Centralised pooled individual data (DUA permits)"})[s.contribution] || "Site-level aggregate")}
- **Suppression rule:** ${orFb(s.suppression, "Suppress cells with <5 events; report as '<5'.")}

**Sensitivity analyses**

${bullets(sensitivity)}

## ${n+1}. Execution and timeline

**Architecture.** ${arch}

**Timeline milestones**

${numbered(milestones)}

## ${n+2}. Ethics, data sharing, dissemination

**Ethics.** ${orFb(s.ethics, "Each participating site obtains local IRB / ethics approval before data extraction.")}

**Dissemination.** ${orFb(s.dissemination, "Primary manuscript to a peer-reviewed pharmacoepidemiology / public-health journal.")}

## ${n+3}. Key references

${numbered(refs)}

---

_Drafted with the AsPEN Descriptive Analysis protocol builder (${today})._
`;
      };

      const render = () => {
        const state = readForm();
        preview.textContent = buildMarkdown(state);
        try { localStorage.setItem(STORAGE_KEY, JSON.stringify(state)); } catch {}
        renderFeasibility(state);
      };
      try { const saved = localStorage.getItem(STORAGE_KEY); if (saved) writeForm(JSON.parse(saved)); } catch {}
      const timelineTa = form.querySelector('[name="timeline"]');
      if (timelineTa && !timelineTa.value) timelineTa.value = TIMELINE_PRESETS["12-month"];
      render();
      form.addEventListener("input", render);
      form.addEventListener("change", render);

      form.addEventListener("click", (e) => {
        const tl = e.target?.closest?.("[data-timeline-preset]");
        if (tl) {
          const ta = form.querySelector('[name="timeline"]');
          if (ta) { ta.value = TIMELINE_PRESETS[tl.dataset.timelinePreset] || ta.value; render(); }
        }
      });

      const buildFilename = (ext) => {
        const state = readForm();
        const slug = (state.shortId || "aspen-protocol-desc").toLowerCase().replace(/[^a-z0-9]+/g, "-").replace(/^-|-$/g, "").slice(0, 60) || "aspen-protocol-desc";
        const today = new Date().toISOString().slice(0, 10);
        return slug + "-" + today + "." + ext;
      };

      document.querySelector("[data-action='download-md']")?.addEventListener("click", () => {
        const blob = new Blob([preview.textContent || ""], { type: "text/markdown;charset=utf-8" });
        const url = URL.createObjectURL(blob);
        const a = document.createElement("a");
        a.href = url; a.download = buildFilename("md");
        document.body.appendChild(a); a.click(); a.remove();
        URL.revokeObjectURL(url);
        setMsg("Downloaded " + a.download);
      });

      document.querySelector("[data-action='copy']")?.addEventListener("click", async () => {
        try { await navigator.clipboard.writeText(preview.textContent || ""); setMsg("Copied to clipboard."); }
        catch { setMsg("Couldn't copy; your browser may block clipboard access.", true); }
      });

      const doReset = () => {
        if (!confirm("Clear every field and forget the saved draft?")) return;
        localStorage.removeItem(STORAGE_KEY);
        localStorage.removeItem(STORAGE_CITATIONS_KEY);
        pickedCitations = {};
        form.querySelectorAll("input, textarea, select").forEach((el) => {
          if (el.type === "checkbox" || el.type === "radio") el.checked = false;
          else if (el.tagName === "SELECT") el.selectedIndex = 0;
          else el.value = "";
        });
        render();
        setMsg("Cleared.");
      };
      document.querySelector("[data-action='reset']")?.addEventListener("click", doReset);
      document.querySelector("[data-action='reset-top']")?.addEventListener("click", doReset);

      document.querySelector("[data-action='download-docx']")?.addEventListener("click", async () => {
        if (typeof docx === "undefined") { setMsg("Word library failed to load.", true); return; }
        setMsg("Building Word document…");
        try {
          const blob = await buildDocx(readForm());
          const url = URL.createObjectURL(blob);
          const a = document.createElement("a");
          a.href = url; a.download = buildFilename("docx");
          document.body.appendChild(a); a.click(); a.remove();
          URL.revokeObjectURL(url);
          setMsg("Downloaded " + a.download);
        } catch (e) { console.error(e); setMsg("Couldn't build the Word file: " + String(e), true); }
      });

      // ── STROBE checklist (.docx) ──────────────────────────
      document.querySelector("[data-action='download-strobe']")?.addEventListener("click", async () => {
        if (typeof docx === "undefined") { setMsg("Word library failed to load.", true); return; }
        setMsg("Building STROBE checklist…");
        try {
          const s = readForm();
          const blob = await buildStrobeDocx(s);
          const url = URL.createObjectURL(blob);
          const a = document.createElement("a");
          const today = new Date().toISOString().slice(0, 10);
          a.href = url;
          a.download = (s.shortId || "descriptive").replace(/[^a-z0-9]+/gi, "-").toLowerCase() + "-STROBE-checklist-" + today + ".docx";
          document.body.appendChild(a); a.click(); a.remove();
          URL.revokeObjectURL(url);
          setMsg("Downloaded " + a.download);
        } catch (e) { console.error(e); setMsg("Couldn't build the STROBE checklist: " + String(e), true); }
      });

      // Map this descriptive-analysis protocol's fields onto the STROBE items.
      const strobeWhere = (s) => {
        const sitesPlain = (() => {
          const parts = (s.sites || []).map((c) => formatSiteFull(c));
          const others = (s.sitesOther || "").split(/\r?\n/).map((l) => l.trim()).filter(Boolean);
          return [...parts, ...others].join("; ") || "(no sites selected)";
        })();
        const bul = (a) => a.length ? a.map((x) => "• " + x).join("\n") : "(none specified)";
        const sens = mergeList(s.sensitivityPick, s.sensitivityCustom);
        const strata = mergeList(s.strataPick, s.strataCustom);
        const metricLabels = (s.metricsPick || []).map((id) => ((OUTPUT_METRICS.find((m) => m.id === id) || {}).label || id));
        const metaTxt = ({ re: "random-effects (DerSimonian-Laird)", "re-reml": "random-effects (REML)", fe: "fixed-effects (inverse-variance)" })[s.metaMethod] || "descriptive cross-site comparison";
        return {
          "1a": "Multi-national descriptive epidemiology study (disease frequency / drug utilisation).",
          "3": "Characterise " + (s.picoMeasure || "(metric)") + " among " + (s.picoP || "(population)") + " across the participating AsPEN sites. Descriptive; no causal hypothesis.",
          "4": "Descriptive cross-national analysis. Population-level rates / proportions are computed within each site and compared; no exposure-outcome causal contrast.",
          "5": "AsPEN sites: " + sitesPlain + ". Observation period and calendar window as defined in the protocol.",
          "6": "Source population: " + (s.populationDef || s.picoP || "(population)") + (s.populationCodes ? " (" + s.populationCodes + ")" : "") + ". Eligibility (e.g. continuous enrolment) per the protocol.",
          "7": "Output metrics:\n" + bul(metricLabels) + "\nNumerator(s): " + (s.outcomeName || s.outcomeDef || "exposures / outcomes / mortality causes per the protocol") + (s.outcomeCodes ? " (" + s.outcomeCodes + ")" : "") + ".",
          "8": "Routinely-collected health data from the contributing databases (" + sitesPlain + "). Each metric's numerator and denominator ascertained from the protocol code sets and enrolment data.",
          "9": "Differential data capture across databases addressed by reporting which sites contribute to each metric and by sensitivity analyses:\n" + bul(sens),
          "11": "Age handled by standardisation and/or banding where indicated in the metric definitions; rates expressed per person-time / per 1000 as specified.",
          "12": "Per-site computation of each selected metric (incidence / prevalence / utilisation, etc.) with the stated denominators and age-standardisation where indicated; site estimates compared / pooled by " + metaTxt + ". Stratified by:\n" + bul(strata) + "\nSensitivity analyses:\n" + bul(sens),
          "14": "Per-site population characteristics and denominators to be tabulated (Table 1).",
          "17": "Stratified analyses:\n" + bul(strata) + "\nSensitivity analyses:\n" + bul(sens),
          "19": "Descriptive estimates reflect coding and capture practices that differ across databases; cross-site comparisons should account for differential ascertainment; no causal interpretation is intended.",
          "21": "Estimates generalise to the source populations of the contributing AsPEN databases: " + sitesPlain + ".",
        };
      };

      const buildStrobeDocx = async (s) => {
        const D = docx;
        const FONT = "Times New Roman";
        const today = new Date().toISOString().slice(0, 10);
        const text = (str, o = {}) => new D.TextRun({ text: String(str ?? ""), font: FONT, size: 22, ...o });
        const p = (ch, o = {}) => new D.Paragraph({ children: Array.isArray(ch) ? ch : [ch], spacing: { before: 50, after: 50 }, ...o });
        const border = { style: D.BorderStyle.SINGLE, size: 4, color: "BBBBBB" };
        const cb = { top: border, bottom: border, left: border, right: border };
        const cell = (children, opt = {}) => new D.TableCell({ borders: cb, margins: { top: 60, bottom: 60, left: 120, right: 120 }, ...opt, children });
        const headerCell = (str) => new D.TableCell({ borders: cb, shading: { fill: "21443E", type: D.ShadingType.CLEAR }, margins: { top: 80, bottom: 80, left: 120, right: 120 }, children: [p([text(str, { bold: true, color: "FFFFFF" })])] });
        const where = strobeWhere(s);
        const rows = [new D.TableRow({ tableHeader: true, children: [headerCell("#"), headerCell("STROBE recommendation"), headerCell("Where addressed in this protocol")] })];
        for (const sec of STROBE_ITEMS) {
          rows.push(new D.TableRow({ children: [new D.TableCell({ borders: cb, columnSpan: 3, shading: { fill: "E8F0EE", type: D.ShadingType.CLEAR }, margins: { top: 60, bottom: 60, left: 120, right: 120 }, children: [p([text(sec.section, { bold: true, color: "21443E" })])] })] }));
          for (const [n, rec] of sec.items) {
            const w = where[n] || "[To be completed at the time of reporting.]";
            rows.push(new D.TableRow({ children: [
              cell([p([text(n, { bold: true })])], { width: { size: 700, type: D.WidthType.DXA }, shading: { fill: "F5F5F5", type: D.ShadingType.CLEAR } }),
              cell([p([text(rec)])], { width: { size: 4163, type: D.WidthType.DXA } }),
              cell(String(w).split("\n").map((l) => p([text(l)])), { width: { size: 4163, type: D.WidthType.DXA } }),
            ] }));
          }
        }
        const table = new D.Table({ width: { size: 9026, type: D.WidthType.DXA }, columnWidths: [700, 4163, 4163], rows });
        const children = [
          new D.Paragraph({ children: [text("STROBE checklist; " + (s.title || "(Untitled multi-national descriptive study)"), { bold: true, size: 32 })], spacing: { after: 120 } }),
          p([new D.TextRun({ text: "This document maps the protocol fields to the STROBE statement (von Elm E, et al. PLoS Med 2007;4:e296). Methods items are pre-filled from your protocol; Results / Discussion items are placeholders to complete at the time of reporting. Full checklist with elaboration: strobe-statement.org.", font: FONT, size: 20, italics: true, color: "555555" })]),
          p([new D.TextRun({ text: "Generated " + today + " from the AsPEN descriptive-analysis protocol builder.", font: FONT, size: 18, italics: true, color: "777777" })]),
          table,
        ];
        const doc = new D.Document({ sections: [{ properties: { page: { size: { width: 11906, height: 16838 }, margin: { top: 1440, right: 1440, bottom: 1440, left: 1440 } } }, children }] });
        return await D.Packer.toBlob(doc);
      };

      const buildDocx = async (s) => {
        const D = docx;
        const FONT = "Times New Roman";
        const today = new Date().toISOString().slice(0, 10);
        const text = (str, opts = {}) => new D.TextRun({ text: String(str ?? ""), font: FONT, size: 22, ...opts });
        const p = (children, opts = {}) => new D.Paragraph({ children: Array.isArray(children) ? children : [children], spacing: { before: 60, after: 60, ...(opts.spacing || {}) }, ...opts });
        const h1 = (str) => new D.Paragraph({ children: [text(str, { bold: true, size: 28 })], spacing: { before: 200, after: 80 }, heading: D.HeadingLevel.HEADING_1 });
        const h2 = (str) => new D.Paragraph({ children: [text(str, { bold: true, size: 24 })], spacing: { before: 160, after: 60 }, heading: D.HeadingLevel.HEADING_2 });
        const para = (str) => p([text(str)]);
        const bullet = (str) => new D.Paragraph({ children: [text(str)], bullet: { level: 0 }, spacing: { before: 0, after: 0 } });
        const numItem = (str) => new D.Paragraph({ children: [text(str)], numbering: { reference: "ordered", level: 0 }, spacing: { before: 0, after: 0 } });
        const border = { style: D.BorderStyle.SINGLE, size: 4, color: "BBBBBB" };
        const cellBorders = { top: border, bottom: border, left: border, right: border };
        const labelTable = (rows) => new D.Table({
          width: { size: 9026, type: D.WidthType.DXA },
          columnWidths: [3000, 6026],
          rows: rows.map(([l, v]) => new D.TableRow({
            children: [
              new D.TableCell({ borders: cellBorders, width: { size: 3000, type: D.WidthType.DXA }, margins: { top: 60, bottom: 60, left: 100, right: 100 }, shading: { fill: "F5F5F5", type: D.ShadingType.CLEAR }, children: [p([text(l, { bold: true })])] }),
              new D.TableCell({ borders: cellBorders, width: { size: 6026, type: D.WidthType.DXA }, margins: { top: 60, bottom: 60, left: 100, right: 100 }, children: [p([text(v || "-")])] }),
            ],
          })),
        });

        const refsUser = (s.references || "").split(/\r?\n/).map((l) => l.trim()).filter(Boolean);
        const refs = (() => { const set = new Set(refsUser); for (const c of Object.values(pickedCitations)) if (c && c.trim()) set.add(c.trim()); return Array.from(set); })();
        const milestones = (s.timeline || "").split(/\r?\n/).map((l) => l.trim()).filter(Boolean);
        const strata = mergeList(s.strataPick, s.strataCustom);
        const inclusion = (s.inclusionCriteria || "").split(/\r?\n/).map((l) => l.trim()).filter(Boolean);
        const exclusion = (s.exclusionCriteria || "").split(/\r?\n/).map((l) => l.trim()).filter(Boolean);
        const sensitivity = mergeList(s.sensitivityPick, s.sensitivityCustom);
        const sitesPart = (s.sites && s.sites.length > 0) ? s.sites.map((c) => formatSiteFull(c)).join("; ") : "";
        const sitesOthersList = (s.sitesOther || "").split(/\r?\n/).map((l) => l.trim()).filter(Boolean);
        const sitesText = !sitesPart && sitesOthersList.length === 0 ? "(no sites selected)" : [sitesPart, sitesOthersList.length > 0 ? ("Others: " + sitesOthersList.join("; ")) : ""].filter(Boolean).join(" | ");
        const meta = ({
          re: "Random-effects (DerSimonian-Laird) pooled estimates; report I² and τ²; forest plot.",
          "re-reml": "Random-effects (REML); report I² and τ²; forest plot.",
          descriptive: "Descriptive only; side-by-side tables and ranked figures.",
        })[s.metaMethod] || "Descriptive across sites";
        const arch = ({
          federated: "Federated; each AsPEN site executes locally; aggregate counts + person-time leave the site.",
          cdm: "Common Data Model; site transforms to agreed CDM, runs shared package.",
          centralised: "Centralised; pooled individual data under DUA.",
        })[s.arch] || "Federated";
        const ciMethod = ({
          "poisson-exact": "Exact Poisson / Wilson score",
          "normal": "Normal approximation",
          "bootstrap": "Non-parametric bootstrap (1000 resamples)",
        })[s.ciMethod] || "Exact Poisson / Wilson";
        const ticked = s.metricsPick || [];

        const children = [];
        children.push(new D.Paragraph({ children: [text(s.title || "(Untitled multi-national descriptive study)", { bold: true, size: 32 })], spacing: { before: 0, after: 120 } }));
        children.push(labelTable([
          ["Study ID", s.shortId || ""],
          ["Lead investigator(s)", s.leadInvestigator || ""],
          ["Version", s.version || ("v0.1 draft · " + today)],
          ["Design", "Multi-national descriptive epidemiology"],
        ]));

        children.push(h1("1. Research question"));
        children.push(labelTable([
          ["Population", s.picoP || ""],
          ["What we measure", s.picoMeasure || ""],
          ["Time window", s.picoWindow || ""],
        ]));

        children.push(h1("2. Sites"));
        children.push(para(sitesText));

        children.push(h1("3. Population (denominator)"));
        children.push(labelTable([
          ["Name", s.populationName || ""],
          ["Operational definition", s.populationDef || ""],
          ["Code set / criteria", s.populationCodes || ""],
          ["Index date rule", s.indexDateRule || ""],
          ["Study calendar period", s.studyCalendar || ""],
        ]));
        if (inclusion.length) { children.push(h2("Inclusion criteria")); inclusion.forEach((l) => children.push(bullet(l))); }
        if (exclusion.length) { children.push(h2("Exclusion criteria")); exclusion.forEach((l) => children.push(bullet(l))); }

        children.push(h1("4. Numerator phenotypes"));
        children.push(labelTable([
          ["Drug exposure; name", s.exposureName || ""],
          ["Drug exposure; codes", s.exposureCodes || ""],
          ["Outcome; name", s.outcomeName || ""],
          ["Outcome; codes", s.outcomeCodes || ""],
          ["Outcome; operational definition", s.outcomeDef || ""],
          ["Cause of death; name", s.mortCauseName || ""],
          ["Cause of death; codes", s.mortCauseCodes || ""],
        ]));

        children.push(h1("5. Output metrics; selected"));
        if (ticked.length === 0) children.push(para("(none selected)"));
        else ticked.forEach((id) => {
          const m = OUTPUT_METRICS.find((x) => x.id === id);
          if (m) children.push(bullet(m.label));
        });

        children.push(h1("6. Stratification"));
        if (strata.length === 0) children.push(para("Overall only (no strata)"));
        else strata.forEach((l) => children.push(bullet(l)));

        // One section per ticked metric.
        let n = 7;
        for (const id of ticked) {
          const block = metricBlock(id, s);
          if (!block) continue;
          children.push(h1(`${n}. ${block.name}`));
          children.push(labelTable([
            ["Unit", block.unit],
            ["Numerator", block.numerator],
            ["Denominator", block.denominator],
            ["Formula", block.formula],
            ["Stratify by", block.stratifyBy],
          ]));
          n++;
        }

        children.push(h1(`${n}. Statistical analysis`));
        children.push(labelTable([
          ["CI method", ciMethod],
          ["Cross-site comparison", meta],
          ["Site contribution model", (({aggregate:"Site-level aggregate (counts + person-time) only",anonymised:"De-identified record-level subset",full:"Centralised pooled individual data (DUA permits)"})[s.contribution] || "Site-level aggregate")],
          ["Suppression rule", s.suppression || "Suppress cells with <5 events"],
        ]));
        children.push(h2("Sensitivity analyses"));
        if (sensitivity.length === 0) children.push(para("(none specified)"));
        else sensitivity.forEach((l) => children.push(bullet(l)));
        n++;

        children.push(h1(`${n}. Execution and timeline`));
        children.push(labelTable([["Architecture", arch]]));
        children.push(h2("Timeline milestones"));
        if (milestones.length === 0) children.push(para("(none)"));
        else milestones.forEach((l) => children.push(numItem(l)));
        n++;

        children.push(h1(`${n}. Ethics, data sharing, dissemination`));
        children.push(p([text("Ethics. ", { bold: true }), text(s.ethics || "Each participating site obtains local IRB / ethics approval before data extraction.")]));
        children.push(p([text("Dissemination. ", { bold: true }), text(s.dissemination || "Primary manuscript to a peer-reviewed pharmacoepidemiology / public-health journal.")]));
        n++;

        children.push(h1(`${n}. Key references`));
        if (refs.length === 0) children.push(para("(none)"));
        else refs.forEach((l) => children.push(numItem(l)));

        children.push(p([new D.TextRun({ text: "Drafted with the AsPEN Descriptive Analysis protocol builder (" + today + ").", font: FONT, size: 18, italics: true, color: "808080" })], { spacing: { before: 400 } }));

        const doc = new D.Document({
          creator: "AsPEN protocol builder",
          title: s.title || "AsPEN descriptive-analysis protocol",
          styles: {
            default: { document: { run: { font: FONT, size: 22 } } },
            paragraphStyles: [
              { id: "Heading1", name: "Heading 1", basedOn: "Normal", next: "Normal", quickFormat: true, run: { size: 28, bold: true, font: FONT }, paragraph: { spacing: { before: 200, after: 80 }, outlineLevel: 0 } },
              { id: "Heading2", name: "Heading 2", basedOn: "Normal", next: "Normal", quickFormat: true, run: { size: 24, bold: true, font: FONT }, paragraph: { spacing: { before: 160, after: 60 }, outlineLevel: 1 } },
            ],
          },
          numbering: { config: [{ reference: "ordered", levels: [{ level: 0, format: D.LevelFormat.DECIMAL, text: "%1.", alignment: D.AlignmentType.LEFT, style: { paragraph: { indent: { left: 720, hanging: 360 } } } }] }] },
          sections: [{ properties: { page: { size: { width: 11906, height: 16838 }, margin: { top: 1440, right: 1440, bottom: 1440, left: 1440 } } }, children }],
        });
        return await D.Packer.toBlob(doc);
      };

      // ── Phenotype library modal ──
      const modal = document.querySelector("[data-library-modal]");
      const modalTitle = document.querySelector("[data-library-title]");
      const modalList = document.querySelector("[data-library-list]");
      const modalSearch = document.querySelector("[data-library-search]");
      let currentCategory = "populations";
      let currentTargets = {};
      const esc = (str) => String(str ?? "").replace(/[&<>"']/g, (c) => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;" }[c]));

      const renderLibrary = (filter = "") => {
        const items = PHENOTYPES[currentCategory] || [];
        const f = filter.trim().toLowerCase();
        const filtered = f ? items.filter((it) => (it.name || "").toLowerCase().includes(f) || (it.codes || "").toLowerCase().includes(f) || (it.definition || "").toLowerCase().includes(f) || (it.validation || "").toLowerCase().includes(f)) : items;
        if (filtered.length === 0) { modalList.innerHTML = '<p class="px-3 py-6 text-sm text-slate-500 italic text-center">No phenotype matches.</p>'; return; }
        modalList.innerHTML = filtered.map((it, idx) => `
          <button type="button" data-phenotype-idx="${idx}" class="block w-full text-left px-4 py-3 rounded-lg border border-transparent hover:border-brand-300 hover:bg-brand-50/40 transition">
            <p class="font-semibold text-slate-900 text-sm">${esc(it.name)}</p>
            ${it.codes ? `<p class="mt-1 text-xs text-slate-700 font-mono leading-relaxed">${esc(it.codes)}</p>` : ""}
            ${it.definition ? `<p class="mt-1 text-xs text-slate-600 leading-relaxed">${esc(it.definition)}</p>` : ""}
          </button>
        `).join("");
        modalList.querySelectorAll("[data-phenotype-idx]").forEach((btn) => {
          btn.addEventListener("click", () => {
            const it = filtered[parseInt(btn.dataset.phenotypeIdx, 10)];
            if (!it) return;
            const fill = (key, val) => { const fieldName = currentTargets[key]; if (!fieldName || val === undefined) return; const el = form.querySelector(`[name="${fieldName}"]`); if (el) el.value = val; };
            fill("name", it.name);
            fill("codes", it.codes);
            fill("def", it.definition);
            if (it.validation) { pickedCitations[it.name] = it.validation; savePickedCitations(); }
            closeLibrary();
            render();
          });
        });
      };
      const openLibrary = (category, targets) => {
        currentCategory = category;
        currentTargets = targets;
        modalTitle.textContent = ({
          populations: "Pick a population (denominator)",
          exposures: "Pick a drug class (exposure)",
          outcomes: "Pick an outcome",
          mortalityCauses: "Pick a cause of death",
        })[category] || "Pick a phenotype";
        modalSearch.value = "";
        renderLibrary("");
        modal.classList.remove("hidden");
        setTimeout(() => modalSearch.focus(), 50);
      };
      const closeLibrary = () => modal.classList.add("hidden");
      document.querySelectorAll("[data-open-library]").forEach((btn) => {
        btn.addEventListener("click", () => openLibrary(btn.dataset.category, { name: btn.dataset.targetName, codes: btn.dataset.targetCodes, def: btn.dataset.targetDef }));
      });
      document.querySelector("[data-library-close]")?.addEventListener("click", closeLibrary);
      modal.addEventListener("click", (e) => { if (e.target === modal) closeLibrary(); });
      document.addEventListener("keydown", (e) => { if (e.key === "Escape") closeLibrary(); });
      modalSearch.addEventListener("input", () => renderLibrary(modalSearch.value));

      setState("ready");
    })();
  </script>
</BaseLayout>
