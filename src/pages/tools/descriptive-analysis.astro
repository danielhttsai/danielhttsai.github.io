              </label>
              <label class="flex flex-col gap-1">
                <span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Outcome; name</span>
                <input type="text" name="outcomeName" placeholder="Incident dementia" class="border border-slate-300 rounded px-3 py-2 text-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500" />
              </label>
              <label class="flex flex-col gap-1">
