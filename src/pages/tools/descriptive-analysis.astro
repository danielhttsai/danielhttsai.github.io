                <label class="flex items-start gap-2 text-xs border border-slate-200 rounded px-3 py-2 hover:bg-slate-50 cursor-pointer">
                  <input type="checkbox" name="strataPick" value={s} checked={[0,3,4,5].includes(i)} class="mt-0.5 rounded border-slate-400 text-brand-700 focus:ring-brand-500" />
                  <span>{s}</span>
                </label>
