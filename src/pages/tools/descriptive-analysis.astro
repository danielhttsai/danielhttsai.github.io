                        class="mt-0.5 rounded border-slate-400 text-brand-700 focus:ring-brand-500" />
                      <span class="flex-1">
                        <span class="font-semibold text-slate-800">{m.label}</span>
                        <span class="block text-[10px] text-slate-500 mt-0.5">{m.hint}</span>
                        <span class="block text-[10px] text-slate-400 font-mono">{m.unit}</span>
                      </span>
                    </label>
                  ))}
                </div>
              </div>
            ))}
          </div>
        </details>

