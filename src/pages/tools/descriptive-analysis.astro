---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHeader from "../../components/PageHeader.astro";
import databasesRaw from "../../data/databases.json";
import { STROBE_ITEMS } from "../../data/strobe";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");

// Feature taxonomy + per-database site catalogue (mirrors ACNU / SCCS / CCO).
const FEATURES = [
  { id: "rx",        short: "Rx",   label: "Prescriptions" },
  { id: "dx",        short: "Dx",   label: "Diagnoses" },
  { id: "labs",      short: "Lab",  label: "Lab results" },
  { id: "imaging",   short: "Img",  label: "Imaging" },
  { id: "mortality", short: "Mor",  label: "Mortality linkage" },
  { id: "cancer",    short: "Can",  label: "Cancer-registry linkage" },
  { id: "pregnancy", short: "Preg", label: "Pregnancy / birth linkage" },
  { id: "genomics",  short: "Gen",  label: "Genomics / biobank linkage" },
];
const shortDbName = (full: string): string => {
  const m = full.match(/\(([^)]+)\)$/);
  return m ? m[1] : full;
};
const COUNTRY_ORDER = ["TW", "KR", "JP", "HK", "AU", "FI", "GB", "NL", "US"];
type DbRow = typeof databasesRaw[number] & { hidden?: boolean; features?: string[] };
const SITES_DB = (databasesRaw as DbRow[])
  .filter((d) => !d.hidden && COUNTRY_ORDER.includes(d.code))
  .map((d) => ({
    id:       `${d.code}-${shortDbName(d.name).replace(/[^A-Za-z0-9]/g, "")}`,
    country:  d.country,
    code:     d.code,
    short:    shortDbName(d.name),
    features: (d.features ?? []) as string[],
  }))
  .sort((a, b) => {
    const ai = COUNTRY_ORDER.indexOf(a.code);
    const bi = COUNTRY_ORDER.indexOf(b.code);
    if (ai !== bi) return ai - bi;
    return a.short.localeCompare(b.short);
  });
const SITES_DETAIL_MAP: Record<string, { country: string; code: string; short: string; features: string[] }> =
  Object.fromEntries(SITES_DB.map((d) => [d.id, d]));
const SITES_BY_COUNTRY: Record<string, typeof SITES_DB> = SITES_DB.reduce((acc, d) => {
  (acc[d.country] ??= []).push(d);
  return acc;
}, {} as Record<string, typeof SITES_DB>);

// Phenotype library; four categories for descriptive epi:
//   · populations   denominator cohorts (the people we count over)
//   · exposures     drug classes (numerator of drug-utilisation metrics)
//   · outcomes      diagnoses (numerator of incidence / prevalence)
//   · mortalityCauses cause-of-death codes for cause-specific mortality
const PHENOTYPES = {
  populations: [
    {
      name: "All adults (≥18 y) continuously enrolled",
      codes: "Define by age at observation start; continuous enrolment ≥365 d before index date.",
      definition: "Base denominator for prevalence / drug-utilisation across age-eligible enrollees.",
      validation: "Standard practice; cite the database-specific enrolment construct (e.g. Lai EC et al, Clin Epidemiol 2019 for NHIRD).",
    },
    {
      name: "Adults ≥65 y (older-adult cohort)",
      codes: "Age ≥65 at observation start; continuous enrolment ≥365 d.",
      definition: "Denominator for geriatric polypharmacy, falls, dementia-medication studies.",
      validation: "AsPEN polypharmacy work; Tan EC et al, Pharmacoepidemiol Drug Saf 2023 (PMID 36821644).",
    },
    {
      name: "Diabetes mellitus (any type)",
      codes: "ICD-10 E10.*, E11.*, E13.*, E14.* (≥1 inpatient or ≥2 outpatient claims ≥30 d apart) OR ≥1 antidiabetic dispensing (ATC A10*).",
      definition: "Adult diabetes cohort, sensitive case-finding combining diagnosis + dispensing.",
      validation: "Lin CY et al, NHIRD diabetes definition; cross-walked with the AsPEN antidiabetic-penetration work (Ooba N et al PDS 2018; PMID 30540837).",
    },
    {
      name: "Type 2 diabetes (T2DM specifically)",
      codes: "ICD-10 E11.*; require ≥1 oral antidiabetic dispensing (ATC A10B*) before insulin (A10A).",
      definition: "T2DM-only cohort excluding T1; for comparative drug-utilisation across SGLT2 / DPP-4 / GLP-1 RAs etc.",
      validation: "Standard NHIRD / NHIS-NHID T2DM definition; cite Wong MCS et al where applicable.",
    },
    {
      name: "Hypertension",
      codes: "ICD-10 I10–I15 OR ≥1 antihypertensive dispensing (ATC C02 / C03 / C07 / C08 / C09).",
      definition: "Adult hypertension cohort, combining diagnosis + drug-based identification.",
      validation: "Cheng CL et al NHIRD validation; widely used denominator.",
    },
    {
      name: "Chronic kidney disease (CKD stage ≥3)",
      codes: "eGFR <60 mL/min/1.73 m² on ≥2 measurements ≥90 d apart (where labs available) OR ICD-10 N18.3, N18.4, N18.5.",
      definition: "Reduced-kidney-function cohort; lab-based gold standard where linked, else diagnosis-based.",
      validation: "Hsu CC et al; Shao SC et al CGRD CKD work.",
    },
    {
      name: "Pregnant women (live-birth cohort)",
      codes: "Link via pregnancy / birth registry; pregnancy episodes defined by LMP estimated from delivery date − gestational age.",
      definition: "Live-birth cohort with mother-child linkage for pregnancy drug-utilisation studies.",
      validation: "AsPEN Nature Medicine 3.6M mother-child paper (PMID 38589601); Hwang HJ et al NHIS-NHID; CPRD mother-baby link.",
    },
    {
      name: "Incident cancer survivors",
      codes: "Linked cancer registry: ICD-O-3 site codes; date of first cancer diagnosis becomes index date.",
      definition: "Cancer-survivor cohort for subsequent drug-utilisation / mortality / second-primary studies.",
      validation: "Cancer-registry linkage validated per site; see /databases for which AsPEN sites carry it.",
    },
    {
      name: "Heart failure cohort",
      codes: "ICD-10 I50.* (≥1 inpatient or ≥2 outpatient) AND ≥1 HF-pathway dispensing (ATC C03DA, C07, C09, A10BK SGLT2, etc.).",
      definition: "Adult HF cohort for guideline-directed therapy uptake studies.",
      validation: "Yeh JJ et al NHIRD HF definition.",
    },
    {
      name: "All-cause mortality denominator",
      codes: "All cohort members contributing person-time until death / censoring (DB end / disenrolment).",
      definition: "Generic denominator structure for mortality-rate computation; cause-specific causes pulled from mortality library.",
      validation: "Requires mortality linkage; see /databases feature matrix for sites with `mortality` flag.",
    },
  ],
  exposures: [
    { name: "SGLT2 inhibitors",            codes: "ATC A10BK* (canagliflozin A10BK02, dapagliflozin A10BK01, empagliflozin A10BK03, ertugliflozin A10BK04)" },
    { name: "DPP-4 inhibitors",            codes: "ATC A10BH* (sitagliptin A10BH01, vildagliptin A10BH02, saxagliptin A10BH03, linagliptin A10BH05, alogliptin A10BH04)" },
    { name: "GLP-1 receptor agonists",     codes: "ATC A10BJ* (exenatide, liraglutide, dulaglutide, semaglutide, tirzepatide A10BX16)" },
    { name: "Metformin",                   codes: "ATC A10BA02" },
    { name: "Sulphonylureas",              codes: "ATC A10BB*" },
    { name: "Insulins (any)",              codes: "ATC A10A*" },
    { name: "Antipsychotics (any)",        codes: "ATC N05A*; Atypicals N05AH/N05AL/N05AX; typicals N05AA-N05AG" },
    { name: "Antidepressants (any)",       codes: "ATC N06A*" },
    { name: "Benzodiazepines / z-drugs",   codes: "ATC N05BA*, N05CD*, N05CF*" },
    { name: "ADHD stimulants",             codes: "ATC N06BA; methylphenidate N06BA04, amphetamine N06BA01, lisdexamfetamine N06BA12" },
    { name: "Opioid analgesics",           codes: "ATC N02A* (excluding diamorphine where required)" },
    { name: "NSAIDs",                      codes: "ATC M01A* (excluding M01AX)" },
    { name: "Gabapentinoids",              codes: "ATC N03AX12 (gabapentin), N03AX16 (pregabalin)" },
    { name: "Anticonvulsants (any)",       codes: "ATC N03A*" },
    { name: "Statins",                     codes: "ATC C10AA*" },
    { name: "Bisphosphonates",             codes: "ATC M05BA* / M05BB*" },
    { name: "Anticoagulants; DOACs",      codes: "ATC B01AE07 (dabigatran), B01AF01 (rivaroxaban), B01AF02 (apixaban), B01AF03 (edoxaban)" },
    { name: "Anticoagulants; warfarin",   codes: "ATC B01AA03" },
    { name: "Cholinesterase inhibitors",   codes: "ATC N06DA; donepezil N06DA02, galantamine N06DA04, rivastigmine N06DA03; plus memantine N06DX01" },
  ],
  outcomes: [
    {
      name: "Myocardial infarction (MI)",
      codes: "ICD-10 I21.*, I22.* (primary discharge diagnosis)",
      definition: "First hospitalisation with a primary discharge diagnosis of acute MI during the observation period.",
      validation: "Cheng CL et al. J Epidemiol 2014;24(6):500-7.",
    },
    {
      name: "Ischemic stroke",
      codes: "ICD-10 I63.*, I64.* (primary discharge diagnosis)",
      definition: "First hospitalisation with primary discharge diagnosis of ischemic stroke.",
      validation: "Hsieh CY et al, J Formos Med Assoc 2015;114(3):254-9.",
    },
    {
      name: "Hip fracture",
      codes: "ICD-10 S72.0, S72.1, S72.2 (primary discharge diagnosis) paired with surgical-fixation procedure code.",
      definition: "First hospitalisation with primary discharge hip-fracture diagnosis.",
      validation: "AsPEN hip-fracture multi-country work; Lai EC et al, BMJ Open 2021/2023.",
    },
    {
      name: "Acute kidney injury (AKI)",
      codes: "ICD-10 N17.* (primary discharge diagnosis); pair with creatinine criteria where lab linkage exists.",
      definition: "First hospitalisation with primary discharge AKI diagnosis.",
      validation: "Shao SC et al CGRD AKI work.",
    },
    {
      name: "Dementia (any cause)",
      codes: "ICD-10 F00.*, F01.*, F02.*, F03, G30.*, G31.0, G31.1.",
      definition: "First record of dementia diagnosis in the observation period.",
      validation: "Used in AsPEN NeuroGEN dementia infrastructure; Tsai DHT et al, Clin Epidemiol 2023 (PMID 38146486).",
    },
    {
      name: "Suicide / self-harm",
      codes: "ICD-10 X60-X84, Y87.0; T-codes for intentional poisoning; mortality cause-of-death codes.",
      definition: "First ED / hospital / mortality record with suicide / intentional self-harm code.",
      validation: "Man KKC et al Lancet Psychiatry 2024 (PMID 39241791).",
    },
    {
      name: "COVID-19 infection (confirmed)",
      codes: "ICD-10 U07.1; lab-confirmed SARS-CoV-2 where linkage available.",
      definition: "First record of confirmed COVID-19 in observation period.",
      validation: "AsPEN COVID multi-organ work (PMID 40626567); psychiatric sequelae paper (PMID 40055683).",
    },
  ],
  mortalityCauses: [
    {
      name: "Cardiovascular death",
      codes: "ICD-10 I00–I99 as underlying cause of death.",
      definition: "Death attributable to circulatory-system diseases (CV death broadly).",
      validation: "WHO standard cause-of-death grouping.",
    },
    {
      name: "Cancer death (all sites)",
      codes: "ICD-10 C00–C97 as underlying cause.",
      definition: "Death from any malignant neoplasm.",
      validation: "WHO standard; pair with cancer-registry linkage where available.",
    },
    {
      name: "External causes (injury / suicide / accident)",
      codes: "ICD-10 V01–Y89 as underlying cause.",
      definition: "Death from external causes; important denominator for excess-mortality calculations.",
      validation: "WHO standard.",
    },
    {
      name: "Respiratory disease death",
      codes: "ICD-10 J00–J99 as underlying cause.",
      definition: "Death from respiratory diseases including pneumonia, COPD, asthma.",
      validation: "WHO standard.",
    },
    {
      name: "Infection death",
      codes: "ICD-10 A00–B99 + select J / N codes for sepsis-related deaths.",
      definition: "Death attributable to infectious / parasitic diseases.",
      validation: "WHO standard; varies by site coding granularity.",
    },
    {
      name: "Cerebrovascular death (stroke)",
      codes: "ICD-10 I60–I69 as underlying cause.",
      definition: "Death from cerebrovascular disease; narrower than 'CV death'.",
      validation: "WHO standard.",
    },
  ],
};

// 13 output metrics. `id` is the stable key used in form state.
const OUTPUT_METRICS = [
  { id: "incidence",       group: "Occurrence",   label: "Incidence rate",                 unit: "cases / 1000 person-years",      hint: "New cases over person-time at risk." },
  { id: "periodPrev",      group: "Occurrence",   label: "Period prevalence",              unit: "% of cohort in window",          hint: "Cases ÷ cohort, over a calendar window." },
  { id: "pointPrev",       group: "Occurrence",   label: "Point prevalence",               unit: "% at index date",                hint: "Cases ÷ cohort on a single calendar date (annual / mid-year typical)." },
  { id: "mortAll",         group: "Mortality",    label: "All-cause mortality rate",       unit: "deaths / 1000 person-years",     hint: "Requires mortality linkage at the site." },
  { id: "mortCause",       group: "Mortality",    label: "Cause-specific mortality",       unit: "deaths / 1000 person-years",     hint: "Uses cause-of-death codes; see library." },
  { id: "ddd",             group: "Utilisation",  label: "DDD / 1000 inhabitants / day",   unit: "DDD/1000/d",                     hint: "WHO ATC/DDD index dose; classic drug-utilisation metric." },
  { id: "initiation",      group: "Utilisation",  label: "Initiation rate",                unit: "new users / 1000 person-years",  hint: "Incident drug exposure rate." },
  { id: "persistence",     group: "Utilisation",  label: "Persistence / discontinuation",  unit: "median days; % at 1 y",          hint: "Time-to-discontinuation (Kaplan-Meier description)." },
  { id: "switching",       group: "Utilisation",  label: "Switching pattern (Sankey)",     unit: "flows between drug classes",     hint: "First-line → second-line → … transitions." },
  { id: "concomitant",     group: "Utilisation",  label: "Concomitant use",                unit: "% on ≥2 classes",                hint: "Proportion using multiple drug classes within a window." },
  { id: "ageStandardised", group: "Adjustment",   label: "Age-standardised rates",         unit: "per 1000 (standardised)",        hint: "Direct or indirect standardisation to a reference population." },
  { id: "joinpoint",       group: "Trends",       label: "Joinpoint / segmented trend",    unit: "APC / AAPC",                     hint: "Annual percent change with break-point detection (Kim 2000)." },
  { id: "trendInTrend",    group: "Trends",       label: "Trend-in-trend (Ji 2017)",       unit: "RR via trend correlation",       hint: "Advanced variant; exploits cross-region trend covariance. May spin off into its own template." },
];

const STRATIFICATION = [
  "Age (5-year bands)",
  "Age (10-year bands)",
  "Age (≥65 vs <65)",
  "Sex (male vs female)",
  "Calendar year",
  "Country / site",
  "Index year stratum (5-year blocks)",
  "Urbanicity (urban / rural)",
  "Socioeconomic status / education",
  "Insurance plan / payer",
];

const SENSITIVITY = [
  "Alternative denominator definition (mid-year vs annual average vs Lexis triangle)",
  "Alternative time-window length (calendar-year vs fiscal-year vs rolling 12-month)",
  "Restrict to incident users only (vs all users)",
  "Restrict to ≥1 year of baseline observation",
  "Negative-control outcome; should show null / flat trend",
  "Exclude index-year transition (washout 30 / 60 / 90 d)",
  "Alternative case-finding rule (≥1 inpatient vs ≥2 outpatient vs algorithm)",
  "Sub-divide by data-source quality (full vs partial linkage)",
  "Limit to sites with ≥X years of follow-up to reduce small-sample noise",
];

const TIMELINE_PRESETS: Record<string, string> = {
  "12-month": [
    "Month 0: Protocol finalised, site IRB submissions begin",
    "Month 3: All site IRB approvals received",
    "Month 4-6: Local cohort assembly and code-set harmonisation",
    "Month 7-9: Local computation of rates / DDD / standardisation",
    "Month 10-11: Site-level estimates returned to coordinating centre; pooled tables and figures",
    "Month 12: First manuscript draft circulated",
  ].join("\n"),
  "18-month": [
    "Month 0-3: Protocol finalisation, code-set harmonisation, IRB submissions",
    "Month 4-7: Local cohort assembly and validation",
    "Month 8-12: Primary metric computation + age-standardisation + joinpoint",
    "Month 13-15: Sensitivity analyses, pooled meta-tabulation, forest / trend plots",
    "Month 16-18: Manuscript drafting and submission",
  ].join("\n"),
};
---

<BaseLayout
  title="Protocol template · Descriptive analysis · AsPEN members"
  description="Guided form for drafting a multi-country descriptive epidemiology protocol (incidence, prevalence, mortality, drug utilisation, switching, age-standardisation, joinpoint trends)."
>
  <PageHeader
    eyebrow="Members → Templates → DA"
    title="Multi-national descriptive analysis builder"
    description="Characterise a population; how common a disease is, how a drug is used, who dies; across AsPEN sites. Standard output for Policy & Utilisation theme work and the denominator on which causal studies depend."
  />

  <section class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-8 space-y-6">
    <div class="flex items-center justify-between gap-3 flex-wrap">
      <a class="text-sm text-brand-700 hover:underline font-semibold" href={`${base}/tools/`}>← All templates</a>
      <button type="button" data-action="reset-top" class="text-xs font-semibold text-rose-700 border border-rose-300 hover:bg-rose-50 px-3 py-1.5 rounded transition">
        ⟲ Clear &amp; start over
      </button>
    </div>

    <div data-state="ready" class="grid gap-8 lg:grid-cols-[1fr,1fr] items-start">

      <form data-builder class="space-y-6">

        <details open class="border border-slate-200 rounded-2xl bg-white shadow-sm">
          <summary class="cursor-pointer select-none px-5 py-4 font-semibold text-slate-900 hover:bg-slate-50 rounded-2xl">1 · Study identification</summary>
          <div class="px-5 pb-5 grid sm:grid-cols-2 gap-3">
            <label class="flex flex-col gap-1 sm:col-span-2">
              <span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Study title</span>
              <input type="text" name="title" placeholder="e.g. DDD/1000/day for anticonvulsants across 14 AsPEN sites, 2010-2023" class="border border-slate-300 rounded px-3 py-2 text-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500" />
            </label>
            <label class="flex flex-col gap-1">
              <span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Short ID</span>
              <input type="text" name="shortId" placeholder="AsPEN-ANTISEIZ-DA-2026" class="border border-slate-300 rounded px-3 py-2 text-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500" />
            </label>
            <label class="flex flex-col gap-1">
              <span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Version · Date</span>
              <input type="text" name="version" placeholder="v0.1 draft · 2026-05-30" class="border border-slate-300 rounded px-3 py-2 text-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500" />
            </label>
            <label class="flex flex-col gap-1 sm:col-span-2">
              <span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Lead investigator(s)</span>
              <input type="text" name="leadInvestigator" placeholder="Name, affiliation; co-leads if any" class="border border-slate-300 rounded px-3 py-2 text-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500" />
            </label>
          </div>
        </details>

        <details open class="border border-slate-200 rounded-2xl bg-white shadow-sm">
          <summary class="cursor-pointer select-none px-5 py-4 font-semibold text-slate-900 hover:bg-slate-50 rounded-2xl">2 · Research question</summary>
          <div class="px-5 pb-5 grid sm:grid-cols-2 gap-3">
            <label class="flex flex-col gap-1 sm:col-span-2">
              <span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Population</span>
              <input type="text" name="picoP" placeholder="Adults ≥18 y with continuous enrolment in each AsPEN site, 2010-2023" class="border border-slate-300 rounded px-3 py-2 text-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500" />
            </label>
            <label class="flex flex-col gap-1">
              <span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">What we measure</span>
              <input type="text" name="picoMeasure" placeholder="DDD/1000/day of anticonvulsants; incidence of dementia" class="border border-slate-300 rounded px-3 py-2 text-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500" />
            </label>
            <label class="flex flex-col gap-1">
              <span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Time window</span>
              <input type="text" name="picoWindow" placeholder="Calendar years 2010–2023 (annual)" class="border border-slate-300 rounded px-3 py-2 text-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500" />
            </label>
          </div>
        </details>

        <details open class="border border-slate-200 rounded-2xl bg-white shadow-sm">
          <summary class="cursor-pointer select-none px-5 py-4 font-semibold text-slate-900 hover:bg-slate-50 rounded-2xl">3 · Sites</summary>
          <div class="px-5 pb-5 space-y-4">
            <p class="text-xs text-slate-500">
              Tick every <strong>database</strong> (not just country). Feature chips show what each carries; for a descriptive protocol the denominator + the metric features need to match (e.g. cause-specific mortality needs <strong>Mortality</strong> linkage; DDD needs <strong>Rx</strong>; cancer-survivor cohorts need <strong>Cancer</strong>).
            </p>
            <div class="flex flex-wrap items-center gap-2 text-[10px] text-slate-500 border-y border-slate-100 py-2">
              <span class="uppercase tracking-widest font-bold text-slate-600">Legend</span>
              {FEATURES.map((f) => (
                <span class="inline-flex items-center gap-1">
                  <span class="text-[10px] bg-brand-50 text-brand-700 border border-brand-100 px-1.5 py-0.5 rounded font-mono font-semibold">{f.short}</span>
                  <span>{f.label}</span>
                </span>
              ))}
            </div>
            <div class="space-y-3">
              {Object.entries(SITES_BY_COUNTRY).map(([country, dbs]) => (
                <div>
                  <p class="text-[11px] font-semibold text-slate-700">{country}</p>
                  <div class="mt-1 grid grid-cols-1 sm:grid-cols-2 gap-1.5">
                    {dbs.map((d) => (
                      <label class="flex items-center gap-2 text-xs border border-slate-200 rounded px-3 py-2 hover:bg-slate-50 cursor-pointer">
                        <input type="checkbox" name="sites" value={d.id} class="rounded border-slate-400 text-brand-700 focus:ring-brand-500" />
                        <span class="font-semibold text-slate-800 shrink-0">{d.short}</span>
                        <span class="flex flex-wrap gap-1 ml-auto">
                          {FEATURES.filter((f) => d.features.includes(f.id)).map((f) => (
                            <span class="text-[10px] bg-brand-50 text-brand-700 border border-brand-100 px-1.5 py-0.5 rounded font-mono font-semibold" title={f.label}>{f.short}</span>
                          ))}
                        </span>
                      </label>
                    ))}
                  </div>
                </div>
              ))}
            </div>
            <label class="flex flex-col gap-1">
              <span class="text-[11px] uppercase tracking-widest text-slate-500 font-semibold">Others (one per line)</span>
              <textarea name="sitesOther" rows="2" placeholder="Sites beyond the active databases list" class="w-full border border-slate-300 rounded px-3 py-2 text-xs focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500"></textarea>
            </label>
            <div data-feasibility class="hidden bg-amber-50 border border-amber-200 rounded-lg p-3 text-xs leading-relaxed">
              <p class="font-bold text-amber-800 uppercase tracking-[0.2em] text-[10px]">⚠ Feasibility heads-up; not a blocker</p>
              <p class="mt-1 text-amber-900">Your chosen metrics or text imply data features that some selected sites don't carry. Cross-country descriptive studies often accommodate this by reporting which sites contribute to which metric; make that explicit in the per-site analytic plan.</p>
              <ul data-feasibility-list class="mt-2 space-y-1 text-amber-900 list-disc list-inside"></ul>
            </div>
          </div>
        </details>

        <details open class="border border-slate-200 rounded-2xl bg-white shadow-sm">
          <summary class="cursor-pointer select-none px-5 py-4 font-semibold text-slate-900 hover:bg-slate-50 rounded-2xl">4 · Population (denominator)</summary>
          <div class="px-5 pb-5 space-y-3">
            <div>
              <button type="button" data-open-library data-category="populations" data-target-def="populationDef" data-target-codes="populationCodes" data-target-name="populationName" class="text-[10px] uppercase tracking-widest font-bold text-brand-700 bg-brand-50 hover:bg-brand-100 border border-brand-200 px-2 py-1 rounded transition">📚 Pick population from library</button>
              <span class="ml-2 text-[11px] text-slate-500">Validation citation auto-appends to References on export.</span>
            </div>
            <label class="flex flex-col gap-1">
