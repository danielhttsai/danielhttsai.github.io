- Maringe C, Benitez Majano S, Exarchakou A, et al. Reflections on modern methods: trial emulation in the presence of immortal-time bias. Int J Epidemiol 2020;49:1719-29.
- Gran JM, Røysland K, Wolbers M, et al. A sequential Cox approach for estimating the causal effect of treatment. Stat Med 2010;29:2757-70.
`;
    };

    const computeChecks = (s) => {
      const checks = [];
      const grace = parseInt(s.grace) || 0, fu = parseInt(s.fudays) || 0, lb = parseRows(s.covlist).length;
      if (grace <= 0) checks.push({ level: "error", msg: "Grace period is 0 — with no grace window the two strategies cannot be distinguished by cloning. Set a grace period > 0." });
      if (fu > 0 && grace >= fu) checks.push({ level: "warn", msg: "Grace period (" + grace + "d) is ≥ the follow-up (" + fu + "d) — almost all follow-up falls inside the grace window. Shorten the grace or lengthen follow-up." });
      if (lb <= 0) checks.push({ level: "warn", msg: "No covariate look-back — baseline confounders and eligibility are assessed only at time zero. Set a look-back window before index." });
      if (!s.timezero || !s.timezero.trim()) checks.push({ level: "warn", msg: "Define time zero — eligibility, cloning, and follow-up must all start there, aligned to avoid immortal-time bias." });
      if (!s.censor || !s.censor.trim()) checks.push({ level: "warn", msg: "No deviation / censoring rule — clones must be censored when their data stop matching the assigned strategy." });
      if (!s.ipcw || !s.ipcw.trim()) checks.push({ level: "warn", msg: "No IPCW covariates listed — the informative censoring created by cloning must be adjusted with inverse-probability-of-censoring weights." });
      if (!mergeList(s.ipcwReasonsPick, s.ipcwReasonsCustom).length) checks.push({ level: "warn", msg: "No censoring events selected for IPCW — pick the events (death, discontinuation, switch, add-on…) that create informative censoring under each strategy." });
      checks.push({ level: "info", msg: "CCW targets the per-protocol effect (adherence to the assigned strategy); the weight models are fitted separately for the treatment and control arms." });
      if (!s.population || !s.population.trim()) checks.push({ level: "info", msg: "Specify the population." });
      if (!s.outcome || !s.outcome.trim()) checks.push({ level: "info", msg: "Specify the outcome." });
      if (!s.stratA || !s.stratB) checks.push({ level: "info", msg: "Specify both treatment strategies (A and B)." });
      return checks;
    };

    const render = () => {
