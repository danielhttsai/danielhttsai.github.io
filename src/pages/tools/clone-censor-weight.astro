      const numItem = (str) => new D.Paragraph({ children: [text(str)], numbering: { reference: "ordered", level: 0 }, spacing: { before: 0, after: 0 } });
      const border = { style: D.BorderStyle.SINGLE, size: 4, color: "BBBBBB" };
      const cb = { top: border, bottom: border, left: border, right: border };
      const labelTable = (rows) => new D.Table({
        width: { size: 9026, type: D.WidthType.DXA }, columnWidths: [3000, 6026],
        rows: rows.map(([label, value]) => new D.TableRow({ children: [
          new D.TableCell({ borders: cb, width: { size: 3000, type: D.WidthType.DXA }, margins: { top: 60, bottom: 60, left: 100, right: 100 }, shading: { fill: "F5F5F5", type: D.ShadingType.CLEAR }, children: [p([text(label, { bold: true })])] }),
          new D.TableCell({ borders: cb, width: { size: 6026, type: D.WidthType.DXA }, margins: { top: 60, bottom: 60, left: 100, right: 100 }, children: [p([text(value || "-")])] }),
        ] })),
      });

      const A = or(s.stratA, "(strategy A)"), B = or(s.stratB, "(strategy B)");
      const subg = mergeList(s.subgroupsPick, s.subgroupsCustom);
      const sens = mergeList(s.sensitivityPick, s.sensitivityCustom);
      const ipcwLines = String(s.ipcw || "").split(/\r?\n/).map((x) => x.trim()).filter(Boolean);

      const children = [];
      children.push(p([text(or(s.title, "(Untitled clone-censor-weight study)"), { bold: true, size: 32 })], { spacing: { after: 40 } }));
      children.push(p([text("Study protocol · clone-censor-weight target-trial emulation · drafted " + today, { italics: true, color: "777777", size: 18 })], { spacing: { after: 160 } }));

      children.push(h1("1. Background and rationale"));
      children.push(para("This study emulates a target trial to estimate the per-protocol effect of two treatment strategies distinguished only by what happens over a grace period of " + s.grace + " days. A conventional as-treated analysis would misclassify person-time and introduce immortal-time bias; the clone-censor-weight (CCW) approach removes these biases (Hernán 2016; Maringe 2020)."));

      children.push(h1("2. Causal question (target trial)"));
      children.push(para("Among " + or(s.population, "(population)") + ", what is the effect of " + A + " versus " + B + " on " + or(s.outcome, "(outcome)") + "?"));

      children.push(h1("3. Design summary"));
      children.push(labelTable([
        ["Design", "Clone-censor-weight target-trial emulation"],
