      children.push(para(or(s.censor, "A clone is censored when its observed data first become incompatible with its assigned strategy. Administrative censoring applies at death, disenrolment, or end of study.")));

      children.push(h1("6. Inverse-probability-of-censoring weights (IPCW)"));
      children.push(para("Each clone receives a time-varying, stabilised inverse-probability-of-censoring weight, modelled by pooled logistic regression using baseline covariates over their look-back windows (" + rowsText(s.covlist) + "); inclusion assessed over " + s.incllookback + " d; exclusions: " + rowsText(s.excllist) + "; plus time-varying predictors:"));
      (ipcwLines.length ? ipcwLines : ["(list the predictors of deviation)"]).forEach((l) => children.push(bullet(l)));
      children.push(para("Separate weight models are fitted for the treatment and control arms. Events weighted by IPCW (each mapping to the assigned strategy): " + (mergeList(s.ipcwReasonsPick, s.ipcwReasonsCustom).join("; ") || "(none selected)") + "."));

      children.push(h1("7. Follow-up and outcome"));
