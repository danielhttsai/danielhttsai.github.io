    }));

    const slugify = () => (readForm().title || "ccw-protocol").toLowerCase().replace(/[^a-z0-9]+/g, "-").replace(/^-|-$/g, "").slice(0, 60) || "ccw-protocol";
    const fname = (ext) => slugify() + "-" + new Date().toISOString().slice(0, 10) + "." + ext;
    const dl = (blob, name) => { const u = URL.createObjectURL(blob); const a = document.createElement("a"); a.href = u; a.download = name; document.body.appendChild(a); a.click(); a.remove(); setTimeout(() => URL.revokeObjectURL(u), 1000); };

    document.querySelector("[data-action='download-md']").addEventListener("click", () =>
      dl(new Blob([preview.textContent || ""], { type: "text/markdown;charset=utf-8" }), fname("md")));

    document.querySelector("[data-action='download-target']").addEventListener("click", async () => {
      const D = window.docx; if (!D || !window.buildTargetChecklistDocx) return;
      const s = readForm();
      const A = or(s.stratA, "(strategy A)"), B = or(s.stratB, "(strategy B)");
      const map = {
        "1a": "This study emulates a target trial of " + A + " vs " + B + " among " + or(s.population, "(population)") + ", using a clone-censor-weight analysis.",
        "1b": or(s.data, ""),
        "3": "Among " + or(s.population, "(population)") + ", what is the effect of " + A + " vs " + B + " on " + or(s.outcome, "(outcome)") + "?",
        "5": or(s.data, ""),
        "6": "Strategies: " + A + " vs " + B + "; time zero: " + or(s.timezero, "(define)") + "; grace period " + s.grace + " days.",
        "7a": or(s.population, "(population)") + " — eligibility (inclusion/exclusion) assessed at time zero.",
        "7b": A + " vs " + B + "; grace period " + s.grace + " days.",
