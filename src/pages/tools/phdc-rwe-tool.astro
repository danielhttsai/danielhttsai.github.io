---
import BaseLayout from "../../layouts/BaseLayout.astro";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const SRC = "https://danielhttsai.github.io/phdc-rwe-tool/";
---

<BaseLayout
  title="PHDc RWE Toolbox — Daniel Tsai"
  description="The Population Health Data Center real-world-evidence tool, embedded on Daniel Tsai's site."
>
  <div class="border-b border-slate-200 bg-slate-50">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 h-12 flex items-center justify-between gap-3">
      <a href={`${base}/tools`} class="text-sm font-semibold text-brand-700 hover:underline">← RWE Tools</a>
      <div class="flex items-center gap-4">
        <span class="text-sm font-semibold text-slate-700 hidden sm:inline">PHDc RWE Toolbox</span>
        <a href={SRC} target="_blank" rel="noopener" class="text-xs text-slate-500 hover:text-brand-700">Open full screen ↗</a>
      </div>
    </div>
  </div>

  <iframe
    src={SRC}
    title="PHDc RWE Toolbox"
    class="w-full border-0 block"
    style="height: calc(100dvh - 7rem);"
    loading="lazy"
    allow="clipboard-write; clipboard-read"
    referrerpolicy="no-referrer-when-downgrade"
  ></iframe>
</BaseLayout>
