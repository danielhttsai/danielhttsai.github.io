---
// The TARGET Checker grew into a multi-framework Protocol Checker (HARPER +
// TARGET). This stub keeps the old /tools/target-checker URL working by
// redirecting to the new page (with ?framework=target intent noted in copy).
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const target = `${base}/tools/protocol-checker`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta http-equiv="refresh" content={`0; url=${target}`} />
    <link rel="canonical" href={target} />
    <meta name="robots" content="noindex" />
    <title>Moved → Protocol Checker</title>
    <script is:inline define:vars={{ target }}>window.location.replace(target);</script>
  </head>
  <body style="font-family: system-ui, sans-serif; padding: 2rem; color: #334155;">
    <p>The TARGET Checker is now the <a href={target}>Protocol Checker</a> (HARPER &amp; TARGET). Redirecting…</p>
  </body>
</html>
