---
import BaseLayout from "../../layouts/BaseLayout.astro";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const SRC = "https://phd-center.github.io/acb-calculator/";
---

<BaseLayout
  title="ACB Calculator — Daniel Hsiang-Te Tsai"
  description="Anticholinergic burden calculator embedded on Daniel Tsai's site: scores total anticholinergic load across 6 scales and quantifies 30-day cardiovascular, pneumonia, and OHCA risk."
>
  <div class="border-b border-slate-200 bg-slate-50">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 h-12 flex items-center justify-between gap-3">
      <a href={`${base}/tools`} class="text-sm font-semibold text-brand-700 hover:underline">← RWE Tools</a>
      <div class="flex items-center gap-4">
        <span class="text-sm font-semibold text-slate-700 hidden sm:inline">ACB Calculator</span>
        <a href={SRC} target="_blank" rel="noopener" class="text-xs text-slate-500 hover:text-brand-700">Open full screen ↗</a>
      </div>
    </div>
  </div>

  <iframe
    src={SRC}
    title="Anticholinergic Burden (ACB) Calculator"
    class="w-full border-0 block"
    style="height: calc(100dvh - 7rem);"
    loading="lazy"
    allow="camera; microphone; clipboard-write; clipboard-read"
    referrerpolicy="no-referrer-when-downgrade"
  ></iframe>
</BaseLayout>
