---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHeader from "../../components/PageHeader.astro";
import DesignDiagram from "../../components/DesignDiagram.astro";
import ProtocolCommon from "../../components/ProtocolCommon.astro";
import databasesRaw from "../../data/databases.json";
import { STROBE_ITEMS } from "../../data/strobe";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");

// Feature taxonomy + per-database site catalogue (mirrors ACNU template).
const FEATURES = [
  { id: "rx",        short: "Rx",   label: "Prescriptions" },
  { id: "dx",        short: "Dx",   label: "Diagnoses" },
  { id: "labs",      short: "Lab",  label: "Lab results" },
  { id: "imaging",   short: "Img",  label: "Imaging" },
  { id: "mortality", short: "Mor",  label: "Mortality linkage" },
  { id: "cancer",    short: "Can",  label: "Cancer-registry linkage" },
  { id: "pregnancy", short: "Preg", label: "Pregnancy / birth linkage" },
  { id: "genomics",  short: "Gen",  label: "Genomics / biobank linkage" },
];
const shortDbName = (full: string): string => {
  const m = full.match(/\(([^)]+)\)$/);
  return m ? m[1] : full;
};
const COUNTRY_ORDER = ["TW", "KR", "JP", "HK", "AU", "FI", "GB", "NL", "US"];
type DbRow = typeof databasesRaw[number] & { hidden?: boolean; features?: string[] };
const SITES_DB = (databasesRaw as DbRow[])
  .filter((d) => !d.hidden && COUNTRY_ORDER.includes(d.code))
  .map((d) => ({
    id:       `${d.code}-${shortDbName(d.name).replace(/[^A-Za-z0-9]/g, "")}`,
    country:  d.country,
    code:     d.code,
    short:    shortDbName(d.name),
    features: (d.features ?? []) as string[],
  }))
  .sort((a, b) => {
    const ai = COUNTRY_ORDER.indexOf(a.code);
    const bi = COUNTRY_ORDER.indexOf(b.code);
    if (ai !== bi) return ai - bi;
    return a.short.localeCompare(b.short);
  });
const SITES_DETAIL_MAP: Record<string, { country: string; code: string; short: string; features: string[] }> =
  Object.fromEntries(SITES_DB.map((d) => [d.id, d]));
const SITES_BY_COUNTRY: Record<string, typeof SITES_DB> = SITES_DB.reduce((acc, d) => {
  (acc[d.country] ??= []).push(d);
  return acc;
}, {} as Record<string, typeof SITES_DB>);

// Shared phenotype library (subset; same shape as ACNU page).
const PHENOTYPES = {
  exposures: [
    { name: "SGLT2 inhibitors",            codes: "ATC A10BK* (canagliflozin A10BK02, dapagliflozin A10BK01, empagliflozin A10BK03, ertugliflozin A10BK04)" },
    { name: "DPP-4 inhibitors",            codes: "ATC A10BH* (sitagliptin A10BH01, vildagliptin A10BH02, saxagliptin A10BH03, linagliptin A10BH05, alogliptin A10BH04)" },
    { name: "GLP-1 receptor agonists",     codes: "ATC A10BJ* (exenatide A10BJ01, liraglutide A10BJ02, dulaglutide A10BJ05, semaglutide A10BJ06, tirzepatide A10BX16)" },
    { name: "Antipsychotics (any)",        codes: "ATC N05A*; Atypicals N05AH/N05AL/N05AX; typicals N05AA-N05AG" },
    { name: "ADHD stimulants",             codes: "ATC N06BA; methylphenidate N06BA04, amphetamine N06BA01, lisdexamfetamine N06BA12" },
    { name: "Opioid analgesics",           codes: "ATC N02A* (excluding diamorphine where required)" },
    { name: "NSAIDs",                      codes: "ATC M01A* (excluding M01AX)" },
    { name: "Bisphosphonates",             codes: "ATC M05BA* / M05BB*" },
    { name: "Anticoagulants; DOACs",      codes: "ATC B01AE07 (dabigatran), B01AF01 (rivaroxaban), B01AF02 (apixaban), B01AF03 (edoxaban)" },
    { name: "Anticoagulants; warfarin",   codes: "ATC B01AA03" },
    { name: "Statins",                     codes: "ATC C10AA*" },
    { name: "Cholinesterase inhibitors",   codes: "ATC N06DA; donepezil N06DA02, galantamine N06DA04, rivastigmine N06DA03; plus memantine N06DX01" },
  ],
  outcomes: [
    {
      name: "Myocardial infarction (MI)",
      codes: "ICD-10 I21.*, I22.* (primary discharge diagnosis)",
      definition: "First hospitalisation with a primary discharge diagnosis of acute MI within the observation period.",
      validation: "Cheng CL et al. Validation of acute MI cases in the NHIRD. J Epidemiol 2014;24(6):500-7.",
    },
    {
      name: "Ischemic stroke",
      codes: "ICD-10 I63.*, I64.* (primary discharge diagnosis)",
      definition: "First hospitalisation with primary discharge diagnosis of ischemic stroke.",
      validation: "Cheng CL et al. Pharmacoepidemiol Drug Saf 2011;20(3):236-42. Hsieh CY et al. J Formos Med Assoc 2015;114(3):254-9.",
    },
    {
      name: "Falls and/or fractures",
      codes: "Falls ICD-10 W00-W19; fracture ICD-10 S02/S12/S22/S32/S42/S52/S62/S72/S82/S92; combined for higher specificity.",
      definition: "First ED / hospital encounter with fall-injury or fracture code during the observation period.",
      validation: "Used as primary outcome in the AsPEN antipsychotic-falls SCCS; Wang GH, Man KKC, Chang WH, Liao TC, Lai ECC. BMJ 2021;PMID 34503972.",
    },
    {
      name: "Hip fracture",
      codes: "ICD-10 S72.0, S72.1, S72.2 (primary discharge diagnosis), ideally paired with surgical-fixation procedure code.",
      definition: "First hospitalisation with primary discharge hip-fracture diagnosis.",
      validation: "AsPEN hip-fracture multi-country work; Lai EC et al, BMJ Open 2021/2023 (protocol & epidemiology).",
    },
    {
      name: "Acute kidney injury (AKI)",
      codes: "ICD-10 N17.* (primary discharge diagnosis)",
      definition: "First hospitalisation with primary discharge AKI diagnosis in the observation period.",
      validation: "Shao SC et al CGRD AKI work; pair with eGFR / serum-creatinine where lab linkage exists.",
    },
    {
      name: "Suicide / self-harm",
      codes: "ICD-10 X60-X84, Y87.0; T-codes for intentional poisoning; combined with mortality-record cause of death.",
      definition: "First ED / hospital / mortality record with suicide / intentional self-harm code.",
      validation: "Man KKC et al Lancet Psychiatry 2024 (PMID 39241791) used a comparable composite definition.",
    },
    {
      name: "Intracranial haemorrhage",
      codes: "ICD-10 I60.*, I61.*, I62.* (primary discharge diagnosis)",
      definition: "First hospitalisation with primary discharge ICH diagnosis.",
      validation: "NHIRD-validated; CGRD-confirmed in Shao SC et al DOAC studies.",
    },
    {
      name: "GI bleeding",
      codes: "ICD-10 K25.0/.2/.4/.6, K26.0/.2/.4/.6, K27.*, K28.*, K29.0, K92.0/.1/.2 (primary discharge diagnosis)",
      definition: "First hospitalisation with primary discharge GI bleeding diagnosis.",
      validation: "Used in AsPEN PSSA NSAID/PPI safety work (Andersen M, Pratt N et al. PDS 2013, founding methods).",
    },
  ],
};

const SUBGROUPS = [
  "Age (≥65 vs <65 years)",
  "Age (≥75 vs <75 years)",
  "Sex (male vs female)",
  "Country / site",
  "First-ever vs repeated exposure",
  "Index calendar year stratum",
  "Baseline CV disease (yes vs no)",
  "Baseline CKD (eGFR <60 vs ≥60)",
  "Frailty / Charlson Comorbidity Index (high vs low)",
  "Concomitant exposure (yes vs no)",
];

const SENSITIVITY = [
  "Alternative risk window length (e.g., 7-30, 0-90, 0-180 d)",
  "Alternative pre-risk window (0, 30, 60 d); checks for event-dependent exposure",
  "Alternative post-risk window (washout) (0, 30, 90 d)",
  "Restrict to first event only (vs all events)",
  "Method of Farrington for event-dependent exposure (SCCS-EDE)",
  "Negative-control outcome; should show null",
  "Exclude seasonal months (if outcome is seasonal)",
  "Restrict to patients with ≥1 year of observation before first exposure",
  "Sub-divide risk window into early (0-14 d) vs late (15+ d) to look at risk attenuation",
];

const TIMELINE_PRESETS: Record<string, string> = {
  "12-month": [
    "Month 0: Protocol finalised, site IRB submissions begin",
    "Month 3: All site IRB approvals received",
    "Month 4-6: Local case identification and exposure window construction",
    "Month 7-9: Conditional Poisson regression at each site",
    "Month 10-11: Site IRRs returned to coordinating centre; meta-analysis",
    "Month 12: First manuscript draft circulated",
  ].join("\n"),
  "18-month": [
    "Month 0-3: Protocol finalisation, code-set harmonisation, IRB submissions",
    "Month 4-7: Local case identification and exposure construction",
    "Month 8-12: Primary SCCS analysis, sensitivity analyses (alt risk windows, SCCS-EDE)",
    "Month 13-15: Meta-analysis and forest plots",
    "Month 16-18: Manuscript drafting and submission",
  ].join("\n"),
};
---

<BaseLayout
  title="Protocol template · SCCS · AsPEN members"
  description="Guided form for drafting a multi-national self-controlled case series (SCCS) protocol."
>
  <PageHeader
    eyebrow="Members → Templates → SCCS"
    title="Multi-national SCCS protocol builder"
    description="Self-controlled case series. Each case acts as their own control; all time-invariant between-person confounding (genetics, lifelong habits) is automatically removed. AsPEN convention: separate a short pretreatment window (e.g., 14 days) before the first dispensing to absorb confounding by indication and benchmark the underlying-disease risk before therapy (see Wang GH et al BMJ 2021; PMID 34503972)."
  />

  <section class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-8 space-y-6">
    <div class="flex items-center justify-between gap-3 flex-wrap">
      <a class="text-sm text-brand-700 hover:underline font-semibold" href={`${base}/tools/protocol-generator/`}>← All templates</a>
      <button type="button" data-action="reset-top" class="text-xs font-semibold text-rose-700 border border-rose-300 hover:bg-rose-50 px-3 py-1.5 rounded transition">
        ⟲ Clear &amp; start over
      </button>
    </div>

    <div data-state="ready" class="grid gap-8 lg:grid-cols-[1fr,1fr] items-start">

      <form data-builder class="space-y-6">

        <details open class="border border-slate-200 rounded-2xl bg-white shadow-sm">
          <summary class="cursor-pointer select-none px-5 py-4 font-semibold text-slate-900 hover:bg-slate-50 rounded-2xl">1 · Study identification</summary>
          <div class="px-5 pb-5 grid sm:grid-cols-2 gap-3">
            <label class="flex flex-col gap-1 sm:col-span-2">
              <span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Study title</span>
              <input type="text" name="title" placeholder="e.g. Antipsychotic dispensing and risk of falls in older adults: an AsPEN multi-country self-controlled case series" class="border border-slate-300 rounded px-3 py-2 text-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500" />
            </label>
            <label class="flex flex-col gap-1">
              <span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Short ID</span>
              <input type="text" name="shortId" placeholder="AsPEN-AP-FALLS-SCCS-2026" class="border border-slate-300 rounded px-3 py-2 text-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500" />
            </label>
            <label class="flex flex-col gap-1">
              <span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Version · Date</span>
              <input type="text" name="version" placeholder="v0.1 draft · 2026-05-29" class="border border-slate-300 rounded px-3 py-2 text-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500" />
            </label>
            <label class="flex flex-col gap-1 sm:col-span-2">
              <span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Lead investigator(s)</span>
              <input type="text" name="leadInvestigator" placeholder="Name, affiliation; co-leads if any" class="border border-slate-300 rounded px-3 py-2 text-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500" />
            </label>
          </div>
        </details>

        <details open class="border border-slate-200 rounded-2xl bg-white shadow-sm">
          <summary class="cursor-pointer select-none px-5 py-4 font-semibold text-slate-900 hover:bg-slate-50 rounded-2xl">2 · Research question</summary>
          <div class="px-5 pb-5 grid sm:grid-cols-2 gap-3">
            <label class="flex flex-col gap-1 sm:col-span-2">
              <span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Population</span>
              <input type="text" name="picoP" placeholder="Adults ≥65y with ≥1 antipsychotic dispensing during the observation period" class="border border-slate-300 rounded px-3 py-2 text-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500" />
            </label>
            <label class="flex flex-col gap-1">
              <span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Exposure</span>
              <input type="text" name="picoI" placeholder="Antipsychotic dispensing" class="border border-slate-300 rounded px-3 py-2 text-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500" />
            </label>
            <label class="flex flex-col gap-1">
              <span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Outcome</span>
              <input type="text" name="picoO" placeholder="Hospitalisation for fall-related injury or fracture" class="border border-slate-300 rounded px-3 py-2 text-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500" />
            </label>
          </div>
        </details>

        <details open class="border border-slate-200 rounded-2xl bg-white shadow-sm">
          <summary class="cursor-pointer select-none px-5 py-4 font-semibold text-slate-900 hover:bg-slate-50 rounded-2xl">3 · Sites</summary>
          <div class="px-5 pb-5 space-y-4">
            <p class="text-xs text-slate-500">
              Tick every <strong>database</strong> (not just country). Feature chips indicate what each database can support; only tick a site whose features cover what your case definition / exposure / time-varying covariates need.
            </p>
            <div class="flex flex-wrap items-center gap-2 text-[10px] text-slate-500 border-y border-slate-100 py-2">
              <span class="uppercase tracking-widest font-bold text-slate-600">Legend</span>
              {FEATURES.map((f) => (
                <span class="inline-flex items-center gap-1">
                  <span class="text-[10px] bg-brand-50 text-brand-700 border border-brand-100 px-1.5 py-0.5 rounded font-mono font-semibold">{f.short}</span>
                  <span>{f.label}</span>
                </span>
              ))}
            </div>
            <div class="space-y-3">
              {Object.entries(SITES_BY_COUNTRY).map(([country, dbs]) => (
                <div>
                  <p class="text-[11px] font-semibold text-slate-700">{country}</p>
                  <div class="mt-1 grid grid-cols-1 sm:grid-cols-2 gap-1.5">
                    {dbs.map((d) => (
                      <label class="flex items-center gap-2 text-xs border border-slate-200 rounded px-3 py-2 hover:bg-slate-50 cursor-pointer">
                        <input type="checkbox" name="sites" value={d.id} class="rounded border-slate-400 text-brand-700 focus:ring-brand-500" />
                        <span class="font-semibold text-slate-800 shrink-0">{d.short}</span>
                        <span class="flex flex-wrap gap-1 ml-auto">
                          {FEATURES.filter((f) => d.features.includes(f.id)).map((f) => (
                            <span class="text-[10px] bg-brand-50 text-brand-700 border border-brand-100 px-1.5 py-0.5 rounded font-mono font-semibold" title={f.label}>{f.short}</span>
                          ))}
                        </span>
                      </label>
                    ))}
                  </div>
                </div>
              ))}
            </div>
            <label class="flex flex-col gap-1">
              <span class="text-[11px] uppercase tracking-widest text-slate-500 font-semibold">Others (one per line)</span>
              <textarea name="sitesOther" rows="2" placeholder="Sites beyond the active databases list" class="w-full border border-slate-300 rounded px-3 py-2 text-xs focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500"></textarea>
            </label>
            <div data-feasibility class="hidden bg-amber-50 border border-amber-200 rounded-lg p-3 text-xs leading-relaxed">
              <p class="font-bold text-amber-800 uppercase tracking-[0.2em] text-[10px]">⚠ Feasibility heads-up; not a blocker</p>
              <p class="mt-1 text-amber-900">Your study question implies data features that some selected sites don't carry. Multi-country SCCS protocols often accommodate this; just be explicit in the per-site analytic plan.</p>
              <ul data-feasibility-list class="mt-2 space-y-1 text-amber-900 list-disc list-inside"></ul>
            </div>
          </div>
        </details>

        <details open class="border border-slate-200 rounded-2xl bg-white shadow-sm">
          <summary class="cursor-pointer select-none px-5 py-4 font-semibold text-slate-900 hover:bg-slate-50 rounded-2xl">4 · Case definition (outcome)</summary>
          <div class="px-5 pb-5 space-y-3">
            <div>
              <button type="button" data-open-library data-category="outcomes" data-target-def="outcomeDef" data-target-codes="outcomeCodes" data-also-fill="picoO" class="text-[10px] uppercase tracking-widest font-bold text-brand-700 bg-brand-50 hover:bg-brand-100 border border-brand-200 px-2 py-1 rounded transition">📚 Pick outcome from library</button>
              <span class="ml-2 text-[11px] text-slate-500">Validation citation auto-appends to References on export.</span>
            </div>
            <label class="flex flex-col gap-1">
              <span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Operational definition</span>
              <textarea name="outcomeDef" rows="3" placeholder="First hospital admission with primary discharge diagnosis of …" class="w-full border border-slate-300 rounded px-3 py-2 text-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500"></textarea>
            </label>
            <label class="flex flex-col gap-1">
              <span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Code set</span>
              <input type="text" name="outcomeCodes" placeholder="ICD-10 W00-W19, S72.* …" class="w-full border border-slate-300 rounded px-3 py-2 text-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500" />
            </label>
            <label class="flex flex-col gap-1">
              <span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Event handling</span>
              <select name="eventHandling" class="border border-slate-300 rounded px-3 py-2 text-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500">
                <option value="all" selected>All events per person (recurrent)</option>
                <option value="first">First event only</option>
              </select>
            </label>
          </div>
        </details>

        <details open class="border border-slate-200 rounded-2xl bg-white shadow-sm">
          <summary class="cursor-pointer select-none px-5 py-4 font-semibold text-slate-900 hover:bg-slate-50 rounded-2xl">5 · Exposure definition</summary>
          <div class="px-5 pb-5 grid sm:grid-cols-2 gap-3">
            <div class="sm:col-span-2">
              <button type="button" data-open-library data-category="exposures" data-target-name="exposureName" data-target-codes="exposureCodes" data-also-fill="picoI" class="text-[10px] uppercase tracking-widest font-bold text-brand-700 bg-brand-50 hover:bg-brand-100 border border-brand-200 px-2 py-1 rounded transition">📚 Pick exposure from library</button>
            </div>
            <label class="flex flex-col gap-1">
              <span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Exposure; name</span>
              <input type="text" name="exposureName" placeholder="Antipsychotics" class="border border-slate-300 rounded px-3 py-2 text-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500" />
            </label>
            <label class="flex flex-col gap-1">
              <span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Exposure; code set</span>
              <input type="text" name="exposureCodes" placeholder="ATC N05A*" class="border border-slate-300 rounded px-3 py-2 text-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500" />
            </label>
            <label class="flex flex-col gap-1 sm:col-span-2">
              <span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Exposure period definition</span>
              <input type="text" name="exposurePeriodDef" value="Continuous exposure inferred from sequential dispensings; gap > grace period ends the episode" class="border border-slate-300 rounded px-3 py-2 text-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500" />
            </label>
            <label class="flex flex-col gap-1">
              <span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Days of supply default (days)</span>
              <input type="number" name="daysOfSupply" value="30" min="1" step="1" class="border border-slate-300 rounded px-3 py-2 text-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500" />
            </label>
            <label class="flex flex-col gap-1">
              <span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Grace period (days)</span>
              <input type="number" name="grace" value="14" min="0" step="1" class="border border-slate-300 rounded px-3 py-2 text-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500" />
            </label>
          </div>
        </details>

        <details open class="border border-slate-200 rounded-2xl bg-white shadow-sm">
          <summary class="cursor-pointer select-none px-5 py-4 font-semibold text-slate-900 hover:bg-slate-50 rounded-2xl">6 · Design variant</summary>
          <div class="px-5 pb-5 grid sm:grid-cols-2 gap-3">
            <label class="flex flex-col gap-1 sm:col-span-2">
              <span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">SCCS variant</span>
              <select name="sccsVariant" class="border border-slate-300 rounded px-3 py-2 text-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500">
                <option value="standard" selected>Standard SCCS (Farrington 1995); within-person exposed vs unexposed time</option>
                <option value="extended-unexposed">SCCS extended with unexposed reference cases; augments within-person estimation with never-exposed cohort members (Whitaker et al, Stat Med 2006)</option>
                <option value="active-comparator">Active-comparator within-person SCCS; case-time on the index drug compared with case-time on a comparator drug (no reliance on a 'no-drug' baseline)</option>
              </select>
              <span class="text-[11px] text-slate-500">Choose Standard when most cases have substantial unexposed time. Choose Extended when within-person unexposed time is sparse and you want to borrow strength from a never-exposed cohort. Choose Active-comparator when patients are continuously on some therapy of the same indication and the relevant question is 'drug A vs drug B'.</span>
            </label>
          </div>
        </details>

        <details open class="border border-slate-200 rounded-2xl bg-white shadow-sm">
          <summary class="cursor-pointer select-none px-5 py-4 font-semibold text-slate-900 hover:bg-slate-50 rounded-2xl">7 · Risk windows</summary>
          <div class="px-5 pb-5 grid sm:grid-cols-2 gap-3">
            <label class="flex flex-col gap-1">
              <span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Pre-risk (pretreatment) window (days)</span>
              <input type="number" name="preRisk" value="14" min="0" step="1" class="border border-slate-300 rounded px-3 py-2 text-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500" />
              <span class="text-[11px] text-slate-500">A short window immediately before first exposure, separated out to (a) absorb event-dependent exposure where the outcome itself triggers prescribing and (b) benchmark the underlying-disease risk just before therapy. AsPEN antipsychotic-falls SCCS used 14 days (Wang GH, BMJ 2021;PMID 34503972) and found the pretreatment IRR was higher than treatment IRRs; confirming underlying disease, not the drugs, drove much of the early risk.</span>
            </label>
            <label class="flex flex-col gap-1">
              <span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Risk window definition</span>
              <select name="riskWindowDef" class="border border-slate-300 rounded px-3 py-2 text-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500">
                <option value="entire" selected>Entire exposure episode</option>
                <option value="0-30">Days 0-30 after exposure start</option>
                <option value="0-90">Days 0-90 after exposure start</option>
                <option value="0-180">Days 0-180 after exposure start</option>
                <option value="early-late">Early (0-14 d) vs Late (15+ d) split</option>
