        const children = [];
        if (__phdcLogo) children.push(new D.Paragraph({ spacing: { after: 120 }, children: [new D.ImageRun({ data: __phdcLogo, transformation: { width: 210, height: 51 } })] }));
        children.push(new D.Paragraph({ children: [text(s.title || "(Untitled multi-national SCCS study)", { bold: true, size: 32 })], spacing: { before: 0, after: 120 } }));
        children.push(labelTable([
          ["Study ID", s.shortId || ""],
          ["Lead investigator(s)", s.leadInvestigator || ""],
          ["Version", s.version || ("v0.1 draft · " + today)],
          ["Design", "Multi-national self-controlled case series (SCCS); " + sccsVariantShort],
        ]));

        window.PC.abstractDocx(D, pcOf(s)).forEach((c) => children.push(c));
        children.push(h1("1. Research question"));
        children.push(labelTable([["Population", s.picoP || ""], ["Exposure", s.picoI || ""], ["Outcome", s.picoO || ""]]));

        children.push(h1("2. Sites"));
        children.push(para(sitesText));

        children.push(h1("3. Case definition (outcome)"));
        children.push(p([text("Operational definition. ", { bold: true }), text(s.outcomeDef || "-")]));
        children.push(p([text("Code set. ", { bold: true }), text(s.outcomeCodes || "-")]));
        children.push(p([text("Event handling. ", { bold: true }), text(eventHandling)]));

        children.push(h1("4. Exposure definition"));
        children.push(labelTable([
          ["Name", s.exposureName || ""],
          ["Code set", s.exposureCodes || ""],
          ["Days of supply (default)", (s.daysOfSupply || "30") + " d"],
          ["Grace period", (s.grace || "14") + " d"],
          ["Exposure period rule", s.exposurePeriodDef || "Continuous exposure inferred from sequential dispensings; gap > grace period ends the episode."],
        ]));

        children.push(h1("5. Design variant"));
        children.push(para(sccsVariantText));

        children.push(h1("6. Risk windows"));
        children.push(labelTable([
          ["Pre-risk window", (s.preRisk || "14") + " days before first exposure"],
          ["Risk window", riskWin],
          ["Post-risk window", (s.postRisk || "14") + " days after exposure end"],
          ["Baseline (control) period", s.baselinePeriod || "All observation time NOT in pre-risk, risk, or post-risk windows"],
        ]));

        children.push(h1("7. Observation period"));
        children.push(labelTable([
          ["Period starts at", ({ "age-cohort": "Later of (a) calendar start or (b) cohort entry age", "study-start": "Calendar start of study period", "age-onset": "Age at first eligibility", enrolment: "Date of database registration" })[s.obsStart] || "-"],
          ["Period ends at", ({ "earliest-of": "Earliest of: end of study period, death, disenrolment", "study-end": "Calendar end of study period", death: "Death", disenrol: "Disenrolment from database" })[s.obsEnd] || "-"],
          ["Study calendar period", s.studyCalendar || "-"],
        ]));

        children.push(h1("8. Time-varying confounders"));
        children.push(labelTable([["Age bands", ageBand + " bands"], ["Season", season]]));
        children.push(h2("Other time-varying covariates"));
        tvCovs.length ? tvCovs.forEach((l) => children.push(bullet(l))) : children.push(para("(none specified)"));

        children.push(h1("9. Statistical analysis"));
        children.push(labelTable([
          ["Primary model", s.primaryModel || "Conditional Poisson regression with offset for log person-time"],
          ["Effect estimate", s.effectMeasure || "Incidence rate ratio (IRR) with 95% CI"],
          ["Meta-analysis", meta],
        ]));
        children.push(h2("Subgroup analyses"));
        subgroups.length ? subgroups.forEach((l) => children.push(bullet(l))) : children.push(para("(none specified)"));
        children.push(h2("Sensitivity analyses"));
        sensitivity.length ? sensitivity.forEach((l) => children.push(bullet(l))) : children.push(para("(none specified)"));

        children.push(h1("10. Execution and timeline"));
        children.push(labelTable([["Architecture", arch]]));
        children.push(h2("Timeline milestones"));
        milestones.length ? milestones.forEach((l) => children.push(numItem(l))) : children.push(para("(none)"));

        children.push(h1("11. Ethics, data sharing, dissemination"));
        children.push(p([text("Ethics. ", { bold: true }), text(s.ethics || "Each participating site obtains local IRB / ethics approval before data extraction.")]));
        children.push(p([text("Dissemination. ", { bold: true }), text(s.dissemination || "Primary manuscript to a peer-reviewed pharmacoepidemiology journal.")]));

        window.PC.tailDocx(D, pcOf(s)).forEach((c) => children.push(c));
        children.push(h1("12. Key references"));
        refs.length ? refs.forEach((l) => children.push(numItem(l))) : children.push(para("(none)"));

        children.push(p([new D.TextRun({ text: "Drafted with the AsPEN SCCS protocol builder (" + today + ").", font: FONT, size: 18, italics: true, color: "808080" })], { spacing: { before: 400 } }));

        const doc = new D.Document({
          creator: "AsPEN protocol builder",
          title: s.title || "AsPEN SCCS protocol",
          styles: {
            default: { document: { run: { font: FONT, size: 22 } } },
            paragraphStyles: [
              { id: "Heading1", name: "Heading 1", basedOn: "Normal", next: "Normal", quickFormat: true, run: { size: 28, bold: true, font: FONT }, paragraph: { spacing: { before: 200, after: 80 }, outlineLevel: 0 } },
              { id: "Heading2", name: "Heading 2", basedOn: "Normal", next: "Normal", quickFormat: true, run: { size: 24, bold: true, font: FONT }, paragraph: { spacing: { before: 160, after: 60 }, outlineLevel: 1 } },
            ],
          },
          numbering: { config: [{ reference: "ordered", levels: [{ level: 0, format: D.LevelFormat.DECIMAL, text: "%1.", alignment: D.AlignmentType.LEFT, style: { paragraph: { indent: { left: 720, hanging: 360 } } } }] }] },
          sections: [{ properties: { page: { size: { width: 11906, height: 16838 }, margin: { top: 1440, right: 1440, bottom: 1440, left: 1440 } } }, children }],
        });
        return await D.Packer.toBlob(doc);
      };

      // ── Phenotype library modal (same shape as ACNU) ──
      const modal = document.querySelector("[data-library-modal]");
      const modalTitle = document.querySelector("[data-library-title]");
      const modalList = document.querySelector("[data-library-list]");
      const modalSearch = document.querySelector("[data-library-search]");
      let currentCategory = "outcomes";
      let currentTargets = {};
      const esc = (s) => String(s ?? "").replace(/[&<>"']/g, (c) => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;" }[c]));

      const renderLibrary = (filter = "") => {
        const items = PHENOTYPES[currentCategory] || [];
        const f = filter.trim().toLowerCase();
        const filtered = f ? items.filter((it) => (it.name || "").toLowerCase().includes(f) || (it.codes || "").toLowerCase().includes(f) || (it.definition || "").toLowerCase().includes(f) || (it.validation || "").toLowerCase().includes(f)) : items;
        if (filtered.length === 0) { modalList.innerHTML = '<p class="px-3 py-6 text-sm text-slate-500 italic text-center">No phenotype matches.</p>'; return; }
        // validation citation hidden in modal; accumulates silently and
        // lands in the Word/MD References section at export time.
        modalList.innerHTML = filtered.map((it, idx) => `
          <button type="button" data-phenotype-idx="${idx}" class="block w-full text-left px-4 py-3 rounded-lg border border-transparent hover:border-brand-300 hover:bg-brand-50/40 transition">
            <p class="font-semibold text-slate-900 text-sm">${esc(it.name)}</p>
            ${it.codes ? `<p class="mt-1 text-xs text-slate-700 font-mono leading-relaxed">${esc(it.codes)}</p>` : ""}
            ${it.definition ? `<p class="mt-1 text-xs text-slate-600 leading-relaxed">${esc(it.definition)}</p>` : ""}
          </button>
        `).join("");
        modalList.querySelectorAll("[data-phenotype-idx]").forEach((btn) => {
          btn.addEventListener("click", () => {
            const it = filtered[parseInt(btn.dataset.phenotypeIdx, 10)];
            if (!it) return;
            const fill = (key, val) => { const fieldName = currentTargets[key]; if (!fieldName || val === undefined) return; const el = form.querySelector(`[name="${fieldName}"]`); if (el) el.value = val; };
            fill("name", it.name);
            fill("codes", it.codes);
            fill("def", it.definition);
            if (currentTargets.alsoFill) { const el = form.querySelector(`[name="${currentTargets.alsoFill}"]`); if (el && it.name) el.value = it.name; }
            if (it.validation) { pickedCitations[it.name] = it.validation; savePickedCitations(); }
            closeLibrary();
            render();
          });
        });
      };
      const openLibrary = (category, targets) => {
        currentCategory = category;
        currentTargets = targets;
        modalTitle.textContent = ({ outcomes: "Pick an outcome (case definition)", exposures: "Pick a drug class (exposure)" })[category] || "Pick a phenotype";
        modalSearch.value = "";
        renderLibrary("");
        modal.classList.remove("hidden");
        setTimeout(() => modalSearch.focus(), 50);
      };
      const closeLibrary = () => modal.classList.add("hidden");
      document.querySelectorAll("[data-open-library]").forEach((btn) => {
        btn.addEventListener("click", () => openLibrary(btn.dataset.category, { name: btn.dataset.targetName, codes: btn.dataset.targetCodes, def: btn.dataset.targetDef, alsoFill: btn.dataset.alsoFill }));
      });
      document.querySelector("[data-library-close]")?.addEventListener("click", closeLibrary);
      modal.addEventListener("click", (e) => { if (e.target === modal) closeLibrary(); });
      document.addEventListener("keydown", (e) => { if (e.key === "Escape") closeLibrary(); });
      modalSearch.addEventListener("input", () => renderLibrary(modalSearch.value));

      // Exported for testing (and any future reuse): the IIFE otherwise hides these.
      window.__builder = { readForm, buildMarkdown, buildDocx };

      setState("ready");
    })();
  </script>
</BaseLayout>
