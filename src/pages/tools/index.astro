---
import BaseLayout from "../../layouts/BaseLayout.astro";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");

const tools = [
  {
    name: "Protocol Generator",
    blurb:
      "Draft a publication-ready pharmacoepidemiology protocol — ACNU, case-crossover, descriptive, or self-controlled case-series — with a validated phenotype library, feasibility checks across Asian databases, and one-click Word / Markdown export.",
    note: "Validated phenotype library · runs entirely in your browser",
    href: `${base}/tools/protocol-generator`,
    cta: "Open the generator",
  },
  {
    name: "TARGET Checker",
    blurb:
      "The flip side of the generator: paste or upload an existing protocol and get an AI-assisted, item-by-item read on whether it conforms to the TARGET reporting guideline for observational studies emulating a target trial — with evidence and fixes for anything missing.",
    note: "AI-assisted (free) · for self-auditing reporting completeness",
    href: `${base}/tools/target-checker`,
    cta: "Open the checker",
  },
  {
    name: "ACB Calculator",
    blurb:
      "Score a patient's total anticholinergic burden across 6 international scales and quantify 30-day risk of cardiovascular events, pneumonia, and out-of-hospital cardiac arrest — with OCR drug-history capture and printable reports.",
    note: "Built on 3 Taiwan NHI studies (BMJ, Clin Epidemiol, Eur Heart J)",
    href: `${base}/tools/acb-calculator`,
    cta: "Open the calculator",
  },
  {
    name: "PHDc RWE Tool",
    blurb:
      "A real-world-evidence utility from the Population Health Data Center for exploring and operationalising claims-based study designs.",
    note: "From PHDc, NCKU · embedded here, no install",
    href: `${base}/tools/phdc-rwe-tool`,
    cta: "Launch the tool",
  },
  {
    name: "NHIRD Data Dictionary",
    blurb:
      "A searchable codebook for Taiwan's National Health Insurance Research Database (NHIRD) and Health & Welfare Data Center datasets — variables, formats, and cross-dataset linkages across claims, mortality, cancer registry, and more.",
    note: "Structured on the DIVERSE data-source framework",
    href: `${base}/tools/nhird-data-dictionary`,
    cta: "Open the dictionary",
  },
];
---

<BaseLayout
  title="RWE Tools — Daniel Hsiang-Te Tsai"
  description="Open, in-browser real-world-evidence tools: a multi-design protocol generator, an anticholinergic-burden calculator, the PHDc RWE tool, and an NHIRD data dictionary."
>
  <header class="relative bg-gradient-to-br from-brand-50 via-white to-brand-100/40 border-b border-slate-200 overflow-hidden">
    <div class="relative mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-14">
      <p class="uppercase tracking-widest text-xs text-brand-600 font-semibold mb-2">Infrastructure</p>
      <h1 class="text-4xl md:text-5xl font-bold text-slate-900">RWE Tools</h1>
      <p class="mt-4 text-lg text-slate-600 max-w-3xl">
        Open, in-browser tools for real-world evidence — no install, nothing leaves your device. The infrastructure
        I build so good RWE is faster to do.
      </p>
    </div>
  </header>

  <section class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-12">
    <a class="text-sm text-brand-700 hover:underline font-semibold" href={`${base}/`}>← Back to home</a>
    <div class="mt-6 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {tools.map((t) => (
        <a href={t.href}
           class="group flex flex-col rounded-2xl border border-slate-200 bg-white p-6 shadow-sm hover:shadow-md hover:border-brand-400 transition">
          <h2 class="text-lg font-bold text-slate-900 group-hover:text-brand-700">{t.name}</h2>
          <p class="mt-2 text-sm text-slate-600 leading-relaxed flex-1">{t.blurb}</p>
          <p class="mt-3 text-xs text-slate-500 italic">{t.note}</p>
          <span class="mt-4 text-sm font-semibold text-brand-700 group-hover:underline">{t.cta} →</span>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
