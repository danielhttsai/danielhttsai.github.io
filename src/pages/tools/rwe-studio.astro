---
import BaseLayout from "../../layouts/BaseLayout.astro";
import WebrEngine from "../../components/WebrEngine.astro";
const base = import.meta.env.BASE_URL.replace(/\/$/, "");

// The four in-scope designs the analysis can run (Phase 5).
const DESIGNS = [
  { v: "descriptive", t: "Descriptive analysis", d: "Characterise a population — incidence, prevalence, drug utilisation, mortality." },
  { v: "acnu", t: "Active-comparator new-user cohort", d: "Compare two treatments' effect on an outcome as users start therapy." },
  { v: "sccs", t: "Self-controlled case series", d: "Transient exposure + acute outcome; each case is its own control." },
  { v: "cco", t: "Case-crossover", d: "Acute, abrupt-onset event; compare exposure in a hazard window vs control windows." },
];
---

<BaseLayout
  title="RWE Studio — Daniel Tsai"
  description="Upload a small, messy hospital dataset and, entirely in your browser, profile and clean it into a tidy master file, then run the analysis for a chosen study design in real R (via WebR). No data leaves your device."
>
  <header class="relative bg-gradient-to-br from-brand-50 via-white to-brand-100/40 border-b border-slate-200 overflow-hidden">
    <div class="relative mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-12">
      <p class="uppercase tracking-widest text-xs text-brand-600 font-semibold mb-2">RWE Tools · experimental</p>
      <h1 class="text-3xl md:text-4xl font-bold text-slate-900">RWE Studio</h1>
      <p class="mt-3 text-base text-slate-600 max-w-3xl">
        Feed in a small, messy hospital dataset → <strong>profile &amp; flag dirtiness</strong> → clean it into a tidy
        <strong>master file</strong> → pick a study design and map your columns → <strong>run the analysis in real R</strong>
        (via WebR, in your browser) → get the estimate, Table 1, and a reproducible R script.
      </p>
      <a class="mt-4 inline-block text-sm text-brand-700 hover:underline font-semibold" href={`${base}/tools`}>← All RWE tools</a>
    </div>
  </header>

  <section class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-8 space-y-6">
    <!-- Privacy -->
    <div class="flex items-start gap-2 rounded-xl border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm text-emerald-900">
      <span class="font-bold">🔒</span>
      <span>All processing happens <strong>in your browser</strong>. Your dataset is never uploaded or sent to any server — parsing, profiling, cleaning, and (soon) the R analysis all run locally on your device.</span>
    </div>

    <!-- Step tracker -->
    <ol class="flex flex-wrap gap-x-4 gap-y-1 text-xs font-semibold text-slate-400">
      <li class="text-brand-700">1 · Question &amp; design</li>
      <li>2 · Upload &amp; profile</li>
      <li>3 · Map columns</li>
      <li>4 · Clean → master file</li>
      <li>5 · Analyse (R)</li>
      <li>6 · Export</li>
    </ol>

    <!-- Step 1: clinical question & design -->
    <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
      <h2 class="text-lg font-bold text-slate-900">1 · Clinical question &amp; study design</h2>
      <p class="mt-1 text-sm text-slate-600">Decide this <strong>first</strong> — the design determines which columns you'll map and what cleaning actually matters.</p>
      <div class="mt-4 grid gap-3 sm:grid-cols-2">
        <label class="block"><span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Population</span>
          <input name="q_pop" class="mt-1 w-full rounded-lg border border-slate-300 p-2 text-sm" placeholder="e.g. Adults with type 2 diabetes" /></label>
        <label class="block"><span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Outcome</span>
          <input name="q_out" class="mt-1 w-full rounded-lg border border-slate-300 p-2 text-sm" placeholder="e.g. Hospitalisation for heart failure" /></label>
        <label class="block"><span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Exposure / intervention</span>
          <input name="q_exp" class="mt-1 w-full rounded-lg border border-slate-300 p-2 text-sm" placeholder="e.g. SGLT2 inhibitor" /></label>
        <label class="block"><span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Comparator (if any)</span>
          <input name="q_comp" class="mt-1 w-full rounded-lg border border-slate-300 p-2 text-sm" placeholder="e.g. DPP-4 inhibitor" /></label>
      </div>

      <div class="mt-4 rounded-xl border border-slate-200 bg-slate-50 p-3">
        <p class="text-xs font-semibold text-slate-700">Not sure which design? Tick what applies, then get a recommendation:</p>
        <div class="mt-2 grid gap-1 sm:grid-cols-2 text-xs text-slate-700">
          <label class="flex items-start gap-2"><input type="checkbox" name="s_describe" class="mt-0.5" /> <span>Goal is to describe / quantify (not test a causal effect)</span></label>
          <label class="flex items-start gap-2"><input type="checkbox" name="s_twodrugs" class="mt-0.5" /> <span>Comparing two active treatments from the same indication</span></label>
          <label class="flex items-start gap-2"><input type="checkbox" name="s_transient" class="mt-0.5" /> <span>Exposure is transient / intermittent (short course)</span></label>
          <label class="flex items-start gap-2"><input type="checkbox" name="s_acute" class="mt-0.5" /> <span>Outcome is acute / abrupt-onset</span></label>
        </div>
        <button id="suggest" type="button" class="mt-2 text-xs font-semibold text-brand-700 hover:underline">→ Recommend a design</button>
        <p id="suggestmsg" class="mt-1 text-xs text-brand-800"></p>
      </div>

      <div class="mt-4">
        <span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Study design</span>
        <div class="mt-1.5 grid gap-2 sm:grid-cols-2">
          {DESIGNS.map((d) => (
            <label class="flex items-start gap-2 rounded-xl border border-slate-200 p-3 cursor-pointer hover:border-brand-400 has-[:checked]:border-brand-500 has-[:checked]:bg-brand-50/60">
              <input type="radio" name="design" value={d.v} class="mt-0.5" />
              <span><span class="text-sm font-semibold text-slate-800">{d.t}</span><br /><span class="text-xs text-slate-600">{d.d}</span></span>
            </label>
          ))}
        </div>
      </div>
    </div>

    <!-- Upload -->
    <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
      <h2 class="text-lg font-bold text-slate-900">2 · Upload a dataset</h2>
      <p class="mt-1 text-sm text-slate-600">CSV or Excel (.xlsx). One row per record; a header row with column names. Small extracts work best.</p>
      <label id="drop" class="mt-4 flex flex-col items-center justify-center gap-2 rounded-xl border-2 border-dashed border-slate-300 bg-slate-50 px-6 py-10 text-center cursor-pointer hover:border-brand-400 hover:bg-brand-50/40 transition">
        <span class="text-3xl">📄</span>
        <span class="text-sm font-semibold text-slate-700">Drop a CSV / XLSX here, or click to choose</span>
        <span id="fileinfo" class="text-xs text-slate-500"></span>
        <input id="file" type="file" accept=".csv,.xlsx,.xls,.tsv" class="hidden" />
      </label>
      <p id="msg" class="mt-2 text-xs"></p>
      <div class="mt-3 text-xs text-slate-500">
        No data handy? <button id="demo" type="button" class="text-brand-700 font-semibold hover:underline">Load a tiny demo dataset</button> (synthetic, 60 rows).
      </div>
    </div>

    <!-- Summary + profile -->
    <div id="results" class="hidden space-y-6">
      <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
        <div class="flex flex-wrap items-center justify-between gap-3">
          <h2 class="text-lg font-bold text-slate-900">Data profile &amp; dictionary</h2>
          <div class="flex flex-wrap gap-2">
            <button id="dlmaster" type="button" class="bg-brand-700 text-white hover:bg-brand-800 font-semibold px-4 py-2 rounded-lg text-sm">⬇ Master file (CSV)</button>
            <button id="dldict" type="button" class="bg-white border border-brand-700 text-brand-700 hover:bg-brand-50 font-semibold px-4 py-2 rounded-lg text-sm">⬇ Data dictionary (CSV)</button>
          </div>
        </div>
        <p id="summary" class="mt-2 text-sm text-slate-600"></p>
        <div id="issues" class="mt-3 space-y-1.5"></div>
        <div class="mt-4 overflow-x-auto">
          <table class="w-full text-xs border-collapse">
            <thead>
              <tr class="text-left text-slate-500 border-b border-slate-200">
                <th class="py-2 pr-3 font-semibold">Column</th>
                <th class="py-2 pr-3 font-semibold">Inferred type</th>
                <th class="py-2 pr-3 font-semibold">Missing</th>
                <th class="py-2 pr-3 font-semibold">Distinct</th>
                <th class="py-2 pr-3 font-semibold">Range / top values</th>
                <th class="py-2 pr-3 font-semibold">Flags</th>
              </tr>
            </thead>
            <tbody id="proftable"></tbody>
          </table>
        </div>
      </div>

    </div>

    <!-- Step 3: map columns to the design's roles -->
    <div id="mapcard" class="hidden rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
      <h2 class="text-lg font-bold text-slate-900">3 · Map columns → <span id="designname" class="text-brand-700"></span> roles</h2>
      <p id="maphint" class="mt-1 text-sm text-slate-600"></p>
      <div id="maproles" class="mt-4 grid gap-3 sm:grid-cols-2"></div>
      <div id="covwrap" class="hidden mt-4">
        <div class="flex flex-wrap items-center justify-between gap-2">
          <span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Baseline covariates (for the propensity score)</span>
          <span class="flex gap-3 text-[11px]">
            <button type="button" id="cov_auto" class="text-brand-700 font-semibold hover:underline">✨ Auto-select (clinical)</button>
            <button type="button" id="cov_all" class="text-brand-700 font-semibold hover:underline">Select all</button>
            <button type="button" id="cov_none" class="text-slate-500 hover:underline">Clear</button>
          </span>
        </div>
        <p class="text-[11px] text-slate-500">Auto-select flags clinically-plausible confounders by column name; then tick/untick to refine.</p>
        <div id="covlist" class="mt-1.5 grid gap-1 sm:grid-cols-3 text-xs text-slate-700"></div>

        <div id="acnuopts" class="hidden mt-4 space-y-3 rounded-xl border border-slate-200 bg-slate-50 p-3">
          <div>
            <span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Estimand</span>
            <div class="mt-1 flex flex-wrap gap-x-4 gap-y-1 text-xs text-slate-700">
              <label class="flex items-center gap-1.5"><input type="checkbox" id="est_itt" checked/> Intention-to-treat (ITT)</label>
              <label class="flex items-center gap-1.5"><input type="checkbox" id="est_pp"/> Per-protocol (PP) — needs a discontinuation-time column mapped</label>
            </div>
          </div>
          <div>
            <span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Propensity-score methods (run together)</span>
            <div class="mt-1 grid gap-1 sm:grid-cols-2 text-xs text-slate-700">
              <label class="flex items-center gap-1.5"><input type="checkbox" id="m_match" checked/> PS matching, ratio
                <select id="m_ratio" class="rounded border border-slate-300 px-1 py-0.5 text-[11px]"><option>1</option><option selected>2</option><option>3</option><option>4</option></select>:1</label>
              <label class="flex items-center gap-1.5"><input type="checkbox" id="m_iptw" checked/> IPTW (ATE)</label>
              <label class="flex items-center gap-1.5"><input type="checkbox" id="m_smrw"/> SMR weighting (ATT)</label>
              <label class="flex items-center gap-1.5"><input type="checkbox" id="m_overlap"/> Overlap weighting</label>
              <label class="flex items-center gap-1.5"><input type="checkbox" id="m_fine"/> Fine stratification,
                <select id="m_nstrata" class="rounded border border-slate-300 px-1 py-0.5 text-[11px]"><option>5</option><option selected>10</option><option>20</option><option>50</option></select> strata</label>
            </div>
            <p class="text-[11px] text-slate-400">Crude is always shown alongside.</p>
          </div>
        </div>
      </div>
      <p id="mapmsg" class="mt-3 text-xs"></p>
    </div>

    <!-- Step 4: clean -> master file -->
    <div id="cleancard" class="hidden rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
      <h2 class="text-lg font-bold text-slate-900">4 · Clean → master file</h2>
      <p class="mt-1 text-sm text-slate-600">Apply the fixes you want; each is logged and re-emitted into the exported R script. The mapped variables are coerced to the types the analysis needs.</p>
      <div class="mt-3 grid gap-1.5 sm:grid-cols-2 text-sm text-slate-700">
        <label class="flex items-center gap-2"><input type="checkbox" id="c_trim" checked /> Trim leading/trailing whitespace</label>
        <label class="flex items-center gap-2"><input type="checkbox" id="c_std" checked /> Standardise Yes/No &amp; sex codes; coerce mapped binaries to 0/1</label>
        <label class="flex items-center gap-2"><input type="checkbox" id="c_dedupe" checked /> Drop exact duplicate rows</label>
        <label class="flex items-center gap-2"><input type="checkbox" id="c_dropmiss" checked /> Drop rows missing a required mapped variable</label>
      </div>
      <div class="mt-4 flex flex-wrap items-center gap-3">
        <button id="applyclean" type="button" class="bg-brand-700 text-white hover:bg-brand-800 font-semibold px-4 py-2 rounded-lg text-sm">Build master file</button>
        <span id="cleaninfo" class="text-xs text-slate-600"></span>
      </div>
    </div>

    <!-- Step 5: analyse in R -->
    <div id="anacard" class="hidden rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
      <h2 class="text-lg font-bold text-slate-900">5 · Analyse in R (WebR)</h2>
      <p class="mt-1 text-sm text-slate-600">Runs the design's model on your master file in real R, in your browser. First run downloads the R runtime (~a few seconds).</p>
      <div class="mt-3 flex flex-wrap items-center gap-3">
        <button id="runanalysis" type="button" class="bg-brand-700 text-white hover:bg-brand-800 font-semibold px-5 py-2.5 rounded-lg text-sm">▶ Run analysis in R</button>
        <span id="anastatus" class="text-xs text-slate-600"></span>
      </div>
      <div id="anaresults" class="mt-4 hidden rounded-xl border border-brand-200 bg-brand-50/60 p-4"></div>
      <div id="table1" class="mt-4 hidden rounded-xl border border-slate-200 bg-white p-4 overflow-x-auto"></div>
      <pre id="routput" class="mt-3 hidden rounded-lg bg-slate-900 text-slate-100 p-4 text-xs leading-relaxed whitespace-pre-wrap overflow-auto max-h-[360px]"></pre>
    </div>

    <!-- Step 6: export -->
    <div id="expcard" class="hidden rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
      <h2 class="text-lg font-bold text-slate-900">6 · Export</h2>
      <p class="mt-1 text-sm text-slate-600">The R script is exactly what ran — it reproduces the on-screen result in desktop R.</p>
      <div class="mt-3 flex flex-wrap gap-2">
        <button id="dlmaster2" type="button" class="bg-white border border-brand-700 text-brand-700 hover:bg-brand-50 font-semibold px-4 py-2 rounded-lg text-sm">⬇ Master file (CSV)</button>
        <button id="dlscript" type="button" class="bg-white border border-brand-700 text-brand-700 hover:bg-brand-50 font-semibold px-4 py-2 rounded-lg text-sm">⬇ R script (.R)</button>
        <button id="dlreportword" type="button" class="bg-brand-700 text-white hover:bg-brand-800 font-semibold px-4 py-2 rounded-lg text-sm">⬇ Report (Word)</button>
        <button id="dlreport" type="button" class="bg-white border border-brand-700 text-brand-700 hover:bg-brand-50 font-semibold px-4 py-2 rounded-lg text-sm">⬇ Report (Markdown)</button>
      </div>
    </div>
  </section>

  <script src="https://unpkg.com/docx@8.5.0/build/index.umd.js" is:inline></script>
  <WebrEngine />

  <script is:inline>
    const $ = (id) => document.getElementById(id);
    const fileInput = $("file"), drop = $("drop");
    const setMsg = (t, bad) => { const el = $("msg"); el.textContent = t || ""; el.className = "mt-2 text-xs " + (bad ? "text-rose-600" : "text-slate-500"); };

    let DATA = { rows: [], columns: [], profile: [], name: "dataset" };

    const loadScript = (src) => new Promise((res, rej) => {
      if (document.querySelector('script[src="' + src + '"]')) return res();
      const s = document.createElement("script"); s.src = src; s.onload = () => res(); s.onerror = () => rej(new Error("load " + src)); document.head.appendChild(s);
    });

    async function parseFile(file) {
      await loadScript("https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js");
      const buf = await file.arrayBuffer();
      const wb = window.XLSX.read(buf, { type: "array", cellDates: true });
      const ws = wb.Sheets[wb.SheetNames[0]];
      const header = (window.XLSX.utils.sheet_to_json(ws, { header: 1, blankrows: false })[0] || []).map((h) => String(h).trim());
      const rows = window.XLSX.utils.sheet_to_json(ws, { defval: null, raw: true, blankrows: false });
      return { rows, columns: header.filter(Boolean) };
    }

    const isBlank = (v) => v === null || v === undefined || (typeof v === "string" && v.trim() === "");
    const isLikelyDate = (v) => v instanceof Date || (typeof v === "string" && /^\d{4}[-/](0?[1-9]|1[0-2])([-/](0?[1-9]|[12]\d|3[01]))?$/.test(v.trim()));
    const asStr = (v) => (v instanceof Date ? v.toISOString().slice(0, 10) : String(v));
    const topCats = (arr, k) => {
      const m = {}; arr.forEach((v) => { m[v] = (m[v] || 0) + 1; });
      return Object.entries(m).sort((a, b) => b[1] - a[1]).slice(0, k).map(([v, c]) => v + " (" + c + ")").join(", ");
    };

    function profileColumn(name, rows) {
      const vals = rows.map((r) => r[name]);
      const n = vals.length;
      const nonNull = vals.filter((v) => !isBlank(v));
      const missing = n - nonNull.length;
      const strs = nonNull.map(asStr);
      const distinct = new Set(nonNull.map((v) => (v instanceof Date ? v.getTime() : v))).size;
      const numeric = nonNull.filter((v) => typeof v === "number" || (typeof v === "string" && v.trim() !== "" && !isNaN(Number(v.replace(/,/g, "")))));
      const dates = nonNull.filter(isLikelyDate);
      let type;
      if (nonNull.length === 0) type = "empty";
      else if (numeric.length === nonNull.length) type = distinct <= 2 ? "binary" : (distinct === nonNull.length && nonNull.length > 10 ? "id" : "number");
      else if (dates.length === nonNull.length) type = "date";
      else if (distinct === nonNull.length && nonNull.length > 5) type = "id";
      else if (distinct <= Math.max(20, nonNull.length * 0.1)) type = "categorical";
      else type = "text";

      const flags = [];
      if (missing > 0) flags.push({ level: missing / n > 0.2 ? "warn" : "info", msg: Math.round((100 * missing) / n) + "% missing" });
      if (numeric.length > 0 && numeric.length < nonNull.length && type !== "categorical" && type !== "text" && type !== "date")
        flags.push({ level: "warn", msg: "mixed numeric / non-numeric" });
      if (dates.length > 0 && dates.length < nonNull.length && type === "date") flags.push({ level: "warn", msg: "some values don't parse as dates" });
      if (strs.some((v) => v !== v.trim())) flags.push({ level: "warn", msg: "stray whitespace" });
      const lc = new Set(strs.map((v) => v.toLowerCase().trim()));
      if ((type === "categorical" || type === "binary") && lc.size < distinct) flags.push({ level: "warn", msg: "inconsistent capitalisation / spacing" });
      if (distinct === 1) flags.push({ level: "info", msg: "constant" });
      if (type === "number") {
        const nums = numeric.map((v) => Number(String(v).replace(/,/g, "")));
        if (nums.some((x) => x < 0)) flags.push({ level: "info", msg: "has negatives" });
      }

      let range = "";
      if (type === "number" || type === "binary") {
        const nums = numeric.map((v) => Number(String(v).replace(/,/g, "")));
        range = "min " + Math.min(...nums) + " · max " + Math.max(...nums);
      } else if (type === "date") {
        const ds = nonNull.map((v) => (v instanceof Date ? v : new Date(v))).map((d) => d.getTime()).filter((t) => !isNaN(t));
        if (ds.length) range = new Date(Math.min(...ds)).toISOString().slice(0, 10) + " → " + new Date(Math.max(...ds)).toISOString().slice(0, 10);
      } else if (type !== "empty") {
        range = topCats(strs, 3);
      }
      return { name, type, missing, missingPct: n ? (100 * missing) / n : 0, distinct, flags, range };
    }

    function dupRowCount(rows, columns) {
      const seen = new Set(); let dups = 0;
      for (const r of rows) { const k = columns.map((c) => asStr(r[c] == null ? "" : r[c])).join(""); if (seen.has(k)) dups++; else seen.add(k); }
      return dups;
    }

    const TYPE_BADGE = { number: "bg-sky-100 text-sky-800", binary: "bg-indigo-100 text-indigo-800", date: "bg-violet-100 text-violet-800", categorical: "bg-emerald-100 text-emerald-800", id: "bg-amber-100 text-amber-800", text: "bg-slate-100 text-slate-700", empty: "bg-rose-100 text-rose-700" };
    const esc = (x) => String(x == null ? "" : x).replace(/[&<>"']/g, (c) => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;" }[c]));

    function render() {
      const { rows, columns, profile } = DATA;
      $("results").classList.remove("hidden");
      const dups = dupRowCount(rows, columns);
      const flagged = profile.filter((p) => p.flags.some((f) => f.level === "warn")).length;
      $("summary").innerHTML = "<strong>" + rows.length + "</strong> rows · <strong>" + columns.length + "</strong> columns · " +
        (dups ? "<span class='text-amber-700 font-semibold'>" + dups + " duplicate row(s)</span>" : "no duplicate rows") +
        " · " + (flagged ? "<span class='text-amber-700 font-semibold'>" + flagged + " column(s) need attention</span>" : "no dirtiness flagged");

      const issues = [];
      if (dups) issues.push({ level: "warn", msg: dups + " fully-duplicated row(s) — likely to be de-duplicated during cleaning." });
      if (!columns.length) issues.push({ level: "error", msg: "No columns detected — is there a header row?" });
      $("issues").innerHTML = issues.map((i) => "<div class='flex items-start gap-2 rounded-lg border px-3 py-2 text-xs " + (i.level === "error" ? "border-rose-200 bg-rose-50 text-rose-800" : "border-amber-200 bg-amber-50 text-amber-800") + "'><span class='font-bold'>" + (i.level === "error" ? "✕" : "!") + "</span><span>" + esc(i.msg) + "</span></div>").join("");

      $("proftable").innerHTML = profile.map((p) => {
        const badges = p.flags.map((f) => "<span class='inline-block rounded px-1.5 py-0.5 text-[10px] font-semibold " + (f.level === "warn" ? "bg-amber-100 text-amber-800" : "bg-slate-100 text-slate-600") + "'>" + esc(f.msg) + "</span>").join(" ") || "<span class='text-emerald-600'>✓ clean</span>";
        return "<tr class='border-b border-slate-100 align-top'>" +
          "<td class='py-2 pr-3 font-semibold text-slate-800'>" + esc(p.name) + "</td>" +
          "<td class='py-2 pr-3'><span class='inline-block rounded px-1.5 py-0.5 text-[10px] font-semibold " + (TYPE_BADGE[p.type] || TYPE_BADGE.text) + "'>" + p.type + "</span></td>" +
          "<td class='py-2 pr-3 " + (p.missingPct > 20 ? "text-amber-700 font-semibold" : "text-slate-600") + "'>" + Math.round(p.missingPct) + "%</td>" +
          "<td class='py-2 pr-3 text-slate-600'>" + p.distinct + "</td>" +
          "<td class='py-2 pr-3 text-slate-600'>" + esc(p.range) + "</td>" +
          "<td class='py-2 pr-3'>" + badges + "</td>" +
        "</tr>";
      }).join("");
      try { renderMap(); } catch (e) {}
    }

    async function ingest(file) {
      setMsg("Parsing " + file.name + "…");
      try {
        const { rows, columns } = await parseFile(file);
        if (!rows.length || !columns.length) { setMsg("Couldn't read any rows/columns. Check the file has a header and data.", true); return; }
        DATA = { rows, columns, profile: columns.map((c) => profileColumn(c, rows)), name: file.name.replace(/\.[^.]+$/, "") || "dataset" };
        $("fileinfo").textContent = file.name + " · " + rows.length + " rows × " + columns.length + " cols";
        setMsg("");
        render();
      } catch (e) { setMsg("Error reading file: " + (e && e.message ? e.message : e), true); }
    }

    fileInput.addEventListener("change", (e) => { const f = e.target.files && e.target.files[0]; if (f) ingest(f); });
    drop.addEventListener("dragover", (e) => { e.preventDefault(); drop.classList.add("border-brand-400", "bg-brand-50/40"); });
    drop.addEventListener("dragleave", () => drop.classList.remove("border-brand-400", "bg-brand-50/40"));
    drop.addEventListener("drop", (e) => { e.preventDefault(); drop.classList.remove("border-brand-400", "bg-brand-50/40"); const f = e.dataTransfer.files && e.dataTransfer.files[0]; if (f) ingest(f); });

    // Tiny synthetic demo (deliberately a bit messy) so the profiler has something to chew on.
    $("demo").addEventListener("click", () => {
      const sexes = ["M", "F", "m", "female ", "F"];
      const rows = [];
      for (let i = 1; i <= 60; i++) {
        rows.push({
          patient_id: 10000 + i,
          index_date: "2019-0" + (1 + (i % 9)) + "-15",
          age: i % 13 === 0 ? null : 40 + (i % 45),
          sex: sexes[i % sexes.length],
          exposure: i % 2,
          outcome: i % 5 === 0 ? 1 : 0,
          event_date: i % 5 === 0 ? "2020-03-1" + (i % 9) : null,
          cci: (i % 7) - 1,
          followup_days: 90 + (i * 37) % 900,
          disc_days: i % 3 === 0 ? Math.round((90 + (i * 37) % 900) * 0.55) : null,
        });
      }
      DATA = { rows, columns: ["patient_id", "index_date", "age", "sex", "exposure", "outcome", "event_date", "cci", "followup_days", "disc_days"], name: "demo-dataset" };
      DATA.profile = DATA.columns.map((c) => profileColumn(c, rows));
      $("fileinfo").textContent = "demo-dataset · 60 rows × 8 cols";
      setMsg("Loaded the synthetic demo dataset.");
      render();
    });

    // ── Exports ──
    const dl = (blob, nm) => { const u = URL.createObjectURL(blob); const a = document.createElement("a"); a.href = u; a.download = nm; document.body.appendChild(a); a.click(); a.remove(); setTimeout(() => URL.revokeObjectURL(u), 1000); };
    const csvCell = (v) => { const s = v == null ? "" : (v instanceof Date ? v.toISOString().slice(0, 10) : String(v)); return /[",\n]/.test(s) ? '"' + s.replace(/"/g, '""') + '"' : s; };
    const toCSV = (cols, rows) => [cols.map(csvCell).join(","), ...rows.map((r) => cols.map((c) => csvCell(r[c])).join(","))].join("\n");

    $("dlmaster").addEventListener("click", () => {
      if (!DATA.rows.length) return;
      dl(new Blob(["﻿" + toCSV(DATA.columns, DATA.rows)], { type: "text/csv;charset=utf-8" }), DATA.name + "-master.csv");
    });
    $("dldict").addEventListener("click", () => {
      if (!DATA.profile.length) return;
      const cols = ["column", "inferred_type", "missing_pct", "distinct", "range_or_top", "flags"];
      const rows = DATA.profile.map((p) => ({ column: p.name, inferred_type: p.type, missing_pct: Math.round(p.missingPct), distinct: p.distinct, range_or_top: p.range, flags: p.flags.map((f) => f.msg).join("; ") }));
      dl(new Blob(["﻿" + toCSV(cols, rows)], { type: "text/csv;charset=utf-8" }), DATA.name + "-dictionary.csv");
    });

    // ── Step 1: clinical question + design (persisted) ──
    const Q_KEY = "daniel.rwe-studio";
    const qNames = ["q_pop", "q_exp", "q_comp", "q_out"];
    const saveQ = () => {
      const s = {};
      qNames.forEach((n) => { const e = document.querySelector('[name="' + n + '"]'); if (e) s[n] = e.value; });
      const d = document.querySelector('[name="design"]:checked'); s.design = d ? d.value : "";
      try { localStorage.setItem(Q_KEY, JSON.stringify(s)); } catch (e) {}
    };
    (() => {
      try {
        const s = JSON.parse(localStorage.getItem(Q_KEY) || "null"); if (!s) return;
        qNames.forEach((n) => { const e = document.querySelector('[name="' + n + '"]'); if (e && s[n] != null) e.value = s[n]; });
        if (s.design) { const r = document.querySelector('[name="design"][value="' + s.design + '"]'); if (r) r.checked = true; }
      } catch (e) {}
    })();
    document.querySelectorAll('[name="q_pop"],[name="q_exp"],[name="q_comp"],[name="q_out"],[name="design"]').forEach((e) => e.addEventListener("input", saveQ));

    const DESIGN_LABEL = { descriptive: "Descriptive analysis", acnu: "Active-comparator new-user cohort", sccs: "Self-controlled case series", cco: "Case-crossover" };
    $("suggest").addEventListener("click", () => {
      const ck = (n) => { const e = document.querySelector('[name="' + n + '"]'); return !!(e && e.checked); };
      let v, why;
      if (ck("s_describe")) { v = "descriptive"; why = "your goal is to describe / quantify rather than test a causal effect."; }
      else if (ck("s_twodrugs")) { v = "acnu"; why = "you're comparing two active treatments — an active-comparator new-user cohort minimises confounding by indication."; }
      else if (ck("s_transient") && ck("s_acute")) { v = "sccs"; why = "a transient exposure with an acute outcome suits a self-controlled design (each case is its own control); a case-crossover is a good alternative."; }
      else if (ck("s_acute")) { v = "cco"; why = "for an acute, abrupt-onset event, a case-crossover contrasts exposure just before the event with earlier control windows."; }
      else { v = "acnu"; why = "defaulting to an active-comparator new-user cohort — tick more boxes for a sharper suggestion."; }
      const r = document.querySelector('[name="design"][value="' + v + '"]'); if (r) { r.checked = true; saveQ(); }
      $("suggestmsg").textContent = "Recommended: " + DESIGN_LABEL[v] + " — " + why;
    });

    // ── Steps 3–6: map → clean → analyse (R) → export ──
    const SPEC = {
      descriptive: {
        label: "Descriptive analysis",
        hint: "One row per person. Map the outcome event and the person-time each person contributes; group/age/sex are optional.",
        covariates: false,
        roles: [
          { k: "EVENT", label: "Outcome event (0/1)", types: ["binary", "number"], req: true },
          { k: "PT", label: "Person-time (days or years)", types: ["number"], req: true },
          { k: "GROUP", label: "Group / stratum", types: ["categorical", "binary", "text", "id"], req: false },
          { k: "AGE", label: "Age", types: ["number"], req: false },
          { k: "SEX", label: "Sex", types: ["categorical", "binary", "text"], req: false },
        ],
        rscript: () =>
          "d<-read.csv('/data.csv')\n" +
          "ev<-sum(d$EVENT==1,na.rm=TRUE); pt<-sum(as.numeric(d$PT),na.rm=TRUE); r<-ev/pt*1000\n" +
          "ci<-tryCatch(poisson.test(ev,pt)$conf.int*1000, error=function(e) c(NA,NA))\n" +
          "cat(sprintf('Overall incidence rate: %.3f per 1000 person-time (95%% CI %.3f to %.3f)\\n', r, ci[1], ci[2]))\n" +
          "cat(sprintf('Events: %d; person-time: %.1f; rows: %d\\n\\n', ev, pt, nrow(d)))\n" +
          "if ('GROUP' %in% names(d)) { cat('By group:\\n'); for (g in sort(unique(d$GROUP))) { s<-d[d$GROUP==g,]; e<-sum(s$EVENT==1,na.rm=TRUE); p<-sum(as.numeric(s$PT),na.rm=TRUE); cat(sprintf('  %s: %.3f/1000 (%d events / %.1f pt)\\n', g, e/p*1000, e, p)) }; cat('\\n') }\n" +
          "cat('Table 1:\\n'); cat(sprintf('  N = %d\\n', nrow(d)))\n" +
          "if ('AGE' %in% names(d)) cat(sprintf('  Age: mean %.1f (SD %.1f)\\n', mean(as.numeric(d$AGE),na.rm=TRUE), sd(as.numeric(d$AGE),na.rm=TRUE)))\n" +
          "if ('SEX' %in% names(d)) { t<-table(d$SEX); cat('  Sex: ', paste(names(t), as.integer(t), sep='=', collapse=', '), '\\n', sep='') }\n" +
          "cat(sprintf('RESULT_ESTIMATE|Incidence rate|%.2f per 1000 (95%% CI %.2f-%.2f)\\n', r, ci[1], ci[2]))",
      },
      acnu: {
        label: "Active-comparator new-user cohort",
        hint: "One row per new user. Map treatment (1=exposure, 0=comparator), follow-up time, and the outcome event; tick baseline covariates for the propensity score.",
        covariates: true,
        roles: [
          { k: "TREAT", label: "Treatment (1=exposure, 0=comparator)", types: ["binary", "number"], req: true },
          { k: "TIME", label: "Follow-up time (days)", types: ["number"], req: true },
          { k: "EVENT", label: "Outcome event (0/1)", types: ["binary", "number"], req: true },
          { k: "DISC", label: "Time to discontinuation / switch (days, for PP)", types: ["number"], req: false },
        ],
        rscript: (cov, opts) => {
          opts = opts || {};
          const covs = cov.map((c) => "'" + c + "'").join(",");
          const M = opts.methods || [], E = (opts.estimands && opts.estimands.length) ? opts.estimands : ["ITT"], ratio = opts.ratio || 2, ns = opts.nstrata || 10;
          let r = "d<-read.csv('/data.csv'); library(survival)\n";
          r += "covs<-c(" + covs + ")\n";
          r += "ps<-predict(glm(as.formula(paste('TREAT ~', paste(covs, collapse=' + '))), data=d, family=binomial), type='response')\n";
          r += "ps<-pmin(pmax(ps,1e-6),1-1e-6); d$lp<-qlogis(ps); tr<-d$TREAT==1; n<-nrow(d)\n";
          r += "cat(sprintf('N = %d; exposure = %d; comparator = %d; events = %d\\n\\n', n, sum(tr), sum(!tr), sum(d$EVENT==1,na.rm=TRUE)))\n";
          r += "wsmd<-function(x,g,w){ m1<-weighted.mean(x[g],w[g]); m0<-weighted.mean(x[!g],w[!g]); v1<-sum(w[g]*(x[g]-m1)^2)/sum(w[g]); v0<-sum(w[!g]*(x[!g]-m0)^2)/sum(w[!g]); (m1-m0)/sqrt((v1+v0)/2) }\n";
          r += "cat('TABLE1|Characteristic|Comparator (n=',sum(!tr),')|Exposure (n=',sum(tr),')|SMD\\n',sep='')\n";
          r += "for(c in covs){ x<-as.numeric(d[[c]]); cat(sprintf('TABLE1|%s, mean (SD)|%.2f (%.2f)|%.2f (%.2f)|%.3f\\n', c, mean(x[!tr]), sd(x[!tr]), mean(x[tr]), sd(x[tr]), wsmd(x,tr,rep(1,n)))) }\ncat('\\n')\n";
          r += "ET<-list(); EE<-list(); ET[['ITT']]<-d$TIME; EE[['ITT']]<-d$EVENT\n";
          if (E.indexOf("PP") >= 0) r += "if('DISC' %in% names(d)){ disc<-ifelse(is.na(d$DISC), Inf, as.numeric(d$DISC)); ET[['PP']]<-pmin(d$TIME, disc); EE[['PP']]<-d$EVENT*(d$TIME<=disc) }\n";
          r += "fitw<-function(t,e,w,idx,label){ dd<-data.frame(t=t[idx],e=e[idx],TREAT=d$TREAT[idx],w=w[idx]); fit<-tryCatch(coxph(Surv(t,e)~TREAT,data=dd,weights=w,robust=TRUE),error=function(x)NULL); if(is.null(fit)){cat(sprintf('RESULT_ESTIMATE|%s|not estimable\\n',label));return(invisible())}; s<-summary(fit); cat(sprintf('RESULT_ESTIMATE|%s|%.2f (95%% CI %.2f-%.2f)\\n', label, s$conf.int[1,'exp(coef)'], s$conf.int[1,'lower .95'], s$conf.int[1,'upper .95'])) }\n";
          if (M.indexOf("matching") >= 0) r += "matchidx<-function(){ ci<-which(!tr); ti<-which(tr); used<-logical(n); cal<-0.2*sd(d$lp); out<-integer(0); ord<-ti[order(d$lp[ti])]; for(i in ord){ cand<-ci[!used[ci]]; if(!length(cand))next; dd<-abs(d$lp[cand]-d$lp[i]); o<-order(dd); k<-0; for(j in o){ if(dd[j]<=cal){ out<-c(out,i,cand[j]); used[cand[j]]<-TRUE; k<-k+1; if(k>=" + ratio + ")break } } }; unique(out) }\n";
          r += "for(est in names(ET)){ t<-ET[[est]]; e<-EE[[est]]; all<-1:n\n";
          r += "  fitw(t,e,rep(1,n),all, paste0('Crude - ',est,' HR'))\n";
          if (M.indexOf("iptw") >= 0) r += "  fitw(t,e,ifelse(tr,1/ps,1/(1-ps)),all, paste0('IPTW (ATE) - ',est,' HR'))\n";
          if (M.indexOf("smrw") >= 0) r += "  fitw(t,e,ifelse(tr,1,ps/(1-ps)),all, paste0('SMR weighting (ATT) - ',est,' HR'))\n";
          if (M.indexOf("overlap") >= 0) r += "  fitw(t,e,ifelse(tr,1-ps,ps),all, paste0('Overlap weighting - ',est,' HR'))\n";
          if (M.indexOf("finestrat") >= 0) r += "  { br<-unique(quantile(ps,probs=seq(0,1,length.out=" + (ns + 1) + "))); if(length(br)>=3){ q<-cut(ps,breaks=br,include.lowest=TRUE,labels=FALSE); keep<-ave(as.integer(tr),q,FUN=function(z)length(unique(z)))==2; ok<-which(keep); dd<-data.frame(t=t[ok],e=e[ok],TREAT=d$TREAT[ok],st=q[ok]); fit<-tryCatch(coxph(Surv(t,e)~TREAT+strata(st),data=dd),error=function(x)NULL); if(!is.null(fit)){s<-summary(fit); cat(sprintf('RESULT_ESTIMATE|Fine stratification (" + ns + " strata) - %s HR|%.2f (95%% CI %.2f-%.2f)\\n',est,s$conf.int[1,'exp(coef)'],s$conf.int[1,'lower .95'],s$conf.int[1,'upper .95']))} } }\n";
          if (M.indexOf("matching") >= 0) r += "  { mi<-matchidx(); if(length(mi)>2){ dd<-data.frame(t=t[mi],e=e[mi],TREAT=d$TREAT[mi]); fit<-tryCatch(coxph(Surv(t,e)~TREAT,data=dd),error=function(x)NULL); if(!is.null(fit)){s<-summary(fit); cat(sprintf('RESULT_ESTIMATE|" + ratio + ":1 PS matching (%d matched) - %s HR|%.2f (95%% CI %.2f-%.2f)\\n',length(mi),est,s$conf.int[1,'exp(coef)'],s$conf.int[1,'lower .95'],s$conf.int[1,'upper .95']))} } }\n";
          r += "}\n";
          return r;
        },
      },
      sccs: {
        label: "Self-controlled case series",
        hint: "Long format — one row per person-interval. Map the case ID, an exposed indicator (0/1), the event count in the interval, and the interval length (person-time).",
        covariates: false,
        roles: [
          { k: "ID", label: "Case ID", types: ["id", "number", "text"], req: true },
          { k: "EXPOSED", label: "Exposed indicator (0/1)", types: ["binary", "number"], req: true },
          { k: "EVENTS", label: "Event count in interval", types: ["number"], req: true },
          { k: "INTERVAL", label: "Interval length (person-time)", types: ["number"], req: true },
        ],
        rscript: () =>
          "d<-read.csv('/data.csv')\n" +
          "fit<-glm(EVENTS ~ EXPOSED + factor(ID), family=poisson, offset=log(INTERVAL), data=d)\n" +
          "b<-coef(fit)['EXPOSED']; se<-sqrt(diag(vcov(fit)))['EXPOSED']; irr<-exp(b)\n" +
          "cat(sprintf('Conditional Poisson incidence-rate ratio (exposed vs unexposed): %.3f (95%% CI %.3f to %.3f)\\n', irr, exp(b-1.96*se), exp(b+1.96*se)))\n" +
          "cat(sprintf('Cases (strata): %d; interval-rows: %d; events: %d\\n', length(unique(d$ID)), nrow(d), sum(d$EVENTS)))\n" +
          "cat(sprintf('RESULT_ESTIMATE|Incidence-rate ratio|%.2f (95%% CI %.2f-%.2f)\\n', irr, exp(b-1.96*se), exp(b+1.96*se)))",
      },
      cco: {
        label: "Case-crossover",
        hint: "Long format — one row per window. Map the case ID (stratum), a case indicator (1=hazard window, 0=control window), and an exposed indicator (0/1).",
        covariates: false,
        roles: [
          { k: "ID", label: "Case ID (stratum)", types: ["id", "number", "text"], req: true },
          { k: "CASE", label: "Case indicator (1=hazard, 0=control)", types: ["binary", "number"], req: true },
          { k: "EXPOSED", label: "Exposed (0/1)", types: ["binary", "number"], req: true },
        ],
        rscript: () =>
          "d<-read.csv('/data.csv'); library(survival)\n" +
          "fit<-clogit(CASE ~ EXPOSED + strata(ID), data=d); s<-summary(fit)\n" +
          "or<-s$conf.int['EXPOSED','exp(coef)']; lci<-s$conf.int['EXPOSED','lower .95']; uci<-s$conf.int['EXPOSED','upper .95']\n" +
          "cat(sprintf('Conditional logistic odds ratio (case vs control windows): %.3f (95%% CI %.3f to %.3f)\\n', or, lci, uci))\n" +
          "cat(sprintf('Strata (cases): %d; rows: %d\\n', length(unique(d$ID)), nrow(d)))\n" +
          "cat(sprintf('RESULT_ESTIMATE|Odds ratio|%.2f (95%% CI %.2f-%.2f)\\n', or, lci, uci))",
      },
    };

    const KW = { EVENT: /event|outcome|death|died|dead|case|status/i, PT: /person|_pt$|persontime|py|followup|fu_|duration|time|days/i, GROUP: /group|arm|stratum|site|cohort/i, AGE: /age/i, SEX: /sex|gender/i, TREAT: /treat|exposure|exposed|arm|drug|group/i, TIME: /time|fu|follow|days|duration|survtime/i, ID: /(^|_)id$|patient|subject|caseid|pid/i, EXPOSED: /expos|treat|drug/i, EVENTS: /event|count|nevent/i, INTERVAL: /interval|persontime|offset|length|days|time/i, CASE: /case|hazard|window|status/i, DISC: /disc|discont|switch|stop|cessation|deviat/i };
    const getDesign = () => { const r = document.querySelector('[name="design"]:checked'); return r ? r.value : ""; };
    let MAP = {}, COVS = [], MASTER = null, LAST = null;

    function suggestCol(role) {
      const kw = KW[role.k];
      let best = "", score = 0;
      for (const p of DATA.profile) { let sc = 0; if (kw && kw.test(p.name)) sc += 3; if (role.types.includes(p.type)) sc += 1; if (sc > score) { score = sc; best = p.name; } }
      return score >= 3 ? best : "";
    }
    function renderMap() {
      const spec = SPEC[getDesign()];
      if (!spec || !DATA.columns.length) { $("mapcard").classList.add("hidden"); return; }
      $("mapcard").classList.remove("hidden");
      $("designname").textContent = spec.label;
      $("maphint").textContent = spec.hint;
      const opts = (sel) => '<option value="">— choose —</option>' + DATA.columns.map((c) => '<option value="' + esc(c) + '"' + (sel === c ? " selected" : "") + ">" + esc(c) + "</option>").join("");
      $("maproles").innerHTML = spec.roles.map((r) => {
        if (!(r.k in MAP)) MAP[r.k] = suggestCol(r);
        return '<label class="block text-xs"><span class="uppercase tracking-widest text-brand-700 font-semibold">' + esc(r.label) + (r.req ? " *" : " (optional)") + '</span><select data-role="' + r.k + '" class="mt-1 w-full rounded-lg border border-slate-300 p-2 text-sm">' + opts(MAP[r.k]) + "</select></label>";
      }).join("");
      $("maproles").querySelectorAll("select[data-role]").forEach((sel) => sel.addEventListener("change", () => { MAP[sel.getAttribute("data-role")] = sel.value; renderCovs(spec); validateMap(); }));
      renderCovs(spec);
      validateMap();
    }
    function renderCovs(spec) {
      if (!spec.covariates) { $("covwrap").classList.add("hidden"); return; }
      $("covwrap").classList.remove("hidden");
      const used = new Set(spec.roles.map((r) => MAP[r.k]).filter(Boolean));
      $("covlist").innerHTML = DATA.columns.filter((c) => !used.has(c)).map((c) => '<label class="flex items-center gap-1.5"><input type="checkbox" data-cov="' + esc(c) + '"' + (COVS.includes(c) ? " checked" : "") + "/> " + esc(c) + "</label>").join("");
      $("covlist").querySelectorAll("input[data-cov]").forEach((cb) => cb.addEventListener("change", () => { const c = cb.getAttribute("data-cov"); if (cb.checked) { if (!COVS.includes(c)) COVS.push(c); } else COVS = COVS.filter((x) => x !== c); validateMap(); }));
      $("acnuopts").classList.toggle("hidden", getDesign() !== "acnu");
    }
    const availCovCols = () => { const spec = SPEC[getDesign()]; const used = new Set(spec.roles.map((r) => MAP[r.k]).filter(Boolean)); return DATA.columns.filter((c) => !used.has(c)); };
    const COV_KW = /age|sex|gender|comorbid|cci|charlson|elix|diab|hyperten|renal|ckd|egfr|copd|asthma|cancer|malig|smok|alcohol|bmi|weight|obes|hba1c|ldl|hdl|chol|creatinin|statin|insulin|metformin|nsaid|ppi|anticoag|antiplatel|steroid|comed|med_|drug|dx_|hx_|prior|baseline|income|ses|deprivation|urban|region|frailty|score/i;
    const COV_EXCL = /(^|_)id$|date|event|outcome|death|died|treat|expos|arm|time|fu_|followup|persontime|disc|switch/i;
    $("cov_auto").addEventListener("click", () => { COVS = availCovCols().filter((c) => COV_KW.test(c) && !COV_EXCL.test(c)); renderCovs(SPEC[getDesign()]); validateMap(); });
    $("cov_all").addEventListener("click", () => { COVS = availCovCols().slice(); renderCovs(SPEC[getDesign()]); validateMap(); });
    $("cov_none").addEventListener("click", () => { COVS = []; renderCovs(SPEC[getDesign()]); validateMap(); });
    function validateMap() {
      const spec = SPEC[getDesign()]; if (!spec) return false;
      const missing = spec.roles.filter((r) => r.req && !MAP[r.k]).map((r) => r.label);
      const needCov = spec.covariates && COVS.length === 0;
      const ok = missing.length === 0 && !needCov;
      const m = $("mapmsg");
      if (missing.length) { m.textContent = "Map the required roles (*): " + missing.join(", "); m.className = "mt-3 text-xs text-amber-700"; }
      else if (needCov) { m.textContent = "Tick at least one baseline covariate for the propensity score."; m.className = "mt-3 text-xs text-amber-700"; }
      else { m.textContent = "Mapping complete ✓ — build the master file below."; m.className = "mt-3 text-xs text-emerald-700"; }
      $("cleancard").classList.toggle("hidden", !ok);
      return ok;
    }

    const NUM_ROLES = ["PT", "TIME", "AGE", "INTERVAL", "EVENTS", "DISC"];
    const BIN_ROLES = ["EVENT", "TREAT", "EXPOSED", "CASE"];
    const stdSex = (v) => { const l = String(v == null ? "" : v).trim().toLowerCase(); return l === "male" || l === "m" ? "M" : (l === "female" || l === "f" ? "F" : v); };
    const toBin = (v) => { if (v == null || v === "") return null; const l = String(v).trim().toLowerCase(); if (["1", "yes", "y", "true", "t", "case", "event", "exposed", "positive"].includes(l)) return 1; if (["0", "no", "n", "false", "f", "control", "none", "unexposed", "negative"].includes(l)) return 0; const n = Number(l); return isNaN(n) ? null : (n > 0 ? 1 : 0); };

    function buildMaster() {
      const spec = SPEC[getDesign()]; if (!spec || !validateMap()) return;
      const roleCol = {}; spec.roles.forEach((r) => { if (MAP[r.k]) roleCol[r.k] = MAP[r.k]; });
      let rows = DATA.rows.map((r) => Object.assign({}, r));
      if ($("c_trim").checked) rows.forEach((r) => DATA.columns.forEach((c) => { if (typeof r[c] === "string") r[c] = r[c].trim(); }));
      if ($("c_std").checked) rows.forEach((r) => {
        if (roleCol.SEX) r[roleCol.SEX] = stdSex(r[roleCol.SEX]);
        BIN_ROLES.forEach((rk) => { if (roleCol[rk]) { const b = toBin(r[roleCol[rk]]); if (b != null) r[roleCol[rk]] = b; } });
      });
      const numCols = NUM_ROLES.map((k) => roleCol[k]).filter(Boolean).concat(spec.covariates ? COVS : []);
      rows.forEach((r) => numCols.forEach((c) => { const n = Number(String(r[c] == null ? "" : r[c]).replace(/,/g, "")); if (!isNaN(n) && String(r[c]).trim() !== "") r[c] = n; }));
      const before = rows.length;
      if ($("c_dedupe").checked) { const seen = new Set(); rows = rows.filter((r) => { const k = DATA.columns.map((c) => String(r[c] == null ? "" : r[c])).join("|"); if (seen.has(k)) return false; seen.add(k); return true; }); }
      if ($("c_dropmiss").checked) { const req = spec.roles.filter((r) => r.req).map((r) => roleCol[r.k]).filter(Boolean).concat(spec.covariates ? COVS : []); rows = rows.filter((r) => req.every((c) => r[c] != null && String(r[c]).trim() !== "")); }
      MASTER = rows;
      $("cleaninfo").textContent = "Master file: " + rows.length + " rows (from " + before + "; " + (before - rows.length) + " removed).";
      $("anacard").classList.remove("hidden"); $("expcard").classList.remove("hidden");
    }

    function analysisCSV() {
      const spec = SPEC[getDesign()]; const outCols = [], colFor = {}, covNames = [];
      spec.roles.forEach((r) => { if (MAP[r.k]) { outCols.push(r.k); colFor[r.k] = MAP[r.k]; } });
      if (spec.covariates) COVS.forEach((src, i) => { const cn = "COV" + (i + 1); outCols.push(cn); colFor[cn] = src; covNames.push(cn); });
      const rows = (MASTER || []).map((r) => { const o = {}; outCols.forEach((cn) => { o[cn] = r[colFor[cn]]; }); return o; });
      return { csv: toCSV(outCols, rows), covNames };
    }
    function acnuOpts() {
      const methods = [];
      if ($("m_match").checked) methods.push("matching");
      if ($("m_iptw").checked) methods.push("iptw");
      if ($("m_smrw").checked) methods.push("smrw");
      if ($("m_overlap").checked) methods.push("overlap");
      if ($("m_fine").checked) methods.push("finestrat");
      const estimands = [];
      if ($("est_itt").checked) estimands.push("ITT");
      if ($("est_pp").checked) estimands.push("PP");
      return { methods: methods, estimands: estimands.length ? estimands : ["ITT"], ratio: parseInt($("m_ratio").value) || 2, nstrata: parseInt($("m_nstrata").value) || 10 };
    }
    function buildScript() { const spec = SPEC[getDesign()]; const { covNames } = analysisCSV(); return getDesign() === "acnu" ? spec.rscript(covNames, acnuOpts()) : spec.rscript(covNames); }

    $("applyclean").addEventListener("click", buildMaster);
    document.querySelectorAll('[name="design"]').forEach((r) => r.addEventListener("change", () => { MAP = {}; COVS = []; MASTER = null; $("anacard").classList.add("hidden"); $("expcard").classList.add("hidden"); renderMap(); }));

    $("runanalysis").addEventListener("click", async () => {
      if (!MASTER) buildMaster();
      if (!MASTER) return;
      const { csv } = analysisCSV(); const script = buildScript();
      const setS = (m) => { $("anastatus").textContent = m; };
      $("runanalysis").disabled = true; $("anaresults").classList.add("hidden"); $("table1").classList.add("hidden");
      try {
        const out = await window.RWEngine.run(script, csv, setS);
        setS("Done ✓");
        const ests = [], t1 = [];
        out.split("\n").forEach((l) => {
          if (l.indexOf("RESULT_ESTIMATE|") === 0) { const p = l.split("|"); ests.push({ label: p[1], value: p.slice(2).join("|") }); }
          else if (l.indexOf("TABLE1|") === 0) { t1.push(l.split("|").slice(1)); }
        });
        const display = out.replace(/^RESULT_ESTIMATE\|.*$/gm, "").replace(/^TABLE1\|.*$/gm, "").replace(/\n{3,}/g, "\n\n").trim();
        if (ests.length) {
          $("anaresults").classList.remove("hidden");
          $("anaresults").innerHTML = '<div class="text-xs uppercase tracking-widest text-brand-700 font-semibold mb-2">Effect estimates</div><div class="overflow-x-auto"><table class="w-full text-sm border-collapse"><thead><tr class="text-left text-slate-500 border-b border-slate-200"><th class="py-1.5 pr-4 font-semibold">Method / estimand</th><th class="py-1.5 font-semibold">Estimate (95% CI)</th></tr></thead><tbody>' + ests.map((e) => '<tr class="border-b border-slate-100"><td class="py-1.5 pr-4 text-slate-700">' + esc(e.label) + '</td><td class="py-1.5 font-bold text-slate-900">' + esc(e.value) + "</td></tr>").join("") + "</tbody></table></div>";
        }
        if (t1.length) {
          $("table1").classList.remove("hidden");
          const head = t1[0], body = t1.slice(1);
          $("table1").innerHTML = '<div class="text-xs uppercase tracking-widest text-brand-700 font-semibold mb-2">Patient characteristics (Table 1)</div><table class="w-full text-xs border-collapse"><thead><tr class="text-left text-slate-500 border-b border-slate-200">' + head.map((h) => '<th class="py-1.5 pr-4 font-semibold">' + esc(h) + "</th>").join("") + "</tr></thead><tbody>" + body.map((rr) => '<tr class="border-b border-slate-100">' + rr.map((c, i) => '<td class="py-1.5 pr-4 ' + (i === 0 ? "text-slate-700" : "text-slate-600") + '">' + esc(c) + "</td>").join("") + "</tr>").join("") + "</tbody></table>";
        }
        $("routput").classList.remove("hidden"); $("routput").textContent = display || "(no output)";
        LAST = { out: display, script: script, ests: ests, t1: t1 };
      } catch (e) { setS("Error"); $("routput").classList.remove("hidden"); $("routput").textContent = "Error: " + (e && e.message ? e.message : e); }
      finally { $("runanalysis").disabled = false; }
    });

    const readQ = () => { const g = (n) => { const e = document.querySelector('[name="' + n + '"]'); return e ? e.value : ""; }; return { pop: g("q_pop"), exp: g("q_exp"), comp: g("q_comp"), out: g("q_out"), design: getDesign() }; };
    function buildReport(q) {
      const today = new Date().toISOString().slice(0, 10);
      const label = (SPEC[q.design] || {}).label || q.design || "(design)";
      const ests = (LAST && LAST.ests) || [], t1 = (LAST && LAST.t1) || [];
      const resTbl = ests.length ? ("| Method / estimand | Estimate (95% CI) |\n|---|---|\n" + ests.map((e) => "| " + e.label + " | " + e.value + " |").join("\n")) : "(run the analysis first)";
      const t1Tbl = t1.length ? (t1.map((r, i) => "| " + r.join(" | ") + " |" + (i === 0 ? "\n|" + r.map(() => "---").join("|") + "|" : "")).join("\n")) : "";
      return "# RWE Studio analysis report\n\n_Generated " + today + " · analysis run locally in the browser via WebR (real R)_\n\n" +
        "## Question\n- Population: " + (q.pop || "(specify)") + "\n- Exposure: " + (q.exp || "(specify)") + "\n- Comparator: " + (q.comp || "—") + "\n- Outcome: " + (q.out || "(specify)") + "\n- Design: " + label + "\n\n" +
        "## Effect estimates\n\n" + resTbl + "\n\n" +
        (t1.length ? "## Patient characteristics (Table 1)\n\n" + t1Tbl + "\n\n" : "") +
        "## R output\n\n```\n" + (LAST ? LAST.out : "(run the analysis first)") + "\n```\n\n" +
        "## Reproducible R script\n\n```r\n" + (LAST ? LAST.script : buildScript()) + "\n```\n";
    }
    async function buildReportDocx(q) {
      const D = window.docx; if (!D) return null;
      const today = new Date().toISOString().slice(0, 10);
      const label = (SPEC[q.design] || {}).label || q.design || "(design)";
      const FONT = "Times New Roman";
      const text = (t, o = {}) => new D.TextRun({ text: String(t == null ? "" : t), font: FONT, size: 22, ...o });
      const p = (ch, o = {}) => new D.Paragraph({ children: Array.isArray(ch) ? ch : [ch], spacing: { before: 60, after: 60, ...(o.spacing || {}) }, ...o });
      const h1 = (t) => new D.Paragraph({ children: [text(t, { bold: true, size: 28 })], spacing: { before: 200, after: 80 }, heading: D.HeadingLevel.HEADING_1 });
      const mono = (l) => new D.Paragraph({ children: [new D.TextRun({ text: l, font: "Consolas", size: 16 })], spacing: { before: 0, after: 0 } });
      const brd = { style: D.BorderStyle.SINGLE, size: 4, color: "BBBBBB" }; const cbr = { top: brd, bottom: brd, left: brd, right: brd };
      const tbl = (rows, hdr) => new D.Table({ width: { size: 9026, type: D.WidthType.DXA }, rows: rows.map((cells, ri) => new D.TableRow({ children: cells.map((c) => new D.TableCell({ borders: cbr, margins: { top: 60, bottom: 60, left: 100, right: 100 }, shading: (hdr && ri === 0) ? { fill: "F5F5F5", type: D.ShadingType.CLEAR } : undefined, children: [p([text(c, { bold: hdr && ri === 0 })])] })) })) });
      let logo = null; try { const rr = await fetch("/images/networks/phdc.png"); if (rr.ok) logo = new Uint8Array(await rr.arrayBuffer()); } catch (e) {}
      const ch = [];
      if (logo) ch.push(new D.Paragraph({ spacing: { after: 120 }, children: [new D.ImageRun({ data: logo, transformation: { width: 210, height: 51 } })] }));
      ch.push(p([text("RWE Studio analysis report", { bold: true, size: 32 })], { spacing: { after: 40 } }));
      ch.push(p([text("Generated " + today + " · analysis run locally in the browser via WebR (real R).", { italics: true, color: "777777", size: 18 })], { spacing: { after: 160 } }));
      ch.push(h1("Question"));
      ch.push(tbl([["Population", q.pop || "(specify)"], ["Exposure", q.exp || "(specify)"], ["Comparator", q.comp || "—"], ["Outcome", q.out || "(specify)"], ["Design", label]], false));
      const ests = (LAST && LAST.ests) || [], t1 = (LAST && LAST.t1) || [];
      ch.push(h1("Effect estimates"));
      if (ests.length) ch.push(tbl([["Method / estimand", "Estimate (95% CI)"]].concat(ests.map((e) => [e.label, e.value])), true)); else ch.push(p([text("(run the analysis first)")]));
      if (t1.length) { ch.push(h1("Patient characteristics (Table 1)")); ch.push(tbl(t1, true)); }
      ch.push(h1("R output"));
      (LAST ? LAST.out : "(run the analysis first)").split("\n").forEach((l) => ch.push(mono(l)));
      ch.push(h1("Reproducible R script"));
      (LAST ? LAST.script : buildScript()).split("\n").forEach((l) => ch.push(mono(l)));
      const doc = new D.Document({ creator: "RWE Studio", title: "RWE Studio report", styles: { default: { document: { run: { font: FONT, size: 22 } } }, paragraphStyles: [{ id: "Heading1", name: "Heading 1", basedOn: "Normal", next: "Normal", quickFormat: true, run: { size: 28, bold: true, font: FONT }, paragraph: { spacing: { before: 200, after: 80 }, outlineLevel: 0 } }] }, sections: [{ properties: { page: { size: { width: 11906, height: 16838 }, margin: { top: 1440, right: 1440, bottom: 1440, left: 1440 } } }, children: ch }] });
      return await D.Packer.toBlob(doc);
    }
    $("dlmaster2").addEventListener("click", () => { if (!MASTER) buildMaster(); if (MASTER) dl(new Blob(["﻿" + toCSV(DATA.columns, MASTER)], { type: "text/csv;charset=utf-8" }), DATA.name + "-master.csv"); });
    $("dlscript").addEventListener("click", () => { const s = LAST ? LAST.script : buildScript(); dl(new Blob(["# Analysis script generated by RWE Studio — reads the master file as data.csv\n# Reproduces the on-screen result in desktop R.\n\n" + s + "\n"], { type: "text/plain;charset=utf-8" }), DATA.name + "-analysis.R"); });
    $("dlreport").addEventListener("click", () => { dl(new Blob([buildReport(readQ())], { type: "text/markdown;charset=utf-8" }), DATA.name + "-report.md"); });
    $("dlreportword").addEventListener("click", async () => { const b = await buildReportDocx(readQ()); if (b) dl(b, DATA.name + "-report.docx"); });
  </script>
</BaseLayout>
