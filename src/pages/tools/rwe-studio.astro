---
import BaseLayout from "../../layouts/BaseLayout.astro";
const base = import.meta.env.BASE_URL.replace(/\/$/, "");

// The four in-scope designs the analysis can run (Phase 5).
const DESIGNS = [
  { v: "descriptive", t: "Descriptive analysis", d: "Characterise a population — incidence, prevalence, drug utilisation, mortality." },
  { v: "acnu", t: "Active-comparator new-user cohort", d: "Compare two treatments' effect on an outcome as users start therapy." },
  { v: "sccs", t: "Self-controlled case series", d: "Transient exposure + acute outcome; each case is its own control." },
  { v: "cco", t: "Case-crossover", d: "Acute, abrupt-onset event; compare exposure in a hazard window vs control windows." },
];
---

<BaseLayout
  title="RWE Studio — Daniel Tsai"
  description="Upload a small, messy hospital dataset and, entirely in your browser, profile and clean it into a tidy master file, then run the analysis for a chosen study design in real R (via WebR). No data leaves your device."
>
  <header class="relative bg-gradient-to-br from-brand-50 via-white to-brand-100/40 border-b border-slate-200 overflow-hidden">
    <div class="relative mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-12">
      <p class="uppercase tracking-widest text-xs text-brand-600 font-semibold mb-2">RWE Tools · experimental</p>
      <h1 class="text-3xl md:text-4xl font-bold text-slate-900">RWE Studio</h1>
      <p class="mt-3 text-base text-slate-600 max-w-3xl">
        Feed in a small, messy hospital dataset → <strong>profile &amp; flag dirtiness</strong> → clean it into a tidy
        <strong>master file</strong> → pick a study design and map your columns → <strong>run the analysis in real R</strong>
        (via WebR, in your browser) → get the estimate, Table 1, and a reproducible R script.
      </p>
      <a class="mt-4 inline-block text-sm text-brand-700 hover:underline font-semibold" href={`${base}/tools`}>← All RWE tools</a>
    </div>
  </header>

  <section class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-8 space-y-6">
    <!-- Privacy -->
    <div class="flex items-start gap-2 rounded-xl border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm text-emerald-900">
      <span class="font-bold">🔒</span>
      <span>All processing happens <strong>in your browser</strong>. Your dataset is never uploaded or sent to any server — parsing, profiling, cleaning, and (soon) the R analysis all run locally on your device.</span>
    </div>

    <!-- Step tracker -->
    <ol class="flex flex-wrap gap-x-4 gap-y-1 text-xs font-semibold text-slate-400">
      <li class="text-brand-700">1 · Question &amp; design</li>
      <li>2 · Upload &amp; profile</li>
      <li>3 · Map columns</li>
      <li>4 · Clean → master file</li>
      <li>5 · Analyse (R)</li>
      <li>6 · Export</li>
    </ol>

    <!-- Step 1: clinical question & design -->
    <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
      <h2 class="text-lg font-bold text-slate-900">1 · Clinical question &amp; study design</h2>
      <p class="mt-1 text-sm text-slate-600">Decide this <strong>first</strong> — the design determines which columns you'll map and what cleaning actually matters.</p>
      <div class="mt-4 grid gap-3 sm:grid-cols-2">
        <label class="block"><span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Population</span>
          <input name="q_pop" class="mt-1 w-full rounded-lg border border-slate-300 p-2 text-sm" placeholder="e.g. Adults with type 2 diabetes" /></label>
        <label class="block"><span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Outcome</span>
          <input name="q_out" class="mt-1 w-full rounded-lg border border-slate-300 p-2 text-sm" placeholder="e.g. Hospitalisation for heart failure" /></label>
        <label class="block"><span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Exposure / intervention</span>
          <input name="q_exp" class="mt-1 w-full rounded-lg border border-slate-300 p-2 text-sm" placeholder="e.g. SGLT2 inhibitor" /></label>
        <label class="block"><span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Comparator (if any)</span>
          <input name="q_comp" class="mt-1 w-full rounded-lg border border-slate-300 p-2 text-sm" placeholder="e.g. DPP-4 inhibitor" /></label>
      </div>

      <div class="mt-4 rounded-xl border border-slate-200 bg-slate-50 p-3">
        <p class="text-xs font-semibold text-slate-700">Not sure which design? Tick what applies, then get a recommendation:</p>
        <div class="mt-2 grid gap-1 sm:grid-cols-2 text-xs text-slate-700">
          <label class="flex items-start gap-2"><input type="checkbox" name="s_describe" class="mt-0.5" /> <span>Goal is to describe / quantify (not test a causal effect)</span></label>
          <label class="flex items-start gap-2"><input type="checkbox" name="s_twodrugs" class="mt-0.5" /> <span>Comparing two active treatments from the same indication</span></label>
          <label class="flex items-start gap-2"><input type="checkbox" name="s_transient" class="mt-0.5" /> <span>Exposure is transient / intermittent (short course)</span></label>
          <label class="flex items-start gap-2"><input type="checkbox" name="s_acute" class="mt-0.5" /> <span>Outcome is acute / abrupt-onset</span></label>
        </div>
        <button id="suggest" type="button" class="mt-2 text-xs font-semibold text-brand-700 hover:underline">→ Recommend a design</button>
        <p id="suggestmsg" class="mt-1 text-xs text-brand-800"></p>
      </div>

      <div class="mt-4">
        <span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Study design</span>
        <div class="mt-1.5 grid gap-2 sm:grid-cols-2">
          {DESIGNS.map((d) => (
            <label class="flex items-start gap-2 rounded-xl border border-slate-200 p-3 cursor-pointer hover:border-brand-400 has-[:checked]:border-brand-500 has-[:checked]:bg-brand-50/60">
              <input type="radio" name="design" value={d.v} class="mt-0.5" />
              <span><span class="text-sm font-semibold text-slate-800">{d.t}</span><br /><span class="text-xs text-slate-600">{d.d}</span></span>
            </label>
          ))}
        </div>
      </div>
    </div>

    <!-- Upload -->
    <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
      <h2 class="text-lg font-bold text-slate-900">2 · Upload a dataset</h2>
      <p class="mt-1 text-sm text-slate-600">CSV or Excel (.xlsx). One row per record; a header row with column names. Small extracts work best.</p>
      <label id="drop" class="mt-4 flex flex-col items-center justify-center gap-2 rounded-xl border-2 border-dashed border-slate-300 bg-slate-50 px-6 py-10 text-center cursor-pointer hover:border-brand-400 hover:bg-brand-50/40 transition">
        <span class="text-3xl">📄</span>
        <span class="text-sm font-semibold text-slate-700">Drop a CSV / XLSX here, or click to choose</span>
        <span id="fileinfo" class="text-xs text-slate-500"></span>
        <input id="file" type="file" accept=".csv,.xlsx,.xls,.tsv" class="hidden" />
      </label>
      <p id="msg" class="mt-2 text-xs"></p>
      <div class="mt-3 text-xs text-slate-500">
        No data handy? <button id="demo" type="button" class="text-brand-700 font-semibold hover:underline">Load a tiny demo dataset</button> (synthetic, 60 rows).
      </div>
    </div>

    <!-- Summary + profile -->
    <div id="results" class="hidden space-y-6">
      <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
        <div class="flex flex-wrap items-center justify-between gap-3">
          <h2 class="text-lg font-bold text-slate-900">Data profile &amp; dictionary</h2>
          <div class="flex flex-wrap gap-2">
            <button id="dlmaster" type="button" class="bg-brand-700 text-white hover:bg-brand-800 font-semibold px-4 py-2 rounded-lg text-sm">⬇ Master file (CSV)</button>
            <button id="dldict" type="button" class="bg-white border border-brand-700 text-brand-700 hover:bg-brand-50 font-semibold px-4 py-2 rounded-lg text-sm">⬇ Data dictionary (CSV)</button>
          </div>
        </div>
        <p id="summary" class="mt-2 text-sm text-slate-600"></p>
        <div id="issues" class="mt-3 space-y-1.5"></div>
        <div class="mt-4 overflow-x-auto">
          <table class="w-full text-xs border-collapse">
            <thead>
              <tr class="text-left text-slate-500 border-b border-slate-200">
                <th class="py-2 pr-3 font-semibold">Column</th>
                <th class="py-2 pr-3 font-semibold">Inferred type</th>
                <th class="py-2 pr-3 font-semibold">Missing</th>
                <th class="py-2 pr-3 font-semibold">Distinct</th>
                <th class="py-2 pr-3 font-semibold">Range / top values</th>
                <th class="py-2 pr-3 font-semibold">Flags</th>
              </tr>
            </thead>
            <tbody id="proftable"></tbody>
          </table>
        </div>
      </div>

      <div class="rounded-2xl border border-brand-200 bg-brand-50/50 p-5 text-sm text-slate-700">
        <strong>Next steps (in progress):</strong> map your columns to the chosen design's roles, guided cleaning →
        tidy master file, then run the analysis in real R via WebR — with the estimate, Table 1, and a reproducible
        R script. The analysis engine is verified working in your browser.
      </div>
    </div>
  </section>

  <script is:inline>
    const $ = (id) => document.getElementById(id);
    const fileInput = $("file"), drop = $("drop");
    const setMsg = (t, bad) => { const el = $("msg"); el.textContent = t || ""; el.className = "mt-2 text-xs " + (bad ? "text-rose-600" : "text-slate-500"); };

    let DATA = { rows: [], columns: [], profile: [], name: "dataset" };

    const loadScript = (src) => new Promise((res, rej) => {
      if (document.querySelector('script[src="' + src + '"]')) return res();
      const s = document.createElement("script"); s.src = src; s.onload = () => res(); s.onerror = () => rej(new Error("load " + src)); document.head.appendChild(s);
    });

    async function parseFile(file) {
      await loadScript("https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js");
      const buf = await file.arrayBuffer();
      const wb = window.XLSX.read(buf, { type: "array", cellDates: true });
      const ws = wb.Sheets[wb.SheetNames[0]];
      const header = (window.XLSX.utils.sheet_to_json(ws, { header: 1, blankrows: false })[0] || []).map((h) => String(h).trim());
      const rows = window.XLSX.utils.sheet_to_json(ws, { defval: null, raw: true, blankrows: false });
      return { rows, columns: header.filter(Boolean) };
    }

    const isBlank = (v) => v === null || v === undefined || (typeof v === "string" && v.trim() === "");
    const isLikelyDate = (v) => v instanceof Date || (typeof v === "string" && /^\d{4}[-/](0?[1-9]|1[0-2])([-/](0?[1-9]|[12]\d|3[01]))?$/.test(v.trim()));
    const asStr = (v) => (v instanceof Date ? v.toISOString().slice(0, 10) : String(v));
    const topCats = (arr, k) => {
      const m = {}; arr.forEach((v) => { m[v] = (m[v] || 0) + 1; });
      return Object.entries(m).sort((a, b) => b[1] - a[1]).slice(0, k).map(([v, c]) => v + " (" + c + ")").join(", ");
    };

    function profileColumn(name, rows) {
      const vals = rows.map((r) => r[name]);
      const n = vals.length;
      const nonNull = vals.filter((v) => !isBlank(v));
      const missing = n - nonNull.length;
      const strs = nonNull.map(asStr);
      const distinct = new Set(nonNull.map((v) => (v instanceof Date ? v.getTime() : v))).size;
      const numeric = nonNull.filter((v) => typeof v === "number" || (typeof v === "string" && v.trim() !== "" && !isNaN(Number(v.replace(/,/g, "")))));
      const dates = nonNull.filter(isLikelyDate);
      let type;
      if (nonNull.length === 0) type = "empty";
      else if (numeric.length === nonNull.length) type = distinct <= 2 ? "binary" : (distinct === nonNull.length && nonNull.length > 10 ? "id" : "number");
      else if (dates.length === nonNull.length) type = "date";
      else if (distinct === nonNull.length && nonNull.length > 5) type = "id";
      else if (distinct <= Math.max(20, nonNull.length * 0.1)) type = "categorical";
      else type = "text";

      const flags = [];
      if (missing > 0) flags.push({ level: missing / n > 0.2 ? "warn" : "info", msg: Math.round((100 * missing) / n) + "% missing" });
      if (numeric.length > 0 && numeric.length < nonNull.length && type !== "categorical" && type !== "text" && type !== "date")
        flags.push({ level: "warn", msg: "mixed numeric / non-numeric" });
      if (dates.length > 0 && dates.length < nonNull.length && type === "date") flags.push({ level: "warn", msg: "some values don't parse as dates" });
      if (strs.some((v) => v !== v.trim())) flags.push({ level: "warn", msg: "stray whitespace" });
      const lc = new Set(strs.map((v) => v.toLowerCase().trim()));
      if ((type === "categorical" || type === "binary") && lc.size < distinct) flags.push({ level: "warn", msg: "inconsistent capitalisation / spacing" });
      if (distinct === 1) flags.push({ level: "info", msg: "constant" });
      if (type === "number") {
        const nums = numeric.map((v) => Number(String(v).replace(/,/g, "")));
        if (nums.some((x) => x < 0)) flags.push({ level: "info", msg: "has negatives" });
      }

      let range = "";
      if (type === "number" || type === "binary") {
        const nums = numeric.map((v) => Number(String(v).replace(/,/g, "")));
        range = "min " + Math.min(...nums) + " · max " + Math.max(...nums);
      } else if (type === "date") {
        const ds = nonNull.map((v) => (v instanceof Date ? v : new Date(v))).map((d) => d.getTime()).filter((t) => !isNaN(t));
        if (ds.length) range = new Date(Math.min(...ds)).toISOString().slice(0, 10) + " → " + new Date(Math.max(...ds)).toISOString().slice(0, 10);
      } else if (type !== "empty") {
        range = topCats(strs, 3);
      }
      return { name, type, missing, missingPct: n ? (100 * missing) / n : 0, distinct, flags, range };
    }

    function dupRowCount(rows, columns) {
      const seen = new Set(); let dups = 0;
      for (const r of rows) { const k = columns.map((c) => asStr(r[c] == null ? "" : r[c])).join(""); if (seen.has(k)) dups++; else seen.add(k); }
      return dups;
    }

    const TYPE_BADGE = { number: "bg-sky-100 text-sky-800", binary: "bg-indigo-100 text-indigo-800", date: "bg-violet-100 text-violet-800", categorical: "bg-emerald-100 text-emerald-800", id: "bg-amber-100 text-amber-800", text: "bg-slate-100 text-slate-700", empty: "bg-rose-100 text-rose-700" };
    const esc = (x) => String(x == null ? "" : x).replace(/[&<>"']/g, (c) => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;" }[c]));

    function render() {
      const { rows, columns, profile } = DATA;
      $("results").classList.remove("hidden");
      const dups = dupRowCount(rows, columns);
      const flagged = profile.filter((p) => p.flags.some((f) => f.level === "warn")).length;
      $("summary").innerHTML = "<strong>" + rows.length + "</strong> rows · <strong>" + columns.length + "</strong> columns · " +
        (dups ? "<span class='text-amber-700 font-semibold'>" + dups + " duplicate row(s)</span>" : "no duplicate rows") +
        " · " + (flagged ? "<span class='text-amber-700 font-semibold'>" + flagged + " column(s) need attention</span>" : "no dirtiness flagged");

      const issues = [];
      if (dups) issues.push({ level: "warn", msg: dups + " fully-duplicated row(s) — likely to be de-duplicated during cleaning." });
      if (!columns.length) issues.push({ level: "error", msg: "No columns detected — is there a header row?" });
      $("issues").innerHTML = issues.map((i) => "<div class='flex items-start gap-2 rounded-lg border px-3 py-2 text-xs " + (i.level === "error" ? "border-rose-200 bg-rose-50 text-rose-800" : "border-amber-200 bg-amber-50 text-amber-800") + "'><span class='font-bold'>" + (i.level === "error" ? "✕" : "!") + "</span><span>" + esc(i.msg) + "</span></div>").join("");

      $("proftable").innerHTML = profile.map((p) => {
        const badges = p.flags.map((f) => "<span class='inline-block rounded px-1.5 py-0.5 text-[10px] font-semibold " + (f.level === "warn" ? "bg-amber-100 text-amber-800" : "bg-slate-100 text-slate-600") + "'>" + esc(f.msg) + "</span>").join(" ") || "<span class='text-emerald-600'>✓ clean</span>";
        return "<tr class='border-b border-slate-100 align-top'>" +
          "<td class='py-2 pr-3 font-semibold text-slate-800'>" + esc(p.name) + "</td>" +
          "<td class='py-2 pr-3'><span class='inline-block rounded px-1.5 py-0.5 text-[10px] font-semibold " + (TYPE_BADGE[p.type] || TYPE_BADGE.text) + "'>" + p.type + "</span></td>" +
          "<td class='py-2 pr-3 " + (p.missingPct > 20 ? "text-amber-700 font-semibold" : "text-slate-600") + "'>" + Math.round(p.missingPct) + "%</td>" +
          "<td class='py-2 pr-3 text-slate-600'>" + p.distinct + "</td>" +
          "<td class='py-2 pr-3 text-slate-600'>" + esc(p.range) + "</td>" +
          "<td class='py-2 pr-3'>" + badges + "</td>" +
        "</tr>";
      }).join("");
    }

    async function ingest(file) {
      setMsg("Parsing " + file.name + "…");
      try {
        const { rows, columns } = await parseFile(file);
        if (!rows.length || !columns.length) { setMsg("Couldn't read any rows/columns. Check the file has a header and data.", true); return; }
        DATA = { rows, columns, profile: columns.map((c) => profileColumn(c, rows)), name: file.name.replace(/\.[^.]+$/, "") || "dataset" };
        $("fileinfo").textContent = file.name + " · " + rows.length + " rows × " + columns.length + " cols";
        setMsg("");
        render();
      } catch (e) { setMsg("Error reading file: " + (e && e.message ? e.message : e), true); }
    }

    fileInput.addEventListener("change", (e) => { const f = e.target.files && e.target.files[0]; if (f) ingest(f); });
    drop.addEventListener("dragover", (e) => { e.preventDefault(); drop.classList.add("border-brand-400", "bg-brand-50/40"); });
    drop.addEventListener("dragleave", () => drop.classList.remove("border-brand-400", "bg-brand-50/40"));
    drop.addEventListener("drop", (e) => { e.preventDefault(); drop.classList.remove("border-brand-400", "bg-brand-50/40"); const f = e.dataTransfer.files && e.dataTransfer.files[0]; if (f) ingest(f); });

    // Tiny synthetic demo (deliberately a bit messy) so the profiler has something to chew on.
    $("demo").addEventListener("click", () => {
      const sexes = ["M", "F", "m", "female ", "F"];
      const rows = [];
      for (let i = 1; i <= 60; i++) {
        rows.push({
          patient_id: 10000 + i,
          index_date: "2019-0" + (1 + (i % 9)) + "-15",
          age: i % 13 === 0 ? null : 40 + (i % 45),
          sex: sexes[i % sexes.length],
          exposure: i % 2,
          outcome: i % 5 === 0 ? 1 : 0,
          event_date: i % 5 === 0 ? "2020-03-1" + (i % 9) : null,
          cci: (i % 7) - 1,
        });
      }
      DATA = { rows, columns: ["patient_id", "index_date", "age", "sex", "exposure", "outcome", "event_date", "cci"], name: "demo-dataset" };
      DATA.profile = DATA.columns.map((c) => profileColumn(c, rows));
      $("fileinfo").textContent = "demo-dataset · 60 rows × 8 cols";
      setMsg("Loaded the synthetic demo dataset.");
      render();
    });

    // ── Exports ──
    const dl = (blob, nm) => { const u = URL.createObjectURL(blob); const a = document.createElement("a"); a.href = u; a.download = nm; document.body.appendChild(a); a.click(); a.remove(); setTimeout(() => URL.revokeObjectURL(u), 1000); };
    const csvCell = (v) => { const s = v == null ? "" : (v instanceof Date ? v.toISOString().slice(0, 10) : String(v)); return /[",\n]/.test(s) ? '"' + s.replace(/"/g, '""') + '"' : s; };
    const toCSV = (cols, rows) => [cols.map(csvCell).join(","), ...rows.map((r) => cols.map((c) => csvCell(r[c])).join(","))].join("\n");

    $("dlmaster").addEventListener("click", () => {
      if (!DATA.rows.length) return;
      dl(new Blob(["﻿" + toCSV(DATA.columns, DATA.rows)], { type: "text/csv;charset=utf-8" }), DATA.name + "-master.csv");
    });
    $("dldict").addEventListener("click", () => {
      if (!DATA.profile.length) return;
      const cols = ["column", "inferred_type", "missing_pct", "distinct", "range_or_top", "flags"];
      const rows = DATA.profile.map((p) => ({ column: p.name, inferred_type: p.type, missing_pct: Math.round(p.missingPct), distinct: p.distinct, range_or_top: p.range, flags: p.flags.map((f) => f.msg).join("; ") }));
      dl(new Blob(["﻿" + toCSV(cols, rows)], { type: "text/csv;charset=utf-8" }), DATA.name + "-dictionary.csv");
    });

    // ── Step 1: clinical question + design (persisted) ──
    const Q_KEY = "daniel.rwe-studio";
    const qNames = ["q_pop", "q_exp", "q_comp", "q_out"];
    const saveQ = () => {
      const s = {};
      qNames.forEach((n) => { const e = document.querySelector('[name="' + n + '"]'); if (e) s[n] = e.value; });
      const d = document.querySelector('[name="design"]:checked'); s.design = d ? d.value : "";
      try { localStorage.setItem(Q_KEY, JSON.stringify(s)); } catch (e) {}
    };
    (() => {
      try {
        const s = JSON.parse(localStorage.getItem(Q_KEY) || "null"); if (!s) return;
        qNames.forEach((n) => { const e = document.querySelector('[name="' + n + '"]'); if (e && s[n] != null) e.value = s[n]; });
        if (s.design) { const r = document.querySelector('[name="design"][value="' + s.design + '"]'); if (r) r.checked = true; }
      } catch (e) {}
    })();
    document.querySelectorAll('[name="q_pop"],[name="q_exp"],[name="q_comp"],[name="q_out"],[name="design"]').forEach((e) => e.addEventListener("input", saveQ));

    const DESIGN_LABEL = { descriptive: "Descriptive analysis", acnu: "Active-comparator new-user cohort", sccs: "Self-controlled case series", cco: "Case-crossover" };
    $("suggest").addEventListener("click", () => {
      const ck = (n) => { const e = document.querySelector('[name="' + n + '"]'); return !!(e && e.checked); };
      let v, why;
      if (ck("s_describe")) { v = "descriptive"; why = "your goal is to describe / quantify rather than test a causal effect."; }
      else if (ck("s_twodrugs")) { v = "acnu"; why = "you're comparing two active treatments — an active-comparator new-user cohort minimises confounding by indication."; }
      else if (ck("s_transient") && ck("s_acute")) { v = "sccs"; why = "a transient exposure with an acute outcome suits a self-controlled design (each case is its own control); a case-crossover is a good alternative."; }
      else if (ck("s_acute")) { v = "cco"; why = "for an acute, abrupt-onset event, a case-crossover contrasts exposure just before the event with earlier control windows."; }
      else { v = "acnu"; why = "defaulting to an active-comparator new-user cohort — tick more boxes for a sharper suggestion."; }
      const r = document.querySelector('[name="design"][value="' + v + '"]'); if (r) { r.checked = true; saveQ(); }
      $("suggestmsg").textContent = "Recommended: " + DESIGN_LABEL[v] + " — " + why;
    });
  </script>
</BaseLayout>
