---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PhenotypeLibrary from "../../components/PhenotypeLibrary.astro";
import SitesPicker from "../../components/SitesPicker.astro";
import DesignDiagram from "../../components/DesignDiagram.astro";
import ProtocolCommon from "../../components/ProtocolCommon.astro";
import TargetChecklist from "../../components/TargetChecklist.astro";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");

// Curated lists surfaced as checkboxes (matching the ACNU/SCCS/CCO/DA builders).
const SUBGROUPS = [
  "Age group (e.g. ≥65 vs <65)",
  "Sex (male vs female)",
  "Comorbidity burden (e.g. CCI ≥2 vs <2)",
  "Prior cardiovascular disease",
  "Baseline disease severity",
  "Prior hospitalisation for the condition",
  "Index / calendar year (before vs after a cut-point)",
  "Baseline risk score (high vs low)",
];
const SENSITIVITY = [
  "Trial interval (e.g. quarterly vs yearly)",
  "Pooled vs trial-stratified estimate (with I²)",
  "Maximum follow-up per trial",
  "Per-protocol (deviation censoring + IPCW) vs ITT",
  "Restrict outcomes to inpatient / emergency records",
  "Negative-control outcome",
  "Alternative propensity-score specification",
  "E-value for unmeasured confounding",
];
---

<BaseLayout
  title="Sequential Trial Emulation (ST) protocol — Daniel Tsai"
  description="A free, in-browser protocol builder for the sequential (nested) trial emulation approach to target-trial emulation, with one-click Word / Markdown export."
>
  <header class="relative bg-gradient-to-br from-brand-50 via-white to-brand-100/40 border-b border-slate-200 overflow-hidden">
    <div class="relative mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-12">
      <p class="uppercase tracking-widest text-xs text-brand-600 font-semibold mb-2">Protocol Generator · ST</p>
      <h1 class="text-3xl md:text-4xl font-bold text-slate-900">Sequential Trial Emulation protocol</h1>
      <p class="mt-3 text-base text-slate-600 max-w-3xl">
        Draft a target-trial-emulation protocol as a <strong>sequence of nested trials</strong> — one emulated trial at
        each eligible time origin. Patients who stay eligible enter several trials; estimates are pooled with a
        patient-clustered robust variance. Handles time-varying eligibility, staggered entry, and the prevalent-user
        problem. Everything runs in your browser.
      </p>
      <a class="mt-4 inline-block text-sm text-brand-700 hover:underline font-semibold" href={`${base}/tools/protocol-generator`}>← All designs</a>
    </div>
  </header>

  <section class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-8">
    <div class="grid gap-8 lg:grid-cols-[1fr,1fr] items-start">
      <!-- Form -->
      <form id="form" class="space-y-6">
        <fieldset class="rounded-2xl border border-slate-200 bg-white p-5 space-y-4">
          <legend class="px-2 text-sm font-bold text-brand-700">1 · Identity</legend>
          <label class="block"><span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Study title</span>
            <input name="title" placeholder="e.g. Metformin vs sulfonylurea and dementia: a sequential trial emulation" class="mt-1 w-full rounded-lg border border-slate-300 p-2 text-sm" /></label>
          <label class="block"><span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Data source(s)</span>
            <input name="data" placeholder="e.g. Taiwan NHIRD (2003–2019)" class="mt-1 w-full rounded-lg border border-slate-300 p-2 text-sm" /></label>
          <SitesPicker target="data" />
        </fieldset>

        <fieldset class="rounded-2xl border border-slate-200 bg-white p-5 space-y-4">
          <legend class="px-2 text-sm font-bold text-brand-700">2 · Causal question</legend>
          <div>
            <div class="flex items-center justify-between">
              <span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Population</span>
              <button type="button" data-open-library data-category="indications" data-target-name="population" class="text-[11px] text-brand-700 font-semibold hover:underline">📚 Library</button>
            </div>
            <input name="population" placeholder="e.g. Adults ≥ 50 with type 2 diabetes, no dementia at baseline" class="mt-1 w-full rounded-lg border border-slate-300 p-2 text-sm" />
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
            <div>
              <div class="flex items-center justify-between">
                <span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Treatment (index)</span>
                <button type="button" data-open-library data-category="exposures" data-target-name="exposure" class="text-[11px] text-brand-700 font-semibold hover:underline">📚</button>
              </div>
              <input name="exposure" placeholder="e.g. Metformin use in the interval" class="mt-1 w-full rounded-lg border border-slate-300 p-2 text-sm" />
            </div>
            <div>
              <div class="flex items-center justify-between">
                <span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Comparator</span>
                <button type="button" data-open-library data-category="exposures" data-target-name="comparator" class="text-[11px] text-brand-700 font-semibold hover:underline">📚</button>
              </div>
              <input name="comparator" placeholder="e.g. Sulfonylurea use (active comparator)" class="mt-1 w-full rounded-lg border border-slate-300 p-2 text-sm" />
            </div>
          </div>
          <div>
            <div class="flex items-center justify-between">
              <span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Outcome</span>
              <button type="button" data-open-library data-category="outcomes" data-target-name="outcome" class="text-[11px] text-brand-700 font-semibold hover:underline">📚 Library</button>
            </div>
            <input name="outcome" placeholder="e.g. Incident all-cause dementia" class="mt-1 w-full rounded-lg border border-slate-300 p-2 text-sm" />
          </div>
        </fieldset>

        <fieldset class="rounded-2xl border border-slate-200 bg-white p-5 space-y-4">
          <legend class="px-2 text-sm font-bold text-brand-700">3 · Sequence of trials</legend>
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
            <label class="block"><span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">First origin</span>
              <input name="first" placeholder="e.g. Jan 2003" class="mt-1 w-full rounded-lg border border-slate-300 p-2 text-sm" /></label>
            <label class="block"><span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Last origin</span>
              <input name="last" placeholder="e.g. Dec 2015" class="mt-1 w-full rounded-lg border border-slate-300 p-2 text-sm" /></label>
            <label class="block"><span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Interval</span>
              <select name="interval" class="mt-1 w-full rounded-lg border border-slate-300 p-2 text-sm">
                <option>monthly</option><option>quarterly</option><option>every 6 months</option><option>yearly</option><option>each eligible day</option>
              </select></label>
          </div>
          <label class="block"><span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Eligibility, re-assessed at each origin</span>
            <textarea name="eligibility" rows="2" class="mt-1 w-full rounded-lg border border-slate-300 p-2 text-sm" placeholder="e.g. At each origin: meets the population definition, is outcome-free, and has not yet been enrolled as an index-treatment initiator in an earlier trial."></textarea></label>
        </fieldset>

        <fieldset class="rounded-2xl border border-slate-200 bg-white p-5 space-y-4">
          <legend class="px-2 text-sm font-bold text-brand-700">4 · Assignment &amp; enrolment</legend>
          <label class="block"><span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Assignment at each origin</span>
            <textarea name="assignment" rows="2" class="mt-1 w-full rounded-lg border border-slate-300 p-2 text-sm" placeholder="e.g. Within each trial, patients using the index treatment in that interval form the treated arm; those using the comparator (and otherwise eligible) form the control arm."></textarea></label>
          <label class="block"><span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Multiple enrolment</span>
            <input name="multiple" placeholder="e.g. A patient may enter several consecutive trials until treated/outcome; variance clustered on patient." class="mt-1 w-full rounded-lg border border-slate-300 p-2 text-sm" /></label>
        </fieldset>

        <fieldset class="rounded-2xl border border-slate-200 bg-white p-5 space-y-4">
          <legend class="px-2 text-sm font-bold text-brand-700">5 · Confounding, estimand &amp; analysis</legend>
          <label class="block"><span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Confounding adjustment</span>
            <input name="confounding" placeholder="e.g. PS estimated per trial (or pooled with a trial indicator); IPTW / matching within trial" class="mt-1 w-full rounded-lg border border-slate-300 p-2 text-sm" /></label>
          <label class="block"><span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Estimand</span>
            <select name="estimand" class="mt-1 w-full rounded-lg border border-slate-300 p-2 text-sm">
              <option value="ITT">Intention-to-treat (assignment at the origin)</option>
              <option value="PP">Per-protocol (censor at deviation + IPCW; combine with CCW)</option>
              <option value="both">Both ITT and per-protocol</option>
            </select></label>
          <label class="block"><span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Follow-up window (per trial)</span>
            <input name="followup" placeholder="e.g. From each origin to outcome, death, disenrolment, or 8 years" class="mt-1 w-full rounded-lg border border-slate-300 p-2 text-sm" /></label>
          <div class="grid grid-cols-3 gap-3">
            <label class="block"><span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">New-user washout (days before origin)</span>
              <input type="number" name="washout" value="365" min="0" step="1" class="mt-1 w-full rounded-lg border border-slate-300 p-2 text-sm" /></label>
            <label class="block"><span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Covariate / eligibility look-back (days before origin)</span>
              <input type="number" name="covlookback" value="365" min="0" step="1" class="mt-1 w-full rounded-lg border border-slate-300 p-2 text-sm" /></label>
            <label class="block"><span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Max follow-up per trial (days)</span>
              <input type="number" name="futrial" value="1825" min="1" step="1" class="mt-1 w-full rounded-lg border border-slate-300 p-2 text-sm" /></label>
          </div>
          <label class="block"><span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Per-covariate look-back windows (optional)</span>
            <textarea name="covWindows" rows="3" placeholder="Comorbidities (CCI) | 365&#10;Comedications | 180" class="mt-1 w-full rounded-lg border border-slate-300 p-2 text-sm"></textarea>
            <div class="flex gap-1 mt-1 flex-wrap">
              {["Demographics (age, sex)", "Comorbidities (CCI)", "Comedications", "Disease severity", "Prior healthcare use", "Labs / vitals", "Frailty"].map((t) => (
                <button type="button" data-add-row data-target="covWindows" data-name={t} class="text-[10px] rounded-full border border-slate-200 px-2 py-0.5 text-slate-600 hover:border-brand-400 hover:text-brand-700">+ {t}</button>
              ))}
            </div>
            <span class="mt-1 block text-[11px] text-slate-500">Give each covariate its own look-back (<code>Name | days</code>), measured before <em>each trial's origin</em> — each becomes a draggable window in the diagram, exactly as in the active-comparator new-user builder. Leave empty to use the single look-back above for all covariates.</span>
          </label>
          <div>
            <span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Subgroup analyses (tick to perform)</span>
            <div class="mt-1.5 grid grid-cols-1 sm:grid-cols-2 gap-x-4 gap-y-1">
              {SUBGROUPS.map((sg, i) => (
                <label class="flex items-start gap-2 text-xs text-slate-700">
                  <input type="checkbox" name="subgroupsPick" value={sg} checked={i < 4} class="mt-0.5 rounded border-slate-400 text-brand-700 focus:ring-brand-500" />
                  <span>{sg}</span>
                </label>
              ))}
            </div>
            <textarea name="subgroupsCustom" rows="2" class="mt-2 w-full rounded-lg border border-slate-300 p-2 text-xs" placeholder="Custom subgroups (one per line)"></textarea>
          </div>
          <div>
            <span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Sensitivity analyses (tick to perform)</span>
            <div class="mt-1.5 grid grid-cols-1 gap-y-1">
              {SENSITIVITY.map((sn, i) => (
                <label class="flex items-start gap-2 text-xs text-slate-700">
                  <input type="checkbox" name="sensitivityPick" value={sn} checked={i < 5} class="mt-0.5 rounded border-slate-400 text-brand-700 focus:ring-brand-500" />
                  <span>{sn}</span>
                </label>
              ))}
            </div>
            <textarea name="sensitivityCustom" rows="2" class="mt-2 w-full rounded-lg border border-slate-300 p-2 text-xs" placeholder="Custom sensitivity analyses (one per line)"></textarea>
          </div>
        </fieldset>

        <div class="flex flex-wrap gap-3">
          <button type="button" data-action="download-docx" class="bg-brand-700 text-white hover:bg-brand-800 font-semibold px-5 py-2.5 rounded-lg text-sm">⬇ Word (.docx)</button>
          <button type="button" data-action="download-md" class="bg-white border border-brand-700 text-brand-700 hover:bg-brand-50 font-semibold px-5 py-2.5 rounded-lg text-sm">⬇ Markdown</button>
          <button type="button" data-action="download-target" class="text-brand-700 hover:underline font-semibold text-sm" title="TARGET checklist (Cashin et al, JAMA 2025) mapped to this protocol.">⬇ TARGET checklist</button>
          <button type="button" data-action="copy" class="text-brand-700 hover:underline font-semibold text-sm">Copy</button>
          <button type="button" data-action="reset" class="ml-auto text-slate-500 hover:text-rose-600 hover:underline text-sm font-semibold">Clear all</button>
          <span class="basis-full text-[11px] text-slate-400">Auto-saved to this browser.</span>
          <p data-action-msg class="basis-full text-xs"></p>
        </div>
      </form>

      <!-- Preview -->
      <div class="lg:sticky lg:top-20 self-start">
        <p class="text-xs uppercase tracking-widest text-slate-500 font-semibold mb-2">Live protocol preview</p>
        <pre id="preview" class="rounded-2xl border border-slate-200 bg-slate-50 p-5 text-xs leading-relaxed whitespace-pre-wrap overflow-auto max-h-[70vh]"></pre>
      </div>
    </div>

    <div class="mt-8 rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
      <h2 class="text-base font-bold text-slate-900">Consistency checks <span class="text-xs font-normal text-slate-400">· target-trial 防呆</span></h2>
      <div id="checks" class="mt-3 space-y-1.5"></div>
    </div>

    <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
      <h2 class="text-lg font-bold text-slate-900">Study design diagram</h2>
      <p id="dcap" class="mt-1 text-xs text-slate-500"></p>
      <p class="mt-4 text-xs font-semibold uppercase tracking-widest text-brand-700">Within one trial — anchored at its origin</p>
      <div class="mt-2 overflow-x-auto"><div id="diagram"></div></div>
      <div id="dlegend" class="mt-3 flex flex-wrap gap-x-4 gap-y-1.5 text-xs text-slate-600"></div>
      <p class="mt-6 text-xs font-semibold uppercase tracking-widest text-brand-700">Across trials — the same trial repeated at every origin</p>
      <div class="mt-2 overflow-x-auto"><div id="diagram2"></div></div>
    </div>

    <PhenotypeLibrary />
    <DesignDiagram />
    <TargetChecklist />
    <ProtocolCommon />
  </section>

  <script src="https://unpkg.com/docx@8.5.0/build/index.umd.js" is:inline></script>
  <script is:inline>
    const STORAGE_KEY = "daniel.st-builder";
    const form = document.getElementById("form");
    const preview = document.getElementById("preview");
    const V = (n) => (form.elements[n]?.value || "").trim();
    const MV = (n) => [...form.querySelectorAll('[name="' + n + '"]:checked')].map((c) => c.value);
    const mergeList = (pick, custom) => [...(pick || []), ...String(custom || "").split(/\r?\n/).map((x) => x.trim()).filter(Boolean)];

    const readForm = () => ({
      title: V("title"), data: V("data"), population: V("population"), exposure: V("exposure"), comparator: V("comparator"),
      outcome: V("outcome"), first: V("first"), last: V("last"), interval: V("interval"), eligibility: V("eligibility"),
      assignment: V("assignment"), multiple: V("multiple"), confounding: V("confounding"), estimand: V("estimand"),
      followup: V("followup"), washout: V("washout") || "365", covlookback: V("covlookback") || "365", covWindows: V("covWindows"), futrial: V("futrial") || "1825",
      subgroupsPick: MV("subgroupsPick"), subgroupsCustom: V("subgroupsCustom"), sensitivityPick: MV("sensitivityPick"), sensitivityCustom: V("sensitivityCustom"),
    });

    const esc = (x) => String(x == null ? "" : x).replace(/[&<>"']/g, (c) => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;" }[c]));
    const parseRows = (txt) => String(txt || "").split(/\r?\n/).map((l) => l.trim()).filter(Boolean).map((l) => { const p = l.split("|"); return { name: (p[0] || "").trim(), days: Math.max(0, parseInt(p[1]) || 0) }; }).filter((r) => r.name);
    const rowsJoin = (rows) => rows.map((r) => r.name + " | " + r.days).join("\n");
    const covLbText = (s) => { const r = parseRows(s.covWindows); return r.length ? r.map((x) => x.name + " " + x.days + " d").join("; ") : ((s.covlookback || "365") + " days before each origin"); };
    const fmtDays = (d) => { const a = Math.abs(d); if (a >= 365) { const y = a / 365; return (Number.isInteger(y) ? y : y.toFixed(1)) + "y"; } if (a >= 60) return Math.round(a / 30) + "mo"; return a + "d"; };

    function renderScheme(s) {
      const interval = s.interval || "monthly";
      const lb = Math.max(0, parseInt(s.covlookback) || 0);
      const wash = Math.max(0, parseInt(s.washout) || 0);
      const fu = Math.max(1, parseInt(s.futrial) || 1825);

      // ── Part 1: within one trial. Uses the SAME shared renderer (and therefore the same
      //    window kinds, colours, labels and drag behaviour) as the ACNU builder — the only
      //    difference is that time zero is each trial's origin rather than a single index date.
      const covRows = parseRows(s.covWindows);
      const wins = [];
      if (covRows.length) covRows.forEach((r, i) => wins.push({ label: r.name, kind: "lookback", startDay: -r.days, endDay: 0, edit: { field: "covWindows", edge: "start", idx: i } }));
      else if (lb > 0) wins.push({ label: "Covariate / eligibility look-back", kind: "lookback", startDay: -lb, endDay: 0, edit: { field: "covlookback", edge: "start" } });
      if (wash > 0) wins.push({ label: "New-user washout (no prior exposure/comparator)", kind: "washout", startDay: -wash, endDay: 0, edit: { field: "washout", edge: "start" } });
      wins.push({ label: "Follow-up (this trial)", kind: "followup", startDay: 0, endDay: fu, edit: { field: "futrial", edge: "end" } });
      const onEdit = (field, day, meta) => {
        if (field === "covWindows") {
          const el = form.elements.covWindows, rows = parseRows(el.value), idx = meta && meta.idx != null ? meta.idx : 0;
          if (rows[idx]) { rows[idx].days = Math.max(1, Math.round(-day)); el.value = rowsJoin(rows); render(); }
          return;
        }
        const el = form.elements[field]; if (!el) return;
        el.value = field === "futrial" ? Math.max(5, Math.round(day)) : Math.round(Math.max(0, -day));
        render();
      };
      window.renderDesignDiagram(document.getElementById("diagram"), document.getElementById("dlegend"), { windows: wins, indexLabel: "Trial origin (day 0) — eligibility, assignment & follow-up start", onEdit: onEdit, snap: 5 });

      // ── Part 2: across trials — that same trial repeated at every origin along calendar time.
      renderTrialStrip(s, interval, Math.max(lb, wash), fu);

      document.getElementById("dcap").textContent =
        "Top — what happens inside one trial, anchored at its origin (day 0): the same scheme as the active-comparator new-user design (washout and covariate look-back before time zero, follow-up after), because each nested trial IS a new-user trial started at that origin. Bottom — that trial is repeated at every origin (" + interval + ", " + (s.first || "start") + "–" + (s.last || "end") + "), staggered along calendar time; a patient enters every trial they stay eligible for, pooled with a patient-clustered robust variance. Drag the ○ handles in the top panel to edit the windows.";
    }

    function renderTrialStrip(s, interval, pre, fu) {
      const total = pre + fu || 1;
      const W = 860, gutter = 104, plotL = gutter, plotR = W - 18, plotW = plotR - plotL;
      const rowH = 36, top = 26, H = top + 4 * rowH + 26;
      const perW = plotW * 0.46, lbW = perW * (pre / total), fuW = perW - lbW, gap = plotW * 0.085;
      const baseOx = plotL + lbW + 4;
      const trials = [["Trial 1", 0], ["Trial 2", 1], ["Trial N (last)", 4]];
      const rowY = [top, top + rowH, top + 3 * rowH];
      let svg = '<svg viewBox="0 0 ' + W + ' ' + H + '" class="w-full h-auto" style="min-width:660px" xmlns="http://www.w3.org/2000/svg">';
      trials.forEach((t, i) => {
        const y = rowY[i], ox = baseOx + t[1] * gap;
        svg += '<line x1="' + ox + '" y1="' + (y - 2) + '" x2="' + ox + '" y2="' + (H - 24) + '" stroke="#eef2f7"/>';
        svg += '<text x="' + (gutter - 10) + '" y="' + (y + 16) + '" text-anchor="end" font-size="11" fill="#334155">' + esc(t[0]) + '</text>';
        if (lbW > 1) svg += '<rect x="' + (ox - lbW) + '" y="' + (y + 5) + '" width="' + lbW + '" height="16" rx="3" fill="#8b5cf6" fill-opacity="0.8"/>';
        svg += '<rect x="' + ox + '" y="' + (y + 5) + '" width="' + fuW + '" height="16" rx="3" fill="#10b981" fill-opacity="0.85"/>';
        svg += '<circle cx="' + ox + '" cy="' + (y + 13) + '" r="4" fill="#0f766e"/>';
        if (i === 0) {
          if (lbW > 30) svg += '<text x="' + (ox - lbW / 2) + '" y="' + (y + 17) + '" text-anchor="middle" font-size="9" fill="#fff" font-weight="600">−' + fmtDays(pre) + '</text>';
          if (fuW > 44) svg += '<text x="' + (ox + fuW / 2) + '" y="' + (y + 17) + '" text-anchor="middle" font-size="9" fill="#fff" font-weight="600">+' + fmtDays(fu) + '</text>';
        }
      });
      const dy = top + 2 * rowH + 14, dxA = baseOx + 1.7 * gap, dxB = baseOx + 3.3 * gap;
      for (let k = 0; k < 3; k++) { const dx = dxA + (dxB - dxA) * (k / 2); svg += '<circle cx="' + dx + '" cy="' + dy + '" r="2.6" fill="#94a3b8"/>'; }
      svg += '<text x="' + ((dxA + dxB) / 2) + '" y="' + (dy - 8) + '" text-anchor="middle" font-size="9.5" fill="#94a3b8">…a new trial at each origin…</text>';
      svg += '<line x1="' + plotL + '" y1="' + (H - 22) + '" x2="' + plotR + '" y2="' + (H - 22) + '" stroke="#cbd5e1"/>';
      svg += '<text x="' + plotR + '" y="' + (H - 8) + '" text-anchor="end" font-size="10" fill="#94a3b8">calendar time → (a new trial each ' + esc(interval) + ')</text>';
      const d2 = document.getElementById("diagram2"); if (d2) d2.innerHTML = svg + "</svg>";
    }

    const or = (s, d) => (s && s.length ? s : d);
    const estimandText = (e) => ({
      ITT: "the **intention-to-treat effect** — the effect of the treatment strategy assigned at each origin, regardless of subsequent adherence",
      PP: "the **per-protocol effect** — the effect of receiving and adhering to the assigned strategy, with censoring at deviation and inverse-probability-of-censoring weights (a clone-censor-weight step within each trial)",
      both: "both the **intention-to-treat** and the **per-protocol** effects (the latter using censoring at deviation with inverse-probability-of-censoring weights)",
    })[e] || "the treatment effect";

    // Normalised inputs for the shared HARPER/TARGET common sections (window.PC).
    const pcOf = (s) => ({
      design: "sequential (nested) trial emulation",
      tte: true,
      population: or(s.population, "(population)"),
      exposure: or(s.exposure, "(treatment)"),
      comparator: or(s.comparator, "(comparator)"),
      outcome: or(s.outcome, "(outcome)"),
      data: s.data,
      analysis: "a sequence of nested trials emulated at each eligible origin and pooled with a patient-clustered robust variance, estimating " + estimandText(s.estimand).replace(/\*\*/g, ""),
      groupBy: "treatment arm",
      limitations: "Patients contribute to several trials, so the robust variance must be correctly clustered on the patient; residual and unmeasured confounding within each trial cannot be excluded.",
      plannedOutputs: ["Per-trial and pooled effect estimates with a heterogeneity summary.", "Within-trial covariate-balance (SMD) diagnostics.", "Cumulative-incidence or survival curves by arm."],
    });

    const buildMarkdown = (s) => {
      const today = new Date().toISOString().slice(0, 10);
      return `# ${or(s.title, "(Untitled sequential trial emulation)")}

_Study protocol · sequential (nested) trial emulation · drafted ${today}_

${window.PC.abstractMd(pcOf(s))}
## 1. Background and rationale
This study emulates a **sequence of nested target trials** to estimate the effect of **${or(s.exposure, "(treatment)")}** versus **${or(s.comparator, "(comparator)")}**. A single-origin new-user design discards eligible person-time and cannot use patients who become eligible later; the sequential design emulates one trial at every eligible time origin, so each person contributes wherever they are eligible, mitigating the prevalent-user and selection problems (Hernán 2008; Danaei 2013; Gran 2010).

## 2. Causal question (target trial)
Among **${or(s.population, "(population)")}**, what is the effect of **${or(s.exposure, "(treatment)")}** versus **${or(s.comparator, "(comparator)")}** on **${or(s.outcome, "(outcome)")}**?

## 3. Study design
A **sequential trial emulation**: a series of nested trials with origins **${or(s.interval, "monthly")}** from **${or(s.first, "(first origin)")}** to **${or(s.last, "(last origin)")}**, using observational data from **${or(s.data, "(data source)")}**.

## 4. Eligibility (re-assessed at each origin)
${or(s.eligibility, "At each origin a patient is eligible if they meet the population definition, are outcome-free, and have not already been enrolled as an index-treatment initiator in an earlier trial.")}

Every nested trial is itself a **new-user trial started at that origin**, so the same windows as an active-comparator new-user design are applied at *each* origin, all measured **before** that origin: a **new-user washout of ${parseInt(s.washout) || 0} days** with no prior exposure or comparator, and a **covariate / eligibility look-back of ${covLbText(s)}**. Because these windows move with the origin, eligibility, treatment assignment and the start of follow-up remain aligned at every trial's time zero — which is what prevents immortal-time bias.

## 5. Time zero and treatment assignment
For each trial, **time zero is that trial's origin**. ${or(s.assignment, "Within each trial, patients using the index treatment in that interval form the treated arm; eligible comparator users form the control arm.")}

## 6. Enrolment across trials
${or(s.multiple, "A patient may be eligible for, and enrol in, several consecutive trials until they are treated or have the outcome. Because the same patient appears in multiple trials, all variance estimates use a robust (sandwich) estimator clustered on the patient.")}

## 7. Confounding adjustment
${or(s.confounding, "The propensity score is estimated within each trial (or pooled across trials with a trial indicator) from baseline covariates measured at that origin; treated and control arms are balanced by inverse-probability-of-treatment weighting (or matching) within trial.")}

## 8. Follow-up and outcome
${or(s.followup, "Within each trial, follow-up runs from the origin to the outcome, death, disenrolment, or the maximum follow-up, whichever comes first.")} Outcome: **${or(s.outcome, "(outcome)")}**.

## 9. Estimand
The target estimand is ${estimandText(s.estimand)}.

## 10. Statistical analysis
1. Construct the nested trials at each origin and assemble the stacked, trial-indexed dataset.
2. Within each trial, estimate the propensity score and apply weighting (or matching).
3. Fit a **pooled logistic (or weighted Cox) model** across all trials for the outcome hazard, with terms for the assigned treatment, follow-up time, and trial; ${s.estimand === "ITT" ? "no deviation censoring (ITT)." : s.estimand === "PP" ? "censor at deviation and apply inverse-probability-of-censoring weights (per-protocol)." : "run ITT and per-protocol (deviation censoring + IPCW) variants."}
4. Estimate a **pooled** effect with 95% CIs from a robust variance clustered on patient (and, as a check, a trial-stratified estimate with a heterogeneity summary).

## 11. Subgroup analyses
${(mergeList(s.subgroupsPick, s.subgroupsCustom).length ? mergeList(s.subgroupsPick, s.subgroupsCustom) : ["(none pre-specified)"]).map((l) => "- " + l).join("\n")}

## 12. Sensitivity analyses
${(mergeList(s.sensitivityPick, s.sensitivityCustom).length ? mergeList(s.sensitivityPick, s.sensitivityCustom) : ["(none pre-specified)"]).map((l) => "- " + l).join("\n")}

${window.PC.tailMd(pcOf(s))}

## References
- Hernán MA, Alonso A, Logan R, et al. Observational studies analyzed like randomized experiments: an application to postmenopausal hormone therapy and coronary heart disease. Epidemiology 2008;19:766-79.
- Danaei G, Rodríguez LAG, Cantero OF, et al. Observational data for comparative effectiveness research: an emulation of randomised trials of statins and primary prevention of coronary heart disease. Stat Methods Med Res 2013;22:70-96.
- Gran JM, Røysland K, Wolbers M, et al. A sequential Cox approach for estimating the causal effect of treatment. Stat Med 2010;29:2757-70.
- Keogh RH, Gran JM, Seaman SR, et al. Causal inference in survival analysis using longitudinal observational data: sequential trials and marginal structural models. Stat Med 2023;42:2191-2225.
`;
    };

    const computeChecks = (s) => {
      const checks = [];
      const lb = parseRows(s.covWindows).length ? 1 : (parseInt(s.covlookback) || 0), fu = parseInt(s.futrial) || 0;
      const wash = parseInt(s.washout) || 0;
      if (wash <= 0) checks.push({ level: "warn", msg: "New-user washout is 0 — each nested trial is itself a new-user trial started at its origin, so prevalent users can be enrolled at every origin. Set a washout with no prior exposure or comparator before each origin." });
      else if (wash < 180) checks.push({ level: "info", msg: "New-user washout < 180 days — consider a longer washout so that patients enrolled at each origin are truly new users." });
      if (!s.first || !s.last) checks.push({ level: "warn", msg: "Set the first and last trial origins so the sequence of nested trials is defined." });
      if (lb <= 0) checks.push({ level: "warn", msg: "No covariate / eligibility look-back — each trial assesses eligibility and covariates only at its origin. Set a look-back window before the origin." });
      if (fu <= 0) checks.push({ level: "warn", msg: "Set the per-trial follow-up window." });
      if (!s.multiple || !s.multiple.trim()) checks.push({ level: "warn", msg: "Patients can enter multiple trials — state the patient-clustered (robust) variance used to handle this re-use, or the analysis will over-state precision." });
      if (!s.confounding || !s.confounding.trim()) checks.push({ level: "warn", msg: "Specify how confounding is controlled within each trial (e.g. PS weighting or matching)." });
      if (!s.population || !s.population.trim()) checks.push({ level: "info", msg: "Specify the population." });
      if (!s.exposure || !s.comparator) checks.push({ level: "info", msg: "Specify the treatment and comparator." });
      if (!s.outcome || !s.outcome.trim()) checks.push({ level: "info", msg: "Specify the outcome." });
      const est = s.estimand;
      if (est === "ITT" || est === "both") checks.push({ level: "info", msg: "ITT (assignment at each origin): the strategy is fixed at the origin — later switching or add-on is ignored (no deviation censoring)." });
      if (est === "PP" || est === "both") checks.push({ level: "info", msg: "Per-protocol: within each trial, censor at deviation and apply IPCW (a clone-censor-weight step) — fit the weights separately per arm and per censoring reason." });
      return checks;
    };

