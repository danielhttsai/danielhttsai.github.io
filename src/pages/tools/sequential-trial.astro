---
import BaseLayout from "../../layouts/BaseLayout.astro";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<BaseLayout
  title="Sequential Trial Emulation (ST) protocol — Daniel Tsai"
  description="A free, in-browser protocol builder for the sequential (nested) trial emulation approach to target-trial emulation, with one-click Word / Markdown export."
>
  <header class="relative bg-gradient-to-br from-brand-50 via-white to-brand-100/40 border-b border-slate-200 overflow-hidden">
    <div class="relative mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-12">
      <p class="uppercase tracking-widest text-xs text-brand-600 font-semibold mb-2">Protocol Generator · ST</p>
      <h1 class="text-3xl md:text-4xl font-bold text-slate-900">Sequential Trial Emulation protocol</h1>
      <p class="mt-3 text-base text-slate-600 max-w-3xl">
        Draft a target-trial-emulation protocol as a <strong>sequence of nested trials</strong> — one emulated trial at
        each eligible time origin. Patients who stay eligible enter several trials; estimates are pooled with a
        patient-clustered robust variance. Handles time-varying eligibility, staggered entry, and the prevalent-user
        problem. Everything runs in your browser.
      </p>
      <a class="mt-4 inline-block text-sm text-brand-700 hover:underline font-semibold" href={`${base}/tools/protocol-generator`}>← All designs</a>
    </div>
  </header>

  <section class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-8">
    <div class="grid lg:grid-cols-2 gap-8">
      <!-- Form -->
      <form id="form" class="space-y-6">
        <fieldset class="rounded-2xl border border-slate-200 bg-white p-5 space-y-4">
          <legend class="px-2 text-sm font-bold text-brand-700">1 · Identity</legend>
          <label class="block"><span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Study title</span>
            <input name="title" placeholder="e.g. Metformin vs sulfonylurea and dementia: a sequential trial emulation" class="mt-1 w-full rounded-lg border border-slate-300 p-2 text-sm" /></label>
          <label class="block"><span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Data source(s)</span>
            <input name="data" placeholder="e.g. Taiwan NHIRD (2003–2019)" class="mt-1 w-full rounded-lg border border-slate-300 p-2 text-sm" /></label>
        </fieldset>

        <fieldset class="rounded-2xl border border-slate-200 bg-white p-5 space-y-4">
          <legend class="px-2 text-sm font-bold text-brand-700">2 · Causal question</legend>
          <label class="block"><span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Population</span>
            <input name="population" placeholder="e.g. Adults ≥ 50 with type 2 diabetes, no dementia at baseline" class="mt-1 w-full rounded-lg border border-slate-300 p-2 text-sm" /></label>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
            <label class="block"><span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Treatment (index)</span>
              <input name="exposure" placeholder="e.g. Metformin use in the interval" class="mt-1 w-full rounded-lg border border-slate-300 p-2 text-sm" /></label>
            <label class="block"><span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Comparator</span>
              <input name="comparator" placeholder="e.g. Sulfonylurea use (active comparator)" class="mt-1 w-full rounded-lg border border-slate-300 p-2 text-sm" /></label>
          </div>
          <label class="block"><span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Outcome</span>
            <input name="outcome" placeholder="e.g. Incident all-cause dementia" class="mt-1 w-full rounded-lg border border-slate-300 p-2 text-sm" /></label>
        </fieldset>

        <fieldset class="rounded-2xl border border-slate-200 bg-white p-5 space-y-4">
          <legend class="px-2 text-sm font-bold text-brand-700">3 · Sequence of trials</legend>
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
            <label class="block"><span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">First origin</span>
              <input name="first" placeholder="e.g. Jan 2003" class="mt-1 w-full rounded-lg border border-slate-300 p-2 text-sm" /></label>
            <label class="block"><span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Last origin</span>
              <input name="last" placeholder="e.g. Dec 2015" class="mt-1 w-full rounded-lg border border-slate-300 p-2 text-sm" /></label>
            <label class="block"><span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Interval</span>
              <select name="interval" class="mt-1 w-full rounded-lg border border-slate-300 p-2 text-sm">
                <option>monthly</option><option>quarterly</option><option>every 6 months</option><option>yearly</option><option>each eligible day</option>
              </select></label>
          </div>
          <label class="block"><span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Eligibility, re-assessed at each origin</span>
            <textarea name="eligibility" rows="2" class="mt-1 w-full rounded-lg border border-slate-300 p-2 text-sm" placeholder="e.g. At each origin: meets the population definition, is outcome-free, and has not yet been enrolled as an index-treatment initiator in an earlier trial."></textarea></label>
        </fieldset>

        <fieldset class="rounded-2xl border border-slate-200 bg-white p-5 space-y-4">
          <legend class="px-2 text-sm font-bold text-brand-700">4 · Assignment &amp; enrolment</legend>
          <label class="block"><span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Assignment at each origin</span>
            <textarea name="assignment" rows="2" class="mt-1 w-full rounded-lg border border-slate-300 p-2 text-sm" placeholder="e.g. Within each trial, patients using the index treatment in that interval form the treated arm; those using the comparator (and otherwise eligible) form the control arm."></textarea></label>
          <label class="block"><span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Multiple enrolment</span>
            <input name="multiple" placeholder="e.g. A patient may enter several consecutive trials until treated/outcome; variance clustered on patient." class="mt-1 w-full rounded-lg border border-slate-300 p-2 text-sm" /></label>
        </fieldset>

        <fieldset class="rounded-2xl border border-slate-200 bg-white p-5 space-y-4">
          <legend class="px-2 text-sm font-bold text-brand-700">5 · Confounding, estimand &amp; analysis</legend>
          <label class="block"><span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Confounding adjustment</span>
            <input name="confounding" placeholder="e.g. PS estimated per trial (or pooled with a trial indicator); IPTW / matching within trial" class="mt-1 w-full rounded-lg border border-slate-300 p-2 text-sm" /></label>
          <label class="block"><span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Estimand</span>
            <select name="estimand" class="mt-1 w-full rounded-lg border border-slate-300 p-2 text-sm">
              <option value="ITT">Intention-to-treat (assignment at the origin)</option>
              <option value="PP">Per-protocol (censor at deviation + IPCW; combine with CCW)</option>
              <option value="both">Both ITT and per-protocol</option>
            </select></label>
          <label class="block"><span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Follow-up window (per trial)</span>
            <input name="followup" placeholder="e.g. From each origin to outcome, death, disenrolment, or 8 years" class="mt-1 w-full rounded-lg border border-slate-300 p-2 text-sm" /></label>
          <label class="block"><span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Sensitivity analyses</span>
            <textarea name="sensitivity" rows="2" class="mt-1 w-full rounded-lg border border-slate-300 p-2 text-sm" placeholder="e.g. Trial interval (quarterly vs yearly); trial-stratified vs pooled estimate with I²; maximum follow-up per trial; negative-control outcomes."></textarea></label>
        </fieldset>

        <div class="flex flex-wrap gap-3">
          <button type="button" data-action="download-docx" class="bg-brand-700 text-white hover:bg-brand-800 font-semibold px-5 py-2.5 rounded-lg text-sm">⬇ Word (.docx)</button>
          <button type="button" data-action="download-md" class="bg-white border border-brand-700 text-brand-700 hover:bg-brand-50 font-semibold px-5 py-2.5 rounded-lg text-sm">⬇ Markdown</button>
          <button type="button" data-action="copy" class="text-brand-700 hover:underline font-semibold text-sm">Copy</button>
          <button type="button" data-action="reset" class="text-slate-500 hover:text-slate-800 text-sm ml-auto">Reset</button>
        </div>
      </form>

      <!-- Preview -->
      <div class="lg:sticky lg:top-20 self-start">
        <p class="text-xs uppercase tracking-widest text-slate-500 font-semibold mb-2">Live protocol preview</p>
        <pre id="preview" class="rounded-2xl border border-slate-200 bg-slate-50 p-5 text-xs leading-relaxed whitespace-pre-wrap overflow-auto max-h-[70vh]"></pre>
      </div>
    </div>
  </section>

  <script src="https://unpkg.com/docx@8.5.0/build/index.umd.js" is:inline></script>
  <script is:inline>
    const STORAGE_KEY = "daniel.st-builder";
    const form = document.getElementById("form");
    const preview = document.getElementById("preview");
    const V = (n) => (form.elements[n]?.value || "").trim();

    const readForm = () => ({
      title: V("title"), data: V("data"), population: V("population"), exposure: V("exposure"), comparator: V("comparator"),
      outcome: V("outcome"), first: V("first"), last: V("last"), interval: V("interval"), eligibility: V("eligibility"),
      assignment: V("assignment"), multiple: V("multiple"), confounding: V("confounding"), estimand: V("estimand"),
      followup: V("followup"), sensitivity: V("sensitivity"),
    });

    const or = (s, d) => (s && s.length ? s : d);
    const estimandText = (e) => ({
      ITT: "the **intention-to-treat effect** — the effect of the treatment strategy assigned at each origin, regardless of subsequent adherence",
      PP: "the **per-protocol effect** — the effect of receiving and adhering to the assigned strategy, with censoring at deviation and inverse-probability-of-censoring weights (a clone-censor-weight step within each trial)",
      both: "both the **intention-to-treat** and the **per-protocol** effects (the latter using censoring at deviation with inverse-probability-of-censoring weights)",
    })[e] || "the treatment effect";

    const buildMarkdown = (s) => {
      const today = new Date().toISOString().slice(0, 10);
      return `# ${or(s.title, "(Untitled sequential trial emulation)")}

_Study protocol · sequential (nested) trial emulation · drafted ${today}_

## 1. Background and rationale
This study emulates a **sequence of nested target trials** to estimate the effect of **${or(s.exposure, "(treatment)")}** versus **${or(s.comparator, "(comparator)")}**. A single-origin new-user design discards eligible person-time and cannot use patients who become eligible later; the sequential design emulates one trial at every eligible time origin, so each person contributes wherever they are eligible, mitigating the prevalent-user and selection problems (Hernán 2008; Danaei 2013; Gran 2010).

## 2. Causal question (target trial)
Among **${or(s.population, "(population)")}**, what is the effect of **${or(s.exposure, "(treatment)")}** versus **${or(s.comparator, "(comparator)")}** on **${or(s.outcome, "(outcome)")}**?

## 3. Study design
A **sequential trial emulation**: a series of nested trials with origins **${or(s.interval, "monthly")}** from **${or(s.first, "(first origin)")}** to **${or(s.last, "(last origin)")}**, using observational data from **${or(s.data, "(data source)")}**.

## 4. Eligibility (re-assessed at each origin)
${or(s.eligibility, "At each origin a patient is eligible if they meet the population definition, are outcome-free, and have not already been enrolled as an index-treatment initiator in an earlier trial.")}

## 5. Time zero and treatment assignment
For each trial, **time zero is that trial's origin**. ${or(s.assignment, "Within each trial, patients using the index treatment in that interval form the treated arm; eligible comparator users form the control arm.")}

## 6. Enrolment across trials
${or(s.multiple, "A patient may be eligible for, and enrol in, several consecutive trials until they are treated or have the outcome. Because the same patient appears in multiple trials, all variance estimates use a robust (sandwich) estimator clustered on the patient.")}

## 7. Confounding adjustment
${or(s.confounding, "The propensity score is estimated within each trial (or pooled across trials with a trial indicator) from baseline covariates measured at that origin; treated and control arms are balanced by inverse-probability-of-treatment weighting (or matching) within trial.")}

## 8. Follow-up and outcome
${or(s.followup, "Within each trial, follow-up runs from the origin to the outcome, death, disenrolment, or the maximum follow-up, whichever comes first.")} Outcome: **${or(s.outcome, "(outcome)")}**.

## 9. Estimand
The target estimand is ${estimandText(s.estimand)}.

## 10. Statistical analysis
1. Construct the nested trials at each origin and assemble the stacked, trial-indexed dataset.
2. Within each trial, estimate the propensity score and apply weighting (or matching).
3. Fit a **pooled logistic (or weighted Cox) model** across all trials for the outcome hazard, with terms for the assigned treatment, follow-up time, and trial; ${s.estimand === "ITT" ? "no deviation censoring (ITT)." : s.estimand === "PP" ? "censor at deviation and apply inverse-probability-of-censoring weights (per-protocol)." : "run ITT and per-protocol (deviation censoring + IPCW) variants."}
4. Estimate a **pooled** effect with 95% CIs from a robust variance clustered on patient (and, as a check, a trial-stratified estimate with a heterogeneity summary).

## 11. Sensitivity analyses
${(s.sensitivity || "Trial interval (e.g. quarterly vs yearly); pooled vs trial-stratified estimate with I²; maximum follow-up per trial; negative-control outcomes; alternative PS specifications.").split(/\r?\n/).map((l) => l.trim()).filter(Boolean).map((l) => "- " + l).join("\n")}

## References
- Hernán MA, Alonso A, Logan R, et al. Observational studies analyzed like randomized experiments: an application to postmenopausal hormone therapy and coronary heart disease. Epidemiology 2008;19:766-79.
- Danaei G, Rodríguez LAG, Cantero OF, et al. Observational data for comparative effectiveness research: an emulation of randomised trials of statins and primary prevention of coronary heart disease. Stat Methods Med Res 2013;22:70-96.
- Gran JM, Røysland K, Wolbers M, et al. A sequential Cox approach for estimating the causal effect of treatment. Stat Med 2010;29:2757-70.
- Keogh RH, Gran JM, Seaman SR, et al. Causal inference in survival analysis using longitudinal observational data: sequential trials and marginal structural models. Stat Med 2023;42:2191-2225.
`;
    };

    const render = () => {
      const s = readForm();
      preview.textContent = buildMarkdown(s);
      try { localStorage.setItem(STORAGE_KEY, JSON.stringify(s)); } catch {}
    };

    (() => {
      try {
        const saved = JSON.parse(localStorage.getItem(STORAGE_KEY) || "null");
        if (saved) for (const k in saved) if (form.elements[k]) form.elements[k].value = saved[k];
      } catch {}
      render();
    })();
    form.addEventListener("input", render);
    form.addEventListener("change", render);

    const slugify = () => (readForm().title || "sequential-trial-protocol").toLowerCase().replace(/[^a-z0-9]+/g, "-").replace(/^-|-$/g, "").slice(0, 60) || "sequential-trial-protocol";
    const fname = (ext) => slugify() + "-" + new Date().toISOString().slice(0, 10) + "." + ext;
    const dl = (blob, name) => { const u = URL.createObjectURL(blob); const a = document.createElement("a"); a.href = u; a.download = name; document.body.appendChild(a); a.click(); a.remove(); setTimeout(() => URL.revokeObjectURL(u), 1000); };

    document.querySelector("[data-action='download-md']").addEventListener("click", () =>
      dl(new Blob([preview.textContent || ""], { type: "text/markdown;charset=utf-8" }), fname("md")));
    document.querySelector("[data-action='copy']").addEventListener("click", async (e) => {
      try { await navigator.clipboard.writeText(preview.textContent || ""); e.target.textContent = "Copied ✓"; setTimeout(() => (e.target.textContent = "Copy"), 1500); } catch {}
    });
    document.querySelector("[data-action='reset']").addEventListener("click", () => {
      if (!confirm("Clear the form?")) return;
      form.reset(); localStorage.removeItem(STORAGE_KEY); render();
    });

    document.querySelector("[data-action='download-docx']").addEventListener("click", async () => {
      const D = window.docx; if (!D) return;
      const FONT = "Calibri";
      const md = preview.textContent || "";
      const children = [];
      for (const raw of md.split(/\r?\n/)) {
        const line = raw.replace(/\*\*/g, "");
        if (/^# /.test(line)) children.push(new D.Paragraph({ heading: D.HeadingLevel.TITLE, spacing: { after: 120 }, children: [new D.TextRun({ text: line.slice(2), font: FONT, bold: true, size: 32 })] }));
        else if (/^## /.test(line)) children.push(new D.Paragraph({ heading: D.HeadingLevel.HEADING_1, spacing: { before: 200, after: 60 }, children: [new D.TextRun({ text: line.slice(3), font: FONT, bold: true, size: 26, color: "21443E" })] }));
        else if (/^- /.test(line)) children.push(new D.Paragraph({ bullet: { level: 0 }, children: [new D.TextRun({ text: line.slice(2), font: FONT, size: 20 })] }));
        else if (/^_.*_$/.test(line)) children.push(new D.Paragraph({ spacing: { after: 120 }, children: [new D.TextRun({ text: line.replace(/^_|_$/g, ""), font: FONT, italics: true, size: 18, color: "777777" })] }));
        else if (line.trim() === "") children.push(new D.Paragraph({ children: [] }));
        else children.push(new D.Paragraph({ spacing: { after: 40 }, children: [new D.TextRun({ text: line, font: FONT, size: 20 })] }));
      }
      const doc = new D.Document({ creator: "Protocol Generator — Sequential Trial", title: readForm().title || "Sequential trial protocol", styles: { default: { document: { run: { font: FONT, size: 20 } } } }, sections: [{ children }] });
      dl(await D.Packer.toBlob(doc), fname("docx"));
    });
  </script>
</BaseLayout>
