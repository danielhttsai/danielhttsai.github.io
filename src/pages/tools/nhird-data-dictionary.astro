---
// The NHIRD data dictionary is its own app (same domain, now wearing the main
// site's header) — no longer embedded in an iframe. This stub redirects the old
// /tools/nhird-data-dictionary URL straight to it.
const DEST = "https://danielhttsai.github.io/nhird-data-dictionary/";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta http-equiv="refresh" content={`0; url=${DEST}`} />
    <link rel="canonical" href={DEST} />
    <meta name="robots" content="noindex" />
    <title>NHIRD Data Dictionary →</title>
    <script is:inline define:vars={{ DEST }}>window.location.replace(DEST);</script>
  </head>
  <body style="font-family: system-ui, sans-serif; padding: 2rem; color: #334155;">
    <p>Opening the <a href={DEST}>NHIRD / HWDC data dictionary</a>…</p>
  </body>
</html>
