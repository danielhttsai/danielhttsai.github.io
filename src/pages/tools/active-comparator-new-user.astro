        return await D.Packer.toBlob(doc);
      };

      // ── Phenotype library modal ─────────────────────
      const modal      = document.querySelector("[data-library-modal]");
      const modalTitle = document.querySelector("[data-library-title]");
      const modalList  = document.querySelector("[data-library-list]");
      const modalSearch= document.querySelector("[data-library-search]");
      let currentCategory = "indications";
      let currentTargets  = {}; // { name?, codes?, def?, validation? }

      const esc = (s) => String(s ?? "").replace(/[&<>"']/g, (c) => ({
        "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;",
      }[c]));

      const renderLibrary = (filter = "") => {
        // Confounding library uses the PS_METHODS array (each has value + label
        // + definition + validation). Phenotype categories use PHENOTYPES.
        const items = currentCategory === "confounding"
          ? PS_METHODS.map((m) => ({ name: m.label, value: m.value, definition: m.definition, validation: m.validation }))
          : (PHENOTYPES[currentCategory] || []);
        const f = filter.trim().toLowerCase();
        const filtered = f
          ? items.filter((it) =>
              (it.name || "").toLowerCase().includes(f) ||
              (it.codes || "").toLowerCase().includes(f) ||
              (it.notes || "").toLowerCase().includes(f) ||
              (it.definition || "").toLowerCase().includes(f))
          : items;
        if (filtered.length === 0) {
          modalList.innerHTML = '<p class="px-3 py-6 text-sm text-slate-500 italic text-center">No matches.</p>';
          return;
        }
        // NOTE: validation citation is NOT shown in the modal; it accumulates
        // silently on pick and lands in the Word/MD References section at the
        // end of export. Modal stays focused on operational definitions.
        modalList.innerHTML = filtered.map((it, idx) => `
          <button type="button" data-phenotype-idx="${idx}"
                  class="block w-full text-left px-4 py-3 rounded-lg border border-transparent hover:border-brand-300 hover:bg-brand-50/40 transition">
            <p class="font-semibold text-slate-900 text-sm">${esc(it.name)}</p>
            ${it.codes ? `<p class="mt-1 text-xs text-slate-700 font-mono leading-relaxed">${esc(it.codes)}</p>` : ""}
            ${it.definition ? `<p class="mt-1 text-xs text-slate-600 leading-relaxed">${esc(it.definition)}</p>` : ""}
            ${it.notes ? `<p class="mt-1 text-[11px] text-slate-500 leading-relaxed">${esc(it.notes)}</p>` : ""}
          </button>
        `).join("");
        // Click handler; fill targets + close
        modalList.querySelectorAll("[data-phenotype-idx]").forEach((btn) => {
          btn.addEventListener("click", () => {
            const it = filtered[parseInt(btn.dataset.phenotypeIdx, 10)];
            if (!it) return;
            const fill = (key, val) => {
              const fieldName = currentTargets[key];
              if (!fieldName || val === undefined) return;
              const el = form.querySelector(`[name="${fieldName}"]`);
              if (el) el.value = val;
            };
            fill("name",  it.name);
            fill("codes", it.codes);
            fill("def",   it.definition);
            // For confounding picks: drop the value into the <select> (psMethod)
            if (currentTargets.value && it.value !== undefined) {
              const el = form.querySelector(`[name="${currentTargets.value}"]`);
              if (el) el.value = it.value;
            }
            if (currentTargets.alsoFill) {
              const el = form.querySelector(`[name="${currentTargets.alsoFill}"]`);
              if (el && it.name) el.value = it.name;
            }
            // Record citation for the References section
            if (it.validation) {
              pickedCitations[it.name] = it.validation;
              savePickedCitations();
            }
            closeLibrary();
            render();
          });
        });
      };

      const openLibrary = (category, targets) => {
        currentCategory = category;
        currentTargets  = targets;
        modalTitle.textContent = ({
          indications: "Pick an indication (cohort definition)",
          exposures:   "Pick a drug class (exposure or comparator)",
          outcomes:    "Pick an outcome; fills definition + codes",
          confounding: "Pick a confounding-control method; fills the method + operational details",
        })[category] || "Pick from library";
        modalSearch.value = "";
        renderLibrary("");
        modal.classList.remove("hidden");
        setTimeout(() => modalSearch.focus(), 50);
      };
      const closeLibrary = () => modal.classList.add("hidden");

      // Bind library triggers (from form section headers)
      document.querySelectorAll("[data-open-library]").forEach((btn) => {
        btn.addEventListener("click", () => {
          openLibrary(btn.dataset.category, {
            name:     btn.dataset.targetName,
            codes:    btn.dataset.targetCodes,
            def:      btn.dataset.targetDef,
            value:    btn.dataset.targetValue,
            alsoFill: btn.dataset.alsoFill,
          });
        });
      });
      document.querySelector("[data-library-close]")?.addEventListener("click", closeLibrary);
      modal.addEventListener("click", (e) => { if (e.target === modal) closeLibrary(); });
      document.addEventListener("keydown", (e) => { if (e.key === "Escape") closeLibrary(); });
      modalSearch.addEventListener("input", () => renderLibrary(modalSearch.value));

      setState("ready");
    })();
  </script>
</BaseLayout>
