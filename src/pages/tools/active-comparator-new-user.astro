                shading: { fill: "F5F5F5", type: D.ShadingType.CLEAR },
                children: [p([text(n, { bold: true })])] }),
              new D.TableCell({ borders: cellBorders, margins: { top: 60, bottom: 60, left: 120, right: 120 },
                width: { size: 4113, type: D.WidthType.DXA },
                children: [p([text(label)])] }),
              new D.TableCell({ borders: cellBorders, margins: { top: 60, bottom: 60, left: 120, right: 120 },
                width: { size: 4113, type: D.WidthType.DXA },
                children: mapped.split("\n").map((l) => p([text(l)])) }),
            ]}));
          }
        }
        const fullChecklistTable = new D.Table({
          width: { size: 9026, type: D.WidthType.DXA },
          columnWidths: [800, 4113, 4113],
          rows: checklistRows,
        });

        const children = [];
        children.push(new D.Paragraph({
          children: [text("TARGET checklist; " + (s.title || "(Untitled multi-national ACNU study)"), { bold: true, size: 32 })],
          spacing: { before: 0, after: 120 },
        }));
        children.push(p([new D.TextRun({
          text: "This document maps the protocol fields to the TARGET (TrAnsparent ReportinG of studies Emulating a Target trial) checklist as published in Cashin AG, Hansford HJ, Hernán MA, Swanson SA, Lee H, Jones MD, et al. JAMA 2025; PMID 40899949. The full checklist with elaboration is at target-guideline.org.",
          font: FONT, size: 20, italics: true, color: "555555",
        })]));
        children.push(p([new D.TextRun({
          text: "Generated " + today + " from the AsPEN ACNU protocol builder. Methods items 5-7 are pre-filled from your protocol; Results / Discussion / Other-information items are placeholders to be completed at the time of reporting.",
          font: FONT, size: 18, italics: true, color: "777777",
        })], { spacing: { after: 240 } }));

        children.push(h1("Item 7; Target trial specification vs emulation"));
        children.push(p([text("Item 7 is the heart of TARGET. Rows a-h show what the target trial would specify and how this study emulates each piece in observational data.")]));
        children.push(item7Table);

        children.push(h1("Full TARGET checklist"));
        children.push(p([text("All 21 reporting items with the protocol's current mapping. Replace bracketed placeholders at the manuscript stage.")]));
        children.push(fullChecklistTable);

        children.push(p([new D.TextRun({
          text: "Citation for the framework: Cashin AG, Hansford HJ, Hernán MA, Swanson SA, et al. Transparent Reporting of Observational Studies Emulating a Target Trial: The TARGET Statement. JAMA 2025. PMID 40899949. License: CC BY-ND 4.0.",
          font: FONT, size: 18, italics: true, color: "777777",
        })], { spacing: { before: 400 } }));

        const doc = new D.Document({
          creator: "AsPEN protocol builder; TARGET checklist generator",
          title: "TARGET checklist; " + (s.title || "ACNU protocol"),
          styles: {
            default: { document: { run: { font: FONT, size: 22 } } },
            paragraphStyles: [
              { id: "Heading1", name: "Heading 1", basedOn: "Normal", next: "Normal", quickFormat: true,
                run: { size: 28, bold: true, font: FONT },
                paragraph: { spacing: { before: 240, after: 100 }, outlineLevel: 0 } },
              { id: "Heading2", name: "Heading 2", basedOn: "Normal", next: "Normal", quickFormat: true,
                run: { size: 24, bold: true, font: FONT },
                paragraph: { spacing: { before: 180, after: 60 }, outlineLevel: 1 } },
