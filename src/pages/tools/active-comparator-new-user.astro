---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHeader from "../../components/PageHeader.astro";
import databasesRaw from "../../data/databases.json";

// Feature taxonomy; same 8 dimensions as the /databases/ compare drawer.
const FEATURES = [
  { id: "rx",        short: "Rx",   label: "Prescriptions" },
  { id: "dx",        short: "Dx",   label: "Diagnoses" },
  { id: "labs",      short: "Lab",  label: "Lab results" },
  { id: "imaging",   short: "Img",  label: "Imaging" },
  { id: "mortality", short: "Mor",  label: "Mortality linkage" },
  { id: "cancer",    short: "Can",  label: "Cancer-registry linkage" },
  { id: "pregnancy", short: "Preg", label: "Pregnancy / birth linkage" },
  { id: "genomics",  short: "Gen",  label: "Genomics / biobank linkage" },
];

// Pull the active databases (hidden flag respected). Extract a short label
// from the parenthesised acronym in the canonical name. Build per-database
// entries that the form can pick individually.
const shortDbName = (full: string): string => {
  const m = full.match(/\(([^)]+)\)$/);
  return m ? m[1] : full;
};
const COUNTRY_ORDER = ["TW", "KR", "JP", "HK", "AU", "FI", "GB", "NL", "US"];
type DbRow = typeof databasesRaw[number] & { hidden?: boolean; features?: string[] };
const SITES_DB = (databasesRaw as DbRow[])
  .filter((d) => !d.hidden && COUNTRY_ORDER.includes(d.code))
  .map((d) => ({
    id:       `${d.code}-${shortDbName(d.name).replace(/[^A-Za-z0-9]/g, "")}`,
    country:  d.country,
    code:     d.code,
    short:    shortDbName(d.name),
    features: (d.features ?? []) as string[],
  }))
  .sort((a, b) => {
    const ai = COUNTRY_ORDER.indexOf(a.code);
    const bi = COUNTRY_ORDER.indexOf(b.code);
    if (ai !== bi) return ai - bi;
    return a.short.localeCompare(b.short);
  });
const SITES_DETAIL_MAP: Record<string, { country: string; code: string; short: string; features: string[] }> =
  Object.fromEntries(SITES_DB.map((d) => [d.id, d]));
const SITES_BY_COUNTRY: Record<string, typeof SITES_DB> = SITES_DB.reduce((acc, d) => {
  (acc[d.country] ??= []).push(d);
  return acc;
}, {} as Record<string, typeof SITES_DB>);

const base = import.meta.env.BASE_URL.replace(/\/$/, "");

// Sites mirroring the active set on /databases/ (countries that have an
// AsPEN-tracked database in databases.json). Anything beyond this list
// goes in the "Others" free-text field below the grid.
const SITES = [
  { code: "TW", name: "Taiwan (NHIRD / CGRD / TWB)" },
  { code: "KR", name: "South Korea (HIRA / NHIS-NHID)" },
  { code: "JP", name: "Japan (NDB / JMDC)" },
  { code: "HK", name: "Hong Kong (CDARS)" },
  { code: "GB", name: "United Kingdom (CPRD / THIN / UKB / ISD)" },
  { code: "NL", name: "Netherlands (PHARMO)" },
  { code: "FI", name: "Finland (FinReg)" },
  { code: "AU", name: "Australia (PBS / VLHD)" },
  { code: "US", name: "United States (Medicare / Medicaid)" },
];

// Curated checkbox lists; keeps the form selectable; user can add custom
// lines below each list.
