          : "";
        const sitesOthersList = (s.sitesOther || "").split(/\r?\n/).map((l) => l.trim()).filter(Boolean);
        const sitesText = !sitesPart && sitesOthersList.length === 0
          ? "(no sites selected)"
          : [sitesPart, sitesOthersList.length > 0 ? ("Others: " + sitesOthersList.join("; ")) : ""].filter(Boolean).join(" | ");

        const children = [];

        // Title block
        children.push(new D.Paragraph({
          children: [text(s.title || "(Untitled multi-national ACNU study)", { bold: true, size: 32 })],
          spacing: { before: 0, after: 120 },
        }));
        children.push(labelTable([
          ["Study ID", s.shortId || ""],
          ["Lead investigator(s)", s.leadInvestigator || ""],
          ["Version", s.version || ("v0.1 draft · " + today)],
          ["Design", "Multi-national ACNU cohort study under a target trial emulation framework"
                       + (s.emulatedTrial ? " (emulating " + s.emulatedTrial + ")" : "")],
        ]));
        children.push(p([text(
          "The active comparator is used as an emulated placebo arm; a drug class with similar indication, similar temporal trends in use, and no known a priori association with the outcome of interest. This minimises confounding by indication and addresses immortal-time / prevalent-user bias by anchoring follow-up at the moment of treatment commencement, similar to randomisation in a target RCT (Hernán & Robins 2016)."
        )]));

        children.push(h1("1. Research question"));
        children.push(labelTable([
          ["Population", s.picoP || ""],
          ["Exposure", s.picoI || ""],
          ["Comparator", s.picoC || ""],
          ["Primary outcome", s.picoO || ""],
        ]));

        children.push(h1("2. Sites"));
        children.push(para(sitesText));

        children.push(h1("3. Cohort definition"));
        children.push(labelTable([
          ["Indication / cohort entry", s.indication || ""],
          ["Age range", resolvedAge],
          ["Sex", sex],
        ]));
        children.push(h2("Inclusion criteria"));
        inclusion.length ? inclusion.forEach((l) => children.push(bullet(l))) : children.push(para("(none specified)"));
        children.push(h2("Exclusion criteria"));
        exclusion.length ? exclusion.forEach((l) => children.push(bullet(l))) : children.push(para("(none specified)"));

        children.push(h1("4. Exposure and comparator"));
        children.push(threeColTable(
          ["", "Name", "Code set"],
          [
            ["Exposure",   s.exposureName,   s.exposureCodes],
            ["Comparator", s.comparatorName, s.comparatorCodes],
          ],
        ));
        children.push(para("Washout period: " + (s.washout || "365") + " days; no prior dispensing of EITHER exposure or comparator in this window before index."));
        children.push(para("Index date: " + resolvedIndexDate));

        children.push(h1("5. Outcome ascertainment"));
        children.push(p([text("Operational definition. ", { bold: true }), text(s.outcomeDef || "-")]));
        children.push(p([text("Code set. ", { bold: true }), text(s.outcomeCodes || "-")]));
        children.push(h2("Secondary outcomes"));
        secondary.length ? secondary.forEach((l) => children.push(bullet(l))) : children.push(para("(none specified)"));

        children.push(h1("6. Follow-up and censoring"));
        children.push(labelTable([
          ["Primary analysis", primAn],
          ["Grace period", (s.grace || "30") + " days"],
          ["Maximum follow-up", resolvedMaxFu],
        ]));
        children.push(h2("Censoring rules"));
        censoring.length ? censoring.forEach((l) => children.push(bullet(l))) : children.push(para("(none specified)"));

        children.push(h1("7. Confounding control"));
        children.push(labelTable([
          ["Method", psM],
          ["Covariate look-back", (s.lookback || "365") + " days prior to index date"],
        ]));
        if (s.psMethodDetails && s.psMethodDetails.trim()) {
          children.push(p([text("Method operational details. ", { bold: true }), text(s.psMethodDetails)]));
        }
        children.push(h2("Baseline covariates"));
        covariates.length ? covariates.forEach((l) => children.push(bullet(l))) : children.push(para("(none specified)"));
        children.push(para("PS model performance is assessed via standardised mean differences (SMDs) before/after weighting/matching (target < 0.1 across all covariates) and the c-statistic of the PS model."));

        children.push(h1("8. Statistical analysis"));
        children.push(labelTable([
          ["Effect estimate", eff],
          ["Meta-analysis", meta],
        ]));
        children.push(h2("Subgroup analyses"));
        subgroups.length ? subgroups.forEach((l) => children.push(bullet(l))) : children.push(para("(none specified)"));
        children.push(h2("Sensitivity analyses"));
        sensitivity.length ? sensitivity.forEach((l) => children.push(bullet(l))) : children.push(para("(none specified)"));

        children.push(h1("9. Sample size and power"));
        children.push(para("To be calculated per site using observed event rates among comparator users in pilot extractions; aim for ≥80% power to detect the smallest clinically meaningful effect for the primary outcome at α = 0.05, two-sided, after pooling. Pilot estimates are circulated before final analytic execution."));

        children.push(h1("10. Execution and timeline"));
        children.push(labelTable([
          ["Architecture", arch],
          ["CDM", s.cdm || "-"],
        ]));
        children.push(h2("Timeline milestones"));
        milestones.length ? milestones.forEach((l) => children.push(numItem(l))) : children.push(para("(none)"));

        children.push(h1("11. Ethics, data sharing, dissemination"));
        children.push(p([text("Ethics. ", { bold: true }), text(s.ethics || "Each participating site obtains local IRB / ethics approval before data extraction.")]));
        children.push(p([text("Dissemination. ", { bold: true }), text(s.dissemination || "Primary manuscript to a peer-reviewed pharmacoepidemiology journal; conference presentation at ICPE / ISPE Asian conference.")]));

        children.push(h1("12. Key references"));
        refs.length ? refs.forEach((l) => children.push(numItem(l))) : children.push(para("(none)"));

        // Footer-style line
        children.push(p([new D.TextRun({ text: "Drafted with the AsPEN protocol builder (" + today + ").", font: FONT, size: 18, italics: true, color: "808080" })], { spacing: { before: 400 } }));

        const doc = new D.Document({
          creator: "AsPEN protocol builder",
          title: s.title || "AsPEN ACNU protocol",
          styles: {
            default: { document: { run: { font: FONT, size: 22 } } },   // 11pt body
            paragraphStyles: [
              { id: "Heading1", name: "Heading 1", basedOn: "Normal", next: "Normal", quickFormat: true,
                run: { size: 28, bold: true, font: FONT },
                paragraph: { spacing: { before: 200, after: 80 }, outlineLevel: 0 } },
              { id: "Heading2", name: "Heading 2", basedOn: "Normal", next: "Normal", quickFormat: true,
                run: { size: 24, bold: true, font: FONT },
                paragraph: { spacing: { before: 160, after: 60 }, outlineLevel: 1 } },
            ],
          },
          numbering: {
            config: [{
              reference: "ordered",
              levels: [{
                level: 0, format: D.LevelFormat.DECIMAL, text: "%1.",
                alignment: D.AlignmentType.LEFT,
                style: { paragraph: { indent: { left: 720, hanging: 360 } } },
              }],
            }],
          },
          sections: [{
            properties: {
              page: {
                size: { width: 11906, height: 16838 },  // A4
                margin: { top: 1440, right: 1440, bottom: 1440, left: 1440 },
              },
            },
            children,
          }],
        });

        return await D.Packer.toBlob(doc);
      };

      // ── TARGET checklist document ────────────────────
      // Produces a Word file mapping the protocol to the TARGET checklist
      // (Cashin AG, Hansford HJ, Hernán MA, Swanson SA et al. JAMA 2025;
      // PMID 40899949). Item 7 (target trial emulation) is the centrepiece -
      // a 3-column table with rows a-h showing 'Target trial specification'
      // vs 'Emulation in this study'. Items in Results / Discussion / Other
      // are stubbed as placeholders to be completed at reporting time.
      const buildTargetDocx = async (s) => {
        const D = docx;
        const FONT = "Times New Roman";
        const today = new Date().toISOString().slice(0, 10);
        const text = (str, opts = {}) => new D.TextRun({ text: String(str ?? ""), font: FONT, size: 22, ...opts });
        const p = (children, opts = {}) => new D.Paragraph({
          children: Array.isArray(children) ? children : [children],
          spacing: { before: 60, after: 60, ...(opts.spacing || {}) },
          ...opts,
        });
        const h1 = (str) => new D.Paragraph({
          children: [text(str, { bold: true, size: 28 })],
          spacing: { before: 240, after: 100 },
          heading: D.HeadingLevel.HEADING_1,
        });
        const h2 = (str) => new D.Paragraph({
          children: [text(str, { bold: true, size: 24 })],
          spacing: { before: 180, after: 60 },
          heading: D.HeadingLevel.HEADING_2,
        });
        const para = (str) => p([text(str)]);
        const border = { style: D.BorderStyle.SINGLE, size: 4, color: "BBBBBB" };
        const cellBorders = { top: border, bottom: border, left: border, right: border };
        const tcell = (str, opts = {}) => new D.TableCell({
          borders: cellBorders,
          margins: { top: 80, bottom: 80, left: 120, right: 120 },
          ...(opts.shading ? { shading: opts.shading } : {}),
          width: opts.width,
          children: (Array.isArray(str) ? str : [str]).map((x) =>
            typeof x === "string" ? p([text(x, opts.runOpts || {})]) : x),
        });
        const HEADER_FILL = { fill: "21443E", type: D.ShadingType.CLEAR };

        // Resolve fields the same way the main Word/MD generators do
        const indexDateLabel = (val) => (INDEX_DATE_OPTIONS.find((o) => o.value === val) || {}).label || "";
        const resolvedIndexDate = s.indexDateChoice === "custom"
          ? (s.indexDateCustom || "Custom; see study-specific protocol")
          : indexDateLabel(s.indexDateChoice) || indexDateLabel("after-washout");
        const resolvedMaxFu = s.maxFollowupChoice === "custom"
          ? (s.maxFollowupCustom || "Custom; see study-specific protocol")
          : (s.maxFollowupChoice || "5 years per patient, or until censoring (whichever first)");
        const resolvedAge = s.ageRangeChoice === "custom"
          ? (s.ageRangeCustom || "(specify)")
          : (s.ageRangeChoice || "≥18, no upper limit");
        const inclusion  = mergeList(s.inclusionPick,  s.inclusionCustom);
        const exclusion  = mergeList(s.exclusionPick,  s.exclusionCustom);
        const censoring  = mergeList(s.censoringPick,  s.censoringCustom);
        const covariates = mergeList(s.covariatesPick, s.covariatesCustom);
        const sensitivity = mergeList(s.sensitivityPick, s.sensitivityCustom);
        const psM   = PS_METHOD_DESCRIPTIONS[s.psMethod] || "PS-based adjustment";
        const eff   = ({ HR: "Hazard ratio (95% CI) from Cox PH models", RR: "Risk ratio (95% CI) from Poisson regression", RD: "Risk difference (95% CI)", IRR: "Incidence rate ratio (95% CI)" })[s.effectMeasure] || "Hazard ratio";
        const primAn= ({ ITT: "Intention-to-treat (ITT)", OT: "On-treatment (per-protocol)", both: "Both ITT and on-treatment" })[s.primaryAnalysisType] || "On-treatment";
        const sitesPlain = (s.sites && s.sites.length > 0)
          ? s.sites.map((c) => formatSiteFull(c)).join("; ")
          : "(no sites selected)";
        const sitesOthersList = (s.sitesOther || "").split(/\r?\n/).map((l) => l.trim()).filter(Boolean);
        const sitesAll = sitesOthersList.length > 0
          ? sitesPlain + " | Others: " + sitesOthersList.join("; ")
          : sitesPlain;
        const bulletText = (arr) => arr.length === 0 ? "(none specified)" : arr.map((l) => "• " + l).join("\n");

        const COL_W = [1700, 3563, 3763];   // sum ≈ 9026 (A4 minus 1" margins)
        const headerCell = (str) => new D.TableCell({
          borders: cellBorders,
          shading: HEADER_FILL,
          margins: { top: 80, bottom: 80, left: 120, right: 120 },
          children: [p([text(str, { bold: true, color: "FFFFFF" })])],
        });

        const row7 = (label, spec, emul) => new D.TableRow({
          children: [
            new D.TableCell({ borders: cellBorders, margins: { top: 80, bottom: 80, left: 120, right: 120 },
              shading: { fill: "F5F5F5", type: D.ShadingType.CLEAR },
              width: { size: COL_W[0], type: D.WidthType.DXA },
              children: [p([text(label, { bold: true })])] }),
            new D.TableCell({ borders: cellBorders, margins: { top: 80, bottom: 80, left: 120, right: 120 },
              width: { size: COL_W[1], type: D.WidthType.DXA },
              children: [p([text(spec)])] }),
            new D.TableCell({ borders: cellBorders, margins: { top: 80, bottom: 80, left: 120, right: 120 },
              width: { size: COL_W[2], type: D.WidthType.DXA },
              children: emul.split("\n").map((line) => p([text(line)])) }),
          ],
        });

        const item7Table = new D.Table({
          width: { size: 9026, type: D.WidthType.DXA },
          columnWidths: COL_W,
          rows: [
            new D.TableRow({
              tableHeader: true,
              children: [
                headerCell("Item 7 element"),
                headerCell("Target trial specification"),
                headerCell("Emulation with the observational data"),
              ],
            }),
            row7("a. Eligibility criteria",
              "Adults of the relevant indication; new users (no prior dispensing of exposure or comparator in the washout window).",
              "Indication: " + (s.indication || "(specify)") + ". Age: " + resolvedAge + ". Sex: " +
              (({ both: "both sexes", female: "female only", male: "male only" })[s.sex] || "both sexes") + ".\n" +
              "Inclusion criteria:\n" + bulletText(inclusion) + "\n" +
              "Exclusion criteria:\n" + bulletText(exclusion)),
            row7("b. Treatment strategies",
              "Initiate " + (s.picoI || s.exposureName || "(exposure)") + " vs initiate " + (s.picoC || s.comparatorName || "(active comparator)") + "; drugs of the same indication that compete for use.",
              "Exposure: " + (s.exposureName || "(name)") + " (" + (s.exposureCodes || "codes TBD") + ").\n" +
              "Active comparator: " + (s.comparatorName || "(name)") + " (" + (s.comparatorCodes || "codes TBD") + ").\n" +
              "Washout for new-user status: " + (s.washout || "365") + " days."),
            row7("c. Assignment procedures",
              "Random assignment at the start of treatment.",
              "Treatment assignment is determined by the first dispensing of either drug after the washout window. Baseline confounding addressed via " + psM + "."),
            row7("d. Follow-up",
              "Follow-up begins at the time of assignment to treatment strategies and ends at outcome, death, or end of study period.",
              "Index date: " + resolvedIndexDate + ".\n" +
              "Follow-up window: " + resolvedMaxFu + ".\n" +
              "Censoring rules:\n" + bulletText(censoring) + ".\n" +
              "Primary analysis: " + primAn + " (grace period " + (s.grace || "30") + " days)."),
            row7("e. Outcomes",
              "Primary outcome: " + (s.picoO || "(specify)") + ".",
              "Operational definition: " + (s.outcomeDef || "(specify)") + "\n" +
              "Code set: " + (s.outcomeCodes || "(specify)")),
            row7("f. Causal contrasts",
              "Effect of starting and following the assigned treatment strategy (per-protocol effect) and effect of being assigned the strategy (intention-to-treat-equivalent effect).",
              "Effect estimate: " + eff + ".\n" +
              "Site-specific estimates pooled via " +
              ({ re: "random-effects (DerSimonian-Laird) meta-analysis with I² and τ²",
                 "re-reml": "random-effects (REML) meta-analysis with I² and τ²",
                 fe: "fixed-effects (inverse-variance) meta-analysis" })[s.metaMethod] || "random-effects meta-analysis" + "."),
            row7("g. Identifying assumptions",
              "Conditional exchangeability would hold by randomisation. No interference; consistency.",
              "Conditional exchangeability assumed given baseline covariates listed below, addressed via " + psM + ". Covariate look-back: " + (s.lookback || "365") + " days. Sensitivity analyses for unmeasured confounding:\n" + bulletText(sensitivity.filter((l) => /negative control|trim|e-value|hdps|sensitivity/i.test(l))) + "\nBaseline covariates:\n" + bulletText(covariates.slice(0, 12)) + (covariates.length > 12 ? "\n…and " + (covariates.length - 12) + " more (see Section 7 of the protocol)." : "")),
            row7("h. Data analysis plan",
              "Statistical analysis estimates the causal contrasts under the identifying assumptions.",
              "Primary: " + psM + ".\n" +
              (s.psMethodDetails ? "Operational details: " + s.psMethodDetails + ".\n" : "") +
              "Subgroup analyses:\n" + bulletText((s.subgroups || "").split(/\r?\n/).map((l) => l.trim()).filter(Boolean)) + "\nSensitivity analyses:\n" + bulletText(sensitivity)),
          ],
        });

        const fullChecklist = [
          ["Abstract", [
            ["1a", "Identify that the study attempts to emulate a target trial using observational data; state objectives and briefly summarise the specified target trial.",
              "This study emulates a target trial of " + (s.picoI || "(exposure)") + " vs " + (s.picoC || "(comparator)") + " among " + (s.picoP || "(population)") +
              (s.emulatedTrial ? ", adapted from " + s.emulatedTrial + "" : "") + "."],
            ["1b", "Report the data source(s) used for emulation.",
              "Multi-national federated analysis using AsPEN sites: " + sitesAll + "."],
            ["1c", "Summarise key assumptions, statistical methods, findings and conclusions.",
              "[To be completed at the time of reporting.]"],
          ]],
          ["Introduction", [
            ["2", "Background; scientific context and gap in knowledge.", "[Background paragraph from your protocol.]"],
            ["3", "Causal question.",
              "Among " + (s.picoP || "(population)") + ", does new use of " + (s.picoI || "(exposure)") + " versus " + (s.picoC || "(comparator)") + " change the incidence of " + (s.picoO || "(outcome)") + "?"],
            ["4", "Rationale for emulating a target trial with the available data; cite informing RCTs.",
              s.emulatedTrial ? "Target trial design adapted from: " + s.emulatedTrial + "." : "Target trial design specified de novo given absence / infeasibility of an RCT."],
          ]],
          ["Methods", [
            ["5", "Data source(s): original purpose, type, geographic location(s), setting, time-period; data linkage if relevant.",
              sitesAll + "."],
            ["6", "Target trial specification.", "See Item 7 specification column below."],
            ["7", "Target trial emulation (a-h).", "See the comparison table above."],
          ]],
          ["Results", [
            ["8",  "Participant selection (flow diagram strongly recommended).", "[To be completed at the time of reporting.]"],
            ["9",  "Baseline data by treatment strategy.", "[Table 1 of the manuscript.]"],
            ["10", "Follow-up length and reasons for end of follow-up.", "[To be completed at the time of reporting.]"],
            ["11", "Missing data, by treatment strategy.", "[To be completed at the time of reporting.]"],
            ["12", "Outcome frequency / distribution, by treatment strategy.", "[To be completed at the time of reporting.]"],
            ["13", "Effect estimates with measures of precision; absolute and relative.", "[To be completed at the time of reporting.]"],
            ["14", "Sensitivity / additional analyses.", "[See sensitivity analyses pre-specified in the protocol Section 9.]"],
          ]],
          ["Discussion", [
            ["15", "Interpretation of key findings.", "[To be completed at the time of reporting.]"],
            ["16", "Limitations; differences between target trial and emulation; plausibility of assumptions.",
              "Residual / unmeasured confounding cannot be excluded. Treatment switching during follow-up is censored per the on-treatment analysis. Misclassification of outcome possible."],
          ]],
          ["Other information", [
            ["17", "Ethics approval and approval number(s).", s.ethics || "Each participating site obtains local IRB / ethics approval before data extraction."],
            ["18", "Study protocol registration (where).", "[Register on ENCePP EU PAS Register and/or ClinicalTrials.gov where applicable.]"],
            ["19", "Sharing of data, analytic code, materials.", "[To be specified.]"],
            ["20", "Funding source(s).", "[To be specified.]"],
            ["21", "Conflicts of interest.", "[To be specified for each author.]"],
          ]],
        ];

        const checklistRows = [
          new D.TableRow({ tableHeader: true, children: [
            headerCell("#"), headerCell("Item"), headerCell("Where reported in this protocol"),
          ]}),
        ];
        for (const [section, items] of fullChecklist) {
          checklistRows.push(new D.TableRow({ children: [
            new D.TableCell({ borders: cellBorders, columnSpan: 3,
              shading: { fill: "E8F0EE", type: D.ShadingType.CLEAR },
              margins: { top: 60, bottom: 60, left: 120, right: 120 },
              children: [p([text(section, { bold: true, color: "21443E" })])] }),
          ]}));
          for (const [n, label, mapped] of items) {
            checklistRows.push(new D.TableRow({ children: [
              new D.TableCell({ borders: cellBorders, margins: { top: 60, bottom: 60, left: 120, right: 120 },
