// Common inclusion / exclusion criteria; surfaced as checkboxes so a
// typical AsPEN ACNU protocol can be assembled almost entirely by ticking.
const INCLUSION = [
  "Adult (≥18 years) at index date",
  "Continuous enrolment in the source database for ≥365 d before index",
  "≥1 outpatient visit in the 365 d before index (engagement with care)",
  "≥1 prior dispensing of indication-defining drug class in look-back",
  "Available primary-care record (CPRD / linked EHR studies only)",
];

const EXCLUSION = [
  "Prior dispensing of EITHER exposure or comparator within the washout window",
  "Type 1 diabetes (ICD-10 E10.x) ever before index",
  "Pregnancy at or in the 90 d before index",
  "eGFR <30 ml/min/1.73m² at index (where available)",
  "End-stage renal disease / chronic dialysis ever",
  "Active cancer in the 365 d before index (solid or haematologic)",
  "Hospice or palliative-care enrolment in the 90 d before index",
  "Severe liver disease ever (cirrhosis, decompensated)",
  "Type 2 MI / unstable angina in the 30 d before index (if CV outcome)",
  "In-hospital at index date",
];

// Thirteen confounding-control approaches with operational definitions
// and method citations. Picking from the library fills both the dropdown
// and an editable 'Method operational details' textarea; the citation
// auto-appends to the References section at export time.
const PS_METHODS: { value: string; label: string; definition: string; validation: string }[] = [
  {
    value: "iptw",
    label: "Stabilised IPTW with PS trimming",
    definition: "Estimate the propensity score (PS) for treatment via multivariable logistic regression on all baseline covariates (Section 7). Compute stabilised inverse-probability-of-treatment weights and trim the weight distribution at the 1st and 99th percentile. Estimate the marginal hazard ratio in a weighted Cox proportional-hazards model.",
    validation: "Robins JM, Hernán MA, Brumback B. Marginal structural models and causal inference in epidemiology. Epidemiology 2000;11(5):550-60. Cole SR, Hernán MA. Constructing inverse probability weights for marginal structural models. Am J Epidemiol 2008;168:656-64.",
  },
  {
    value: "iptw-overlap",
    label: "Overlap weights",
    definition: "Estimate the PS; compute overlap weights as PS × (1 − PS), which down-weight units with extreme PS values. Apply weights in a marginal Cox model. Overlap weights guarantee exact mean balance on all measured covariates in the weighted population and are robust to extreme PS values.",
    validation: "Li F, Morgan KL, Zaslavsky AM. Balancing covariates via propensity score weighting. J Am Stat Assoc 2018;113:390-400. Li F, Thomas LE, Li F. Addressing extreme propensity scores via the overlap weights. Am J Epidemiol 2019;188:250-7.",
  },
  {
    value: "match-1to1",
    label: "1:1 PS matching",
    definition: "Estimate the PS via multivariable logistic regression. Match exposed and comparator users 1:1 using nearest-neighbour matching on the logit of the PS, with a caliper of 0.2 × SD of the logit PS, without replacement. Estimate the matched hazard ratio in a Cox model stratified on matched pair.",
    validation: "Austin PC. Some methods of propensity-score matching had superior performance to others. Biom J 2009;51:171-84.",
  },
  {
    value: "match-1ton",
    label: "1:N variable-ratio PS matching",
    definition: "Estimate the PS. Match each exposed user to up to N (typically 4) nearest-neighbour comparators on the logit PS with a 0.2 × SD logit-PS caliper, without replacement, allowing variable ratios. Analyse via a Cox model with cluster-robust variance.",
    validation: "Ming K, Rosenbaum PR. Substantial gains in bias reduction from matching with a variable number of controls. Biometrics 2000;56:118-24.",
  },
  {
    value: "match-greedy",
    label: "Greedy PS matching with replacement",
    definition: "Estimate the PS. Match each exposed user to the nearest-neighbour comparator on the PS within a 0.2 × SD logit-PS caliper, allowing comparators to be re-used. Analyse via Cox regression with cluster-robust variance to account for re-use.",
    validation: "Rosenbaum PR, Rubin DB. The bias due to incomplete matching. Biometrics 1985;41:103-16.",
  },
  {
    value: "strat",
    label: "PS stratification (deciles)",
    definition: "Estimate the PS and stratify the cohort into deciles. Estimate within-stratum hazard ratios using a Cox model stratified on PS decile; pool across strata via a stratified analysis.",
    validation: "Rosenbaum PR, Rubin DB. Reducing bias in observational studies using subclassification on the propensity score. J Am Stat Assoc 1984;79:516-24.",
  },
  {
    value: "hdps",
    label: "High-dimensional propensity score (HDPS)",
    definition: "Generate empirical covariates from claims (diagnoses, procedures, dispensings, healthcare utilisation in the look-back window). Prioritise covariates by their potential to confound using the Bross formula. Include top 200-500 empirical covariates plus pre-specified covariates in the PS model. Apply via IPTW or matching.",
    validation: "Schneeweiss S, Rassen JA, Glynn RJ, Avorn J, Mogun H, Brookhart MA. High-dimensional propensity score adjustment in studies of treatment effects using health care claims data. Epidemiology 2009;20:512-22.",
  },
  {
    value: "drs",
    label: "Disease risk score (DRS) adjustment",
    definition: "Model the outcome on baseline covariates in the unexposed (or full cohort) to derive each patient's predicted absolute risk (DRS). Match or stratify exposed vs unexposed users on DRS quantiles, or include DRS as a regression adjustment.",
    validation: "Arbogast PG, Ray WA. Use of disease risk scores in pharmacoepidemiologic studies. Stat Methods Med Res 2009;18:67-80. Hansen BB. The prognostic analogue of the propensity score. Biometrika 2008;95:481-8.",
  },
  {
    value: "tmle",
    label: "Targeted maximum likelihood estimation (TMLE)",
    definition: "Estimate the PS and the outcome regression flexibly (e.g., Super Learner with multiple algorithms). Apply a targeted update step to the outcome regression using the score equation derived from the PS. TMLE is doubly robust: consistent if either the PS or the outcome model is correct.",
    validation: "van der Laan MJ, Rose S. Targeted Learning. Springer 2011. Schuler MS, Rose S. Targeted maximum likelihood estimation for causal inference in observational studies. Am J Epidemiol 2017;185:65-73.",
  },
  {
    value: "gformula",
    label: "G-formula / parametric standardisation",
    definition: "Fit an outcome regression model on covariates and exposure. Predict counterfactual outcomes under exposure and non-exposure for each individual, holding covariates at their observed values, and average across the population to obtain the marginal hazard ratio or risk difference.",
    validation: "Robins JM. A new approach to causal inference in mortality studies with sustained exposure periods. Math Modelling 1986;7:1393-512. Snowden JM, Rose S, Mortimer KM. Am J Epidemiol 2011;173:731-8.",
  },
  {
    value: "msm",
    label: "Marginal structural model (stabilised IPTW + Cox)",
    definition: "Compute stabilised inverse-probability weights via PS modelling. Fit a marginal structural Cox model on the weighted population. Allows time-varying confounders affected by previous exposure; for ACNU with fixed treatment assignment typically reduces to standard IPTW Cox.",
    validation: "Robins JM, Hernán MA, Brumback B. Marginal structural models and causal inference in epidemiology. Epidemiology 2000;11:550-60.",
  },
  {
    value: "outcome-reg",
    label: "Multivariable outcome regression",
    definition: "Fit a multivariable Cox proportional-hazards regression directly, including the exposure indicator and all pre-specified baseline covariates (Section 7). No PS used. Best when the outcome model is correctly specified and covariate balance between groups is acceptable.",
    validation: "Hernán MA, Robins JM. Causal Inference: What If. Chapman & Hall/CRC 2020.",
  },
  {
    value: "iv",
    label: "Instrumental variable (IV) analysis",
    definition: "Use an instrument (e.g., physician's preference for exposure or geographic variation) that affects exposure but is independent of unmeasured confounders. Estimate the local average treatment effect via two-stage least squares (continuous outcome) or two-stage residual inclusion (time-to-event).",
    validation: "Brookhart MA, Wang PS, Solomon DH, Schneeweiss S. Evaluating short-term drug effects using a physician-specific prescribing preference as an instrumental variable. Epidemiology 2006;17:268-75.",
  },
];

const PS_METHOD_DESCRIPTIONS: Record<string, string> = Object.fromEntries(PS_METHODS.map((m) => [m.value, m.label]));

const INDEX_DATE_OPTIONS: { value: string; label: string }[] = [
