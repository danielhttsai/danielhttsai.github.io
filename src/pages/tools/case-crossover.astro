---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHeader from "../../components/PageHeader.astro";
import DesignDiagram from "../../components/DesignDiagram.astro";
import ProtocolCommon from "../../components/ProtocolCommon.astro";
import databasesRaw from "../../data/databases.json";
import { STROBE_ITEMS } from "../../data/strobe";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");

// Feature taxonomy + per-database site catalogue (mirrors ACNU / SCCS templates).
const FEATURES = [
  { id: "rx",        short: "Rx",   label: "Prescriptions" },
  { id: "dx",        short: "Dx",   label: "Diagnoses" },
  { id: "labs",      short: "Lab",  label: "Lab results" },
  { id: "imaging",   short: "Img",  label: "Imaging" },
  { id: "mortality", short: "Mor",  label: "Mortality linkage" },
  { id: "cancer",    short: "Can",  label: "Cancer-registry linkage" },
  { id: "pregnancy", short: "Preg", label: "Pregnancy / birth linkage" },
  { id: "genomics",  short: "Gen",  label: "Genomics / biobank linkage" },
];
const shortDbName = (full: string): string => {
  const m = full.match(/\(([^)]+)\)$/);
  return m ? m[1] : full;
};
const COUNTRY_ORDER = ["TW", "KR", "JP", "HK", "AU", "FI", "GB", "NL", "US"];
type DbRow = typeof databasesRaw[number] & { hidden?: boolean; features?: string[] };
const SITES_DB = (databasesRaw as DbRow[])
  .filter((d) => !d.hidden && COUNTRY_ORDER.includes(d.code))
  .map((d) => ({
    id:       `${d.code}-${shortDbName(d.name).replace(/[^A-Za-z0-9]/g, "")}`,
    country:  d.country,
    code:     d.code,
    short:    shortDbName(d.name),
    features: (d.features ?? []) as string[],
  }))
  .sort((a, b) => {
    const ai = COUNTRY_ORDER.indexOf(a.code);
    const bi = COUNTRY_ORDER.indexOf(b.code);
    if (ai !== bi) return ai - bi;
    return a.short.localeCompare(b.short);
  });
const SITES_DETAIL_MAP: Record<string, { country: string; code: string; short: string; features: string[] }> =
  Object.fromEntries(SITES_DB.map((d) => [d.id, d]));
const SITES_BY_COUNTRY: Record<string, typeof SITES_DB> = SITES_DB.reduce((acc, d) => {
  (acc[d.country] ??= []).push(d);
  return acc;
}, {} as Record<string, typeof SITES_DB>);

const PHENOTYPES = {
  exposures: [
    { name: "SGLT2 inhibitors",          codes: "ATC A10BK*" },
    { name: "GLP-1 receptor agonists",   codes: "ATC A10BJ*" },
    { name: "Antipsychotics (any)",      codes: "ATC N05A*" },
    { name: "ADHD stimulants",           codes: "ATC N06BA; methylphenidate N06BA04, amphetamine N06BA01, lisdexamfetamine N06BA12" },
    { name: "Opioid analgesics",         codes: "ATC N02A*" },
    { name: "NSAIDs",                    codes: "ATC M01A* (excluding M01AX)" },
    { name: "PPIs",                      codes: "ATC A02BC*" },
    { name: "Z-drugs (zolpidem etc.)",   codes: "ATC N05CF*" },
    { name: "Benzodiazepines",           codes: "ATC N05BA*, N05CD*" },
    { name: "Anticholinergics",          codes: "ATC N06AA*, N04A*, R06AA*, R06AD*, A03BA*" },
    { name: "Anticoagulants; DOACs",    codes: "ATC B01AE07, B01AF01, B01AF02, B01AF03" },
    { name: "Anticoagulants; warfarin", codes: "ATC B01AA03" },
  ],
  outcomes: [
    {
      name: "Myocardial infarction (MI)",
      codes: "ICD-10 I21.*, I22.* (primary discharge diagnosis)",
      definition: "First hospitalisation with a primary discharge diagnosis of acute MI within the case-ascertainment window.",
      validation: "Cheng CL et al. Validation of acute MI cases in the NHIRD. J Epidemiol 2014;24(6):500-7.",
    },
    {
      name: "Ischemic stroke",
      codes: "ICD-10 I63.*, I64.* (primary discharge diagnosis)",
      definition: "First hospitalisation with primary discharge diagnosis of ischemic stroke.",
      validation: "Cheng CL et al. Pharmacoepidemiol Drug Saf 2011;20(3):236-42. Hsieh CY et al. J Formos Med Assoc 2015;114(3):254-9.",
    },
    {
      name: "Hip fracture",
      codes: "ICD-10 S72.0, S72.1, S72.2 (primary discharge diagnosis), paired with surgical-fixation procedure code.",
      definition: "First hospitalisation with primary discharge hip-fracture diagnosis during the case-ascertainment window.",
      validation: "AsPEN hip-fracture multi-country work; Lai EC et al, BMJ Open 2021/2023.",
    },
    {
      name: "Falls",
      codes: "ICD-10 W00-W19 (external cause), with paired injury codes for higher specificity.",
      definition: "First ED / hospital encounter with a fall code.",
      validation: "Used in the AsPEN antipsychotic-cholinesterase falls/fractures SCCS (Wang GH et al, BMJ 2021;PMID 34503972).",
    },
    {
      name: "Acute kidney injury (AKI)",
      codes: "ICD-10 N17.* (primary discharge diagnosis), with creatinine criteria where lab linkage exists.",
      definition: "First hospitalisation with primary discharge AKI diagnosis.",
      validation: "Shao SC et al CGRD AKI work.",
    },
    {
      name: "Intracranial haemorrhage",
      codes: "ICD-10 I60.*, I61.*, I62.* (primary discharge diagnosis)",
      definition: "First hospitalisation with primary discharge ICH diagnosis.",
      validation: "NHIRD-validated; CGRD-confirmed in Shao SC et al DOAC studies.",
    },
    {
      name: "GI bleeding",
      codes: "ICD-10 K25.0/.2/.4/.6, K26.0/.2/.4/.6, K27.*, K28.*, K29.0, K92.0/.1/.2 (primary discharge diagnosis)",
      definition: "First hospitalisation with primary discharge GI bleed diagnosis.",
      validation: "Used in AsPEN PSSA NSAID/PPI safety work (Andersen M, Pratt N et al. PDS 2013).",
    },
    {
      name: "Suicide / self-harm",
      codes: "ICD-10 X60-X84, Y87.0; T-codes for intentional poisoning.",
      definition: "First ED / hospital / mortality record with suicide or intentional self-harm code.",
      validation: "Man KKC et al Lancet Psychiatry 2024 (PMID 39241791).",
    },
  ],
};

const SUBGROUPS = [
  "Age (≥65 vs <65 years)",
  "Age (≥75 vs <75 years)",
  "Sex (male vs female)",
  "Country / site",
  "First-ever vs repeated exposure",
  "Index calendar year stratum",
  "Baseline CV disease (yes vs no)",
  "Baseline CKD (eGFR <60 vs ≥60)",
  "Frailty / Charlson Comorbidity Index (high vs low)",
  "Concomitant exposure (yes vs no)",
];

const SENSITIVITY = [
  "Alternative hazard window length (e.g., 1 d, 7 d, 14 d, 30 d)",
  "Alternative control window offset (30, 60, 90, 180 d before)",
  "Multiple control windows (e.g., 4 control periods to reduce variance)",
  "Restrict to incident exposure only (first ever dispensing)",
  "Time-stratified case-crossover (Janes et al 2005); controls drawn from same calendar stratum",
  "Symmetric bidirectional sampling (control before and after event)",
  "Negative-control outcome; should show null",
  "Exclude events within 30 days of cohort entry to avoid prevalent-user bias",
  "Stratify by season to control for time-trends in exposure",
];

const TIMELINE_PRESETS: Record<string, string> = {
  "12-month": [
    "Month 0: Protocol finalised, site IRB submissions begin",
    "Month 3: All site IRB approvals received",
    "Month 4-6: Local case identification and hazard/control window construction",
    "Month 7-9: Conditional logistic regression at each site",
    "Month 10-11: Site ORs returned to coordinating centre; meta-analysis",
    "Month 12: First manuscript draft circulated",
  ].join("\n"),
  "18-month": [
    "Month 0-3: Protocol finalisation, code-set harmonisation, IRB submissions",
    "Month 4-7: Local case identification and window construction",
    "Month 8-12: Primary case-crossover, time-stratified sensitivity",
    "Month 13-15: Meta-analysis and forest plots",
    "Month 16-18: Manuscript drafting and submission",
  ].join("\n"),
};
---

<BaseLayout
  title="Protocol template · Case-crossover · AsPEN members"
  description="Guided form for drafting a multi-national case-crossover protocol."
>
  <PageHeader
    eyebrow="Members → Templates → Case-crossover"
    title="Multi-national case-crossover builder"
    description="Each case acts as their own control across time. Compare exposure prevalence in a short hazard window immediately before the event with prevalence in matched control windows further back."
  />

  <section class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-8 space-y-6">
    <div class="flex items-center justify-between gap-3 flex-wrap">
      <a class="text-sm text-brand-700 hover:underline font-semibold" href={`${base}/tools/protocol-generator/`}>← All templates</a>
      <button type="button" data-action="reset-top" class="text-xs font-semibold text-rose-700 border border-rose-300 hover:bg-rose-50 px-3 py-1.5 rounded transition">
        ⟲ Clear &amp; start over
      </button>
    </div>

    <div data-state="ready" class="grid gap-8 lg:grid-cols-[1fr,1fr] items-start">

      <form data-builder class="space-y-6">

        <details open class="border border-slate-200 rounded-2xl bg-white shadow-sm">
          <summary class="cursor-pointer select-none px-5 py-4 font-semibold text-slate-900 hover:bg-slate-50 rounded-2xl">1 · Study identification</summary>
          <div class="px-5 pb-5 grid sm:grid-cols-2 gap-3">
            <label class="flex flex-col gap-1 sm:col-span-2">
              <span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Study title</span>
              <input type="text" name="title" placeholder="e.g. NSAID dispensing in the 7 days before acute MI: an AsPEN multi-country case-crossover study" class="border border-slate-300 rounded px-3 py-2 text-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500" />
            </label>
            <label class="flex flex-col gap-1">
              <span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Short ID</span>
              <input type="text" name="shortId" placeholder="AsPEN-NSAID-MI-CCO-2026" class="border border-slate-300 rounded px-3 py-2 text-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500" />
            </label>
            <label class="flex flex-col gap-1">
              <span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Version · Date</span>
              <input type="text" name="version" placeholder="v0.1 draft · 2026-05-29" class="border border-slate-300 rounded px-3 py-2 text-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500" />
            </label>
            <label class="flex flex-col gap-1 sm:col-span-2">
              <span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Lead investigator(s)</span>
              <input type="text" name="leadInvestigator" placeholder="Name, affiliation; co-leads if any" class="border border-slate-300 rounded px-3 py-2 text-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500" />
            </label>
          </div>
        </details>

        <details open class="border border-slate-200 rounded-2xl bg-white shadow-sm">
          <summary class="cursor-pointer select-none px-5 py-4 font-semibold text-slate-900 hover:bg-slate-50 rounded-2xl">2 · Research question</summary>
          <div class="px-5 pb-5 grid sm:grid-cols-2 gap-3">
            <label class="flex flex-col gap-1 sm:col-span-2">
              <span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Population</span>
              <input type="text" name="picoP" placeholder="Adults hospitalised with a first MI during the study period" class="border border-slate-300 rounded px-3 py-2 text-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500" />
            </label>
            <label class="flex flex-col gap-1">
              <span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Exposure</span>
              <input type="text" name="picoI" placeholder="NSAID dispensing" class="border border-slate-300 rounded px-3 py-2 text-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500" />
            </label>
            <label class="flex flex-col gap-1">
              <span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Outcome (defines case)</span>
              <input type="text" name="picoO" placeholder="Acute myocardial infarction" class="border border-slate-300 rounded px-3 py-2 text-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500" />
            </label>
          </div>
        </details>

        <details open class="border border-slate-200 rounded-2xl bg-white shadow-sm">
          <summary class="cursor-pointer select-none px-5 py-4 font-semibold text-slate-900 hover:bg-slate-50 rounded-2xl">3 · Sites</summary>
          <div class="px-5 pb-5 space-y-4">
            <p class="text-xs text-slate-500">
              Tick every <strong>database</strong> (not just country). Feature chips indicate what each database can support; case-crossover needs Rx (or whatever the exposure source is) and Dx (case ascertainment), and any extra data the case definition demands.
            </p>
            <div class="flex flex-wrap items-center gap-2 text-[10px] text-slate-500 border-y border-slate-100 py-2">
              <span class="uppercase tracking-widest font-bold text-slate-600">Legend</span>
              {FEATURES.map((f) => (
                <span class="inline-flex items-center gap-1">
                  <span class="text-[10px] bg-brand-50 text-brand-700 border border-brand-100 px-1.5 py-0.5 rounded font-mono font-semibold">{f.short}</span>
                  <span>{f.label}</span>
                </span>
              ))}
            </div>
            <div class="space-y-3">
              {Object.entries(SITES_BY_COUNTRY).map(([country, dbs]) => (
                <div>
                  <p class="text-[11px] font-semibold text-slate-700">{country}</p>
                  <div class="mt-1 grid grid-cols-1 sm:grid-cols-2 gap-1.5">
                    {dbs.map((d) => (
                      <label class="flex items-center gap-2 text-xs border border-slate-200 rounded px-3 py-2 hover:bg-slate-50 cursor-pointer">
                        <input type="checkbox" name="sites" value={d.id} class="rounded border-slate-400 text-brand-700 focus:ring-brand-500" />
                        <span class="font-semibold text-slate-800 shrink-0">{d.short}</span>
                        <span class="flex flex-wrap gap-1 ml-auto">
                          {FEATURES.filter((f) => d.features.includes(f.id)).map((f) => (
                            <span class="text-[10px] bg-brand-50 text-brand-700 border border-brand-100 px-1.5 py-0.5 rounded font-mono font-semibold" title={f.label}>{f.short}</span>
                          ))}
                        </span>
                      </label>
                    ))}
                  </div>
                </div>
              ))}
            </div>
            <label class="flex flex-col gap-1">
              <span class="text-[11px] uppercase tracking-widest text-slate-500 font-semibold">Others (one per line)</span>
              <textarea name="sitesOther" rows="2" placeholder="Sites beyond the active databases list" class="w-full border border-slate-300 rounded px-3 py-2 text-xs focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500"></textarea>
            </label>
            <div data-feasibility class="hidden bg-amber-50 border border-amber-200 rounded-lg p-3 text-xs leading-relaxed">
              <p class="font-bold text-amber-800 uppercase tracking-[0.2em] text-[10px]">⚠ Feasibility heads-up; not a blocker</p>
              <p class="mt-1 text-amber-900">Your study question implies data features that some selected sites don't carry. Multi-country case-crossover protocols often accommodate this; just be explicit in the per-site analytic plan.</p>
              <ul data-feasibility-list class="mt-2 space-y-1 text-amber-900 list-disc list-inside"></ul>
            </div>
          </div>
        </details>

        <details open class="border border-slate-200 rounded-2xl bg-white shadow-sm">
          <summary class="cursor-pointer select-none px-5 py-4 font-semibold text-slate-900 hover:bg-slate-50 rounded-2xl">4 · Case definition (outcome)</summary>
          <div class="px-5 pb-5 space-y-3">
            <div>
              <button type="button" data-open-library data-category="outcomes" data-target-def="outcomeDef" data-target-codes="outcomeCodes" data-also-fill="picoO" class="text-[10px] uppercase tracking-widest font-bold text-brand-700 bg-brand-50 hover:bg-brand-100 border border-brand-200 px-2 py-1 rounded transition">📚 Pick outcome from library</button>
              <span class="ml-2 text-[11px] text-slate-500">Validation citation auto-appends to References on export.</span>
            </div>
            <label class="flex flex-col gap-1">
              <span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Operational case definition</span>
              <textarea name="outcomeDef" rows="3" placeholder="First hospitalisation with primary discharge diagnosis of …" class="w-full border border-slate-300 rounded px-3 py-2 text-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500"></textarea>
            </label>
            <label class="flex flex-col gap-1">
              <span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Code set</span>
              <input type="text" name="outcomeCodes" placeholder="ICD-10 I21.*, I22.*" class="w-full border border-slate-300 rounded px-3 py-2 text-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500" />
            </label>
            <label class="flex flex-col gap-1">
              <span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Index date for the case</span>
              <input type="text" name="indexDateDef" value="Admission date of first hospitalisation meeting the case definition" class="w-full border border-slate-300 rounded px-3 py-2 text-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500" />
            </label>
          </div>
        </details>

        <details open class="border border-slate-200 rounded-2xl bg-white shadow-sm">
          <summary class="cursor-pointer select-none px-5 py-4 font-semibold text-slate-900 hover:bg-slate-50 rounded-2xl">5 · Exposure definition</summary>
          <div class="px-5 pb-5 grid sm:grid-cols-2 gap-3">
            <div class="sm:col-span-2">
              <button type="button" data-open-library data-category="exposures" data-target-name="exposureName" data-target-codes="exposureCodes" data-also-fill="picoI" class="text-[10px] uppercase tracking-widest font-bold text-brand-700 bg-brand-50 hover:bg-brand-100 border border-brand-200 px-2 py-1 rounded transition">📚 Pick exposure from library</button>
            </div>
            <label class="flex flex-col gap-1">
              <span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Exposure; name</span>
              <input type="text" name="exposureName" placeholder="NSAIDs" class="border border-slate-300 rounded px-3 py-2 text-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500" />
            </label>
            <label class="flex flex-col gap-1">
              <span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Exposure; code set</span>
              <input type="text" name="exposureCodes" placeholder="ATC M01A*" class="border border-slate-300 rounded px-3 py-2 text-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500" />
            </label>
            <label class="flex flex-col gap-1 sm:col-span-2">
              <span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Exposure ascertainment rule</span>
              <input type="text" name="exposureRule" value="Any dispensing within the window counts as exposed" class="border border-slate-300 rounded px-3 py-2 text-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500" />
            </label>
          </div>
        </details>

        <details open class="border border-slate-200 rounded-2xl bg-white shadow-sm">
          <summary class="cursor-pointer select-none px-5 py-4 font-semibold text-slate-900 hover:bg-slate-50 rounded-2xl">6 · Hazard (case) window</summary>
          <div class="px-5 pb-5 grid sm:grid-cols-2 gap-3">
            <label class="flex flex-col gap-1">
              <span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Hazard window length (days)</span>
              <input type="number" name="hazardLen" value="7" min="1" step="1" class="border border-slate-300 rounded px-3 py-2 text-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500" />
              <span class="text-[11px] text-slate-500">e.g. 1 (immediate trigger), 7, 14, 30. Drag the hazard bar in the diagram to adjust.</span>
            </label>
            <label class="flex flex-col gap-1">
              <span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Gap before event (days)</span>
              <input type="number" name="hazardEnd" value="1" min="0" step="1" class="border border-slate-300 rounded px-3 py-2 text-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500" />
              <span class="text-[11px] text-slate-500">1 (hazard window ends at day −1) avoids reverse causation where the exposure is dispensed because the event occurred; 0 includes the event day.</span>
            </label>
          </div>
        </details>

        <details open class="border border-slate-200 rounded-2xl bg-white shadow-sm">
          <summary class="cursor-pointer select-none px-5 py-4 font-semibold text-slate-900 hover:bg-slate-50 rounded-2xl">7 · Control window(s)</summary>
          <div class="px-5 pb-5 grid sm:grid-cols-2 gap-3">
            <label class="flex flex-col gap-1">
              <span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Number of control windows</span>
              <select name="nControls" class="border border-slate-300 rounded px-3 py-2 text-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500">
                <option value="1">1 control window</option>
                <option value="2">2 control windows</option>
                <option value="3" selected>3 control windows (reduces variance)</option>
                <option value="4">4 control windows</option>
              </select>
            </label>
            <label class="flex flex-col gap-1">
              <span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Offset to first control (days before event)</span>
              <input type="number" name="controlOffset" value="60" min="1" step="1" class="border border-slate-300 rounded px-3 py-2 text-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500" />
              <span class="text-[11px] text-slate-500">e.g. 30, 60, 90, or 365 (annual recurrence control). Drag control window 1 to adjust.</span>
            </label>
            <label class="flex flex-col gap-1 sm:col-span-2">
              <span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Length of each control window (days)</span>
              <input type="number" name="controlLen" min="1" step="1" placeholder="blank = same as the hazard window (matched)" class="border border-slate-300 rounded px-3 py-2 text-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500" />
            </label>
          </div>
        </details>

        <details open class="border border-slate-200 rounded-2xl bg-white shadow-sm">
          <summary class="cursor-pointer select-none px-5 py-4 font-semibold text-slate-900 hover:bg-slate-50 rounded-2xl">8 · Design variant</summary>
          <div class="px-5 pb-5 grid sm:grid-cols-2 gap-3">
            <label class="flex flex-col gap-1 sm:col-span-2">
              <span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Case-crossover variant</span>
              <select name="ccoVariant" class="border border-slate-300 rounded px-3 py-2 text-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500">
                <option value="standard" selected>Standard (Maclure 1991); fixed offset(s) before event</option>
                <option value="time-stratified">Time-stratified (Janes 2005); controls drawn from same calendar stratum</option>
                <option value="symmetric">Symmetric bidirectional; controls before AND after event</option>
                <option value="cctc">Case-case-time-control (CCTC); pairs current-case crossover with a future-case control crossover to address both confounding by indication AND protopathic bias</option>
              </select>
              <span class="text-[11px] text-slate-500">Time-stratified controls for secular trends in exposure prevalence. Symmetric requires post-event exposure not to be influenced by the event. CCTC (Huang WC, Yang ASH, Tsai DHT, Shao SC, Lin SJ, Lai ECC. BMJ 2023;382:e076045; PMID 37758279) computes OR_CCTC = OR_Case / OR_Control where the control crossover uses future cases to subtract out time-trends in exposure; strong when reverse causality between symptoms and prescribing is a concern.</span>
            </label>
          </div>
        </details>

        <details open class="border border-slate-200 rounded-2xl bg-white shadow-sm">
          <summary class="cursor-pointer select-none px-5 py-4 font-semibold text-slate-900 hover:bg-slate-50 rounded-2xl">9 · Statistical analysis</summary>
          <div class="px-5 pb-5 grid sm:grid-cols-2 gap-3">
            <label class="flex flex-col gap-1 sm:col-span-2">
              <span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Primary model</span>
              <input type="text" name="primaryModel" value="Conditional logistic regression with the case as the conditioning stratum; exposure indicator coded for each hazard/control window" class="border border-slate-300 rounded px-3 py-2 text-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500" />
            </label>
            <label class="flex flex-col gap-1">
              <span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Effect estimate</span>
              <input type="text" name="effectMeasure" value="Odds ratio (OR); interpreted as incidence rate ratio under the rare-disease assumption" class="border border-slate-300 rounded px-3 py-2 text-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500" />
            </label>
            <label class="flex flex-col gap-1">
              <span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Meta-analysis</span>
              <select name="metaMethod" class="border border-slate-300 rounded px-3 py-2 text-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500">
                <option value="re" selected>Random-effects (DerSimonian-Laird)</option>
                <option value="re-reml">Random-effects (REML)</option>
                <option value="fe">Fixed-effects (inverse-variance)</option>
              </select>
            </label>
            <div class="sm:col-span-2">
              <p class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Subgroup analyses; tick those to perform</p>
              <div class="mt-2 grid sm:grid-cols-2 gap-1.5">
                {SUBGROUPS.map((g, i) => (
                  <label class="flex items-start gap-2 text-xs border border-slate-200 rounded px-3 py-2 hover:bg-slate-50 cursor-pointer">
                    <input type="checkbox" name="subgroupsPick" value={g} checked={[0,2,3,4].includes(i)} class="mt-0.5 rounded border-slate-400 text-brand-700 focus:ring-brand-500" />
                    <span>{g}</span>
