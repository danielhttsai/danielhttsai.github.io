        currentCategory = category;
        currentTargets = targets;
        modalTitle.textContent = ({ outcomes: "Pick an outcome (case definition)", exposures: "Pick a drug class (exposure)" })[category] || "Pick a phenotype";
        modalSearch.value = "";
        renderLibrary("");
        modal.classList.remove("hidden");
        setTimeout(() => modalSearch.focus(), 50);
      };
      const closeLibrary = () => modal.classList.add("hidden");
      document.querySelectorAll("[data-open-library]").forEach((btn) => {
        btn.addEventListener("click", () => openLibrary(btn.dataset.category, { name: btn.dataset.targetName, codes: btn.dataset.targetCodes, def: btn.dataset.targetDef, alsoFill: btn.dataset.alsoFill }));
      });
      document.querySelector("[data-library-close]")?.addEventListener("click", closeLibrary);
      modal.addEventListener("click", (e) => { if (e.target === modal) closeLibrary(); });
      document.addEventListener("keydown", (e) => { if (e.key === "Escape") closeLibrary(); });
      modalSearch.addEventListener("input", () => renderLibrary(modalSearch.value));

      // Exported for testing (and any future reuse): the IIFE otherwise hides these.
      window.__builder = { readForm, buildMarkdown, buildDocx };

      setState("ready");
    })();
  </script>
</BaseLayout>
