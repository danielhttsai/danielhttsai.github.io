              </label>
            </div>
          </div>
        </details>

        <details open class="border border-slate-200 rounded-2xl bg-white shadow-sm">
          <summary class="cursor-pointer select-none px-5 py-4 font-semibold text-slate-900 hover:bg-slate-50 rounded-2xl">10 · Sensitivity analyses</summary>
          <div class="px-5 pb-5 space-y-3">
            <div class="grid sm:grid-cols-2 gap-1.5">
              {SENSITIVITY.map((s, i) => (
                <label class="flex items-start gap-2 text-xs border border-slate-200 rounded px-3 py-2 hover:bg-slate-50 cursor-pointer">
                  <input type="checkbox" name="sensitivityPick" value={s} checked={i < 5} class="mt-0.5 rounded border-slate-400 text-brand-700 focus:ring-brand-500" />
                  <span>{s}</span>
                </label>
              ))}
            </div>
            <label class="flex flex-col gap-1">
              <span class="text-[11px] uppercase tracking-widest text-slate-500 font-semibold">Custom sensitivity analyses (one per line)</span>
              <textarea name="sensitivityCustom" rows="2" class="w-full border border-slate-300 rounded px-3 py-2 text-xs focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500"></textarea>
            </label>
          </div>
        </details>

        <details open class="border border-slate-200 rounded-2xl bg-white shadow-sm">
          <summary class="cursor-pointer select-none px-5 py-4 font-semibold text-slate-900 hover:bg-slate-50 rounded-2xl">11 · Execution &amp; timeline</summary>
          <div class="px-5 pb-5 space-y-3">
            <div class="grid sm:grid-cols-2 gap-3">
              <label class="flex flex-col gap-1">
                <span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Architecture</span>
                <select name="arch" class="border border-slate-300 rounded px-3 py-2 text-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500">
                  <option value="federated" selected>Federated</option>
                  <option value="cdm">Common Data Model</option>
                  <option value="centralised">Centralised (DUA permits)</option>
                </select>
              </label>
            </div>
            <div>
              <p class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Timeline preset</p>
              <div class="mt-2 flex gap-2 flex-wrap">
                <button type="button" data-timeline-preset="12-month" class="text-xs border border-brand-300 text-brand-700 hover:bg-brand-50 font-semibold px-3 py-1.5 rounded transition">Use 12-month plan</button>
                <button type="button" data-timeline-preset="18-month" class="text-xs border border-brand-300 text-brand-700 hover:bg-brand-50 font-semibold px-3 py-1.5 rounded transition">Use 18-month plan</button>
              </div>
              <label class="flex flex-col gap-1 mt-3">
                <span class="text-[11px] uppercase tracking-widest text-slate-500 font-semibold">Milestones (one per line)</span>
                <textarea name="timeline" rows="6" class="w-full border border-slate-300 rounded px-3 py-2 text-xs focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500"></textarea>
              </label>
            </div>
          </div>
        </details>

        <details class="border border-slate-200 rounded-2xl bg-white shadow-sm">
          <summary class="cursor-pointer select-none px-5 py-4 font-semibold text-slate-900 hover:bg-slate-50 rounded-2xl">12 · Ethics, dissemination, references (optional)</summary>
          <div class="px-5 pb-5 space-y-3">
            <label class="flex flex-col gap-1">
              <span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Ethics</span>
              <textarea name="ethics" rows="2" class="w-full border border-slate-300 rounded px-3 py-2 text-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500">Each participating site obtains local IRB / ethics approval before data extraction. Under a federated design only aggregate site-level estimates are shared with the coordinating centre.</textarea>
            </label>
            <label class="flex flex-col gap-1">
              <span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Dissemination</span>
              <textarea name="dissemination" rows="2" class="w-full border border-slate-300 rounded px-3 py-2 text-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500">Primary manuscript to a peer-reviewed pharmacoepidemiology journal; presentation at ICPE / ISPE Asian conference.</textarea>
            </label>
            <label class="flex flex-col gap-1">
              <span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Key references (one per line)</span>
              <textarea name="references" rows="8" class="w-full border border-slate-300 rounded px-3 py-2 text-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500">Maclure M. The case-crossover design: a method for studying transient effects on the risk of acute events. Am J Epidemiol 1991;133(2):144-53.
Mittleman MA, Maclure M, Robins JM. Control sampling strategies for the case-crossover design: an assessment of relative efficiency. Am J Epidemiol 1995;142(1):91-8.
Janes H, Sheppard L, Lumley T. Case-crossover analyses of air pollution exposure data: referent selection strategies and their implications for bias. Epidemiology 2005;16(6):717-26.
Huang WC, Yang ASH, Tsai DHT, Shao SC, Lin SJ, Lai ECC. Association between recently raised anticholinergic burden and risk of acute cardiovascular events: nationwide case-case-time-control study. BMJ 2023;382:e076045. PMID: 37758279. (AsPEN exemplar of the CCTC variant; hazard day -1 to -30, four 30-d reference periods in -61 to -180, 60-d washout.)
Wang SV, Schneeweiss S. A general propensity score for signal identification using tree-based scan statistics. Am J Epidemiol 2018 (case-case-time-control discussion).
Hsieh CY, Su CC, Shao SC, Sung SF, Lin SJ, Kao Yang YH, Lai EC. Taiwan's NHIRD: past and future. Clin Epidemiol 2019;11:349-358.
Shao SC, Chan YY, Kao Yang YH, Lin SJ, Hung MJ, Chien RN, Lai CC, Lai EC. The Chang Gung Research Database. Pharmacoepidemiol Drug Saf 2019;28(5):593-600.</textarea>
            </label>
          </div>
        </details>

        <div class="flex flex-wrap gap-3 pt-2 items-center">
          <button type="button" data-action="download-docx" class="bg-white border border-brand-700 text-brand-700 hover:bg-brand-50 font-semibold px-5 py-2.5 rounded-lg transition text-sm">⬇ Download Word (.docx)</button>
          <button type="button" data-action="download-md" class="text-brand-700 hover:underline font-semibold text-sm">⬇ Markdown</button>
          <button type="button" data-action="download-strobe" class="text-brand-700 hover:underline font-semibold text-sm" title="Generate the STROBE reporting checklist (von Elm 2007; strobe-statement.org) as a Word document, pre-filled from your protocol fields.">⬇ STROBE checklist</button>
          <button type="button" data-action="copy" class="text-brand-700 hover:underline font-semibold text-sm">📋 Copy</button>
          <button type="button" data-action="reset" class="ml-auto text-slate-500 hover:text-rose-600 hover:underline text-sm font-semibold">Clear all</button>
          <p data-action-msg class="basis-full text-xs"></p>
        </div>
      </form>

      <aside class="lg:sticky lg:top-20">
        <div class="border border-slate-200 rounded-2xl bg-slate-50 shadow-sm overflow-hidden">
          <header class="flex items-center justify-between px-4 py-2 bg-white border-b border-slate-200">
            <p class="text-xs uppercase tracking-widest text-brand-700 font-bold">Live preview</p>
            <p class="text-[10px] text-slate-500">Auto-saved to this browser</p>
          </header>
          <pre data-preview class="text-xs leading-relaxed text-slate-800 p-4 overflow-auto max-h-[calc(100vh-12rem)] whitespace-pre-wrap font-mono"></pre>
        </div>
      </aside>
    </div>

    <!-- Study design diagram -->
    <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
      <h2 class="text-lg font-bold text-slate-900">Study design diagram</h2>
      <p class="mt-1 text-xs text-slate-500">Outcome-anchored: the hazard window immediately before the event vs the matched control (referent) window(s) further back — updates with the form.</p>
      <div class="mt-4 overflow-x-auto"><div id="diagram"></div></div>
      <div id="dlegend" class="mt-3 flex flex-wrap gap-x-4 gap-y-1.5 text-xs text-slate-600"></div>
    </div>
    <DesignDiagram />
    <ProtocolCommon />

    <div data-library-modal class="hidden fixed inset-0 z-50 bg-slate-900/40 backdrop-blur-sm flex items-start justify-center p-4 sm:p-8 overflow-y-auto">
      <div class="bg-white border border-slate-200 rounded-2xl shadow-2xl w-full max-w-3xl my-8">
        <header class="flex items-center justify-between gap-3 px-5 py-4 border-b border-slate-100">
          <div>
            <p class="text-xs uppercase tracking-widest text-brand-700 font-bold">Validated phenotype library</p>
            <h3 class="text-lg font-bold text-slate-900 mt-0.5" data-library-title>Pick a phenotype</h3>
          </div>
          <button type="button" data-library-close class="text-slate-400 hover:text-slate-700 text-2xl leading-none">×</button>
        </header>
        <div class="px-5 py-3 border-b border-slate-100">
          <input type="text" data-library-search placeholder="Filter…" class="w-full border border-slate-300 rounded px-3 py-2 text-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500" />
        </div>
        <div data-library-list class="px-2 py-2 max-h-[60vh] overflow-y-auto"></div>
      </div>
    </div>
  </section>

  <script src="https://unpkg.com/docx@8.5.0/build/index.umd.js" is:inline></script>

  <script is:inline define:vars={{ BASE: base, SITES_DETAIL_MAP, FEATURES, PHENOTYPES, TIMELINE_PRESETS, STROBE_ITEMS }}>
    (() => {
      const setState = (name) => { document.querySelectorAll("[data-state]").forEach((el) => el.classList.toggle("hidden", el.dataset.state !== name)); };

      const STORAGE_KEY = "aspen.protocol-builder.cco";
      const STORAGE_CITATIONS_KEY = "aspen.protocol-builder.cco.citations";
      const form = document.querySelector("[data-builder]");
      const preview = document.querySelector("[data-preview]");
      const actionMsg = document.querySelector("[data-action-msg]");
      const setMsg = (msg, isError = false) => { if (!actionMsg) return; actionMsg.textContent = msg; actionMsg.classList.toggle("text-rose-700", isError); actionMsg.classList.toggle("text-brand-700", !isError); };
      let pickedCitations = {};
      try { pickedCitations = JSON.parse(localStorage.getItem(STORAGE_CITATIONS_KEY) || "{}") || {}; } catch {}
      const savePickedCitations = () => { try { localStorage.setItem(STORAGE_CITATIONS_KEY, JSON.stringify(pickedCitations)); } catch {} };
      // Format a site id into "Country · Short [Rx Dx ...]".
      const formatSiteFull = (id) => {
        const d = SITES_DETAIL_MAP[id];
        if (!d) return id;
        const feats = (d.features || []).map((f) => (FEATURES.find((x) => x.id === f) || {}).short || f).join(" ");
        return d.country + " · " + d.short + (feats ? " [" + feats + "]" : "");
      };

      // ── Feasibility detection ───────────────────────────────
      // Permissive regex map: typed text → data features needed.
      // Case-crossover almost always uses Rx (or some pharmacy/exposure source)
      // + Dx (case ascertainment); those two are seeded as universal.
      const FEATURE_TRIGGERS = {
        labs:      /\b(hba1c|egfr|creatinine|bmi|blood\s*pressure|systolic|diastolic|ldl|hdl|cholesterol|glucose|albumin|hemoglobin|haemoglobin|inr|tsh|lipid|biochemical|biochemist|labora?tor[yi]|lab[s]?\b)/i,
        mortality: /\b(mortality|all-?cause death|cv death|cardiovascular death|cause of death|died|fatal|death|survival)\b/i,
        cancer:    /\b(cancer|carcinom|malignan|neoplasm|tumou?r|sarcoma|leuk[ae]mia|lymphoma|registr[yi].*cancer|cancer.*registr[yi])\b/i,
        pregnancy: /\b(pregnan|birth|neonatal|gestation|trimester|maternal|fetal|foetal|infant)\b/i,
        imaging:   /\b(imaging|mri|ct\s*scan|x-?ray|ultrasound|echocardio|angio|radiolog)\b/i,
        genomics:  /\b(genomic|snp|gwas|biobank|genotype|exome|gene(?:tic)?\b)\b/i,
      };
      const FEATURE_TEXT_FIELDS = [
        "outcomeDef","outcomeCodes","indexDateDef",
        "picoP","picoI","picoO",
        "exposureName","exposureCodes","exposureRule",
        "subgroupsCustom","sensitivityCustom",
      ];
      const FEATURE_MULTI_FIELDS = ["subgroupsPick","sensitivityPick"];

      const computeRequiredFeatures = (state) => {
        let blob = "";
        for (const f of FEATURE_TEXT_FIELDS) blob += " " + (state[f] || "");
        for (const f of FEATURE_MULTI_FIELDS) blob += " " + ((state[f] || []).join(" "));
        const req = new Set(["rx","dx"]);    // case-crossover: Rx exposure + Dx case ascertainment
        for (const [feat, rx] of Object.entries(FEATURE_TRIGGERS)) {
          if (rx.test(blob)) req.add(feat);
        }
        return req;
      };

      const renderFeasibility = (state) => {
        const panel  = document.querySelector("[data-feasibility]");
        const list   = document.querySelector("[data-feasibility-list]");
        if (!panel || !list) return;
        const required = computeRequiredFeatures(state);
        const selected = state.sites || [];
        if (selected.length === 0) { panel.classList.add("hidden"); return; }

        const gaps = [];
        for (const featId of required) {
          if (featId === "rx" || featId === "dx") continue; // universal in claims/EHR
          const featLabel = (FEATURES.find((f) => f.id === featId) || {}).label || featId;
          const missing = [];
          const have    = [];
          for (const sid of selected) {
            const d = SITES_DETAIL_MAP[sid];
            if (!d) continue;
            (d.features.includes(featId) ? have : missing).push(d.short);
          }
          if (missing.length > 0) {
            gaps.push({ feature: featLabel, missing, have });
          }
        }

        if (gaps.length === 0) { panel.classList.add("hidden"); return; }
        list.innerHTML = gaps.map((g) =>
          `<li><strong>${g.feature}</strong>; implied by your study text. Missing at: <strong>${g.missing.join(", ")}</strong>` +
          (g.have.length > 0 ? `. Available at: ${g.have.join(", ")}.` : `.`) + `</li>`
        ).join("");
        panel.classList.remove("hidden");
      };

      const readForm = () => {
        const data = new FormData(form);
        const out = {};
        const multi = new Set(["sites", "sensitivityPick", "subgroupsPick"]);
        for (const k of multi) out[k] = [];
        for (const [k, v] of data.entries()) { if (multi.has(k)) out[k].push(String(v)); else out[k] = String(v); }
        return out;
      };
      const writeForm = (state) => {
        const multi = new Set(["sites", "sensitivityPick", "subgroupsPick"]);
        for (const el of form.querySelectorAll("input, textarea, select")) {
          const name = el.name; if (!name) continue;
          if (el.type === "checkbox" && multi.has(name)) el.checked = (state[name] || []).includes(el.value);
          else if (state[name] !== undefined) el.value = state[name];
        }
      };
      const mergeList = (picks, customText) => { const lines = (customText || "").split(/\r?\n/).map((l) => l.trim()).filter(Boolean); return [...(picks || []), ...lines]; };
      const bullets = (arr) => arr.length === 0 ? "_(none specified)_" : arr.map((l) => "- " + l).join("\n");
      const numbered = (arr) => arr.length === 0 ? "_(none)_" : arr.map((l, i) => (i + 1) + ". " + l).join("\n");
      const orFb = (s, fb) => (s && s.trim()) ? s : fb;
      const pcOf = (s) => ({
        design: "case-crossover study",
        tte: false,
        population: orFb(s.picoP, "(population)"),
        exposure: orFb(s.picoI, "(exposure)"),
        comparator: "",
        outcome: orFb(s.picoO, "(outcome)"),
        data: (s.sites && s.sites.length ? s.sites.length + " AsPEN data source(s)" : "multi-national AsPEN data sources"),
        analysis: "conditional logistic regression contrasting exposure in the hazard window vs matched control windows within each case, pooled across sites",
        groupBy: "hazard vs control window",
        skip: ["ethics"],
        limitations: "The case-crossover design assumes a transient exposure and an abrupt-onset outcome with no time trend in exposure prevalence; an exposure-time trend or carry-over would bias the estimate (mitigated by a time-stratified or case-time-control variant).",
        plannedOutputs: ["Case-selection flow diagram.", "Exposure discordance across hazard / control windows.", "Odds ratio with a forest plot across sites."],
      });
      const sitesLine = (ids, otherText) => {
        const parts = (ids || []).map((c) => "- " + formatSiteFull(c));
        const others = (otherText || "").split(/\r?\n/).map((l) => l.trim()).filter(Boolean);
        if (parts.length === 0 && others.length === 0) return "_(no sites selected)_";
        let out = parts.join("\n");
        if (others.length > 0) out += (out ? "\n\n**Other sites:**\n" : "**Other sites:**\n") + others.map((o) => "- " + o).join("\n");
        return out;
      };

      const buildMarkdown = (s) => {
        const today = new Date().toISOString().slice(0, 10);
        const title = orFb(s.title, "(Untitled multi-national case-crossover study)");
        const _gap = Math.max(0, parseInt(s.hazardEnd) || 0); const hazardEnd = _gap <= 0 ? "Day 0 (event day inclusive)" : ("Day -" + _gap + " (" + _gap + " day(s) before the event)");
        const variant = ({ standard: "Standard (Maclure 1991); fixed offset(s) before event", "time-stratified": "Time-stratified (Janes 2005); controls drawn from same calendar stratum", symmetric: "Symmetric bidirectional; controls before AND after event", cctc: "Case-case-time-control (CCTC, Huang/Yang/Tsai BMJ 2023; PMID 37758279); current-case crossover paired with a future-case control crossover; OR_CCTC = OR_Case / OR_Control" })[s.ccoVariant] || "Standard";
        const controlLenText = (parseInt(s.controlLen) > 0) ? (parseInt(s.controlLen) + " days") : ("Same as hazard window (" + (s.hazardLen || "7") + " days, matched)");
        const meta = ({ re: "Random-effects (DerSimonian-Laird) meta-analysis pooling site-specific ORs; report I² and τ². Forest plot per outcome.", "re-reml": "Random-effects (REML) meta-analysis; report I² and τ²; forest plot per outcome.", fe: "Fixed-effects (inverse-variance) meta-analysis; forest plot per outcome." })[s.metaMethod] || "Random-effects meta-analysis.";
        const arch = ({ federated: "Federated; each AsPEN site executes a common analytic package locally and shares aggregate ORs.", cdm: "Common Data Model; each site transforms data into agreed CDM, runs shared package.", centralised: "Centralised; site-level individual data pooled under DUA." })[s.arch] || "Federated";

        const refsUser = (s.references || "").split(/\r?\n/).map((l) => l.trim()).filter(Boolean);
        const refs = (() => { const set = new Set(refsUser); for (const c of Object.values(pickedCitations)) if (c && c.trim()) set.add(c.trim()); return Array.from(set); })();
        const milestones  = (s.timeline  || "").split(/\r?\n/).map((l) => l.trim()).filter(Boolean);
        const subgroups   = mergeList(s.subgroupsPick, s.subgroupsCustom);
        const sensitivity = mergeList(s.sensitivityPick, s.sensitivityCustom);

        return `# ${title}

**Study ID:** ${orFb(s.shortId, "(short id)")}
**Lead investigator(s):** ${orFb(s.leadInvestigator, "(lead)")}
**Version:** ${orFb(s.version, "v0.1 draft · " + today)}
**Design:** Multi-national case-crossover study

---

${window.PC.abstractMd(pcOf(s))}
## 1. Research question

| | |
|---|---|
| **Population** | ${orFb(s.picoP, "_(population)_")} |
| **Exposure**   | ${orFb(s.picoI, "_(exposure)_")} |
| **Outcome (case)** | ${orFb(s.picoO, "_(outcome)_")} |

## 2. Sites

${sitesLine(s.sites, s.sitesOther)}

## 3. Case definition

**Operational definition.** ${orFb(s.outcomeDef, "_(case definition)_")}

**Code set.** ${orFb(s.outcomeCodes, "_(codes)_")}

**Index date.** ${orFb(s.indexDateDef, "Admission date of first hospitalisation meeting the case definition.")}

## 4. Exposure definition

| | |
|---|---|
| **Name** | ${orFb(s.exposureName, "_(exposure)_")} |
| **Code set** | ${orFb(s.exposureCodes, "_(codes)_")} |
| **Ascertainment rule** | ${orFb(s.exposureRule, "Any dispensing within the window counts as exposed.")} |

## 5. Hazard (case) window

| | |
|---|---|
| **Length** | ${s.hazardLen || "7"} days |
| **End anchor** | ${hazardEnd} |

## 6. Control window(s)

| | |
|---|---|
| **Number of control windows** | ${s.nControls || "3"} |
| **Offset to first control** | ${s.controlOffset || "60"} days before event |
| **Length** | ${controlLenText} |

## 7. Design variant

${variant}

## 8. Statistical analysis

- **Primary model:** ${orFb(s.primaryModel, "Conditional logistic regression with the case as the conditioning stratum.")}
- **Effect estimate:** ${orFb(s.effectMeasure, "Odds ratio (OR); interpreted as IRR under the rare-disease assumption.")}
- **Meta-analysis across sites:** ${meta}

**Subgroup analyses**

${bullets(subgroups)}

**Sensitivity analyses**

${bullets(sensitivity)}

## 9. Execution and timeline

**Architecture.** ${arch}

**Timeline milestones**

${numbered(milestones)}

## 10. Ethics, data sharing, dissemination

**Ethics.** ${orFb(s.ethics, "Each participating site obtains local IRB / ethics approval before data extraction.")}

**Dissemination.** ${orFb(s.dissemination, "Primary manuscript to a peer-reviewed pharmacoepidemiology journal.")}

${window.PC.tailMd(pcOf(s))}

## 11. Key references

${numbered(refs)}

---

_Drafted with the AsPEN case-crossover builder (${today})._
`;
      };

      const renderScheme = (s) => {
        const hlen = Math.max(1, parseInt(s.hazardLen) || 1);
        const hend = Math.max(0, parseInt(s.hazardEnd) || 0);
        const clen = Math.max(1, parseInt(s.controlLen) || hlen);
        const off = Math.max(1, parseInt(s.controlOffset) || (hlen + 1));
        const n = Math.min(6, Math.max(1, parseInt(s.nControls) || 1));
        const wins = [{ label: "Hazard window", kind: "hazard", startDay: -(hend + hlen), endDay: -hend, edits: [{ field: "hazardLen", edge: "start", allowPast: true }, { field: "hazardEnd", edge: "end", allowPast: true }] }];
        for (let k = 1; k <= n; k++) {
          const end = -hend - k * off;
          wins.push({ label: "Control window " + k, kind: "control", startDay: end - clen, endDay: end, edits: k === 1 ? [{ field: "controlLen", edge: "start", allowPast: true }, { field: "controlOffset", edge: "end", allowPast: true }] : undefined });
        }
        const onEdit = (field, day) => {
          const el = form.elements[field]; if (!el) return;
          const cHend = Math.max(0, parseInt(form.elements.hazardEnd && form.elements.hazardEnd.value) || 0);
          const cOff = Math.max(1, parseInt(form.elements.controlOffset && form.elements.controlOffset.value) || 60);
          let v;
          if (field === "hazardLen") v = Math.max(1, (-day) - cHend);          // hazard spans -(hend+hlen) … -hend
          else if (field === "hazardEnd") v = Math.max(0, -day);               // gap before the event
          else if (field === "controlOffset") v = Math.max(1, (-day) - cHend); // control 1 ends at -hend-off
          else if (field === "controlLen") v = Math.max(1, (-cHend - cOff) - day); // control 1 starts at -hend-off-clen
          else return;
          el.value = Math.round(v);
          render();
        };
        window.renderDesignDiagram(document.getElementById("diagram"), document.getElementById("dlegend"), { windows: wins, indexLabel: "Event (day 0)", onEdit: onEdit, snap: 5 });
      };
